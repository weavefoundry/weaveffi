# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
.idea/

# Generated by WeaveFFI CLI (outputs from `weaveffi generate`)
/generated/

# Compiled C example binary
/c_example

# Node.js
node_modules/
*.node

# macOS
.DS_Store

# Ralphy progress tracking
.ralphy/progress.txt

# mdBook build outputs (do not commit generated docs)
/docs/book/
/docs/site/
/docs/api/
/site/

# WeaveFFI cache
.weaveffi-cache

# insta snapshot review artifacts (committed `.snap` files only)
**/*.snap.new
**/*.pending-snap

# Consumer example build artifacts
examples/dart/.dart_tool/
examples/dart/.packages
examples/go/go.sum
examples/ruby/Gemfile.lock
examples/swift/.build/
examples/swift/.swiftpm/
examples/swift/Package.resolved
examples/dotnet/Contacts/bin/
examples/dotnet/Contacts/obj/

# cargo-fuzz runtime artifacts (seeds/ is committed; the rest is generated)
crates/weaveffi-fuzz/fuzz/artifacts/
crates/weaveffi-fuzz/fuzz/corpus/
crates/weaveffi-fuzz/fuzz/coverage/
