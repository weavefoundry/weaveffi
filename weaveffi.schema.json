{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Api",
  "description": "Top-level WeaveFFI API definition.",
  "type": "object",
  "required": [
    "modules",
    "version"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "package": {
      "description": "Package identity used to name, version, and describe every generated consumer package (npm, PyPI, gem, NuGet, pub.dev, SwiftPM, Gradle, Go). When omitted, generators fall back to the IDL file stem and version `0.1.0`, but publishable artifacts should always set this explicitly.",
      "anyOf": [
        {
          "$ref": "#/definitions/Package"
        },
        {
          "type": "null"
        }
      ]
    },
    "modules": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Module"
      }
    },
    "generators": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    }
  },
  "definitions": {
    "Package": {
      "description": "Package identity for the generated consumer artifacts.",
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "description": "Canonical package name (e.g. `kvstore`). Per-target name overrides in `generators:` (such as `python.package_name`) still take precedence.",
          "type": "string"
        },
        "version": {
          "description": "Semantic version stamped into every manifest (e.g. `1.2.0`).",
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "license": {
          "type": [
            "string",
            "null"
          ]
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "homepage": {
          "type": [
            "string",
            "null"
          ]
        },
        "repository": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Module": {
      "description": "A WeaveFFI module: a named group of functions, types, callbacks, listeners, and errors.",
      "type": "object",
      "required": [
        "functions",
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "functions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Function"
          }
        },
        "structs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StructDef"
          }
        },
        "enums": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EnumDef"
          }
        },
        "callbacks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CallbackDef"
          }
        },
        "listeners": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ListenerDef"
          }
        },
        "errors": {
          "anyOf": [
            {
              "$ref": "#/definitions/ErrorDomain"
            },
            {
              "type": "null"
            }
          ]
        },
        "modules": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Module"
          }
        }
      }
    },
    "Function": {
      "type": "object",
      "required": [
        "name",
        "params"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "params": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Param"
          }
        },
        "return": {
          "anyOf": [
            {
              "$ref": "#/definitions/TypeRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "doc": {
          "type": [
            "string",
            "null"
          ]
        },
        "async": {
          "type": "boolean"
        },
        "cancellable": {
          "type": "boolean"
        },
        "deprecated": {
          "type": [
            "string",
            "null"
          ]
        },
        "since": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Param": {
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/TypeRef"
        },
        "mutable": {
          "type": "boolean"
        },
        "doc": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "TypeRef": {
      "title": "TypeRef",
      "description": "Reference to a type. Encoded as a string with custom syntax: primitives (`i8`, `i16`, `i32`, `i64`, `u8`, `u16`, `u32`, `u64`, `f32`, `f64`, `bool`, `string`, `bytes`, `handle`), borrowed types (`&str`, `&[u8]`), typed handles (`handle<{name}>`), iterators (`iter<{T}>`), lists (`[{T}]`), maps (`{{K:V}}`), optionals (`{T}?`), or any user-defined struct/enum name.",
      "type": "string"
    },
    "StructDef": {
      "description": "A struct (record) type with named fields.",
      "type": "object",
      "required": [
        "fields",
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "doc": {
          "type": [
            "string",
            "null"
          ]
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StructField"
          }
        },
        "builder": {
          "type": "boolean"
        }
      }
    },
    "StructField": {
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/TypeRef"
        },
        "doc": {
          "type": [
            "string",
            "null"
          ]
        },
        "default": true
      }
    },
    "EnumDef": {
      "description": "An enum type. C-style when every variant is a bare discriminant; an algebraic sum type when any variant declares fields.",
      "type": "object",
      "required": [
        "name",
        "variants"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "doc": {
          "type": [
            "string",
            "null"
          ]
        },
        "variants": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EnumVariant"
          }
        }
      }
    },
    "EnumVariant": {
      "description": "`Eq` is omitted because `StructField::default` may contain `serde_yaml::Value`.",
      "type": "object",
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "value": {
          "type": "integer",
          "format": "int32"
        },
        "doc": {
          "type": [
            "string",
            "null"
          ]
        },
        "fields": {
          "description": "Associated data carried by this variant. Empty for a unit variant or a C-style enum; non-empty makes the owning enum a sum type (see [`EnumDef::is_rich`]). Variant fields reuse [`StructField`] but ignore the `default` slot (a sum-type payload has no defaultable fields).",
          "type": "array",
          "items": {
            "$ref": "#/definitions/StructField"
          }
        }
      }
    },
    "CallbackDef": {
      "type": "object",
      "required": [
        "name",
        "params"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "params": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Param"
          }
        },
        "doc": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ListenerDef": {
      "type": "object",
      "required": [
        "event_callback",
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "event_callback": {
          "type": "string"
        },
        "doc": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ErrorDomain": {
      "type": "object",
      "required": [
        "codes",
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "codes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ErrorCode"
          }
        }
      }
    },
    "ErrorCode": {
      "type": "object",
      "required": [
        "code",
        "message",
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "doc": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
