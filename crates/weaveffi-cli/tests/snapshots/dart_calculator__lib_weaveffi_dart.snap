// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

// ignore_for_file: non_constant_identifier_names, camel_case_types, unused_element

import 'dart:ffi';
import 'dart:io' show Platform;
import 'package:ffi/ffi.dart';

DynamicLibrary _openLibrary() {
  // An explicit path in WEAVEFFI_LIBRARY wins, so callers can point at a
  // specific build artifact regardless of its file name or location.
  final override = Platform.environment['WEAVEFFI_LIBRARY'];
  if (override != null && override.isNotEmpty) return DynamicLibrary.open(override);
  if (Platform.isMacOS) return DynamicLibrary.open('libweaveffi.dylib');
  if (Platform.isLinux) return DynamicLibrary.open('libweaveffi.so');
  if (Platform.isWindows) return DynamicLibrary.open('weaveffi.dll');
  throw UnsupportedError('Unsupported platform: ${Platform.operatingSystem}');
}

final DynamicLibrary _lib = _openLibrary();

final class _WeaveFFIError extends Struct {
  @Int32()
  external int code;
  external Pointer<Utf8> message;
}

typedef _NativeWeaveffiErrorClear = Void Function(Pointer<_WeaveFFIError>);
typedef _DartWeaveffiErrorClear = void Function(Pointer<_WeaveFFIError>);
final _weaveffiErrorClear = _lib.lookupFunction<
    _NativeWeaveffiErrorClear, _DartWeaveffiErrorClear>('weaveffi_error_clear');

typedef _NativeWeaveffiFreeString = Void Function(Pointer<Utf8>);
typedef _DartWeaveffiFreeString = void Function(Pointer<Utf8>);
final _weaveffiFreeString = _lib.lookupFunction<
    _NativeWeaveffiFreeString, _DartWeaveffiFreeString>('weaveffi_free_string');

typedef _NativeWeaveffiFreeBytes = Void Function(Pointer<Uint8>, Size);
typedef _DartWeaveffiFreeBytes = void Function(Pointer<Uint8>, int);
final _weaveffiFreeBytes = _lib.lookupFunction<
    _NativeWeaveffiFreeBytes, _DartWeaveffiFreeBytes>('weaveffi_free_bytes');

/// Generic WeaveFFI failure: panics, marshalling errors, and unknown codes.
class WeaveFFIException implements Exception {
  final int code;
  final String message;
  WeaveFFIException(this.code, this.message);
  @override
  String toString() => '$runtimeType($code): $message';
}

void _checkError(Pointer<_WeaveFFIError> err) {
  if (err.ref.code != 0) {
    final code = err.ref.code;
    final msg = err.ref.message.toDartString();
    _weaveffiErrorClear(err);
    throw WeaveFFIException(code, msg);
  }
}

/// Typed error domain `CalcError` declared by module `calculator`.
class CalcException extends WeaveFFIException {
  CalcException(super.code, super.message);
}

/// division by zero
class DivisionByZeroException extends CalcException {
  DivisionByZeroException([String message = 'division by zero']) : super(1, message);
}

WeaveFFIException _mapCalcException(int code, String message) {
  switch (code) {
    case 1:
      return DivisionByZeroException(message);
    default:
      return WeaveFFIException(code, message);
  }
}

void _checkCalcException(Pointer<_WeaveFFIError> err) {
  if (err.ref.code != 0) {
    final code = err.ref.code;
    final msg = err.ref.message.toDartString();
    _weaveffiErrorClear(err);
    throw _mapCalcException(code, msg);
  }
}

typedef _NativeWeaveffiCalculatorAdd = Int32 Function(Int32, Int32, Pointer<_WeaveFFIError>);
typedef _DartWeaveffiCalculatorAdd = int Function(int, int, Pointer<_WeaveFFIError>);
final _weaveffiCalculatorAdd = _lib.lookupFunction<
    _NativeWeaveffiCalculatorAdd, _DartWeaveffiCalculatorAdd>('weaveffi_calculator_add');

/// Add two integers
int add(int a, int b) {
  final err = calloc<_WeaveFFIError>();
  try {
    final result = _weaveffiCalculatorAdd(a, b, err);
    _checkError(err);
    return result;
  } finally {
    calloc.free(err);
  }
}

typedef _NativeWeaveffiCalculatorMul = Int32 Function(Int32, Int32, Pointer<_WeaveFFIError>);
typedef _DartWeaveffiCalculatorMul = int Function(int, int, Pointer<_WeaveFFIError>);
final _weaveffiCalculatorMul = _lib.lookupFunction<
    _NativeWeaveffiCalculatorMul, _DartWeaveffiCalculatorMul>('weaveffi_calculator_mul');

/// Multiply two integers
int mul(int a, int b) {
  final err = calloc<_WeaveFFIError>();
  try {
    final result = _weaveffiCalculatorMul(a, b, err);
    _checkError(err);
    return result;
  } finally {
    calloc.free(err);
  }
}

typedef _NativeWeaveffiCalculatorDiv = Int32 Function(Int32, Int32, Pointer<_WeaveFFIError>);
typedef _DartWeaveffiCalculatorDiv = int Function(int, int, Pointer<_WeaveFFIError>);
final _weaveffiCalculatorDiv = _lib.lookupFunction<
    _NativeWeaveffiCalculatorDiv, _DartWeaveffiCalculatorDiv>('weaveffi_calculator_div');

/// Divide two integers, failing on a zero divisor
///
/// Throws [CalcException] on domain errors.
int div(int a, int b) {
  final err = calloc<_WeaveFFIError>();
  try {
    final result = _weaveffiCalculatorDiv(a, b, err);
    _checkCalcException(err);
    return result;
  } finally {
    calloc.free(err);
  }
}

typedef _NativeWeaveffiCalculatorEcho = Pointer<Utf8> Function(Pointer<Utf8>, Pointer<_WeaveFFIError>);
typedef _DartWeaveffiCalculatorEcho = Pointer<Utf8> Function(Pointer<Utf8>, Pointer<_WeaveFFIError>);
final _weaveffiCalculatorEcho = _lib.lookupFunction<
    _NativeWeaveffiCalculatorEcho, _DartWeaveffiCalculatorEcho>('weaveffi_calculator_echo');

/// Echo a string back
String echo(String s) {
  final sPtr = s.toNativeUtf8();
  final err = calloc<_WeaveFFIError>();
  try {
    final result = _weaveffiCalculatorEcho(sPtr, err);
    _checkError(err);
    final value = result.toDartString();
    _weaveffiFreeString(result);
    return value;
  } finally {
    calloc.free(sPtr);
    calloc.free(err);
  }
}

