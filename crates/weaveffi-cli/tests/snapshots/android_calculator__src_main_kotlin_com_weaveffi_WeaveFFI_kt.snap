/** Generic WeaveFFI failure: panics, marshalling errors, and unknown codes. */
open class WeaveFFIException(val code: Int, message: String) : Exception(message)

/** Typed error domain `CalcError` declared by module `calculator`. */
sealed class CalcException(code: Int, message: String) : WeaveFFIException(code, message) {
    class DivisionByZero(message: String = "division by zero") : CalcException(1, message)

    companion object {
        /** Map a raw `CalcError` code to its typed exception; unknown codes yield the generic [WeaveFFIException]. */
        fun fromCode(code: Int, message: String): WeaveFFIException = when (code) {
            1 -> DivisionByZero(message)
            else -> WeaveFFIException(code, message)
        }
    }
