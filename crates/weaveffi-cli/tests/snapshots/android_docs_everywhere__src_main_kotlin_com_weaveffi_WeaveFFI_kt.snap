// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

package com.weaveffi

import kotlinx.coroutines.suspendCancellableCoroutine
import kotlin.coroutines.resume
import kotlin.coroutines.resumeWithException

class WeaveFFI {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @Volatile private var callbackExceptionHandler: ((Throwable) -> Unit)? = null

        /**
         * Installs a handler for exceptions thrown by listener callbacks and
         * async continuations on native producer threads. These exceptions have
         * no Kotlin caller to propagate to; when no handler is installed, they
         * are logged with their stack trace and dropped. Pass `null` to
         * restore the default logging behavior.
         */
        @JvmStatic fun setCallbackExceptionHandler(handler: ((Throwable) -> Unit)?) {
            callbackExceptionHandler = handler
        }

        // Invoked from the JNI glue; rethrowing signals "no handler" so the
        // glue falls back to ExceptionDescribe.
        @JvmStatic private fun dispatchCallbackException(t: Throwable) {
            callbackExceptionHandler?.invoke(t) ?: throw t
        }

        /**
         * Subscribe to document-saved notifications
         *
         * Exceptions thrown by the callback cannot propagate to a caller (events fire on a producer thread); they are delivered to the handler installed via [setCallbackExceptionHandler], or logged with their stack trace and dropped when no handler is set.
         */
        @JvmStatic external fun registerSavedListener(callback: (Long, Int) -> Unit): Long
        @JvmStatic external fun unregisterSavedListener(id: Long)
        /**
         * Create a brand new document.
         *
         * The document starts in `Draft` status; callers must publish
         * it explicitly to make it visible.
         * @param title Human-readable title for the new document
         * @param tags Initial set of tags (may be empty)
         */
        @JvmStatic private external fun createDocumentJni(title: String, tags: Array<String>): Long
        @JvmStatic fun createDocument(title: String, tags: Array<String>): Document = Document(createDocumentJni(title, tags))
        /**
         * Look up a document by identifier
         * @param id Identifier returned from create_document
         */
        @JvmStatic private external fun getDocumentJni(id: Long): Long?
        @JvmStatic fun getDocument(id: Long): Document? = getDocumentJni(id)?.let { Document(it) }
        /**
         * Publish a document in the background
         * @param id Identifier of the document to publish
         */
        @JvmStatic private external fun publishAsyncAsync(id: Long, callback: Any)
        @JvmStatic suspend fun publishAsync(id: Long): Boolean = suspendCancellableCoroutine { cont ->
            publishAsyncAsync(id, WeaveContinuation(cont) { code, message -> WeaveFFIException(code, message) })
        }
    }
}

/**
 * Lifecycle status of a document.
 *
 * Used to drive UI badges and filters.
 */
enum class Status(val value: Int) {
    /** Document is being edited */
    Draft(0),
    /** Document is publicly visible */
    Published(1),
    /** Document is hidden from listings */
    Archived(2);

    companion object {
        fun fromValue(value: Int): Status = entries.first { it.value == value }
    }
}

/**
 * Represents a single document tracked by the system.
 *
 * Documents are persisted to disk and exposed via the public API.
 */
class Document internal constructor(internal var handle: Long) : java.io.Closeable {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic external fun nativeCreate(id: Long, title: String, status: Int, tags: Array<String>): Long
        @JvmStatic external fun nativeDestroy(handle: Long)
        @JvmStatic external fun nativeGetId(handle: Long): Long
        @JvmStatic external fun nativeGetTitle(handle: Long): String
        @JvmStatic external fun nativeGetStatus(handle: Long): Int
        @JvmStatic external fun nativeGetTags(handle: Long): Array<String>

        fun create(id: Long, title: String, status: Int, tags: Array<String>): Document = Document(nativeCreate(id, title, status, tags))
    }

    /** Stable opaque identifier */
    val id: Long get() = nativeGetId(handle)
    /** Human-readable title shown in lists */
    val title: String get() = nativeGetTitle(handle)
    /** Current lifecycle status */
    val status: Status get() = Status.fromValue(nativeGetStatus(handle))
    /** Free-form tags for grouping */
    val tags: Array<String> get() = nativeGetTags(handle)

    override fun close() {
        if (handle != 0L) {
            nativeDestroy(handle)
            handle = 0L
        }
    }

    protected fun finalize() {
        close()
    }
}

/**
 * Represents a single document tracked by the system.
 *
 * Documents are persisted to disk and exposed via the public API.
 */
class DocumentBuilder {
    private var id: Long? = null
    private var title: String? = null
    private var status: Status? = null
    private var tags: Array<String>? = null
    /** Stable opaque identifier */
    fun withId(id: Long): DocumentBuilder {
        this.id = id
        return this
    }
    /** Human-readable title shown in lists */
    fun withTitle(title: String): DocumentBuilder {
        this.title = title
        return this
    }
    /** Current lifecycle status */
    fun withStatus(status: Status): DocumentBuilder {
        this.status = status
        return this
    }
    /** Free-form tags for grouping */
    fun withTags(tags: Array<String>): DocumentBuilder {
        this.tags = tags
        return this
    }
    fun build(): Document {
        return Document.create(
            id ?: throw IllegalStateException("missing field: id"),
            title ?: throw IllegalStateException("missing field: title"),
            status ?: throw IllegalStateException("missing field: status"),
            tags ?: throw IllegalStateException("missing field: tags")
        )
    }
}

/**
 * An ordered collection of documents.
 *
 * Notebooks own their documents and release them when destroyed.
 */
class Notebook internal constructor(internal var handle: Long) : java.io.Closeable {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic private external fun nativeNew(): Long
        @JvmStatic private external fun nativeMaxDocuments(): Int
        @JvmStatic private external fun nativeInsert(selfHandle: Long, document: Long): Int
        @JvmStatic private external fun nativeFind(selfHandle: Long, id: Long): Long
        @JvmStatic private external fun nativeSize(selfHandle: Long): Int
        @JvmStatic private external fun nativeDestroy(handle: Long)

        /**
         * Create an empty notebook
         */
        operator fun invoke(): Notebook = Notebook(nativeNew())

        /**
         * The largest number of documents one notebook will hold
         */
        fun maxDocuments(): Int = nativeMaxDocuments()
    }

    /**
     * Add a document, returning its position in the notebook
     * @param document The document to add
     */
    fun insert(document: Document): Int = nativeInsert(handle, document.handle)

    /**
     * Look up a document by identifier, failing when none matches
     * @param id Identifier of the document to find
     */
    fun find(id: Long): Document = Document(nativeFind(handle, id))

    /**
     * The number of documents currently held
     */
    fun size(): Int = nativeSize(handle)

    override fun close() {
        if (handle != 0L) {
            nativeDestroy(handle)
            handle = 0L
        }
    }

    protected fun finalize() {
        close()
    }
}

/** Generic WeaveFFI failure: panics, marshalling errors, and unknown codes. */
open class WeaveFFIException(val code: Int, message: String) : Exception(message)

/** Typed error domain `DocsErrors` declared by module `docs`. */
sealed class DocsErrorsException(code: Int, message: String) : WeaveFFIException(code, message) {
    /** Returned when no document matches the requested id */
    class NotFound(message: String = "Document not found") : DocsErrorsException(1, message)
    /** Raised when attempting to move into a forbidden state */
    class InvalidStatus(message: String = "Invalid status transition") : DocsErrorsException(2, message)

    companion object {
        /** Map a raw `DocsErrors` code to its typed exception; unknown codes yield the generic [WeaveFFIException]. */
        fun fromCode(code: Int, message: String): WeaveFFIException = when (code) {
            1 -> NotFound(message)
            2 -> InvalidStatus(message)
            else -> WeaveFFIException(code, message)
        }
    }
}

internal class WeaveContinuation<T>(
    private val cont: kotlinx.coroutines.CancellableContinuation<T>,
    private val mapError: (Int, String) -> Throwable
) {
    @Suppress("UNCHECKED_CAST")
    fun onSuccess(result: Any?) { cont.resume(result as T) }
    fun onError(code: Int, message: String) { cont.resumeWithException(mapError(code, message)) }
}

