// Generated types for WeaveFFI functions
// module events
/**
 * Send a message, triggering the OnMessage callback
 * Maps to C function: weaveffi_events_send_message
 */
export function send_message(text: string): void
/**
 * Return an iterator over all sent messages
 * Maps to C function: weaveffi_events_get_messages
 */
export function get_messages(): string[]
