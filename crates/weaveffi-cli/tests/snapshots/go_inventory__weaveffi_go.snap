package weaveffi

/*
#cgo LDFLAGS: -lweaveffi
#include "weaveffi.h"
#include <stdlib.h>
*/
import "C"

import (
	"fmt"
	"unsafe"
)

func boolToC(b bool) C._Bool {
	if b {
		return 1
	}
	return 0
}

func cToBool(b C._Bool) bool {
	return b != 0
}

type Category int32

const (
	CategoryElectronics Category = 0
	CategoryClothing Category = 1
	CategoryFood Category = 2
	CategoryBooks Category = 3
)

type Product struct {
	ptr *C.weaveffi_products_Product
}

func (s *Product) Id() int64 {
	return int64(C.weaveffi_products_Product_get_id(s.ptr))
}

func (s *Product) Name() string {
	return C.GoString(C.weaveffi_products_Product_get_name(s.ptr))
}

func (s *Product) Description() *string {
	cStr := C.weaveffi_products_Product_get_description(s.ptr)
	if cStr == nil {
		return nil
	}
	v := C.GoString(cStr)
	return &v
}

func (s *Product) Price() float64 {
	return float64(C.weaveffi_products_Product_get_price(s.ptr))
}

func (s *Product) Category() Category {
	return Category(C.weaveffi_products_Product_get_category(s.ptr))
}

func (s *Product) Tags() []string {
	return []string(C.weaveffi_products_Product_get_tags(s.ptr))
}

func (s *Product) Close() {
	if s.ptr != nil {
		C.weaveffi_products_Product_destroy(s.ptr)
		s.ptr = nil
	}
}

func ProductsCreateProduct(name string, price float64, category Category) (int64, error) {
	cName := C.CString(name)
	defer C.free(unsafe.Pointer(cName))
	var cErr C.weaveffi_error
	result := C.weaveffi_products_create_product(cName, C.double(price), C.weaveffi_products_Category(category), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return 0, goErr
	}
	return int64(result), nil
}

func ProductsGetProduct(id int64) (*Product, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_products_get_product(C.weaveffi_handle_t(id), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	return &Product{ptr: result}, nil
}

func ProductsSearchProducts(category Category) ([]*Product, error) {
	var cOutLen C.size_t
	var cErr C.weaveffi_error
	result := C.weaveffi_products_search_products(C.weaveffi_products_Category(category), &cOutLen, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	count := int(cOutLen)
	if count == 0 || result == nil {
		return nil, nil
	}
	goResult := make([]*Product, count)
	cSlice := unsafe.Slice((**C.weaveffi_products_Product)(unsafe.Pointer(result)), count)
	for i, v := range cSlice {
		goResult[i] = &Product{ptr: v}
	}
	return goResult, nil
}

func ProductsUpdatePrice(id int64, price float64) (bool, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_products_update_price(C.weaveffi_handle_t(id), C.double(price), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return false, goErr
	}
	return cToBool(result), nil
}

func ProductsDeleteProduct(id int64) (bool, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_products_delete_product(C.weaveffi_handle_t(id), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return false, goErr
	}
	return cToBool(result), nil
}

type OrderItem struct {
	ptr *C.weaveffi_orders_OrderItem
}

func (s *OrderItem) ProductId() int64 {
	return int64(C.weaveffi_orders_OrderItem_get_product_id(s.ptr))
}

func (s *OrderItem) Quantity() int32 {
	return int32(C.weaveffi_orders_OrderItem_get_quantity(s.ptr))
}

func (s *OrderItem) UnitPrice() float64 {
	return float64(C.weaveffi_orders_OrderItem_get_unit_price(s.ptr))
}

func (s *OrderItem) Close() {
	if s.ptr != nil {
		C.weaveffi_orders_OrderItem_destroy(s.ptr)
		s.ptr = nil
	}
}

type Order struct {
	ptr *C.weaveffi_orders_Order
}

func (s *Order) Id() int64 {
	return int64(C.weaveffi_orders_Order_get_id(s.ptr))
}

func (s *Order) Items() []*OrderItem {
	return []*OrderItem(C.weaveffi_orders_Order_get_items(s.ptr))
}

func (s *Order) Total() float64 {
	return float64(C.weaveffi_orders_Order_get_total(s.ptr))
}

func (s *Order) Status() string {
	return C.GoString(C.weaveffi_orders_Order_get_status(s.ptr))
}

func (s *Order) Close() {
	if s.ptr != nil {
		C.weaveffi_orders_Order_destroy(s.ptr)
		s.ptr = nil
	}
}

func OrdersCreateOrder(items []*OrderItem) (int64, error) {
	cItemsLen := C.size_t(len(items))
	cItemsArr := make([]*C.weaveffi_orders_OrderItem, len(items))
	for i, item := range items {
		cItemsArr[i] = item.ptr
	}
	var cItemsPtr **C.weaveffi_orders_OrderItem
	if len(cItemsArr) > 0 {
		cItemsPtr = (**C.weaveffi_orders_OrderItem)(unsafe.Pointer(&cItemsArr[0]))
	}
	var cErr C.weaveffi_error
	result := C.weaveffi_orders_create_order(cItemsPtr, cItemsLen, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return 0, goErr
	}
	return int64(result), nil
}

func OrdersGetOrder(id int64) (*Order, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_orders_get_order(C.weaveffi_handle_t(id), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	return &Order{ptr: result}, nil
}

func OrdersCancelOrder(id int64) (bool, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_orders_cancel_order(C.weaveffi_handle_t(id), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return false, goErr
	}
	return cToBool(result), nil
}

func OrdersAddProductToOrder(orderId int64, product *Product) (bool, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_orders_add_product_to_order(C.weaveffi_handle_t(orderId), product.ptr, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return false, goErr
	}
	return cToBool(result), nil
}
