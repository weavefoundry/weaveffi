}

// ProductsError codes.
const (
	// ProductsErrorInvalidPrice price must be positive
	ProductsErrorInvalidPrice int32 = 1
	// ProductsErrorProductNotFound product not found
	ProductsErrorProductNotFound int32 = 2
)

// wvMapProducts converts a non-zero code from the `products` domain into a
// *ProductsError, falling back to the generic *WeaveFFIError for unknown codes.
func wvMapProducts(code int32, message string) error {
	switch code {
	case ProductsErrorInvalidPrice:
		if message == "" {
			message = "price must be positive"
		}
		return &ProductsError{Code: code, Message: message}
	case ProductsErrorProductNotFound:
		if message == "" {
			message = "product not found"
		}
		return &ProductsError{Code: code, Message: message}
	default:
		return wvBrandError(code, message)
	}
}

