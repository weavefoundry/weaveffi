// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

import CWeaveFFI
import Foundation

public enum WeaveFFIError: Error, LocalizedError {
    case error(code: Int32, message: String)
    public var errorDescription: String? {
        switch self {
        case let .error(_, message): return message
        }
    }
    public var errorCode: Int32 {
        switch self {
        case let .error(code, _): return code
        }
    }
}

@inline(__always)
func check(_ err: inout weaveffi_error) throws {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        throw WeaveFFIError.error(code: code, message: message)
    }
}

@inline(__always)
func trap(_ err: inout weaveffi_error) {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        fatalError("\(code): \(message)")
    }
}

@inline(__always)
func withOptionalPointer<T, R>(to value: T?, _ body: (UnsafePointer<T>?) throws -> R) rethrows -> R {
    guard let value = value else { return try body(nil) }
    return try withUnsafePointer(to: value) { try body($0) }
}

@inline(__always)
func withOptionalCString<R>(_ value: String?, _ body: (UnsafePointer<CChar>?) throws -> R) rethrows -> R {
    guard let value = value else { return try body(nil) }
    return try value.withCString { try body($0) }
}

@inline(__always)
func wvFreeArray<T>(_ ptr: UnsafeMutablePointer<T>, _ count: Int) {
    weaveffi_free_bytes(UnsafeMutableRawPointer(ptr).assumingMemoryBound(to: UInt8.self), count * MemoryLayout<T>.stride)
}

@inline(__always)
func wvFreeBox<T>(_ ptr: UnsafeMutablePointer<T>) {
    weaveffi_free_bytes(UnsafeMutableRawPointer(ptr).assumingMemoryBound(to: UInt8.self), MemoryLayout<T>.size)
}

private final class ContinuationRef<T, E: Error> {
    let value: CheckedContinuation<T, E>
    init(_ value: CheckedContinuation<T, E>) { self.value = value }
}

final class WvCallbackBox<T> {
    let value: T
    init(_ value: T) { self.value = value }
}

var wvListenerContexts: [UInt64: UnsafeMutableRawPointer] = [:]
let wvListenerLock = NSLock()

/// Typed errors reported by the `kv` module.
public enum KvError: Error, LocalizedError {
    /// No entry exists for the requested key
    case keyNotFound(message: String)
    /// The entry exists but its TTL has elapsed
    case expired(message: String)
    /// The store has reached its capacity limit
    case storeFull(message: String)
    /// Underlying storage reported an I/O failure
    case ioError(message: String)
    public var errorDescription: String? {
        switch self {
        case let .keyNotFound(message): return message
        case let .expired(message): return message
        case let .storeFull(message): return message
        case let .ioError(message): return message
        }
    }
    /// The numeric ABI code carried by this error.
    public var errorCode: Int32 {
        switch self {
        case .keyNotFound: return 1001
        case .expired: return 1002
        case .storeFull: return 1003
        case .ioError: return 1004
        }
    }
}

@inline(__always)
func mapKv(code: Int32, message: String) -> Error {
    switch code {
    case 1001: return KvError.keyNotFound(message: message.isEmpty ? "key not found" : message)
    case 1002: return KvError.expired(message: message.isEmpty ? "entry expired" : message)
    case 1003: return KvError.storeFull(message: message.isEmpty ? "store has reached capacity" : message)
    case 1004: return KvError.ioError(message: message.isEmpty ? "I/O failure" : message)
    default: return WeaveFFIError.error(code: code, message: message)
    }
}

@inline(__always)
func checkKv(_ err: inout weaveffi_error) throws {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        throw mapKv(code: code, message: message)
    }
}

/// Persistence semantics applied to a stored entry
public enum EntryKind: UInt32 {
    /// In-memory only; lost on close
    case volatile = 0
    /// Flushed to durable storage
    case persistent = 1
    /// Persistent and encrypted at rest
    case encrypted = 2
}

/// A single key-value entry persisted in the store
public class Entry {
    let ptr: OpaquePointer

    init(ptr: OpaquePointer) {
        self.ptr = ptr
    }

    deinit {
        weaveffi_kv_Entry_destroy(ptr)
    }

    /// Stable monotonic identifier assigned on insert
    public var id: Int64 {
        return weaveffi_kv_Entry_get_id(ptr)
    }

    /// UTF-8 lookup key
    public var key: String {
        let raw = weaveffi_kv_Entry_get_key(ptr)
        guard let raw = raw else { return "" }
        defer { weaveffi_free_string(raw) }
        return String(cString: raw)
    }

    /// Opaque binary payload
    public var value: Data {
        var outLen: Int = 0
        let raw = weaveffi_kv_Entry_get_value(ptr, &outLen)
        guard let raw = raw else { return Data() }
        defer { weaveffi_free_bytes(UnsafeMutablePointer(mutating: raw), outLen) }
        return Data(bytes: raw, count: outLen)
    }

    /// Unix-timestamp seconds when the entry was created
    public var created_at: Int64 {
        return weaveffi_kv_Entry_get_created_at(ptr)
    }

    /// Optional unix-timestamp seconds at which the entry expires
    public var expires_at: Int64? {
        let p = weaveffi_kv_Entry_get_expires_at(ptr)
        guard let p = p else { return nil }
        defer { wvFreeBox(p) }
        return p.pointee
    }

    /// Free-form labels attached to the entry
    public var tags: [String] {
        var outLen: Int = 0
        let rv = weaveffi_kv_Entry_get_tags(ptr, &outLen)
        guard let rv = rv else { return [] }
        defer { wvFreeArray(rv, outLen) }
        var items: [String] = []
        items.reserveCapacity(outLen)
        for i in 0..<outLen {
            items.append(String(cString: rv[i]!))
            weaveffi_free_string(rv[i])
        }
        return items
    }

    /// Arbitrary string-valued metadata pairs
    public var metadata: [String: String] {
        var outKeysPtr: UnsafeMutablePointer<UnsafePointer<CChar>?>? = nil
        var outValuesPtr: UnsafeMutablePointer<UnsafePointer<CChar>?>? = nil
        var outLen: Int = 0
        weaveffi_kv_Entry_get_metadata(ptr, &outKeysPtr, &outValuesPtr, &outLen)
        guard let outKeys = outKeysPtr, let outValues = outValuesPtr else { return [:] }
        defer { wvFreeArray(outKeys, outLen); wvFreeArray(outValues, outLen) }
        var result: [String: String] = [:]
        for i in 0..<outLen {
            result[String(cString: outKeys[i]!)] = String(cString: outValues[i]!)
            weaveffi_free_string(outKeys[i])
            weaveffi_free_string(outValues[i])
        }
        return result
    }
}

/// A single key-value entry persisted in the store
public class EntryBuilder {
    private var _id: Int64?
    private var _key: String?
    private var _value: Data?
    private var _created_at: Int64?
    private var _expires_at: Int64??
    private var _tags: [String]?
    private var _metadata: [String: String]?

    public init() {}

    /// Stable monotonic identifier assigned on insert
    @discardableResult
    public func withId(_ value: Int64) -> Self {
        self._id = value
        return self
    }

    /// UTF-8 lookup key
    @discardableResult
    public func withKey(_ value: String) -> Self {
        self._key = value
        return self
    }

    /// Opaque binary payload
    @discardableResult
    public func withValue(_ value: Data) -> Self {
        self._value = value
        return self
    }

    /// Unix-timestamp seconds when the entry was created
    @discardableResult
    public func withCreatedAt(_ value: Int64) -> Self {
        self._created_at = value
        return self
    }

    /// Optional unix-timestamp seconds at which the entry expires
    @discardableResult
    public func withExpiresAt(_ value: Int64?) -> Self {
        self._expires_at = value
        return self
    }

    /// Free-form labels attached to the entry
    @discardableResult
    public func withTags(_ value: [String]) -> Self {
        self._tags = value
        return self
    }

    /// Arbitrary string-valued metadata pairs
    @discardableResult
    public func withMetadata(_ value: [String: String]) -> Self {
        self._metadata = value
        return self
    }

    public func build() throws -> Entry {
        guard let id = _id else { throw WeaveFFIError.error(code: -1, message: "missing field: id") }
        guard let key = _key else { throw WeaveFFIError.error(code: -1, message: "missing field: key") }
        guard let value = _value else { throw WeaveFFIError.error(code: -1, message: "missing field: value") }
        guard let created_at = _created_at else { throw WeaveFFIError.error(code: -1, message: "missing field: created_at") }
        guard let expires_at = _expires_at else { throw WeaveFFIError.error(code: -1, message: "missing field: expires_at") }
        guard let tags = _tags else { throw WeaveFFIError.error(code: -1, message: "missing field: tags") }
        guard let metadata = _metadata else { throw WeaveFFIError.error(code: -1, message: "missing field: metadata") }
        var err = weaveffi_error(code: 0, message: nil)
        let value_bytes = Array(value)
        let tags_cstrs: [UnsafePointer<CChar>?] = tags.map { UnsafePointer(strdup($0)) }
        defer { tags_cstrs.forEach { if let s = $0 { free(UnsafeMutablePointer(mutating: s)) } } }
        let metadata_keys = Array(metadata.keys)
        let metadata_values = metadata_keys.map { metadata[$0]! }
        let metadata_keysCstrs: [UnsafePointer<CChar>?] = metadata_keys.map { UnsafePointer(strdup($0)) }
        defer { metadata_keysCstrs.forEach { if let s = $0 { free(UnsafeMutablePointer(mutating: s)) } } }
        let metadata_valuesCstrs: [UnsafePointer<CChar>?] = metadata_values.map { UnsafePointer(strdup($0)) }
        defer { metadata_valuesCstrs.forEach { if let s = $0 { free(UnsafeMutablePointer(mutating: s)) } } }
        let result: OpaquePointer? = key.withCString { key_ptr in
            return value_bytes.withUnsafeBufferPointer { value_buf in
                let value_ptr = value_buf.baseAddress!
                let value_len = value_buf.count
                return withOptionalPointer(to: expires_at) { expires_at_ptr in
                    return tags_cstrs.withUnsafeBufferPointer { tags_buf in
                        let tags_ptr = tags_buf.baseAddress
                        let tags_len = tags_buf.count
                        return metadata_keysCstrs.withUnsafeBufferPointer { metadata_keys_buf in
                            let metadata_keys_ptr = metadata_keys_buf.baseAddress
                            return metadata_valuesCstrs.withUnsafeBufferPointer { metadata_values_buf in
                                let metadata_values_ptr = metadata_values_buf.baseAddress
                                let metadata_len = metadata_values_buf.count
                                    return weaveffi_kv_Entry_create(id, key_ptr, value_ptr, value_len, created_at, expires_at_ptr, tags_ptr, tags_len, metadata_keys_ptr, metadata_values_ptr, metadata_len, &err)
                            }
                        }
                    }
                }
            }
        }
        try check(&err)
        guard let result = result else { throw WeaveFFIError.error(code: -1, message: "null pointer") }
        return Entry(ptr: result)
    }
}

/// An in-memory key-value store owning its entries; destroying the object releases all of its state
public final class Store {
    let ptr: OpaquePointer

    init(ptr: OpaquePointer) {
        self.ptr = ptr
    }

    deinit {
        weaveffi_kv_Store_destroy(ptr)
    }
    /// Open (or create) a store backed by the given filesystem path
    public static func open(path: String) throws -> Store {
        var err = weaveffi_error(code: 0, message: nil)
        let result: OpaquePointer? = path.withCString { path_ptr in
                return weaveffi_kv_Store_open(path_ptr, &err)
        }
        try checkKv(&err)
        guard let result = result else { throw WeaveFFIError.error(code: -1, message: "null pointer") }
        return Store(ptr: result)
    }
    /// Insert or replace a value, returning true on success
    public func put(key: String, value: Data, kind: EntryKind, ttlSeconds: Int64?) throws -> Bool {
        var err = weaveffi_error(code: 0, message: nil)
        let value_bytes = Array(value)
        let result: Bool = key.withCString { key_ptr in
            return value_bytes.withUnsafeBufferPointer { value_buf in
                let value_ptr = value_buf.baseAddress!
                let value_len = value_buf.count
                return withOptionalPointer(to: ttlSeconds) { ttlSeconds_ptr in
                        return weaveffi_kv_Store_put(ptr, key_ptr, value_ptr, value_len, weaveffi_kv_EntryKind(kind.rawValue), ttlSeconds_ptr, &err)
                }
            }
        }
        try checkKv(&err)
        return result
    }
    /// Look up an entry by key; returns null if missing or expired
    public func get(key: String) throws -> Entry? {
        var err = weaveffi_error(code: 0, message: nil)
        let result: Entry? = try key.withCString { key_ptr in
                let rv = weaveffi_kv_Store_get(ptr, key_ptr, &err)
                try checkKv(&err)
                return rv.map { Entry(ptr: $0) }
        }
        return result
    }
    /// Remove the entry for the given key, returning true if it existed
    public func delete(key: String) throws -> Bool {
        var err = weaveffi_error(code: 0, message: nil)
        let result: Bool = key.withCString { key_ptr in
                return weaveffi_kv_Store_delete(ptr, key_ptr, &err)
        }
        try checkKv(&err)
        return result
    }
    /// Stream every key, optionally filtered by a prefix
    /// - Returns: A lazy sequence that pulls one element per step from the
    ///   producer; the underlying iterator is destroyed when the sequence is
    ///   exhausted or deinitialized.
    /// - Throws: The module's typed error if the launch fails. Mid-stream
    ///   errors end iteration and are stored in the sequence's `error`
    ///   property instead of being thrown.
    public func listKeys(prefix: String?) throws -> KvStoreListKeysIterator {
        var err = weaveffi_error(code: 0, message: nil)
        let result: KvStoreListKeysIterator = try withOptionalCString(prefix) { prefix_ptr in
                let iter = weaveffi_kv_Store_list_keys(ptr, prefix_ptr, &err)
                try checkKv(&err)
                guard let iter = iter else { throw WeaveFFIError.error(code: -1, message: "null iterator") }
                return KvStoreListKeysIterator(handle: iter)
        }
        return result
    }
    /// Return the number of live entries in the store
    public func count() -> Int64 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kv_Store_count(ptr, &err)
        trap(&err)
        return rv
    }
    /// Drop every entry from the store
    public func clear() -> Void {
        var err = weaveffi_error(code: 0, message: nil)
        weaveffi_kv_Store_clear(ptr, &err)
        trap(&err)
    }
    /// Reclaim space asynchronously; returns the number of bytes reclaimed
    public func compact() async throws -> Int64 {
        try await withCheckedThrowingContinuation { (continuation: CheckedContinuation<Int64, Error>) in
            let ctx = Unmanaged.passRetained(ContinuationRef(continuation)).toOpaque()
            weaveffi_kv_Store_compact_async(ptr, nil, { context, err, result in
                let contRef = Unmanaged<ContinuationRef<Int64, Error>>.fromOpaque(context!).takeRetainedValue()
                if let err = err, err.pointee.code != 0 {
                    let code = err.pointee.code
                    let msg = err.pointee.message.flatMap { String(cString: $0) } ?? ""
                    contRef.value.resume(throwing: mapKv(code: code, message: msg))
                } else {
                    contRef.value.resume(returning: result)
                }
            }, ctx)
        }
    }
    /// Legacy single-shot put kept for compatibility
    @available(*, deprecated, message: "use put() with explicit kind")
    public func legacyPut(key: String, value: Data) throws -> Bool {
        var err = weaveffi_error(code: 0, message: nil)
        let value_bytes = Array(value)
        let result: Bool = key.withCString { key_ptr in
            return value_bytes.withUnsafeBufferPointer { value_buf in
                let value_ptr = value_buf.baseAddress!
                let value_len = value_buf.count
                    return weaveffi_kv_Store_legacy_put(ptr, key_ptr, value_ptr, value_len, &err)
            }
        }
        try checkKv(&err)
        return result
    }
    /// The largest number of live entries one store will hold
    public static func defaultCapacity() -> Int64 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kv_Store_default_capacity(&err)
        trap(&err)
        return rv
    }
}

/// A lazy sequence over the `String` elements streamed by `weaveffi_kv_Store_list_keys`.
///
/// Each `next()` call pulls exactly one element from the producer. The
/// underlying C iterator is destroyed eagerly on exhaustion and from
/// `deinit` when iteration is abandoned early.
///
/// If the producer reports an error mid-stream, iteration ends and the
/// error is stored in ``error`` for the caller to inspect after the loop.
public final class KvStoreListKeysIterator: Sequence, IteratorProtocol {
    private var handle: OpaquePointer?
    /// The error that ended iteration early, if any.
    public private(set) var error: Error?

    init(handle: OpaquePointer) {
        self.handle = handle
    }

    deinit {
        destroyHandle()
    }

    private func destroyHandle() {
        guard let handle = handle else { return }
        weaveffi_kv_Store_ListKeysIterator_destroy(handle)
        self.handle = nil
    }

    /// Pulls the next element from the producer, or returns `nil` once the
    /// stream is exhausted (destroying the underlying iterator).
    public func next() -> String? {
        guard let handle = handle else { return nil }
        var item: UnsafePointer<CChar>? = nil
        var err = weaveffi_error(code: 0, message: nil)
        if weaveffi_kv_Store_ListKeysIterator_next(handle, &item, &err) == 0 {
            if err.code != 0 {
                let code = err.code
                let message = err.message.flatMap { String(cString: $0) } ?? ""
                weaveffi_error_clear(&err)
                self.error = mapKv(code: code, message: message)
            }
            destroyHandle()
            return nil
        }
        let element = String(cString: item!)
        weaveffi_free_string(item)
        return element
    }
}

/// Aggregate store statistics
public class Stats {
    let ptr: OpaquePointer

    init(ptr: OpaquePointer) {
        self.ptr = ptr
    }

    deinit {
        weaveffi_kv_stats_Stats_destroy(ptr)
    }

    /// Number of live entries
    public var total_entries: Int64 {
        return weaveffi_kv_stats_Stats_get_total_entries(ptr)
    }

    /// Sum of all value byte lengths
    public var total_bytes: Int64 {
        return weaveffi_kv_stats_Stats_get_total_bytes(ptr)
    }

    /// Number of entries past their TTL but not yet evicted
    public var expired_entries: Int64 {
        return weaveffi_kv_stats_Stats_get_expired_entries(ptr)
    }
}

public enum Kv {
    /// Subscribe to per-key eviction notifications
    /// - Returns: A subscription id for ``unregisterEvictionListener(_:)``.
    public static func registerEvictionListener(_ callback: @escaping (String) -> Void) -> UInt64 {
        let box = WvCallbackBox(callback)
        let ctx = Unmanaged.passRetained(box).toOpaque()
        let id = weaveffi_kv_register_eviction_listener({ key, context in
            let cb = Unmanaged<WvCallbackBox<(String) -> Void>>.fromOpaque(context!).takeUnretainedValue().value
            cb(String(cString: key!))
        }, ctx)
        wvListenerLock.lock()
        wvListenerContexts[id] = ctx
        wvListenerLock.unlock()
        return id
    }
    /// Unregisters a listener previously registered with ``registerEvictionListener(_:)``.
    public static func unregisterEvictionListener(_ id: UInt64) {
        weaveffi_kv_unregister_eviction_listener(id)
        wvListenerLock.lock()
        let ctx = wvListenerContexts.removeValue(forKey: id)
        wvListenerLock.unlock()
        if let ctx = ctx {
            Unmanaged<WvCallbackBox<(String) -> Void>>.fromOpaque(ctx).release()
        }
    }
    public enum Stats {
        /// Snapshot the current store statistics
        public static func getStats(store: Store) throws -> WeaveFFI.Stats {
            var err = weaveffi_error(code: 0, message: nil)
            let rv = weaveffi_kv_stats_get_stats(store.ptr, &err)
            try checkKv(&err)
            guard let rv = rv else { throw WeaveFFIError.error(code: -1, message: "null pointer") }
            return WeaveFFI.Stats(ptr: rv)
        }
    }
}

