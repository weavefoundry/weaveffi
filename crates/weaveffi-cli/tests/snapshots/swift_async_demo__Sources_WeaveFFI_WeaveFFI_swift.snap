import CWeaveFFI
import Foundation

public enum WeaveFFIError: Error, LocalizedError {
    case error(code: Int32, message: String)
    public var errorDescription: String? {
        switch self {
        case let .error(_, message): return message
        }
    }
    public var errorCode: Int32 {
        switch self {
        case let .error(code, _): return code
        }
    }
}

@inline(__always)
func check(_ err: inout weaveffi_error) throws {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        throw WeaveFFIError.error(code: code, message: message)
    }
}

@inline(__always)
func withOptionalPointer<T, R>(to value: T?, _ body: (UnsafePointer<T>?) throws -> R) rethrows -> R {
    guard let value = value else { return try body(nil) }
    return try withUnsafePointer(to: value) { try body($0) }
}

private final class ContinuationRef<T> {
    let value: CheckedContinuation<T, Error>
    init(_ value: CheckedContinuation<T, Error>) { self.value = value }
}

public class TaskResult {
    let ptr: OpaquePointer

    init(ptr: OpaquePointer) {
        self.ptr = ptr
    }

    deinit {
        weaveffi_tasks_TaskResult_destroy(ptr)
    }

    public var id: Int64 {
        return weaveffi_tasks_TaskResult_get_id(ptr)
    }

    public var value: String {
        let raw = weaveffi_tasks_TaskResult_get_value(ptr)
        guard let raw = raw else { return "" }
        defer { weaveffi_free_string(raw) }
        return String(cString: raw)
    }

    public var success: Bool {
        return weaveffi_tasks_TaskResult_get_success(ptr)
    }
}

public enum Tasks {
    public static func run_task(_ name: String) async throws -> TaskResult {
        try await withCheckedThrowingContinuation { (continuation: CheckedContinuation<TaskResult, Error>) in
            let ctx = Unmanaged.passRetained(ContinuationRef(continuation)).toOpaque()
            let name_bytes = Array(name.utf8)
            name_bytes.withUnsafeBufferPointer { name_buf in
                let name_ptr = name_buf.baseAddress!
                let name_len = name_buf.count
                weaveffi_tasks_run_task_async(name_ptr, name_len, { context, err, result in
                    let contRef = Unmanaged<ContinuationRef<TaskResult>>.fromOpaque(context!).takeRetainedValue()
                    if let err = err, err.pointee.code != 0 {
                        let code = err.pointee.code
                        let msg = err.pointee.message.flatMap { String(cString: $0) } ?? ""
                        contRef.value.resume(throwing: WeaveFFIError.error(code: code, message: msg))
                    } else {
                        guard let result = result else {
                            contRef.value.resume(throwing: WeaveFFIError.error(code: -1, message: "null pointer"))
                            return
                        }
                        contRef.value.resume(returning: TaskResult(ptr: result))
                    }
                }, ctx)
            }
        }
    }
    public static func run_batch(_ names: [String]) async throws -> [TaskResult] {
        try await withCheckedThrowingContinuation { (continuation: CheckedContinuation<[TaskResult], Error>) in
            let ctx = Unmanaged.passRetained(ContinuationRef(continuation)).toOpaque()
            names.withUnsafeBufferPointer { names_buf in
                let names_ptr = names_buf.baseAddress
                let names_len = names_buf.count
                weaveffi_tasks_run_batch_async(names_ptr, names_len, { context, err, result, resultLen in
                    let contRef = Unmanaged<ContinuationRef<[TaskResult]>>.fromOpaque(context!).takeRetainedValue()
                    if let err = err, err.pointee.code != 0 {
                        let code = err.pointee.code
                        let msg = err.pointee.message.flatMap { String(cString: $0) } ?? ""
                        contRef.value.resume(throwing: WeaveFFIError.error(code: code, message: msg))
                    } else {
                        guard let result = result else {
                            contRef.value.resume(returning: [])
                            return
                        }
                        let len = Int(resultLen)
                        contRef.value.resume(returning: (0..<len).map { TaskResult(ptr: result[$0]!) })
                    }
                }, ctx)
            }
        }
    }
    public static func cancel_task(_ id: Int64) throws -> Bool {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_tasks_cancel_task(id, &err)
        try check(&err)
        return rv
    }
}
