    _enabled = value;
    return this;
  }

  /// Scaling ratio
  ItemBuilder withRatio(double value) {
    _ratio = value;
    return this;
  }

  ItemBuilder withNick(int value) {
    _nick = value;
    return this;
  }

  ItemBuilder withPayload(List<int> value) {
    _payload = value;
    return this;
  }

  ItemBuilder withTags(List<String> value) {
    _tags = value;
    return this;
  }

  ItemBuilder withAttrs(Map<String, String> value) {
    _attrs = value;
    return this;
  }

  ItemBuilder withParent(int? value) {
    _parent = value;
    return this;
  }

  /// Cross-module struct reference
  ItemBuilder withToken(Token value) {
    _token = value;
    return this;
  }

  ItemBuilder withPriority(Priority value) {
    _priority = value;
    return this;
  }

  Item build() {
    if (_id == null) {
      throw StateError('missing field: id');
    }
    if (_name == null) {
      throw StateError('missing field: name');
    }
    if (_count == null) {
      throw StateError('missing field: count');
    }
    if (_enabled == null) {
      throw StateError('missing field: enabled');
    }
    if (_ratio == null) {
      throw StateError('missing field: ratio');
    }
    if (_nick == null) {
      throw StateError('missing field: nick');
    }
    if (_payload == null) {
      throw StateError('missing field: payload');
    }
    if (_tags == null) {
      throw StateError('missing field: tags');
    }
    if (_attrs == null) {
      throw StateError('missing field: attrs');
    }
    if (_token == null) {
      throw StateError('missing field: token');
    }
    if (_priority == null) {
      throw StateError('missing field: priority');
    }
    throw UnimplementedError('ItemBuilder.build requires FFI backing');
  }
