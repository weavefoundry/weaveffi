/// Typed error domain `KitchenErrors` declared by module `kitchen`.
class KitchenErrorsException extends WeaveFFIException {
  KitchenErrorsException(super.code, super.message);
}

/// Item not found
class NotFoundException extends KitchenErrorsException {
  NotFoundException([String message = 'Item not found']) : super(1, message);
}

/// Invalid input
class InvalidInputException extends KitchenErrorsException {
  InvalidInputException([String message = 'Invalid input']) : super(2, message);
}

WeaveFFIException _mapKitchenErrorsException(int code, String message) {
  switch (code) {
    case 1:
      return NotFoundException(message);
    case 2:
      return InvalidInputException(message);
    default:
      return WeaveFFIException(code, message);
  }
}

void _checkKitchenErrorsException(Pointer<_WeaveFFIError> err) {
  if (err.ref.code != 0) {
    final code = err.ref.code;
    final msg = err.ref.message.toDartString();
    _weaveffiErrorClear(err);
    throw _mapKitchenErrorsException(code, msg);
  }
}

/// Task priority levels
enum Priority {
  /// Low priority
  low(0),
  /// Normal priority
  normal(1),
  /// High priority
  high(2),
  ;
  const Priority(this.value);
  final int value;

  static Priority fromValue(int value) =>
      Priority.values.firstWhere((e) => e.value == value);
}

