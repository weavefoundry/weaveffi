  String describe() {
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiKitchenGadgetDescribe(_handle, err);
      _checkError(err);
      return result.toDartString();
    } finally {
      calloc.free(err);
    }
  }

  /// Poke the gadget a number of times, failing on a negative count
  ///
  /// Throws [KitchenErrorsException] on domain errors.
  int poke(int times) {
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiKitchenGadgetPoke(_handle, times, err);
      _checkKitchenErrorsException(err);
      return result;
    } finally {
