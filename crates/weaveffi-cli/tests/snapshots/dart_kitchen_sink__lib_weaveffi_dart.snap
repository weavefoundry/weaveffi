typedef _NativeWeaveffiKitchenDoAsyncAsync = Void Function(Pointer<Utf8>, Pointer<NativeFunction<_NativeAsyncCb_weaveffi_kitchen_do_async>>, Pointer<Void>);
typedef _DartWeaveffiKitchenDoAsyncAsync = void Function(Pointer<Utf8>, Pointer<NativeFunction<_NativeAsyncCb_weaveffi_kitchen_do_async>>, Pointer<Void>);
final _weaveffiKitchenDoAsyncAsync = _lib.lookupFunction<
    _NativeWeaveffiKitchenDoAsyncAsync, _DartWeaveffiKitchenDoAsyncAsync>('weaveffi_kitchen_do_async_async');

/// Async operation
Future<String> doAsync(String input) {
  final completer = Completer<String>();
  final inputPtr = input.toNativeUtf8();
  late NativeCallable<_NativeAsyncCb_weaveffi_kitchen_do_async> callable;
  callable = NativeCallable<_NativeAsyncCb_weaveffi_kitchen_do_async>.listener((Pointer<Void> context, Pointer<_WeaveFFIError> err, Pointer<Utf8> result) {
    try {
      if (err.address != 0 && err.ref.code != 0) {
        final code = err.ref.code;
        final msg = err.ref.message.toDartString();
        _weaveffiErrorClear(err);
        completer.completeError(WeaveFFIException(code, msg));
        return;
      }
      completer.complete(result.toDartString());
    } catch (e) {
      completer.completeError(e);
    } finally {
      callable.close();
    }
  });
  try {
    _weaveffiKitchenDoAsyncAsync(inputPtr, callable.nativeFunction, nullptr);
  } catch (e) {
    callable.close();
    calloc.free(inputPtr);
    rethrow;
  }
  return completer.future.whenComplete(() {
    calloc.free(inputPtr);
  });
}

