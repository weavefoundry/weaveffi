/// Subscribe to OnReady events
/// Registers a OnReady listener. Returns a subscription id for unregisterReadyListener().
int registerReadyListener(void Function(int code, String msg) callback) {
  final callable = NativeCallable<_NativeCb_weaveffi_kitchen_OnReady_fn>.isolateLocal((int code, Pointer<Utf8> msg, Pointer<Void> context) {
    callback(code, msg == nullptr ? '' : msg.toDartString());
  });
  final id = _weaveffiKitchenRegisterReadyListener(callable.nativeFunction, nullptr);
  _listenerCallables[id] = callable;
  return id;
}

/// Unregisters a listener previously registered with registerReadyListener().
void unregisterReadyListener(int id) {
  _weaveffiKitchenUnregisterReadyListener(id);
  _listenerCallables.remove(id)?.close();
}

