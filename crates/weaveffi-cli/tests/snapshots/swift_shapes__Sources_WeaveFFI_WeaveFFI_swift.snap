    public static func shapes_make_numerics(_ a: Int8, _ b: Int16, _ c: Int32, _ d: Int64, _ e: UInt8, _ f: UInt16, _ g: UInt32, _ h: UInt64, _ i: Float, _ j: Double) throws -> Numerics {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_shapes_make_numerics(a, b, c, d, e, f, g, h, i, j, &err)
        try check(&err)
        guard let rv = rv else { throw WeaveFFIError.error(code: -1, message: "null pointer") }
        return Numerics(ptr: rv)
