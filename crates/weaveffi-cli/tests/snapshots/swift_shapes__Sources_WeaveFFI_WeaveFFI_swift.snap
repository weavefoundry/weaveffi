        var err = weaveffi_error(code: 0, message: nil)
        let result: UInt64 = values.withUnsafeBufferPointer { values_buf in
            let values_ptr = values_buf.baseAddress
            let values_len = values_buf.count
                return weaveffi_shapes_sum_bytes(values_ptr, values_len, &err)
        }
        try check(&err)
        return result
    }
