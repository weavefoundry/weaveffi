        /// back to <see cref="WeaveFFIException"/> for unknown codes.</summary>
        internal static WeaveFFIException FromCode(int code, string message)
        {
            switch (code)
            {
                case InvalidPrice:
                    return new ProductsException(code, string.IsNullOrEmpty(message) ? "price must be positive" : message);
                case ProductNotFound:
                    return new ProductsException(code, string.IsNullOrEmpty(message) ? "product not found" : message);
                default:
