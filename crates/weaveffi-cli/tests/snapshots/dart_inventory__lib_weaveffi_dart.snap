/// Throws [OrdersException] on domain errors.
int createOrder(List<OrderItem> items) {
  final itemsPtr = items.isEmpty ? nullptr : calloc<Pointer<Void>>(items.length);
  for (var i = 0; i < items.length; i++) {
    itemsPtr[i] = items[i]._handle;
  }
  final err = calloc<_WeaveFFIError>();
  try {
    final result = _weaveffiOrdersCreateOrder(itemsPtr, items.length, err);
    _checkOrdersException(err);
    return result;
  } finally {
    if (itemsPtr != nullptr) calloc.free(itemsPtr);
    calloc.free(err);
  }
}

