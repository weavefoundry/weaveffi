}

/// order not found
class OrderNotFoundException extends OrdersException {
  OrderNotFoundException([String message = 'order not found']) : super(1, message);
}

/// order must contain at least one item
class EmptyOrderException extends OrdersException {
  EmptyOrderException([String message = 'order must contain at least one item']) : super(2, message);
}

WeaveFFIException _mapOrdersException(int code, String message) {
  switch (code) {
    case 1:
      return OrderNotFoundException(message);
    case 2:
      return EmptyOrderException(message);
    default:
      return WeaveFFIException(code, message);
  }
}

void _checkOrdersException(Pointer<_WeaveFFIError> err) {
  if (err.ref.code != 0) {
    final code = err.ref.code;
    final msg = err.ref.message.toDartString();
    _weaveffiErrorClear(err);
    throw _mapOrdersException(code, msg);
  }
}

