class ProductsException extends WeaveFFIException {
  ProductsException(super.code, super.message);
}

/// price must be positive
class InvalidPriceException extends ProductsException {
  InvalidPriceException([String message = 'price must be positive']) : super(1, message);
}

/// product not found
class ProductNotFoundException extends ProductsException {
  ProductNotFoundException([String message = 'product not found']) : super(2, message);
}

WeaveFFIException _mapProductsException(int code, String message) {
  switch (code) {
    case 1:
      return InvalidPriceException(message);
    case 2:
      return ProductNotFoundException(message);
    default:
      return WeaveFFIException(code, message);
  }
}

