    final code = err.ref.code;
    final msg = err.ref.message.toDartString();
    _weaveffiErrorClear(err);
    throw _mapProductsException(code, msg);
  }
}

enum Category {
  electronics(0),
  clothing(1),
  food(2),
  books(3),
  ;
  const Category(this.value);
  final int value;

  static Category fromValue(int value) =>
      Category.values.firstWhere((e) => e.value == value);
}

