from enum import IntEnum
from typing import Dict, Iterator, List, Optional

class ContactType(IntEnum):
    Personal: int
    Work: int
    Other: int

class Contact:
    @property
    def id(self) -> int: ...
    @property
    def first_name(self) -> str: ...
    @property
    def last_name(self) -> str: ...
    @property
    def email(self) -> Optional[str]: ...
    @property
    def contact_type(self) -> "ContactType": ...

def create_contact(first_name: str, last_name: str, email: Optional[str], contact_type: "ContactType") -> int: ...

def get_contact(id: int) -> "Contact": ...

def list_contacts() -> List["Contact"]: ...

def delete_contact(id: int) -> bool: ...

def count_contacts() -> int: ...
