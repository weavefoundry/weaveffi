# frozen_string_literal: true
# WeaveFFI Ruby FFI bindings (auto-generated)

require 'ffi'

module WeaveFFI
  extend FFI::Library

  case FFI::Platform::OS
  when /darwin/
    ffi_lib 'libweaveffi.dylib'
  when /mswin|mingw/
    ffi_lib 'weaveffi.dll'
  else
    ffi_lib 'libweaveffi.so'
  end

  class ErrorStruct < FFI::Struct
    layout :code, :int32,
           :message, :pointer
  end

  class Error < StandardError
    attr_reader :code

    def initialize(code, message)
      @code = code
      super(message)
    end
  end

  attach_function :weaveffi_error_clear, [:pointer], :void
  attach_function :weaveffi_free_string, [:pointer], :void
  attach_function :weaveffi_free_bytes, [:pointer, :size_t], :void

  def self.check_error!(err)
    return if err[:code].zero?
    code = err[:code]
    msg_ptr = err[:message]
    msg = msg_ptr.null? ? '' : msg_ptr.read_string
    weaveffi_error_clear(err.to_ptr)
    raise Error.new(code, msg)
  end

  # === Module: products ===

  module Category
    ELECTRONICS = 0
    CLOTHING = 1
    FOOD = 2
    BOOKS = 3
  end

  attach_function :weaveffi_products_Product_destroy, [:pointer], :void
  attach_function :weaveffi_products_Product_get_id, [:pointer], :int64
  attach_function :weaveffi_products_Product_get_name, [:pointer], :pointer
  attach_function :weaveffi_products_Product_get_description, [:pointer], :pointer
  attach_function :weaveffi_products_Product_get_price, [:pointer], :double
  attach_function :weaveffi_products_Product_get_category, [:pointer], :int32
  attach_function :weaveffi_products_Product_get_tags, [:pointer, :pointer], :pointer
  attach_function :weaveffi_products_create_product, [:string, :double, :int32, :pointer], :uint64
  attach_function :weaveffi_products_get_product, [:uint64, :pointer], :pointer
  attach_function :weaveffi_products_search_products, [:int32, :pointer, :pointer], :pointer
  attach_function :weaveffi_products_update_price, [:uint64, :double, :pointer], :int32
  attach_function :weaveffi_products_delete_product, [:uint64, :pointer], :int32

  class ProductPtr < FFI::AutoPointer
    def self.release(ptr)
      WeaveFFI.weaveffi_products_Product_destroy(ptr)
    end
  end

  class Product
    attr_reader :handle

    def initialize(handle)
      @handle = ProductPtr.new(handle)
    end

    def self.create(handle)
      new(handle)
    end

    def destroy
      return if @handle.nil?
      @handle.free
      @handle = nil
    end

    def id
      result = WeaveFFI.weaveffi_products_Product_get_id(@handle)
      result
    end

    def name
      result = WeaveFFI.weaveffi_products_Product_get_name(@handle)
      return '' if result.null?
      str = result.read_string
      WeaveFFI.weaveffi_free_string(result)
      str
    end

    def description
      result = WeaveFFI.weaveffi_products_Product_get_description(@handle)
      return nil if result.null?
      str = result.read_string
      WeaveFFI.weaveffi_free_string(result)
      str
    end

    def price
      result = WeaveFFI.weaveffi_products_Product_get_price(@handle)
      result
    end

    def category
      result = WeaveFFI.weaveffi_products_Product_get_category(@handle)
      result
    end

    def tags
      out_len = FFI::MemoryPointer.new(:size_t)
      result = WeaveFFI.weaveffi_products_Product_get_tags(@handle, out_len)
      return [] if result.null?
      len = out_len.read(:size_t)
      result.read_array_of_pointer(len).map { |p| p.null? ? '' : p.read_string }
    end
  end

  def self.create_product(name, price, category)
    err = ErrorStruct.new
    result = weaveffi_products_create_product(name, price, category, err)
    check_error!(err)
    result
  end

  def self.get_product(id)
    err = ErrorStruct.new
    result = weaveffi_products_get_product(id, err)
    check_error!(err)
    raise Error.new(-1, 'null pointer') if result.null?
    Product.new(result)
  end

  def self.search_products(category)
    err = ErrorStruct.new
    out_len = FFI::MemoryPointer.new(:size_t)
    result = weaveffi_products_search_products(category, out_len, err)
    check_error!(err)
    return [] if result.null?
    len = out_len.read(:size_t)
    result.read_array_of_pointer(len).map { |p| Product.new(p) }
  end

  def self.update_price(id, price)
    err = ErrorStruct.new
    result = weaveffi_products_update_price(id, price, err)
    check_error!(err)
    result != 0
  end

  def self.delete_product(id)
    err = ErrorStruct.new
    result = weaveffi_products_delete_product(id, err)
    check_error!(err)
    result != 0
  end

  # === Module: orders ===

  attach_function :weaveffi_orders_OrderItem_destroy, [:pointer], :void
  attach_function :weaveffi_orders_OrderItem_get_product_id, [:pointer], :int64
  attach_function :weaveffi_orders_OrderItem_get_quantity, [:pointer], :int32
  attach_function :weaveffi_orders_OrderItem_get_unit_price, [:pointer], :double

  attach_function :weaveffi_orders_Order_destroy, [:pointer], :void
  attach_function :weaveffi_orders_Order_get_id, [:pointer], :int64
  attach_function :weaveffi_orders_Order_get_items, [:pointer, :pointer], :pointer
  attach_function :weaveffi_orders_Order_get_total, [:pointer], :double
  attach_function :weaveffi_orders_Order_get_status, [:pointer], :pointer
  attach_function :weaveffi_orders_create_order, [:pointer, :size_t, :pointer], :uint64
  attach_function :weaveffi_orders_get_order, [:uint64, :pointer], :pointer
  attach_function :weaveffi_orders_cancel_order, [:uint64, :pointer], :int32
  attach_function :weaveffi_orders_add_product_to_order, [:uint64, :pointer, :pointer], :int32

  class OrderItemPtr < FFI::AutoPointer
    def self.release(ptr)
      WeaveFFI.weaveffi_orders_OrderItem_destroy(ptr)
    end
  end

  class OrderItem
    attr_reader :handle

    def initialize(handle)
      @handle = OrderItemPtr.new(handle)
    end

    def self.create(handle)
      new(handle)
    end

    def destroy
      return if @handle.nil?
      @handle.free
      @handle = nil
    end

    def product_id
      result = WeaveFFI.weaveffi_orders_OrderItem_get_product_id(@handle)
      result
    end

    def quantity
      result = WeaveFFI.weaveffi_orders_OrderItem_get_quantity(@handle)
      result
    end

    def unit_price
      result = WeaveFFI.weaveffi_orders_OrderItem_get_unit_price(@handle)
      result
    end
  end

  class OrderPtr < FFI::AutoPointer
    def self.release(ptr)
      WeaveFFI.weaveffi_orders_Order_destroy(ptr)
    end
  end

  class Order
    attr_reader :handle

    def initialize(handle)
      @handle = OrderPtr.new(handle)
    end

    def self.create(handle)
      new(handle)
    end

    def destroy
      return if @handle.nil?
      @handle.free
      @handle = nil
    end

    def id
      result = WeaveFFI.weaveffi_orders_Order_get_id(@handle)
      result
    end

    def items
      out_len = FFI::MemoryPointer.new(:size_t)
      result = WeaveFFI.weaveffi_orders_Order_get_items(@handle, out_len)
      return [] if result.null?
      len = out_len.read(:size_t)
      result.read_array_of_pointer(len).map { |p| OrderItem.new(p) }
    end

    def total
      result = WeaveFFI.weaveffi_orders_Order_get_total(@handle)
      result
    end

    def status
      result = WeaveFFI.weaveffi_orders_Order_get_status(@handle)
      return '' if result.null?
      str = result.read_string
      WeaveFFI.weaveffi_free_string(result)
      str
    end
  end

  def self.create_order(items)
    err = ErrorStruct.new
    items_buf = FFI::MemoryPointer.new(:pointer, items.length)
    items_buf.write_array_of_pointer(items.map(&:handle))
    result = weaveffi_orders_create_order(items_buf, items.length, err)
    check_error!(err)
    result
  end

  def self.get_order(id)
    err = ErrorStruct.new
    result = weaveffi_orders_get_order(id, err)
    check_error!(err)
    raise Error.new(-1, 'null pointer') if result.null?
    Order.new(result)
  end

  def self.cancel_order(id)
    err = ErrorStruct.new
    result = weaveffi_orders_cancel_order(id, err)
    check_error!(err)
    result != 0
  end

  def self.add_product_to_order(order_id, product)
    err = ErrorStruct.new
    result = weaveffi_orders_add_product_to_order(order_id, product.handle, err)
    check_error!(err)
    result != 0
  end
end
