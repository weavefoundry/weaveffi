// WeaveFFI WASM bindings (auto-generated)
//
// Complex type conventions at the WASM boundary:
//
//   Structs   -> i64 opaque handle (pointer into linear memory)
//   Enums     -> i32 discriminant value
//   Optionals -> 0/null for absent; for numerics a separate _is_present i32 flag
//   Lists     -> (i32 pointer, i32 length) pair into linear memory

const _encoder = new TextEncoder();
const _decoder = new TextDecoder();

function _encodeString(wasm, str) {
  const bytes = _encoder.encode(str);
  const ptr = wasm.weaveffi_alloc(bytes.length);
  new Uint8Array(wasm.memory.buffer, ptr, bytes.length).set(bytes);
  return [ptr, bytes.length];
}

function _decodeString(wasm, ptr, len) {
  return _decoder.decode(new Uint8Array(wasm.memory.buffer, ptr, len));
}

function _allocError(wasm) {
  return wasm.weaveffi_alloc(8);
}

function _checkError(wasm, errPtr) {
  const buffer = wasm.memory.buffer;
  const code = new Int32Array(buffer, errPtr, 1)[0];
  if (code !== 0) {
    const msgPtr = new Uint32Array(buffer, errPtr + 4, 1)[0];
    const bytes = new Uint8Array(buffer, msgPtr);
    let end = 0;
    while (bytes[end] !== 0) end++;
    const msg = new TextDecoder().decode(new Uint8Array(buffer, msgPtr, end));
    wasm.weaveffi_error_clear(errPtr);
    throw new Error(`WeaveFFI error ${code}: ${msg}`);
  }
}

function _registerTrampoline(table, paramTypes, handler) {
  const idx = table.grow(1);
  table.set(idx, new WebAssembly.Function(
    { parameters: paramTypes, results: [] },
    handler
  ));
  return idx;
}

export const Priority = Object.freeze({
  Low: 0,
  Normal: 1,
  High: 2,
});

class Token {
  constructor(wasm, handle) {
    this._wasm = wasm;
    this._handle = handle;
  }
  get id() {
    return this._wasm.weaveffi_shared_Token_get_id(this._handle);
  }
  get label() {
    const retptr = this._wasm.weaveffi_alloc(8);
    this._wasm.weaveffi_shared_Token_get_label(retptr, this._handle);
    const view = new DataView(this._wasm.memory.buffer);
    return _decodeString(this._wasm, view.getInt32(retptr, true), view.getInt32(retptr + 4, true));
  }
}

class Item {
  constructor(wasm, handle) {
    this._wasm = wasm;
    this._handle = handle;
  }
  get id() {
    return this._wasm.weaveffi_kitchen_Item_get_id(this._handle);
  }
  get name() {
    const retptr = this._wasm.weaveffi_alloc(8);
    this._wasm.weaveffi_kitchen_Item_get_name(retptr, this._handle);
    const view = new DataView(this._wasm.memory.buffer);
    return _decodeString(this._wasm, view.getInt32(retptr, true), view.getInt32(retptr + 4, true));
  }
  get count() {
    return this._wasm.weaveffi_kitchen_Item_get_count(this._handle);
  }
  get enabled() {
    return this._wasm.weaveffi_kitchen_Item_get_enabled(this._handle) !== 0;
  }
  get ratio() {
    return this._wasm.weaveffi_kitchen_Item_get_ratio(this._handle);
  }
  get nick() {
    return this._wasm.weaveffi_kitchen_Item_get_nick(this._handle);
  }
  get payload() {
    return this._wasm.weaveffi_kitchen_Item_get_payload(this._handle);
  }
  get tags() {
    return this._wasm.weaveffi_kitchen_Item_get_tags(this._handle);
  }
  get attrs() {
    return this._wasm.weaveffi_kitchen_Item_get_attrs(this._handle);
  }
  get parent() {
    return this._wasm.weaveffi_kitchen_Item_get_parent(this._handle);
  }
  get token() {
    return this._wasm.weaveffi_kitchen_Item_get_token(this._handle);
  }
  get priority() {
    return this._wasm.weaveffi_kitchen_Item_get_priority(this._handle);
  }
}

/**
 * Load a WeaveFFI WASM module from the given URL.
 *
 * @param {string} url - URL to the `.wasm` file.
 * @returns {Promise<Object>} The API bindings.
 *
 * Exported functions follow the C ABI naming convention:
 *   weaveffi_{module}_{function}(params...) -> result
 *
 * @example
 * const api = await loadWeaveffiWasm('lib.wasm');
 *
 * // Primitive: (i32, i32) -> i32
 * const sum = api.math.add(1, 2);
 *
 * // Struct handle: () -> i64 (opaque pointer)
 * const handle = api.contacts.create();
 *
 * // Enum: (i32 discriminant) -> void
 * api.ui.set_color(0); // 0 = first variant
 *
 * // Optional: (i32 is_present, i32 value) -> void
 * api.config.set_timeout(1, 5000); // present
 * api.config.set_timeout(0, 0);    // absent
 *
 * // List: (i32 pointer, i32 length) -> void
 * api.data.process(ptr, len);
 */
export async function loadWeaveffiWasm(url) {
  const response = await fetch(url);
  const bytes = await response.arrayBuffer();
  const { instance } = await WebAssembly.instantiate(bytes, {});
  const wasm = instance.exports;

  let _nextCtxId = 1;
  const _asyncContexts = new Map();
  const _table = wasm.__indirect_function_table;

  function _asyncHandler(ctxId, errPtr, ...results) {
    const ctx = _asyncContexts.get(ctxId);
    if (!ctx) return;
    _asyncContexts.delete(ctxId);
    try {
      if (errPtr !== 0) _checkError(wasm, errPtr);
      ctx.resolve(ctx.unwrap ? ctx.unwrap(wasm, ...results) : results[0]);
    } catch (e) {
      ctx.reject(e);
    }
  }

  const _cbPtr_i32_i32_i32 = _registerTrampoline(_table, ['i32', 'i32', 'i32'], _asyncHandler);

  return {
    _raw: wasm,
    shared: {
      ping() {
        const _err = _allocError(wasm);
        const retptr = wasm.weaveffi_alloc(8);
        wasm.weaveffi_shared_ping(retptr, _err);
        _checkError(wasm, _err);
        const view = new DataView(wasm.memory.buffer);
        return _decodeString(wasm, view.getInt32(retptr, true), view.getInt32(retptr + 4, true));
      },
    },
    kitchen: {
      bool_id(x) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_bool_id(x, _err);
        _checkError(wasm, _err);
        return _result !== 0;
      },
      i32_id(x) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_i32_id(x, _err);
        _checkError(wasm, _err);
        return _result;
      },
      u32_id(x) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_u32_id(x, _err);
        _checkError(wasm, _err);
        return _result;
      },
      i64_id(x) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_i64_id(x, _err);
        _checkError(wasm, _err);
        return _result;
      },
      f64_id(x) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_f64_id(x, _err);
        _checkError(wasm, _err);
        return _result;
      },
      echo_string(s) {
        const _err = _allocError(wasm);
        const retptr = wasm.weaveffi_alloc(8);
        const [s_ptr, s_len] = _encodeString(wasm, s);
        wasm.weaveffi_kitchen_echo_string(retptr, s_ptr, s_len, _err);
        _checkError(wasm, _err);
        const view = new DataView(wasm.memory.buffer);
        return _decodeString(wasm, view.getInt32(retptr, true), view.getInt32(retptr + 4, true));
      },
      echo_bytes(b) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_echo_bytes(b, _err);
        _checkError(wasm, _err);
        return _result;
      },
      echo_borrowed_str(s) {
        const _err = _allocError(wasm);
        const retptr = wasm.weaveffi_alloc(8);
        wasm.weaveffi_kitchen_echo_borrowed_str(retptr, s, _err);
        _checkError(wasm, _err);
        const view = new DataView(wasm.memory.buffer);
        return _decodeString(wasm, view.getInt32(retptr, true), view.getInt32(retptr + 4, true));
      },
      echo_borrowed_bytes(b) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_echo_borrowed_bytes(b, _err);
        _checkError(wasm, _err);
        return _result;
      },
      open_handle() {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_open_handle(_err);
        _checkError(wasm, _err);
        return _result;
      },
      open_typed_handle() {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_open_typed_handle(_err);
        _checkError(wasm, _err);
        return _result;
      },
      maybe_item(id) {
        const _err = _allocError(wasm);
        const result = wasm.weaveffi_kitchen_maybe_item(id, _err);
        _checkError(wasm, _err);
        return result === 0n ? null : new Item(wasm, result);
      },
      list_items() {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_list_items(_err);
        _checkError(wasm, _err);
        return _result;
      },
      get_attrs() {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_get_attrs(_err);
        _checkError(wasm, _err);
        return _result;
      },
      stream_items() {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_stream_items(_err);
        _checkError(wasm, _err);
        return _result;
      },
      cross_module_token() {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_cross_module_token(_err);
        _checkError(wasm, _err);
        return new Token(wasm, _result);
      },
      do_async(input) {
        return new Promise((resolve, reject) => {
          const ctxId = _nextCtxId++;
          _asyncContexts.set(ctxId, { resolve, reject, unwrap: (w, ptr) => {
            const b = new Uint8Array(w.memory.buffer, ptr);
            let e = 0; while (b[e] !== 0) e++;
            return new TextDecoder().decode(new Uint8Array(w.memory.buffer, ptr, e));
          } });
          const [input_ptr, input_len] = _encodeString(wasm, input);
          wasm.weaveffi_kitchen_do_async_async(input_ptr, input_len, _cbPtr_i32_i32_i32, ctxId);
        }));
      },
      do_cancellable(input) {
        return new Promise((resolve, reject) => {
          const ctxId = _nextCtxId++;
          _asyncContexts.set(ctxId, { resolve, reject, unwrap: (w, ptr) => {
            const b = new Uint8Array(w.memory.buffer, ptr);
            let e = 0; while (b[e] !== 0) e++;
            return new TextDecoder().decode(new Uint8Array(w.memory.buffer, ptr, e));
          } });
          const [input_ptr, input_len] = _encodeString(wasm, input);
          wasm.weaveffi_kitchen_do_cancellable_async(input_ptr, input_len, 0, _cbPtr_i32_i32_i32, ctxId);
        }));
      },
      /** @deprecated Use new_op instead */
      legacy_op() {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_legacy_op(_err);
        _checkError(wasm, _err);
        return _result;
      },
      new_op() {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kitchen_new_op(_err);
        _checkError(wasm, _err);
        return _result;
      },
      nested: {
        hello() {
          const _err = _allocError(wasm);
          const retptr = wasm.weaveffi_alloc(8);
          wasm.weaveffi_kitchen_nested_hello(retptr, _err);
          _checkError(wasm, _err);
          const view = new DataView(wasm.memory.buffer);
          return _decodeString(wasm, view.getInt32(retptr, true), view.getInt32(retptr + 4, true));
        },
      },
    },
  };
}
