// Generated TypeScript declarations for WeaveFFI WASM bindings

export interface Token {
  readonly id: number;
  readonly label: string;
}

export interface Item {
  readonly id: number;
  readonly name: string;
  readonly count: number;
  readonly enabled: boolean;
  readonly ratio: number;
  readonly nick: number;
  readonly payload: Buffer;
  readonly tags: string[];
  readonly attrs: Record<string, string>;
  readonly parent: number | null;
  readonly token: Token;
  readonly priority: Priority;
}

export declare const Priority: Readonly<{
  Low: 0;
  Normal: 1;
  High: 2;
}>;

export interface WeaveffiWasmModule {
  _raw: WebAssembly.Exports;
  shared: {
    /** @throws {Error} if the native call fails */
    ping(): string;
  };
  kitchen: {
    /** @throws {Error} if the native call fails */
    bool_id(x: boolean): boolean;
    /** @throws {Error} if the native call fails */
    i32_id(x: number): number;
    /** @throws {Error} if the native call fails */
    u32_id(x: number): number;
    /** @throws {Error} if the native call fails */
    i64_id(x: number): number;
    /** @throws {Error} if the native call fails */
    f64_id(x: number): number;
    /** @throws {Error} if the native call fails */
    echo_string(s: string): string;
    /** @throws {Error} if the native call fails */
    echo_bytes(b: Buffer): Buffer;
    /** @throws {Error} if the native call fails */
    echo_borrowed_str(s: string): string;
    /** @throws {Error} if the native call fails */
    echo_borrowed_bytes(b: Buffer): Buffer;
    /** @throws {Error} if the native call fails */
    open_handle(): bigint;
    /** @throws {Error} if the native call fails */
    open_typed_handle(): Token;
    /** @throws {Error} if the native call fails */
    maybe_item(id: number): Item | null;
    /** @throws {Error} if the native call fails */
    list_items(): Item[];
    /** @throws {Error} if the native call fails */
    get_attrs(): Record<string, number>;
    /** @throws {Error} if the native call fails */
    stream_items(): Item[];
    /** @throws {Error} if the native call fails */
    cross_module_token(): Token;
    /** @throws {Error} if the native call fails */
    do_async(input: string): Promise<string>;
    /** @throws {Error} if the native call fails */
    do_cancellable(input: string): Promise<string>;
    /** @deprecated Use new_op instead */
    /** @throws {Error} if the native call fails */
    legacy_op(): number;
    /** @throws {Error} if the native call fails */
    new_op(): number;
    nested: {
      /** @throws {Error} if the native call fails */
      hello(): string;
    };
  };
}

export function loadWeaveffiWasm(url: string): Promise<WeaveffiWasmModule>;
