// WeaveFFI WASM bindings (auto-generated)
//
// Complex type conventions at the WASM boundary:
//
//   Structs   -> i64 opaque handle (pointer into linear memory)
//   Enums     -> i32 discriminant value
//   Optionals -> 0/null for absent; for numerics a separate _is_present i32 flag
//   Lists     -> (i32 pointer, i32 length) pair into linear memory

const _encoder = new TextEncoder();
const _decoder = new TextDecoder();

function _encodeString(wasm, str) {
  const bytes = _encoder.encode(str);
  const ptr = wasm.weaveffi_alloc(bytes.length);
  new Uint8Array(wasm.memory.buffer, ptr, bytes.length).set(bytes);
  return [ptr, bytes.length];
}

function _decodeString(wasm, ptr, len) {
  return _decoder.decode(new Uint8Array(wasm.memory.buffer, ptr, len));
}

function _allocError(wasm) {
  return wasm.weaveffi_alloc(8);
}

function _checkError(wasm, errPtr) {
  const buffer = wasm.memory.buffer;
  const code = new Int32Array(buffer, errPtr, 1)[0];
  if (code !== 0) {
    const msgPtr = new Uint32Array(buffer, errPtr + 4, 1)[0];
    const bytes = new Uint8Array(buffer, msgPtr);
    let end = 0;
    while (bytes[end] !== 0) end++;
    const msg = new TextDecoder().decode(new Uint8Array(buffer, msgPtr, end));
    wasm.weaveffi_error_clear(errPtr);
    throw new Error(`WeaveFFI error ${code}: ${msg}`);
  }
}

/**
 * Load a WeaveFFI WASM module from the given URL.
 *
 * @param {string} url - URL to the `.wasm` file.
 * @returns {Promise<Object>} The API bindings.
 *
 * Exported functions follow the C ABI naming convention:
 *   weaveffi_{module}_{function}(params...) -> result
 *
 * @example
 * const api = await loadWeaveffiWasm('lib.wasm');
 *
 * // Primitive: (i32, i32) -> i32
 * const sum = api.math.add(1, 2);
 *
 * // Struct handle: () -> i64 (opaque pointer)
 * const handle = api.contacts.create();
 *
 * // Enum: (i32 discriminant) -> void
 * api.ui.set_color(0); // 0 = first variant
 *
 * // Optional: (i32 is_present, i32 value) -> void
 * api.config.set_timeout(1, 5000); // present
 * api.config.set_timeout(0, 0);    // absent
 *
 * // List: (i32 pointer, i32 length) -> void
 * api.data.process(ptr, len);
 */
export async function loadWeaveffiWasm(url) {
  const response = await fetch(url);
  const bytes = await response.arrayBuffer();
  const { instance } = await WebAssembly.instantiate(bytes, {});
  const wasm = instance.exports;

  return {
    _raw: wasm,
    calculator: {
      add(a, b) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_calculator_add(a, b, _err);
        _checkError(wasm, _err);
        return _result;
      },
      mul(a, b) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_calculator_mul(a, b, _err);
        _checkError(wasm, _err);
        return _result;
      },
      div(a, b) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_calculator_div(a, b, _err);
        _checkError(wasm, _err);
        return _result;
      },
      echo(s) {
        const _err = _allocError(wasm);
        const retptr = wasm.weaveffi_alloc(8);
        const [s_ptr, s_len] = _encodeString(wasm, s);
        wasm.weaveffi_calculator_echo(retptr, s_ptr, s_len, _err);
        _checkError(wasm, _err);
        const view = new DataView(wasm.memory.buffer);
        return _decodeString(wasm, view.getInt32(retptr, true), view.getInt32(retptr + 4, true));
      },
    },
  };
}
