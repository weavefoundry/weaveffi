  class ItemPtr < FFI::AutoPointer
    def self.release(ptr)
      WeaveFFI.weaveffi_kitchen_Item_destroy(ptr)
    end
  end

  class Item
    attr_reader :handle

    def initialize(handle)
      @handle = ItemPtr.new(handle)
    end

    def self.create(handle)
      new(handle)
    end

    def destroy
      return if @handle.nil?
      @handle.free
      @handle = nil
    end

    def id
      result = WeaveFFI.weaveffi_kitchen_Item_get_id(@handle)
      result
    end

    def name
      result = WeaveFFI.weaveffi_kitchen_Item_get_name(@handle)
      return '' if result.null?
      str = result.read_string
      WeaveFFI.weaveffi_free_string(result)
      str
    end

    def count
      result = WeaveFFI.weaveffi_kitchen_Item_get_count(@handle)
      result
    end

    def enabled
      result = WeaveFFI.weaveffi_kitchen_Item_get_enabled(@handle)
      result != 0
    end

    def ratio
      result = WeaveFFI.weaveffi_kitchen_Item_get_ratio(@handle)
      result
    end

    def nick
      result = WeaveFFI.weaveffi_kitchen_Item_get_nick(@handle)
      result
    end

    def payload
      out_len = FFI::MemoryPointer.new(:size_t)
      result = WeaveFFI.weaveffi_kitchen_Item_get_payload(@handle, out_len)
      return ''.b if result.null?
      len = out_len.read(:size_t)
      data = result.read_string(len)
      WeaveFFI.weaveffi_free_bytes(result, len)
      data
    end

    def tags
      out_len = FFI::MemoryPointer.new(:size_t)
      result = WeaveFFI.weaveffi_kitchen_Item_get_tags(@handle, out_len)
      return [] if result.null?
      len = out_len.read(:size_t)
      result.read_array_of_pointer(len).map { |p| p.null? ? '' : p.read_string }
    end

    def attrs
      out_keys = FFI::MemoryPointer.new(:pointer)
      out_values = FFI::MemoryPointer.new(:pointer)
      out_len = FFI::MemoryPointer.new(:size_t)
      WeaveFFI.weaveffi_kitchen_Item_get_attrs(@handle, out_keys, out_values, out_len)
      len = out_len.read(:size_t)
      keys_ptr = out_keys.read_pointer
      vals_ptr = out_values.read_pointer
      return {} if keys_ptr.null? || vals_ptr.null?
      keys_ptr.read_array_of_pointer(len).zip(vals_ptr.read_array_of_pointer(len)).each_with_object({}) { |(k, v), h| h[k.null? ? '' : k.read_string] = v.null? ? '' : v.read_string }
    end

    def parent
      result = WeaveFFI.weaveffi_kitchen_Item_get_parent(@handle)
      return nil if result.null?
      result.read_int64
    end

    def token
      result = WeaveFFI.weaveffi_kitchen_Item_get_token(@handle)
      raise Error.new(-1, 'null pointer') if result.null?
      Token.new(result)
    end

    def priority
      result = WeaveFFI.weaveffi_kitchen_Item_get_priority(@handle)
      result
    end
  end

  class ItemBuilder
    def initialize
      @id = nil
