  # Iterator return type
  def self.stream_items()
    err = ErrorStruct.new
    iter = weaveffi_kitchen_stream_items(err)
    check_error!(err)
    items = []
    return items if iter.null?
    loop do
      out_item = FFI::MemoryPointer.new(:pointer)
      item_err = ErrorStruct.new
      has_item = weaveffi_kitchen_StreamItemsIterator_next(iter, out_item, item_err)
      if item_err[:code] != 0
        weaveffi_kitchen_StreamItemsIterator_destroy(iter)
        check_error!(item_err)
      end
      break if has_item.zero?
      item_ptr = out_item.read_pointer
      items << Item.new(item_ptr) unless item_ptr.null?
    end
    weaveffi_kitchen_StreamItemsIterator_destroy(iter)
    items
  end

