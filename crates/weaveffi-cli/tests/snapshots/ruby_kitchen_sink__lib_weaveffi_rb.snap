  # Async operation
  # Blocks until the async producer completes.
  def self.do_async(input)
    queue = Queue.new
    callback = FFI::Function.new(:void, [:pointer, :pointer, :pointer]) do |_context, err_ptr, result|
      err = err_ptr.null? ? nil : ErrorStruct.new(err_ptr)
      if err && err[:code] != 0
        code = err[:code]
        msg = err[:message].null? ? '' : err[:message].read_string
        weaveffi_error_clear(err_ptr)
        queue << Error.new(code, msg)
      else
        if result.null?
          queue << ''
        else
          s = result.read_string
          weaveffi_free_string(result)
          queue << s
        end
      end
    end
    weaveffi_kitchen_do_async_async(input, callback, FFI::Pointer::NULL)
    value = queue.pop
    raise value if value.is_a?(Error)
    value
  end

  # Cancellable async operation
  # Blocks until the async producer completes (cancellation token not exposed; pass-through is NULL).
  def self.do_cancellable(input)
    queue = Queue.new
    callback = FFI::Function.new(:void, [:pointer, :pointer, :pointer]) do |_context, err_ptr, result|
      err = err_ptr.null? ? nil : ErrorStruct.new(err_ptr)
      if err && err[:code] != 0
        code = err[:code]
        msg = err[:message].null? ? '' : err[:message].read_string
        weaveffi_error_clear(err_ptr)
        queue << Error.new(code, msg)
      else
        if result.null?
          queue << ''
        else
          s = result.read_string
          weaveffi_free_string(result)
          queue << s
        end
      end
    end
    weaveffi_kitchen_do_cancellable_async(input, FFI::Pointer::NULL, callback, FFI::Pointer::NULL)
    value = queue.pop
    raise value if value.is_a?(Error)
    value
  end

