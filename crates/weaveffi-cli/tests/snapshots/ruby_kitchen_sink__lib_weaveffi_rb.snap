  # Subscribe to OnReady events
  # Registers a OnReady listener block. Returns a subscription id for
  # unregister_ready_listener.
  def self.register_ready_listener(&block)
    trampoline = FFI::Function.new(:void, [:int32, :string, :pointer]) do |code, msg, _context|
      block.call(code, msg)
    end
    listener_id = weaveffi_kitchen_register_ready_listener(trampoline, FFI::Pointer::NULL)
    @listener_refs[listener_id] = trampoline
    listener_id
  end

  # Unregisters a listener previously registered with register_ready_listener.
  def self.unregister_ready_listener(listener_id)
    weaveffi_kitchen_unregister_ready_listener(listener_id)
    @listener_refs.delete(listener_id)
    nil
  end

