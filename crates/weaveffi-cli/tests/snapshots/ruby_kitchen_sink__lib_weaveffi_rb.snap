    def build
      raise "missing field: id" if @id.nil?
      raise "missing field: name" if @name.nil?
      raise "missing field: count" if @count.nil?
      raise "missing field: enabled" if @enabled.nil?
      raise "missing field: ratio" if @ratio.nil?
