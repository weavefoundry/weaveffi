    def build
      err = WeaveFFI::ErrorStruct.new
      id = @id
      name = @name
      count = @count
      enabled = @enabled
      enabled_c = enabled ? 1 : 0
      ratio = @ratio
      nick = @nick
      payload = @payload
      payload_buf = FFI::MemoryPointer.new(:uint8, payload.bytesize)
      payload_buf.put_bytes(0, payload)
      tags = @tags
      tags_buf = FFI::MemoryPointer.new(:pointer, tags.length)
      tags_ptrs = tags.map { |s| FFI::MemoryPointer.from_string(s) }
      tags_buf.write_array_of_pointer(tags_ptrs)
      attrs = @attrs
      attrs_k = attrs.keys
      attrs_v = attrs.values
      attrs_keys_buf = FFI::MemoryPointer.new(:pointer, attrs_k.length)
      attrs_vals_buf = FFI::MemoryPointer.new(:pointer, attrs_v.length)
      attrs_keys_ptrs = attrs_k.map { |s| FFI::MemoryPointer.from_string(s) }
      attrs_keys_buf.write_array_of_pointer(attrs_keys_ptrs)
      attrs_vals_ptrs = attrs_v.map { |s| FFI::MemoryPointer.from_string(s) }
      attrs_vals_buf.write_array_of_pointer(attrs_vals_ptrs)
      parent = @parent
      parent_c = parent.nil? ? FFI::Pointer::NULL : begin; p = FFI::MemoryPointer.new(:int64); p.write_int64(parent); p; end
      token = @token
      priority = @priority
      result = WeaveFFI.weaveffi_kitchen_Item_create(id, name, count, enabled_c, ratio, nick, payload_buf, payload.bytesize, tags_buf, tags.length, attrs_keys_buf, attrs_vals_buf, attrs.length, parent_c, token.handle, priority, err)
