      raise "missing field: priority" if @priority.nil?
      raise NotImplementedError, "ItemBuilder.build requires FFI backing"
    end
  end

  def self.bool_id(x)
    err = ErrorStruct.new
    x_c = x ? 1 : 0
    result = weaveffi_kitchen_bool_id(x_c, err)
    check_error!(err)
    result != 0
  end

