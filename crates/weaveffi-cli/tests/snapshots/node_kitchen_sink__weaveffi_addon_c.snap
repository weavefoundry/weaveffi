typedef struct {
    napi_deferred deferred;
    napi_threadsafe_function tsfn;
    int32_t err_code;
    char* err_msg;
    char* result;
    int result_null;
} weaveffi_kitchen_do_async_napi_actx;

static void weaveffi_kitchen_do_async_napi_cb(void* context, weaveffi_error* err, const char* result) {
    weaveffi_kitchen_do_async_napi_actx* ctx = (weaveffi_kitchen_do_async_napi_actx*)context;
    if (err != NULL && err->code != 0) {
        ctx->err_code = err->code;
        ctx->err_msg = err->message ? strdup(err->message) : strdup("unknown error");
    } else {
        ctx->result_null = result == NULL;
        ctx->result = result ? strdup(result) : NULL;
    }
    napi_call_threadsafe_function(ctx->tsfn, ctx, napi_tsfn_blocking);
}

static void weaveffi_kitchen_do_async_napi_settle(napi_env env, napi_value js_cb, void* context, void* data) {
    (void)js_cb;
    (void)context;
    weaveffi_kitchen_do_async_napi_actx* ctx = (weaveffi_kitchen_do_async_napi_actx*)data;
    if (env != NULL) {
    if (ctx->err_code != 0) {
        napi_value err_msg;
        napi_create_string_utf8(env, ctx->err_msg ? ctx->err_msg : "", NAPI_AUTO_LENGTH, &err_msg);
        napi_value err_obj;
        napi_create_error(env, NULL, err_msg, &err_obj);
        napi_value err_code;
        napi_create_int32(env, ctx->err_code, &err_code);
        napi_set_named_property(env, err_obj, "code", err_code);
        napi_reject_deferred(env, ctx->deferred, err_obj);
    } else {
        napi_value val;
        if (ctx->result_null) napi_get_null(env, &val); else napi_create_string_utf8(env, ctx->result ? ctx->result : "", NAPI_AUTO_LENGTH, &val);
        napi_resolve_deferred(env, ctx->deferred, val);
    }
    }
    free(ctx->err_msg);
    free(ctx->result);
    napi_release_threadsafe_function(ctx->tsfn, napi_tsfn_release);
    free(ctx);
}

static napi_value Napi_weaveffi_kitchen_do_async(napi_env env, napi_callback_info info) {
  size_t argc = 1;
  napi_value args[1];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  size_t input_len;
  napi_get_value_string_utf8(env, args[0], NULL, 0, &input_len);
  char* input = (char*)malloc(input_len + 1);
  napi_get_value_string_utf8(env, args[0], input, input_len + 1, &input_len);
  weaveffi_kitchen_do_async_napi_actx* ctx = (weaveffi_kitchen_do_async_napi_actx*)calloc(1, sizeof(weaveffi_kitchen_do_async_napi_actx));
  napi_value promise;
  napi_create_promise(env, &ctx->deferred, &promise);
  napi_value resource_name;
  napi_create_string_utf8(env, "weaveffi_kitchen_do_async", NAPI_AUTO_LENGTH, &resource_name);
  napi_create_threadsafe_function(env, NULL, NULL, resource_name, 0, 1, NULL, NULL, NULL, weaveffi_kitchen_do_async_napi_settle, &ctx->tsfn);
  weaveffi_kitchen_do_async_async(input, weaveffi_kitchen_do_async_napi_cb, ctx);
  free(input);
  return promise;
}

