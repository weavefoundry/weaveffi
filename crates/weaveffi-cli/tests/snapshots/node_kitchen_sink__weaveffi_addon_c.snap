          for (size_t elem_attrs_i = 0; elem_attrs_i < elem_attrs_len; elem_attrs_i++) {
            napi_value elem_attrs_v;
            napi_create_string_utf8(env, elem_attrs_vals[elem_attrs_i], NAPI_AUTO_LENGTH, &elem_attrs_v);
            weaveffi_free_string((char*)(elem_attrs_vals[elem_attrs_i]));
            napi_set_named_property(env, elem_attrs, elem_attrs_keys[elem_attrs_i], elem_attrs_v);
            weaveffi_free_string((char*)elem_attrs_keys[elem_attrs_i]);
          }
        }
      }
      napi_set_named_property(env, elem, "attrs", elem_attrs);
      napi_value elem_parent;
      {
        int64_t* elem_parent_p = weaveffi_kitchen_Item_get_parent(elem_p);
        if (elem_parent_p == NULL) { napi_get_null(env, &elem_parent); }
        else { napi_create_int64(env, *elem_parent_p, &elem_parent); }
      }
      napi_set_named_property(env, elem, "parent", elem_parent);
      napi_value elem_token;
      {
        weaveffi_shared_Token* elem_token_p = (weaveffi_shared_Token*)weaveffi_kitchen_Item_get_token(elem_p);
        napi_create_object(env, &elem_token);
        napi_value elem_token_id;
        napi_create_int64(env, weaveffi_shared_Token_get_id(elem_token_p), &elem_token_id);
        napi_set_named_property(env, elem_token, "id", elem_token_id);
        napi_value elem_token_label;
        {
          char* elem_token_label_s = (char*)weaveffi_shared_Token_get_label(elem_token_p);
          napi_create_string_utf8(env, elem_token_label_s, NAPI_AUTO_LENGTH, &elem_token_label);
          weaveffi_free_string(elem_token_label_s);
        }
        napi_set_named_property(env, elem_token, "label", elem_token_label);
        weaveffi_shared_Token_destroy(elem_token_p);
      }
      napi_set_named_property(env, elem, "token", elem_token);
      napi_value elem_priority;
      napi_create_int32(env, (int32_t)weaveffi_kitchen_Item_get_priority(elem_p), &elem_priority);
      napi_set_named_property(env, elem, "priority", elem_priority);
      weaveffi_kitchen_Item_destroy(elem_p);
    }
    napi_set_element(env, ret, (uint32_t)ret_i, elem);
  }
  free(result);
  return ret;
}

