package com.weaveffi

import kotlinx.coroutines.suspendCancellableCoroutine
import kotlin.coroutines.resume
import kotlin.coroutines.resumeWithException

class WeaveFFI {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @Volatile private var callbackExceptionHandler: ((Throwable) -> Unit)? = null

        /**
         * Installs a handler for exceptions thrown by listener callbacks and
         * async continuations on native producer threads. These exceptions have
         * no Kotlin caller to propagate to; when no handler is installed, they
         * are logged with their stack trace and dropped. Pass `null` to
         * restore the default logging behavior.
         */
        @JvmStatic fun setCallbackExceptionHandler(handler: ((Throwable) -> Unit)?) {
            callbackExceptionHandler = handler
        }

        // Invoked from the JNI glue; rethrowing signals "no handler" so the
        // glue falls back to ExceptionDescribe.
        @JvmStatic private fun dispatchCallbackException(t: Throwable) {
            callbackExceptionHandler?.invoke(t) ?: throw t
        }

        /**
         * Subscribe to per-key eviction notifications
         *
         * Exceptions thrown by the callback cannot propagate to a caller (events fire on a producer thread); they are delivered to the handler installed via [setCallbackExceptionHandler], or logged with their stack trace and dropped when no handler is set.
         */
        @JvmStatic external fun registerEvictionListener(callback: (String) -> Unit): Long
        @JvmStatic external fun unregisterEvictionListener(id: Long)
        /**
         * Snapshot the current store statistics
         */
        @JvmStatic private external fun getStatsJni(store: Long): Long
        @JvmStatic fun getStats(store: Store): Stats = Stats(getStatsJni(store.handle))
    }
}

/** Persistence semantics applied to a stored entry */
enum class EntryKind(val value: Int) {
    /** In-memory only; lost on close */
    Volatile(0),
    /** Flushed to durable storage */
    Persistent(1),
    /** Persistent and encrypted at rest */
    Encrypted(2);

    companion object {
        fun fromValue(value: Int): EntryKind = entries.first { it.value == value }
    }
}

/** A single key-value entry persisted in the store */
