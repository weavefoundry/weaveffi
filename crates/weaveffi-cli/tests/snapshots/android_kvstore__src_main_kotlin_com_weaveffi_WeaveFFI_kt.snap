    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic external fun nativeCreate(id: Long, key: String, value: ByteArray, created_at: Long, expires_at: Long?, tags: Array<String>, metadata: Map<String, String>): Long
        @JvmStatic external fun nativeDestroy(handle: Long)
        @JvmStatic external fun nativeGetId(handle: Long): Long
        @JvmStatic external fun nativeGetKey(handle: Long): String
        @JvmStatic external fun nativeGetValue(handle: Long): ByteArray
        @JvmStatic external fun nativeGetCreatedAt(handle: Long): Long
        @JvmStatic external fun nativeGetExpiresAt(handle: Long): Long?
        @JvmStatic external fun nativeGetTags(handle: Long): Array<String>
        @JvmStatic external fun nativeGetMetadata(handle: Long): Map<String, String>

        fun create(id: Long, key: String, value: ByteArray, created_at: Long, expires_at: Long?, tags: Array<String>, metadata: Map<String, String>): Entry = Entry(nativeCreate(id, key, value, created_at, expires_at, tags, metadata))
    }

    /** Stable monotonic identifier assigned on insert */
    val id: Long get() = nativeGetId(handle)
    /** UTF-8 lookup key */
    val key: String get() = nativeGetKey(handle)
    /** Opaque binary payload */
    val value: ByteArray get() = nativeGetValue(handle)
    /** Unix-timestamp seconds when the entry was created */
    val created_at: Long get() = nativeGetCreatedAt(handle)
    /** Optional unix-timestamp seconds at which the entry expires */
    val expires_at: Long? get() = nativeGetExpiresAt(handle)
    /** Free-form labels attached to the entry */
    val tags: Array<String> get() = nativeGetTags(handle)
    /** Arbitrary string-valued metadata pairs */
    val metadata: Map<String, String> get() = nativeGetMetadata(handle)

    override fun close() {
        if (handle != 0L) {
            nativeDestroy(handle)
            handle = 0L
        }
    }

    protected fun finalize() {
        close()
    }
}

