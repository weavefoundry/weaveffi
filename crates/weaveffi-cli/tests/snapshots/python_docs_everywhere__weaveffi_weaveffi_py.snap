"""WeaveFFI Python ctypes bindings (auto-generated)"""
import contextlib
import ctypes
import platform
from enum import IntEnum
from typing import Dict, Iterator, List, Optional


class WeaveffiError(Exception):
    def __init__(self, code: int, message: str) -> None:
        self.code = code
        self.message = message
        super().__init__(f"({code}) {message}")


class _WeaveffiErrorStruct(ctypes.Structure):
    _fields_ = [
        ("code", ctypes.c_int32),
        ("message", ctypes.c_char_p),
    ]


def _load_library() -> ctypes.CDLL:
    system = platform.system()
    if system == "Darwin":
        name = "libweaveffi.dylib"
    elif system == "Windows":
        name = "weaveffi.dll"
    else:
        name = "libweaveffi.so"
    return ctypes.CDLL(name)


_lib = _load_library()
_lib.weaveffi_error_clear.argtypes = [ctypes.POINTER(_WeaveffiErrorStruct)]
_lib.weaveffi_error_clear.restype = None
_lib.weaveffi_free_string.argtypes = [ctypes.c_char_p]
_lib.weaveffi_free_string.restype = None
_lib.weaveffi_free_bytes.argtypes = [ctypes.POINTER(ctypes.c_uint8), ctypes.c_size_t]
_lib.weaveffi_free_bytes.restype = None


def _check_error(err: _WeaveffiErrorStruct) -> None:
    if err.code != 0:
        code = err.code
        message = err.message.decode("utf-8") if err.message else ""
        _lib.weaveffi_error_clear(ctypes.byref(err))
        raise WeaveffiError(code, message)


class _PointerGuard(contextlib.AbstractContextManager):
    def __init__(self, ptr, free_fn) -> None:
        self.ptr = ptr
        self._free_fn = free_fn

    def __exit__(self, *exc) -> bool:
        if self.ptr is not None:
            self._free_fn(self.ptr)
            self.ptr = None
        return False


def _string_to_bytes(s: Optional[str]) -> Optional[bytes]:
    if s is None:
        return None
    return s.encode("utf-8")


def _bytes_to_string(ptr) -> Optional[str]:
    if ptr is None:
        return None
    return ptr.decode("utf-8")

import asyncio
import threading


# === Module: docs ===

class Status(IntEnum):
    """
    Lifecycle status of a document.

    Used to drive UI badges and filters.
    """
    # Document is being edited
    Draft = 0
    # Document is publicly visible
    Published = 1
    # Document is hidden from listings
    Archived = 2


class Document:
    """
    Represents a single document tracked by the system.

    Documents are persisted to disk and exposed via the public API.
    """

    def __init__(self, _ptr: int) -> None:
        self._ptr = _ptr

    def __del__(self) -> None:
        if self._ptr is not None:
            _lib.weaveffi_docs_Document_destroy.argtypes = [ctypes.c_void_p]
            _lib.weaveffi_docs_Document_destroy.restype = None
            _lib.weaveffi_docs_Document_destroy(self._ptr)
            self._ptr = None

    @property
    def id(self) -> int:
        """Stable opaque identifier"""
        _fn = _lib.weaveffi_docs_Document_get_id
        _fn.argtypes = [ctypes.c_void_p]
        _fn.restype = ctypes.c_int64
        _result = _fn(self._ptr)
        return _result


    @property
    def title(self) -> str:
        """Human-readable title shown in lists"""
        _fn = _lib.weaveffi_docs_Document_get_title
        _fn.argtypes = [ctypes.c_void_p]
        _fn.restype = ctypes.c_char_p
        _result = _fn(self._ptr)
        return _bytes_to_string(_result) or ""


    @property
    def status(self) -> "Status":
        """Current lifecycle status"""
        _fn = _lib.weaveffi_docs_Document_get_status
        _fn.argtypes = [ctypes.c_void_p]
        _fn.restype = ctypes.c_int32
        _result = _fn(self._ptr)
        return Status(_result)


    @property
    def tags(self) -> List[str]:
        """Free-form tags for grouping"""
        _fn = _lib.weaveffi_docs_Document_get_tags
        _fn.argtypes = [ctypes.c_void_p, ctypes.POINTER(ctypes.c_size_t)]
        _fn.restype = ctypes.POINTER(ctypes.c_char_p)
        _out_len = ctypes.c_size_t(0)
        _result = _fn(self._ptr, ctypes.byref(_out_len))
        if not _result:
            return []
        return [_bytes_to_string(_result[_i]) for _i in range(_out_len.value)]



class DocumentBuilder:
    """
    Represents a single document tracked by the system.

    Documents are persisted to disk and exposed via the public API.
    """
    def __init__(self) -> None:
        self._id: Optional[int] = None
        self._title: Optional[str] = None
        self._status: Optional["Status"] = None
        self._tags: Optional[List[str]] = None

    def with_id(self, value: int) -> "DocumentBuilder":
        """Stable opaque identifier"""
        self._id = value
        return self

    def with_title(self, value: str) -> "DocumentBuilder":
        """Human-readable title shown in lists"""
        self._title = value
        return self

    def with_status(self, value: "Status") -> "DocumentBuilder":
        """Current lifecycle status"""
        self._status = value
        return self

    def with_tags(self, value: List[str]) -> "DocumentBuilder":
        """Free-form tags for grouping"""
        self._tags = value
        return self

    def build(self) -> "Document":
        if self._id is None:
            raise ValueError("missing field: id")
        if self._title is None:
            raise ValueError("missing field: title")
        if self._status is None:
            raise ValueError("missing field: status")
        if self._tags is None:
            raise ValueError("missing field: tags")
        raise NotImplementedError("DocumentBuilder.build requires FFI backing")


def create_document(title: str, tags: List[str]) -> "Document":
    """
    Create a brand new document.

    The document starts in `Draft` status; callers must publish
    it explicitly to make it visible.

    Parameters
    ----------
    title : Human-readable title for the new document
    tags : Initial set of tags (may be empty)
    """
    _fn = _lib.weaveffi_docs_create_document
    _fn.argtypes = [ctypes.c_char_p, ctypes.POINTER(ctypes.c_char_p), ctypes.c_size_t, ctypes.POINTER(_WeaveffiErrorStruct)]
    _fn.restype = ctypes.c_void_p
    _tags_arr = (ctypes.c_char_p * len(tags))(*[_string_to_bytes(v) for v in tags])
    _err = _WeaveffiErrorStruct()
    _result = _fn(_string_to_bytes(title), _tags_arr, len(tags), ctypes.byref(_err))
    _check_error(_err)
    if _result is None:
        raise WeaveffiError(-1, "null pointer")
    return Document(_result)


def get_document(id: int) -> Optional["Document"]:
    """Look up a document by identifier

    Parameters
    ----------
    id : Identifier returned from create_document
    """
    _fn = _lib.weaveffi_docs_get_document
    _fn.argtypes = [ctypes.c_int64, ctypes.POINTER(_WeaveffiErrorStruct)]
    _fn.restype = ctypes.c_void_p
    _err = _WeaveffiErrorStruct()
    _result = _fn(id, ctypes.byref(_err))
    _check_error(_err)
    if _result is None:
        return None
    return Document(_result)


def _publish_async_sync(id: int) -> bool:
    """Publish a document in the background

    Parameters
    ----------
    id : Identifier of the document to publish
    """
    _fn = _lib.weaveffi_docs_publish_async_async
    _ev = threading.Event()
    _state = {"err": None, "val": None}
    def _cb_impl(context, err, result):
        try:
            if err and err.contents.code != 0:
                _code = err.contents.code
                _msg = err.contents.message.decode("utf-8") if err.contents.message else ""
                _lib.weaveffi_error_clear(ctypes.byref(err.contents))
                _state["err"] = WeaveffiError(_code, _msg)
            else:
            _state["val"] = bool(result)
        finally:
            _ev.set()
    _cb_type = ctypes.CFUNCTYPE(None, ctypes.c_void_p, ctypes.POINTER(_WeaveffiErrorStruct), ctypes.c_int32)
    _cb = _cb_type(_cb_impl)
    _fn.argtypes = [ctypes.c_int64, _cb_type, ctypes.c_void_p]
    _fn.restype = None
    _fn(id, _cb, None)
    _ev.wait()
    if _state["err"] is not None:
        raise _state["err"]
    return _state["val"]


async def publish_async(id: int) -> bool:
    """Publish a document in the background

    Parameters
    ----------
    id : Identifier of the document to publish
    """
    _loop = asyncio.get_event_loop()
    return await _loop.run_in_executor(None, _publish_async_sync, id)
