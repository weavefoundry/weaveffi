/// Build a Numerics struct from every numeric primitive
Numerics makeNumerics(int a, int b, int c, int d, int e, int f, int g, int h, double i, double j) {
  final err = calloc<_WeaveFFIError>();
  try {
    final result = _weaveffiShapesMakeNumerics(a, b, c, d, e, f, g, h, i, j, err);
    _checkError(err);
    return Numerics._(result);
  } finally {
    calloc.free(err);
  }
}

