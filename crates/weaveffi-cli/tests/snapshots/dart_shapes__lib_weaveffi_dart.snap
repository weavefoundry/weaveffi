  }

  /// A labeled shape with a small count
  factory Shape.labeled(String label, int count) {
  final labelPtr = label.toNativeUtf8();
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiShapesShapeLabeledNew(labelPtr, count, err);
      _checkError(err);
      return Shape._(result);
    } finally {
      calloc.free(labelPtr);
      calloc.free(err);
    }
  }

  /// Radius in points
  double get circleRadius {
    final result = _weaveffiShapesShapeCircleGetRadius(_handle);
    return result;
  }

