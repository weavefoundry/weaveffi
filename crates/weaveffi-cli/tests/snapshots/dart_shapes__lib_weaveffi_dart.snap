  /// The empty shape (a unit variant)
  empty(0),
  /// A circle with a radius
  circle(1),
  /// An axis-aligned rectangle
  rectangle(2),
  /// An integer-bounded shape (exercises narrow + wide ints)
  bounded(3),
  /// A labeled shape with a small count
  labeled(4),
  ;
  const ShapeTag(this.value);
  final int value;

  static ShapeTag fromValue(int value) =>
      ShapeTag.values.firstWhere((e) => e.value == value);
}

