/// Sum a list of bytes into a wide integer (numerics smoke)
int sumBytes(List<int> values) {
  final valuesPtr = values.isEmpty ? nullptr : calloc<Uint8>(values.length);
  for (var i = 0; i < values.length; i++) {
    valuesPtr[i] = values[i];
  }
  final err = calloc<_WeaveFFIError>();
  try {
    final result = _weaveffiShapesSumBytes(valuesPtr, values.length, err);
    _checkError(err);
    return result;
  } finally {
    if (valuesPtr != nullptr) calloc.free(valuesPtr);
    calloc.free(err);
  }
}

