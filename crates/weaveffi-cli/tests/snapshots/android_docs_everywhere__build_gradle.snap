---
source: crates/weaveffi-cli/tests/snapshots.rs
---
plugins {
    id 'com.android.library'
    id 'org.jetbrains.kotlin.android' version '1.9.22' apply false
}

android {
    namespace 'com.weaveffi'
    compileSdk 34
    defaultConfig {
        minSdk 24
        externalNativeBuild {
            cmake {
                cppFlags ""
            }
        }
    }
    externalNativeBuild {
        cmake {
            path "src/main/cpp/CMakeLists.txt"
        }
    }
}
