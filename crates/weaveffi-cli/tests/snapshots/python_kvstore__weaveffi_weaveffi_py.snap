        _fn = _lib.weaveffi_kv_stats_Stats_get_total_bytes
        _fn.argtypes = [ctypes.c_void_p]
        _fn.restype = ctypes.c_int64
        _result = _fn(self._ptr)
        return _result


    @property
    def expired_entries(self) -> int:
        """Number of entries past their TTL but not yet evicted"""
        _fn = _lib.weaveffi_kv_stats_Stats_get_expired_entries
        _fn.argtypes = [ctypes.c_void_p]
        _fn.restype = ctypes.c_int64
        _result = _fn(self._ptr)
        return _result



def get_stats(store: "Store") -> "Stats":
    """Snapshot the current store statistics

    Raises
    ------
    KvError
        If the call reports one of the domain's error codes.
    """
    _fn = _lib.weaveffi_kv_stats_get_stats
    _fn.argtypes = [ctypes.c_void_p, ctypes.POINTER(_WeaveFFIErrorStruct)]
    _fn.restype = ctypes.c_void_p
    _err = _WeaveFFIErrorStruct()
    _result = _fn(store._ptr, ctypes.byref(_err))
    _check_kv_error(_err)
    if _result is None:
        raise WeaveFFIError(-1, "null pointer")
    return Stats(_result)

