        self._tags: Optional[List[str]] = None
        self._metadata: Optional[Dict[str, str]] = None

    def with_id(self, value: int) -> "EntryBuilder":
        """Stable monotonic identifier assigned on insert"""
        self._id = value
        return self

    def with_key(self, value: str) -> "EntryBuilder":
        """UTF-8 lookup key"""
        self._key = value
        return self

    def with_value(self, value: bytes) -> "EntryBuilder":
        """Opaque binary payload"""
        self._value = value
        return self

    def with_created_at(self, value: int) -> "EntryBuilder":
        """Unix-timestamp seconds when the entry was created"""
        self._created_at = value
        return self

    def with_expires_at(self, value: Optional[int]) -> "EntryBuilder":
        """Optional unix-timestamp seconds at which the entry expires"""
        self._expires_at = value
        return self

    def with_tags(self, value: List[str]) -> "EntryBuilder":
        """Free-form labels attached to the entry"""
        self._tags = value
        return self

    def with_metadata(self, value: Dict[str, str]) -> "EntryBuilder":
        """Arbitrary string-valued metadata pairs"""
        self._metadata = value
        return self

    def build(self) -> "Entry":
        if self._id is None:
            raise ValueError("missing field: id")
        if self._key is None:
            raise ValueError("missing field: key")
        if self._value is None:
            raise ValueError("missing field: value")
        if self._created_at is None:
            raise ValueError("missing field: created_at")
        if self._expires_at is None:
            raise ValueError("missing field: expires_at")
        if self._tags is None:
            raise ValueError("missing field: tags")
        if self._metadata is None:
            raise ValueError("missing field: metadata")
        raise NotImplementedError("EntryBuilder.build requires FFI backing")


