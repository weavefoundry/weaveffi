  # Subscribe to per-key eviction notifications
  # Registers a OnEvict listener block. Returns a subscription id for
  # unregister_eviction_listener.
  def self.register_eviction_listener(&block)
    trampoline = FFI::Function.new(:void, [:string, :pointer]) do |key, _context|
      block.call(key)
    end
    listener_id = weaveffi_kv_register_eviction_listener(trampoline, FFI::Pointer::NULL)
    @listener_refs[listener_id] = trampoline
    listener_id
  end

  # Unregisters a listener previously registered with register_eviction_listener.
  def self.unregister_eviction_listener(listener_id)
    weaveffi_kv_unregister_eviction_listener(listener_id)
    @listener_refs.delete(listener_id)
    nil
  end

