    # Insert or replace a value, returning true on success
    def put(key, value, kind, ttl_seconds)
      err = ErrorStruct.new
      value_buf = FFI::MemoryPointer.new(:uint8, value.bytesize)
      value_buf.put_bytes(0, value)
      ttl_seconds_c = ttl_seconds.nil? ? FFI::Pointer::NULL : begin; p = FFI::MemoryPointer.new(:int64); p.write_int64(ttl_seconds); p; end
      result = WeaveFFI.weaveffi_kv_Store_put(@handle, key, value_buf, value.bytesize, kind, ttl_seconds_c, err)
      WeaveFFI.check_kv_error!(err)
      result != 0
