      warn "[DEPRECATED] use put() with explicit kind"
      err = ErrorStruct.new
      value_buf = FFI::MemoryPointer.new(:uint8, value.bytesize)
      value_buf.put_bytes(0, value)
      result = WeaveFFI.weaveffi_kv_Store_legacy_put(@handle, key, value_buf, value.bytesize, err)
      WeaveFFI.check_kv_error!(err)
      result != 0
