    # Reclaim space asynchronously; returns the number of bytes reclaimed
    # Blocks until the async producer completes (cancellation token not exposed; pass-through is NULL).
    def compact()
      queue = Queue.new
      callback = FFI::Function.new(:void, [:pointer, :pointer, :int64]) do |_context, err_ptr, result|
        err = err_ptr.null? ? nil : ErrorStruct.new(err_ptr)
        if err && err[:code] != 0
          code = err[:code]
          msg = err[:message].null? ? '' : err[:message].read_string
          WeaveFFI.weaveffi_error_clear(err_ptr)
          queue << WeaveFFI.kv_error_from(code, msg)
        else
          queue << result
        end
      end
      WeaveFFI.weaveffi_kv_Store_compact_async(@handle, FFI::Pointer::NULL, callback, FFI::Pointer::NULL)
      value = queue.pop
      raise value if value.is_a?(Error)
      value
    end

