    def count()
      err = ErrorStruct.new
      result = WeaveFFI.weaveffi_kv_Store_count(@handle, err)
      WeaveFFI.check_error!(err)
      result
    end

    # Drop every entry from the store
    def clear()
      err = ErrorStruct.new
      WeaveFFI.weaveffi_kv_Store_clear(@handle, err)
