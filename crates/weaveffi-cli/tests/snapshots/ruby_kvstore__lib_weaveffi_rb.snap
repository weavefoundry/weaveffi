# frozen_string_literal: true
# WeaveFFI Ruby FFI bindings (auto-generated)

require 'ffi'

module WeaveFFI
  extend FFI::Library

  case FFI::Platform::OS
  when /darwin/
    ffi_lib 'libweaveffi.dylib'
  when /mswin|mingw/
    ffi_lib 'weaveffi.dll'
  else
    ffi_lib 'libweaveffi.so'
  end

  class ErrorStruct < FFI::Struct
    layout :code, :int32,
           :message, :pointer
  end

  class Error < StandardError
    attr_reader :code

    def initialize(code, message)
      @code = code
      super(message)
    end
  end

  attach_function :weaveffi_error_clear, [:pointer], :void
  attach_function :weaveffi_free_string, [:pointer], :void
  attach_function :weaveffi_free_bytes, [:pointer, :size_t], :void

  def self.check_error!(err)
    return if err[:code].zero?
    code = err[:code]
    msg_ptr = err[:message]
    msg = msg_ptr.null? ? '' : msg_ptr.read_string
    weaveffi_error_clear(err.to_ptr)
    raise Error.new(code, msg)
  end

  # === Module: kv ===

  # Persistence semantics applied to a stored entry
  module EntryKind
    # In-memory only; lost on close
    VOLATILE = 0
    # Flushed to durable storage
    PERSISTENT = 1
    # Persistent and encrypted at rest
    ENCRYPTED = 2
  end

  attach_function :weaveffi_kv_Store_destroy, [:pointer], :void
  # Internal store identifier
  attach_function :weaveffi_kv_Store_get_id, [:pointer], :int64

  attach_function :weaveffi_kv_Entry_destroy, [:pointer], :void
  # Stable monotonic identifier assigned on insert
  attach_function :weaveffi_kv_Entry_get_id, [:pointer], :int64
  # UTF-8 lookup key
  attach_function :weaveffi_kv_Entry_get_key, [:pointer], :pointer
  # Opaque binary payload
  attach_function :weaveffi_kv_Entry_get_value, [:pointer, :pointer], :pointer
  # Unix-timestamp seconds when the entry was created
  attach_function :weaveffi_kv_Entry_get_created_at, [:pointer], :int64
  # Optional unix-timestamp seconds at which the entry expires
  attach_function :weaveffi_kv_Entry_get_expires_at, [:pointer], :pointer
  # Free-form labels attached to the entry
  attach_function :weaveffi_kv_Entry_get_tags, [:pointer, :pointer], :pointer
  # Arbitrary string-valued metadata pairs
  attach_function :weaveffi_kv_Entry_get_metadata, [:pointer, :pointer, :pointer, :pointer], :void
  # Open (or create) a store backed by the given filesystem path
  attach_function :weaveffi_kv_open_store, [:string, :pointer], :pointer
  # Close the store and release all in-memory resources
  attach_function :weaveffi_kv_close_store, [:pointer, :pointer], :void
  # Insert or replace a value, returning true on success
  attach_function :weaveffi_kv_put, [:pointer, :string, :pointer, :size_t, :int32, :pointer, :pointer], :int32
  # Look up an entry by key; returns null if missing or expired
  attach_function :weaveffi_kv_get, [:pointer, :string, :pointer], :pointer
  # Remove the entry for the given key, returning true if it existed
  attach_function :weaveffi_kv_delete, [:pointer, :string, :pointer], :int32
  # Stream every key, optionally filtered by a prefix
  attach_function :weaveffi_kv_list_keys, [:pointer, :string, :pointer, :pointer], :pointer
  # Return the number of live entries in the store
  attach_function :weaveffi_kv_count, [:pointer, :pointer], :int64
  # Drop every entry from the store
  attach_function :weaveffi_kv_clear, [:pointer, :pointer], :void
  # Legacy single-shot put kept for compatibility
  attach_function :weaveffi_kv_legacy_put, [:pointer, :string, :pointer, :size_t, :pointer], :int32

  class StorePtr < FFI::AutoPointer
    def self.release(ptr)
      WeaveFFI.weaveffi_kv_Store_destroy(ptr)
    end
  end

  # Opaque key-value store handle target type
  class Store
    attr_reader :handle

    def initialize(handle)
      @handle = StorePtr.new(handle)
    end

    def self.create(handle)
      new(handle)
    end

    def destroy
      return if @handle.nil?
      @handle.free
      @handle = nil
    end

    # Internal store identifier
    def id
      result = WeaveFFI.weaveffi_kv_Store_get_id(@handle)
      result
    end
  end

  class EntryPtr < FFI::AutoPointer
    def self.release(ptr)
      WeaveFFI.weaveffi_kv_Entry_destroy(ptr)
    end
  end

  # A single key-value entry persisted in the store
  class Entry
    attr_reader :handle

    def initialize(handle)
      @handle = EntryPtr.new(handle)
    end

    def self.create(handle)
      new(handle)
    end

    def destroy
      return if @handle.nil?
      @handle.free
      @handle = nil
    end

    # Stable monotonic identifier assigned on insert
    def id
      result = WeaveFFI.weaveffi_kv_Entry_get_id(@handle)
      result
    end

    # UTF-8 lookup key
    def key
      result = WeaveFFI.weaveffi_kv_Entry_get_key(@handle)
      return '' if result.null?
      str = result.read_string
      WeaveFFI.weaveffi_free_string(result)
      str
    end

    # Opaque binary payload
    def value
      out_len = FFI::MemoryPointer.new(:size_t)
      result = WeaveFFI.weaveffi_kv_Entry_get_value(@handle, out_len)
      return ''.b if result.null?
      len = out_len.read(:size_t)
      data = result.read_string(len)
      WeaveFFI.weaveffi_free_bytes(result, len)
      data
    end

    # Unix-timestamp seconds when the entry was created
    def created_at
      result = WeaveFFI.weaveffi_kv_Entry_get_created_at(@handle)
      result
    end

    # Optional unix-timestamp seconds at which the entry expires
    def expires_at
      result = WeaveFFI.weaveffi_kv_Entry_get_expires_at(@handle)
      return nil if result.null?
      result.read_int64
    end

    # Free-form labels attached to the entry
    def tags
      out_len = FFI::MemoryPointer.new(:size_t)
      result = WeaveFFI.weaveffi_kv_Entry_get_tags(@handle, out_len)
      return [] if result.null?
      len = out_len.read(:size_t)
      result.read_array_of_pointer(len).map { |p| p.null? ? '' : p.read_string }
    end

    # Arbitrary string-valued metadata pairs
    def metadata
      out_keys = FFI::MemoryPointer.new(:pointer)
      out_values = FFI::MemoryPointer.new(:pointer)
      out_len = FFI::MemoryPointer.new(:size_t)
      WeaveFFI.weaveffi_kv_Entry_get_metadata(@handle, out_keys, out_values, out_len)
      len = out_len.read(:size_t)
      keys_ptr = out_keys.read_pointer
      vals_ptr = out_values.read_pointer
      return {} if keys_ptr.null? || vals_ptr.null?
      keys_ptr.read_array_of_pointer(len).zip(vals_ptr.read_array_of_pointer(len)).each_with_object({}) { |(k, v), h| h[k.null? ? '' : k.read_string] = v.null? ? '' : v.read_string }
    end
  end

  # A single key-value entry persisted in the store
  class EntryBuilder
    def initialize
      @id = nil
      @key = nil
      @value = nil
      @created_at = nil
      @expires_at = nil
      @tags = nil
      @metadata = nil
    end

    # Stable monotonic identifier assigned on insert
    def with_id(value)
      @id = value
      self
    end

    # UTF-8 lookup key
    def with_key(value)
      @key = value
      self
    end

    # Opaque binary payload
    def with_value(value)
      @value = value
      self
    end

    # Unix-timestamp seconds when the entry was created
    def with_created_at(value)
      @created_at = value
      self
    end

    # Optional unix-timestamp seconds at which the entry expires
    def with_expires_at(value)
      @expires_at = value
      self
    end

    # Free-form labels attached to the entry
    def with_tags(value)
      @tags = value
      self
    end

    # Arbitrary string-valued metadata pairs
    def with_metadata(value)
      @metadata = value
      self
    end

    def build
      raise "missing field: id" if @id.nil?
      raise "missing field: key" if @key.nil?
      raise "missing field: value" if @value.nil?
      raise "missing field: created_at" if @created_at.nil?
      raise "missing field: expires_at" if @expires_at.nil?
      raise "missing field: tags" if @tags.nil?
      raise "missing field: metadata" if @metadata.nil?
      raise NotImplementedError, "EntryBuilder.build requires FFI backing"
    end
  end

  # Open (or create) a store backed by the given filesystem path
  def self.open_store(path)
    err = ErrorStruct.new
    result = weaveffi_kv_open_store(path, err)
    check_error!(err)
    raise Error.new(-1, 'null pointer') if result.null?
    Store.new(result)
  end

  # Close the store and release all in-memory resources
  def self.close_store(store)
    err = ErrorStruct.new
    weaveffi_kv_close_store(store.handle, err)
    check_error!(err)
  end

  # Insert or replace a value, returning true on success
  def self.put(store, key, value, kind, ttl_seconds)
    err = ErrorStruct.new
    value_buf = FFI::MemoryPointer.new(:uint8, value.bytesize)
    value_buf.put_bytes(0, value)
    ttl_seconds_c = ttl_seconds.nil? ? FFI::Pointer::NULL : begin; p = FFI::MemoryPointer.new(:int64); p.write_int64(ttl_seconds); p; end
    result = weaveffi_kv_put(store.handle, key, value_buf, value.bytesize, kind, ttl_seconds_c, err)
    check_error!(err)
    result != 0
  end

  # Look up an entry by key; returns null if missing or expired
  def self.get(store, key)
    err = ErrorStruct.new
    result = weaveffi_kv_get(store.handle, key, err)
    check_error!(err)
    return nil if result.null?
    Entry.new(result)
  end

  # Remove the entry for the given key, returning true if it existed
  def self.delete(store, key)
    err = ErrorStruct.new
    result = weaveffi_kv_delete(store.handle, key, err)
    check_error!(err)
    result != 0
  end

  # Stream every key, optionally filtered by a prefix
  def self.list_keys(store, prefix)
    err = ErrorStruct.new
    out_len = FFI::MemoryPointer.new(:size_t)
    result = weaveffi_kv_list_keys(store.handle, prefix, out_len, err)
    check_error!(err)
    return [] if result.null?
    len = out_len.read(:size_t)
    result.read_array_of_pointer(len).map { |p| p.null? ? '' : p.read_string }
  end

  # Return the number of live entries in the store
  def self.count(store)
    err = ErrorStruct.new
    result = weaveffi_kv_count(store.handle, err)
    check_error!(err)
    result
  end

  # Drop every entry from the store
  def self.clear(store)
    err = ErrorStruct.new
    weaveffi_kv_clear(store.handle, err)
    check_error!(err)
  end

  # Legacy single-shot put kept for compatibility
  def self.legacy_put(store, key, value)
    warn "[DEPRECATED] use put() with explicit kind"
    err = ErrorStruct.new
    value_buf = FFI::MemoryPointer.new(:uint8, value.bytesize)
    value_buf.put_bytes(0, value)
    result = weaveffi_kv_legacy_put(store.handle, key, value_buf, value.bytesize, err)
    check_error!(err)
    result != 0
  end

  # === Module: kv_stats ===

  attach_function :weaveffi_kv_stats_Stats_destroy, [:pointer], :void
  # Number of live entries
  attach_function :weaveffi_kv_stats_Stats_get_total_entries, [:pointer], :int64
  # Sum of all value byte lengths
  attach_function :weaveffi_kv_stats_Stats_get_total_bytes, [:pointer], :int64
  # Number of entries past their TTL but not yet evicted
  attach_function :weaveffi_kv_stats_Stats_get_expired_entries, [:pointer], :int64
  # Snapshot the current store statistics
  attach_function :weaveffi_kv_stats_get_stats, [:pointer, :pointer], :pointer

  class StatsPtr < FFI::AutoPointer
    def self.release(ptr)
      WeaveFFI.weaveffi_kv_stats_Stats_destroy(ptr)
    end
  end

  # Aggregate store statistics
  class Stats
    attr_reader :handle

    def initialize(handle)
      @handle = StatsPtr.new(handle)
    end

    def self.create(handle)
      new(handle)
    end

    def destroy
      return if @handle.nil?
      @handle.free
      @handle = nil
    end

    # Number of live entries
    def total_entries
      result = WeaveFFI.weaveffi_kv_stats_Stats_get_total_entries(@handle)
      result
    end

    # Sum of all value byte lengths
    def total_bytes
      result = WeaveFFI.weaveffi_kv_stats_Stats_get_total_bytes(@handle)
      result
    end

    # Number of entries past their TTL but not yet evicted
    def expired_entries
      result = WeaveFFI.weaveffi_kv_stats_Stats_get_expired_entries(@handle)
      result
    end
  end

  # Snapshot the current store statistics
  def self.get_stats(store)
    err = ErrorStruct.new
    result = weaveffi_kv_stats_get_stats(store.handle, err)
    check_error!(err)
    raise Error.new(-1, 'null pointer') if result.null?
    Stats.new(result)
  end
end
