      WeaveFFI.check_kv_error!(err)
      result != 0
    end

    # Stream every key, optionally filtered by a prefix
    def list_keys(prefix)
      err = ErrorStruct.new
      iter = WeaveFFI.weaveffi_kv_Store_list_keys(@handle, prefix, err)
      WeaveFFI.check_kv_error!(err)
      items = []
      return items if iter.null?
      loop do
        out_item = FFI::MemoryPointer.new(:pointer)
        item_err = ErrorStruct.new
        has_item = WeaveFFI.weaveffi_kv_Store_ListKeysIterator_next(iter, out_item, item_err)
        if item_err[:code] != 0
          WeaveFFI.weaveffi_kv_Store_ListKeysIterator_destroy(iter)
          WeaveFFI.check_kv_error!(item_err)
        end
        break if has_item.zero?
        item_ptr = out_item.read_pointer
        if item_ptr.null?
          items << ''
        else
          items << item_ptr.read_string
          WeaveFFI.weaveffi_free_string(item_ptr)
        end
      end
      WeaveFFI.weaveffi_kv_Store_ListKeysIterator_destroy(iter)
      items
    end

