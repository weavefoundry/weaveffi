Shape.Tag = Object.freeze({
  Empty: 0,
  Circle: 1,
  Rectangle: 2,
  Bounded: 3,
  Labeled: 4,
});

/**
 * Load a WeaveFFI Wasm module from the given URL.
 *
 * @param {string} url - URL to the `.wasm` file.
 * @returns {Promise<Object>} The API bindings.
 *
 * Exported functions follow the C ABI naming convention:
 *   weaveffi_{module}_{function}(params...) -> result
 *
 * @example
 * const api = await loadWeaveffiWasm('lib.wasm');
 *
 * // Primitive: plain numbers in, number out.
 * const sum = api.math.add(1, 2);
 *
 * // Struct: returns a wrapper instance exposing field getters.
 * const person = api.contacts.create();
 * console.log(person.name);
 *
 * // Enum: pass the integer discriminant.
 * api.ui.set_color(0); // 0 = first variant
 *
 * // Optional: pass null to omit, a value to provide.
 * api.config.set_timeout(5000); // present
 * api.config.set_timeout(null); // absent
 *
 * // List/Map: pass arrays/objects; receive arrays/objects.
 * const names = api.data.all_names();
 */
export async function loadWeaveffiWasm(url) {
  const response = await fetch(url);
  const bytes = await response.arrayBuffer();
  const { instance } = await WebAssembly.instantiate(bytes, {});
  const wasm = instance.exports;

  return {
    _raw: wasm,
    shapes: {
      describe(shape) {
        const _err = _allocErr(wasm);
        const _r = wasm.weaveffi_shapes_describe(shape._handle, _err);
        _checkErr(wasm, _err);
        _freeErr(wasm, _err);
        return _takeCStr(wasm, _r);
      },
      scale(shape, factor) {
        const _err = _allocErr(wasm);
        const _r = wasm.weaveffi_shapes_scale(shape._handle, factor, _err);
        _checkErr(wasm, _err);
        _freeErr(wasm, _err);
        return new Shape(wasm, _r);
      },
      sumBytes(values) {
        const a0_arr = values || [];
        const a0_n = a0_arr.length;
        const a0_base = wasm.weaveffi_alloc(a0_n ? a0_n * 1 : 1);
        {
          const dv = new DataView(wasm.memory.buffer);
          for (let i = 0; i < a0_n; i++) {
            dv.setUint8(a0_base + i * 1, a0_arr[i]);
          }
        }
        const _err = _allocErr(wasm);
        const _r = wasm.weaveffi_shapes_sum_bytes(a0_base, a0_n, _err);
        wasm.weaveffi_dealloc(a0_base, a0_n ? a0_n * 1 : 1);
        _checkErr(wasm, _err);
        _freeErr(wasm, _err);
        return _r;
      },
      makeNumerics(a, b, c, d, e, f, g, h, i, j) {
        const _err = _allocErr(wasm);
        const _r = wasm.weaveffi_shapes_make_numerics(a, b, c, BigInt(d), e, f, g, BigInt(h), i, j, _err);
        _checkErr(wasm, _err);
        _freeErr(wasm, _err);
        return new Numerics(wasm, _r);
      },
      Numerics: {
        create: (...args) => Numerics.create(wasm, ...args),
      },
      Shape: {
        empty: (...args) => Shape.empty(wasm, ...args),
        circle: (...args) => Shape.circle(wasm, ...args),
        rectangle: (...args) => Shape.rectangle(wasm, ...args),
        bounded: (...args) => Shape.bounded(wasm, ...args),
        labeled: (...args) => Shape.labeled(wasm, ...args),
        Tag: Shape.Tag,
      },
    },
  };
}

