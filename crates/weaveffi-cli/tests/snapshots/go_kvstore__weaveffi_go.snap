	return b
}

// WithKey: UTF-8 lookup key
func (b *EntryBuilder) WithKey(value string) *EntryBuilder {
	b.key = value
	return b
}

// WithValue: Opaque binary payload
func (b *EntryBuilder) WithValue(value []byte) *EntryBuilder {
	b.value = value
	return b
}

// WithCreatedAt: Unix-timestamp seconds when the entry was created
func (b *EntryBuilder) WithCreatedAt(value int64) *EntryBuilder {
	b.createdAt = value
	return b
}

// WithExpiresAt: Optional unix-timestamp seconds at which the entry expires
func (b *EntryBuilder) WithExpiresAt(value *int64) *EntryBuilder {
	b.expiresAt = value
	return b
}

// WithTags: Free-form labels attached to the entry
func (b *EntryBuilder) WithTags(value []string) *EntryBuilder {
	b.tags = value
	return b
}

// WithMetadata: Arbitrary string-valued metadata pairs
func (b *EntryBuilder) WithMetadata(value map[string]string) *EntryBuilder {
	b.metadata = value
	return b
}

func (b *EntryBuilder) Build() (*Entry, error) {
	id := b.id
	key := b.key
	cKey := C.CString(key)
	defer C.free(unsafe.Pointer(cKey))
	value := b.value
	var cValuePtr *C.uint8_t
	cValueLen := C.size_t(len(value))
	if len(value) > 0 {
		cValuePtr = (*C.uint8_t)(unsafe.Pointer(&value[0]))
	}
	createdAt := b.createdAt
	expiresAt := b.expiresAt
	var cExpiresAt *C.int64_t
	if expiresAt != nil {
		tmp := C.int64_t(*expiresAt)
		cExpiresAt = &tmp
	}
	tags := b.tags
	cTagsLen := C.size_t(len(tags))
	cTagsArr := make([]*C.char, len(tags))
	for i, s := range tags {
		cTagsArr[i] = C.CString(s)
	}
	defer func() {
		for _, p := range cTagsArr {
			C.free(unsafe.Pointer(p))
		}
	}()
	var cTagsPtr **C.char
	if len(cTagsArr) > 0 {
		cTagsPtr = (**C.char)(unsafe.Pointer(&cTagsArr[0]))
	}
	metadata := b.metadata
	cMetadataLen := C.size_t(len(metadata))
	keysMetadata := make([]string, 0, len(metadata))
	valsMetadata := make([]string, 0, len(metadata))
	for mk, mv := range metadata {
		keysMetadata = append(keysMetadata, mk)
		valsMetadata = append(valsMetadata, mv)
	}
	cMetadataKeysPtrArr := make([]*C.char, len(keysMetadata))
	for i, s := range keysMetadata {
		cMetadataKeysPtrArr[i] = C.CString(s)
	}
	defer func() {
		for _, p := range cMetadataKeysPtrArr {
			C.free(unsafe.Pointer(p))
		}
	}()
	var cMetadataKeysPtr **C.char
	if len(cMetadataKeysPtrArr) > 0 {
		cMetadataKeysPtr = (**C.char)(unsafe.Pointer(&cMetadataKeysPtrArr[0]))
	}
	cMetadataValsPtrArr := make([]*C.char, len(valsMetadata))
	for i, s := range valsMetadata {
		cMetadataValsPtrArr[i] = C.CString(s)
	}
	defer func() {
		for _, p := range cMetadataValsPtrArr {
			C.free(unsafe.Pointer(p))
		}
	}()
	var cMetadataValsPtr **C.char
	if len(cMetadataValsPtrArr) > 0 {
		cMetadataValsPtr = (**C.char)(unsafe.Pointer(&cMetadataValsPtrArr[0]))
	}
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_Entry_create(C.int64_t(id), cKey, cValuePtr, cValueLen, C.int64_t(createdAt), cExpiresAt, cTagsPtr, cTagsLen, cMetadataKeysPtr, cMetadataValsPtr, cMetadataLen, &cErr)
	if cErr.code != 0 {
		return nil, wvBrandError(wvTakeError(&cErr))
	}
	return &Entry{ptr: result}, nil
}

// Store: An in-memory key-value store owning its entries; destroying the object releases all of its state
type Store struct {
	ptr *C.weaveffi_kv_Store
}

// OpenStore: Open (or create) a store backed by the given filesystem path
func OpenStore(path string) (*Store, error) {
	cPath := C.CString(path)
	defer C.free(unsafe.Pointer(cPath))
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_Store_open(cPath, &cErr)
	if cErr.code != 0 {
		return nil, wvMapKv(wvTakeError(&cErr))
	}
	return &Store{ptr: result}, nil
}

// Put: Insert or replace a value, returning true on success
func (s *Store) Put(key string, value []byte, kind EntryKind, ttlSeconds *int64) (bool, error) {
	cKey := C.CString(key)
	defer C.free(unsafe.Pointer(cKey))
	var cValuePtr *C.uint8_t
	cValueLen := C.size_t(len(value))
	if len(value) > 0 {
		cValuePtr = (*C.uint8_t)(unsafe.Pointer(&value[0]))
	}
	var cTtlSeconds *C.int64_t
	if ttlSeconds != nil {
		tmp := C.int64_t(*ttlSeconds)
		cTtlSeconds = &tmp
	}
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_Store_put(s.ptr, cKey, cValuePtr, cValueLen, C.weaveffi_kv_EntryKind(kind), cTtlSeconds, &cErr)
	if cErr.code != 0 {
		return false, wvMapKv(wvTakeError(&cErr))
	}
	return cToBool(result), nil
}

// Get: Look up an entry by key; returns null if missing or expired
func (s *Store) Get(key string) (*Entry, error) {
	cKey := C.CString(key)
	defer C.free(unsafe.Pointer(cKey))
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_Store_get(s.ptr, cKey, &cErr)
	if cErr.code != 0 {
		return nil, wvMapKv(wvTakeError(&cErr))
	}
	if result == nil {
		return nil, nil
	}
	return &Entry{ptr: result}, nil
}

// Delete: Remove the entry for the given key, returning true if it existed
func (s *Store) Delete(key string) (bool, error) {
	cKey := C.CString(key)
	defer C.free(unsafe.Pointer(cKey))
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_Store_delete(s.ptr, cKey, &cErr)
	if cErr.code != 0 {
		return false, wvMapKv(wvTakeError(&cErr))
	}
	return cToBool(result), nil
}

// ListKeys: Stream every key, optionally filtered by a prefix
func (s *Store) ListKeys(prefix *string) ([]string, error) {
	var cPrefix *C.char
	if prefix != nil {
		cPrefix = C.CString(*prefix)
		defer C.free(unsafe.Pointer(cPrefix))
	}
	var cErr C.weaveffi_error
	it := C.weaveffi_kv_Store_list_keys(s.ptr, cPrefix, &cErr)
	if cErr.code != 0 {
		return nil, wvMapKv(wvTakeError(&cErr))
	}
	defer C.weaveffi_kv_Store_ListKeysIterator_destroy(it)
	goResult := []string{}
	for {
		var outItem *C.char
		var iterErr C.weaveffi_error
		if C.weaveffi_kv_Store_ListKeysIterator_next(it, &outItem, &iterErr) == 0 {
			break
		}
		if iterErr.code != 0 {
			return nil, wvMapKv(wvTakeError(&iterErr))
		}
		goResult = append(goResult, C.GoString(outItem))
		C.weaveffi_free_string(outItem)
	}
	return goResult, nil
}

// Count: Return the number of live entries in the store
func (s *Store) Count() int64 {
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_Store_count(s.ptr, &cErr)
	wvTrap(&cErr)
	return int64(result)
}

// Clear: Drop every entry from the store
func (s *Store) Clear() {
	var cErr C.weaveffi_error
	C.weaveffi_kv_Store_clear(s.ptr, &cErr)
	wvTrap(&cErr)
}

type wvOutcomeKvStoreCompact struct {
	val int64
	err error
}

//export goWv_weaveffi_kv_Store_compact_callback
func goWv_weaveffi_kv_Store_compact_callback(context unsafe.Pointer, err *C.weaveffi_error, result C.int64_t) {
	v := wvCallbackTake(uint64(uintptr(context)))
	if v == nil {
		return
	}
	ch := v.(chan wvOutcomeKvStoreCompact)
	if err != nil && err.code != 0 {
		ch <- wvOutcomeKvStoreCompact{err: wvMapKv(wvTakeError(err))}
		return
	}
	ch <- wvOutcomeKvStoreCompact{val: int64(result)}
}

// Compact: Reclaim space asynchronously; returns the number of bytes reclaimed
// Blocks until the async producer completes.
func (s *Store) Compact() (int64, error) {
	ch := make(chan wvOutcomeKvStoreCompact, 1)
	ctxID := wvCallbackStore(ch)
	C.weaveffi_kv_Store_compact_async(s.ptr, nil, C.weaveffi_kv_Store_compact_callback(unsafe.Pointer(C.goWv_weaveffi_kv_Store_compact_callback)), unsafe.Pointer(uintptr(ctxID)))
	outcome := <-ch
	if outcome.err != nil {
		return 0, outcome.err
	}
	return outcome.val, nil
}

// LegacyPut: Legacy single-shot put kept for compatibility
// Deprecated: use put() with explicit kind
func (s *Store) LegacyPut(key string, value []byte) (bool, error) {
	cKey := C.CString(key)
	defer C.free(unsafe.Pointer(cKey))
	var cValuePtr *C.uint8_t
	cValueLen := C.size_t(len(value))
	if len(value) > 0 {
		cValuePtr = (*C.uint8_t)(unsafe.Pointer(&value[0]))
	}
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_Store_legacy_put(s.ptr, cKey, cValuePtr, cValueLen, &cErr)
	if cErr.code != 0 {
		return false, wvMapKv(wvTakeError(&cErr))
	}
	return cToBool(result), nil
}

// StoreDefaultCapacity: The largest number of live entries one store will hold
func StoreDefaultCapacity() int64 {
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_Store_default_capacity(&cErr)
	wvTrap(&cErr)
	return int64(result)
}

func (s *Store) Close() {
	if s.ptr != nil {
		C.weaveffi_kv_Store_destroy(s.ptr)
		s.ptr = nil
	}
}

//export goWv_weaveffi_kv_OnEvict_fn
func goWv_weaveffi_kv_OnEvict_fn(key *C.char, context unsafe.Pointer) {
	v := wvCallbackLoad(uint64(uintptr(context)))
	if v == nil {
		return
	}
	cb := v.(func(key string))
	arg0 := ""
	if key != nil {
		arg0 = C.GoString(key)
	}
	cb(arg0)
}

// RegisterEvictionListener: Subscribe to per-key eviction notifications
// Returns a subscription id for UnregisterEvictionListener.
func RegisterEvictionListener(callback func(key string)) uint64 {
	ctxID := wvCallbackStore(callback)
	id := uint64(C.weaveffi_kv_register_eviction_listener(C.weaveffi_kv_OnEvict_fn(unsafe.Pointer(C.goWv_weaveffi_kv_OnEvict_fn)), unsafe.Pointer(uintptr(ctxID))))
	wvCallbackMu.Lock()
	wvListenerCtx[id] = ctxID
	wvCallbackMu.Unlock()
	return id
}

// UnregisterEvictionListener unregisters a listener previously registered with RegisterEvictionListener.
func UnregisterEvictionListener(id uint64) {
	C.weaveffi_kv_unregister_eviction_listener(C.uint64_t(id))
	wvCallbackMu.Lock()
	ctxID, ok := wvListenerCtx[id]
	delete(wvListenerCtx, id)
	wvCallbackMu.Unlock()
	if ok {
		wvCallbackDelete(ctxID)
	}
}

// Stats: Aggregate store statistics
type Stats struct {
	ptr *C.weaveffi_kv_stats_Stats
}

// TotalEntries: Number of live entries
func (s *Stats) TotalEntries() int64 {
	return int64(C.weaveffi_kv_stats_Stats_get_total_entries(s.ptr))
}

// TotalBytes: Sum of all value byte lengths
func (s *Stats) TotalBytes() int64 {
	return int64(C.weaveffi_kv_stats_Stats_get_total_bytes(s.ptr))
}

// ExpiredEntries: Number of entries past their TTL but not yet evicted
func (s *Stats) ExpiredEntries() int64 {
	return int64(C.weaveffi_kv_stats_Stats_get_expired_entries(s.ptr))
}

func (s *Stats) Close() {
	if s.ptr != nil {
		C.weaveffi_kv_stats_Stats_destroy(s.ptr)
		s.ptr = nil
	}
}

// GetStats: Snapshot the current store statistics
func GetStats(store *Store) (*Stats, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_stats_get_stats(store.ptr, &cErr)
	if cErr.code != 0 {
		return nil, wvMapKv(wvTakeError(&cErr))
	}
	return &Stats{ptr: result}, nil
}


