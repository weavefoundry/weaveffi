	if result == nil {
		return nil
	}
	return C.GoBytes(unsafe.Pointer(result), C.int(cOutLen))
}

// CreatedAt: Unix-timestamp seconds when the entry was created
func (s *Entry) CreatedAt() int64 {
	return int64(C.weaveffi_kv_Entry_get_created_at(s.ptr))
}

// ExpiresAt: Optional unix-timestamp seconds at which the entry expires
func (s *Entry) ExpiresAt() *int64 {
	cVal := C.weaveffi_kv_Entry_get_expires_at(s.ptr)
	if cVal == nil {
		return nil
	}
	v := int64(*cVal)
	return &v
}

// Tags: Free-form labels attached to the entry
func (s *Entry) Tags() []string {
	var cOutLen C.size_t
	result := C.weaveffi_kv_Entry_get_tags(s.ptr, &cOutLen)
	count := int(cOutLen)
	goResult := make([]string, count)
	if count > 0 && result != nil {
		for i, v := range unsafe.Slice((**C.char)(unsafe.Pointer(result)), count) {
			goResult[i] = C.GoString(v)
		}
	}
	return goResult
}

// Metadata: Arbitrary string-valued metadata pairs
func (s *Entry) Metadata() map[string]string {
	var cMapKeys **C.char
	var cMapVals **C.char
	var cOutLen C.size_t
	C.weaveffi_kv_Entry_get_metadata(s.ptr, &cMapKeys, &cMapVals, &cOutLen)
	count := int(cOutLen)
	goResult := make(map[string]string, count)
	if count > 0 && cMapKeys != nil && cMapVals != nil {
		keySlice := unsafe.Slice(cMapKeys, count)
		valSlice := unsafe.Slice(cMapVals, count)
		for i := 0; i < count; i++ {
			goResult[C.GoString(keySlice[i])] = C.GoString(valSlice[i])
		}
	}
	return goResult
}

func (s *Entry) Close() {
	if s.ptr != nil {
		C.weaveffi_kv_Entry_destroy(s.ptr)
		s.ptr = nil
	}
}

