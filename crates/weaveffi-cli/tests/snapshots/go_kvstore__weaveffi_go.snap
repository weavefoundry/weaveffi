// KvListKeys: Stream every key, optionally filtered by a prefix
func KvListKeys(store *Store, prefix *string) ([]string, error) {
	var cPrefix *C.char
	if prefix != nil {
		cPrefix = C.CString(*prefix)
		defer C.free(unsafe.Pointer(cPrefix))
	}
	var cErr C.weaveffi_error
	it := C.weaveffi_kv_list_keys(store.ptr, cPrefix, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	defer C.weaveffi_kv_ListKeysIterator_destroy(it)
	goResult := []string{}
	for {
		var outItem *C.char
		var iterErr C.weaveffi_error
		if C.weaveffi_kv_ListKeysIterator_next(it, &outItem, &iterErr) == 0 {
			break
		}
		if iterErr.code != 0 {
			goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(iterErr.message), int(iterErr.code))
			C.weaveffi_error_clear(&iterErr)
			return nil, goErr
		}
		goResult = append(goResult, C.GoString(outItem))
		C.weaveffi_free_string(outItem)
	}
	return goResult, nil
}

// KvCount: Return the number of live entries in the store
func KvCount(store *Store) (int64, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_count(store.ptr, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return 0, goErr
	}
	return int64(result), nil
}

// KvClear: Drop every entry from the store
func KvClear(store *Store) error {
	var cErr C.weaveffi_error
	C.weaveffi_kv_clear(store.ptr, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return goErr
	}
	return nil
}

type wvOutcomeKvCompactAsync struct {
	val int64
	err error
}

//export goWv_weaveffi_kv_compact_async_callback
func goWv_weaveffi_kv_compact_async_callback(context unsafe.Pointer, err *C.weaveffi_error, result C.int64_t) {
	v := wvCallbackTake(uint64(uintptr(context)))
	if v == nil {
		return
	}
	ch := v.(chan wvOutcomeKvCompactAsync)
	if err != nil && err.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(err.message), int(err.code))
		C.weaveffi_error_clear(err)
		ch <- wvOutcomeKvCompactAsync{err: goErr}
		return
	}
	ch <- wvOutcomeKvCompactAsync{val: int64(result)}
}

// KvCompactAsync: Reclaim space asynchronously; returns the number of bytes reclaimed
// Blocks until the async producer completes.
func KvCompactAsync(store *Store) (int64, error) {
	ch := make(chan wvOutcomeKvCompactAsync, 1)
	ctxID := wvCallbackStore(ch)
	C.weaveffi_kv_compact_async_async(store.ptr, nil, C.weaveffi_kv_compact_async_callback(unsafe.Pointer(C.goWv_weaveffi_kv_compact_async_callback)), unsafe.Pointer(uintptr(ctxID)))
	outcome := <-ch
	if outcome.err != nil {
		return 0, outcome.err
	}
	return outcome.val, nil
}

// KvLegacyPut: Legacy single-shot put kept for compatibility
// Deprecated: use put() with explicit kind
func KvLegacyPut(store *Store, key string, value []byte) (bool, error) {
	cKey := C.CString(key)
	defer C.free(unsafe.Pointer(cKey))
	var cValuePtr *C.uint8_t
	cValueLen := C.size_t(len(value))
	if len(value) > 0 {
		cValuePtr = (*C.uint8_t)(unsafe.Pointer(&value[0]))
	}
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_legacy_put(store.ptr, cKey, cValuePtr, cValueLen, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return false, goErr
	}
	return cToBool(result), nil
}

// Stats: Aggregate store statistics
type Stats struct {
	ptr *C.weaveffi_kv_stats_Stats
}

// TotalEntries: Number of live entries
func (s *Stats) TotalEntries() int64 {
	return int64(C.weaveffi_kv_stats_Stats_get_total_entries(s.ptr))
}

// TotalBytes: Sum of all value byte lengths
func (s *Stats) TotalBytes() int64 {
	return int64(C.weaveffi_kv_stats_Stats_get_total_bytes(s.ptr))
}

// ExpiredEntries: Number of entries past their TTL but not yet evicted
func (s *Stats) ExpiredEntries() int64 {
	return int64(C.weaveffi_kv_stats_Stats_get_expired_entries(s.ptr))
}

func (s *Stats) Close() {
	if s.ptr != nil {
		C.weaveffi_kv_stats_Stats_destroy(s.ptr)
		s.ptr = nil
	}
}

// KvStatsGetStats: Snapshot the current store statistics
func KvStatsGetStats(store *Store) (*Stats, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_stats_get_stats(store.ptr, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	return &Stats{ptr: result}, nil
}


