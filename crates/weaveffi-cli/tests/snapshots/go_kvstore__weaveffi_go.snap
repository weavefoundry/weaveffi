package weaveffi

/*
#cgo LDFLAGS: -lweaveffi
#include "weaveffi.h"
#include <stdlib.h>
*/
import "C"

import (
	"fmt"
	"unsafe"
)

func boolToC(b bool) C._Bool {
	if b {
		return 1
	}
	return 0
}

func cToBool(b C._Bool) bool {
	return b != 0
}

// EntryKind: Persistence semantics applied to a stored entry
type EntryKind int32

const (
	// EntryKindVolatile: In-memory only; lost on close
	EntryKindVolatile EntryKind = 0
	// EntryKindPersistent: Flushed to durable storage
	EntryKindPersistent EntryKind = 1
	// EntryKindEncrypted: Persistent and encrypted at rest
	EntryKindEncrypted EntryKind = 2
)

// Store: Opaque key-value store handle target type
type Store struct {
	ptr *C.weaveffi_kv_Store
}

// Id: Internal store identifier
func (s *Store) Id() int64 {
	return int64(C.weaveffi_kv_Store_get_id(s.ptr))
}

func (s *Store) Close() {
	if s.ptr != nil {
		C.weaveffi_kv_Store_destroy(s.ptr)
		s.ptr = nil
	}
}

// Entry: A single key-value entry persisted in the store
type Entry struct {
	ptr *C.weaveffi_kv_Entry
}

// Id: Stable monotonic identifier assigned on insert
func (s *Entry) Id() int64 {
	return int64(C.weaveffi_kv_Entry_get_id(s.ptr))
}

// Key: UTF-8 lookup key
func (s *Entry) Key() string {
	return C.GoString(C.weaveffi_kv_Entry_get_key(s.ptr))
}

// Value: Opaque binary payload
func (s *Entry) Value() []byte {
	return []byte(C.weaveffi_kv_Entry_get_value(s.ptr))
}

// CreatedAt: Unix-timestamp seconds when the entry was created
func (s *Entry) CreatedAt() int64 {
	return int64(C.weaveffi_kv_Entry_get_created_at(s.ptr))
}

// ExpiresAt: Optional unix-timestamp seconds at which the entry expires
func (s *Entry) ExpiresAt() *int64 {
	cVal := C.weaveffi_kv_Entry_get_expires_at(s.ptr)
	if cVal == nil {
		return nil
	}
	v := int64(*cVal)
	return &v
}

// Tags: Free-form labels attached to the entry
func (s *Entry) Tags() []string {
	return []string(C.weaveffi_kv_Entry_get_tags(s.ptr))
}

// Metadata: Arbitrary string-valued metadata pairs
func (s *Entry) Metadata() map[string]string {
	return map[string]string(C.weaveffi_kv_Entry_get_metadata(s.ptr))
}

func (s *Entry) Close() {
	if s.ptr != nil {
		C.weaveffi_kv_Entry_destroy(s.ptr)
		s.ptr = nil
	}
}

// EntryBuilder: A single key-value entry persisted in the store
type EntryBuilder struct {
	fields map[string]interface{}
}

func NewEntryBuilder() *EntryBuilder {
	return &EntryBuilder{fields: make(map[string]interface{})}
}

// WithId: Stable monotonic identifier assigned on insert
func (b *EntryBuilder) WithId(value int64) *EntryBuilder {
	b.fields["id"] = value
	return b
}

// WithKey: UTF-8 lookup key
func (b *EntryBuilder) WithKey(value string) *EntryBuilder {
	b.fields["key"] = value
	return b
}

// WithValue: Opaque binary payload
func (b *EntryBuilder) WithValue(value []byte) *EntryBuilder {
	b.fields["value"] = value
	return b
}

// WithCreatedAt: Unix-timestamp seconds when the entry was created
func (b *EntryBuilder) WithCreatedAt(value int64) *EntryBuilder {
	b.fields["created_at"] = value
	return b
}

// WithExpiresAt: Optional unix-timestamp seconds at which the entry expires
func (b *EntryBuilder) WithExpiresAt(value *int64) *EntryBuilder {
	b.fields["expires_at"] = value
	return b
}

// WithTags: Free-form labels attached to the entry
func (b *EntryBuilder) WithTags(value []string) *EntryBuilder {
	b.fields["tags"] = value
	return b
}

// WithMetadata: Arbitrary string-valued metadata pairs
func (b *EntryBuilder) WithMetadata(value map[string]string) *EntryBuilder {
	b.fields["metadata"] = value
	return b
}

// KvOpenStore: Open (or create) a store backed by the given filesystem path
func KvOpenStore(path string) (*Store, error) {
	cPath := C.CString(path)
	defer C.free(unsafe.Pointer(cPath))
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_open_store(cPath, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	return &Store{ptr: result}, nil
}

// KvCloseStore: Close the store and release all in-memory resources
func KvCloseStore(store *Store) error {
	var cErr C.weaveffi_error
	C.weaveffi_kv_close_store(store.ptr, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return goErr
	}
	return nil
}

// KvPut: Insert or replace a value, returning true on success
func KvPut(store *Store, key string, value []byte, kind EntryKind, ttlSeconds *int64) (bool, error) {
	cKey := C.CString(key)
	defer C.free(unsafe.Pointer(cKey))
	var cValuePtr *C.uint8_t
	cValueLen := C.size_t(len(value))
	if len(value) > 0 {
		cValuePtr = (*C.uint8_t)(unsafe.Pointer(&value[0]))
	}
	var cTtlSeconds *C.int64_t
	if ttlSeconds != nil {
		tmp := C.int64_t(*ttlSeconds)
		cTtlSeconds = &tmp
	}
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_put(store.ptr, cKey, cValuePtr, cValueLen, C.weaveffi_kv_EntryKind(kind), cTtlSeconds, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return false, goErr
	}
	return cToBool(result), nil
}

// KvGet: Look up an entry by key; returns null if missing or expired
func KvGet(store *Store, key string) (*Entry, error) {
	cKey := C.CString(key)
	defer C.free(unsafe.Pointer(cKey))
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_get(store.ptr, cKey, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	if result == nil {
		return nil, nil
	}
	return &Entry{ptr: result}, nil
}

// KvDelete: Remove the entry for the given key, returning true if it existed
func KvDelete(store *Store, key string) (bool, error) {
	cKey := C.CString(key)
	defer C.free(unsafe.Pointer(cKey))
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_delete(store.ptr, cKey, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return false, goErr
	}
	return cToBool(result), nil
}

// KvListKeys: Stream every key, optionally filtered by a prefix
func KvListKeys(store *Store, prefix *string) ([]string, error) {
	var cPrefix *C.char
	if prefix != nil {
		cPrefix = C.CString(*prefix)
		defer C.free(unsafe.Pointer(cPrefix))
	}
	var cOutLen C.size_t
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_list_keys(store.ptr, cPrefix, &cOutLen, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	count := int(cOutLen)
	if count == 0 || result == nil {
		return nil, nil
	}
	goResult := make([]string, count)
	cSlice := unsafe.Slice((**C.char)(unsafe.Pointer(result)), count)
	for i, v := range cSlice {
		goResult[i] = C.GoString(v)
	}
	return goResult, nil
}

// KvCount: Return the number of live entries in the store
func KvCount(store *Store) (int64, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_count(store.ptr, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return 0, goErr
	}
	return int64(result), nil
}

// KvClear: Drop every entry from the store
func KvClear(store *Store) error {
	var cErr C.weaveffi_error
	C.weaveffi_kv_clear(store.ptr, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return goErr
	}
	return nil
}

// KvLegacyPut: Legacy single-shot put kept for compatibility
// Deprecated: use put() with explicit kind
func KvLegacyPut(store *Store, key string, value []byte) (bool, error) {
	cKey := C.CString(key)
	defer C.free(unsafe.Pointer(cKey))
	var cValuePtr *C.uint8_t
	cValueLen := C.size_t(len(value))
	if len(value) > 0 {
		cValuePtr = (*C.uint8_t)(unsafe.Pointer(&value[0]))
	}
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_legacy_put(store.ptr, cKey, cValuePtr, cValueLen, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return false, goErr
	}
	return cToBool(result), nil
}

// Stats: Aggregate store statistics
type Stats struct {
	ptr *C.weaveffi_kv_stats_Stats
}

// TotalEntries: Number of live entries
func (s *Stats) TotalEntries() int64 {
	return int64(C.weaveffi_kv_stats_Stats_get_total_entries(s.ptr))
}

// TotalBytes: Sum of all value byte lengths
func (s *Stats) TotalBytes() int64 {
	return int64(C.weaveffi_kv_stats_Stats_get_total_bytes(s.ptr))
}

// ExpiredEntries: Number of entries past their TTL but not yet evicted
func (s *Stats) ExpiredEntries() int64 {
	return int64(C.weaveffi_kv_stats_Stats_get_expired_entries(s.ptr))
}

func (s *Stats) Close() {
	if s.ptr != nil {
		C.weaveffi_kv_stats_Stats_destroy(s.ptr)
		s.ptr = nil
	}
}

// KvStatsGetStats: Snapshot the current store statistics
func KvStatsGetStats(store *Store) (*Stats, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_kv_stats_get_stats(store.ptr, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	return &Stats{ptr: result}, nil
}
