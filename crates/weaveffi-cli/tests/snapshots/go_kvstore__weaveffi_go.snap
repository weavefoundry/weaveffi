func wvCallbackStore(v interface{}) uint64 {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	wvCallbackSeq++
	wvCallbacks[wvCallbackSeq] = v
	return wvCallbackSeq
}

func wvCallbackLoad(id uint64) interface{} {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	return wvCallbacks[id]
}

func wvCallbackTake(id uint64) interface{} {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	v := wvCallbacks[id]
	delete(wvCallbacks, id)
	return v
}

func wvCallbackDelete(id uint64) {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	delete(wvCallbacks, id)
}

// EntryKind: Persistence semantics applied to a stored entry
type EntryKind int32

const (
	// EntryKindVolatile: In-memory only; lost on close
	EntryKindVolatile EntryKind = 0
	// EntryKindPersistent: Flushed to durable storage
	EntryKindPersistent EntryKind = 1
	// EntryKindEncrypted: Persistent and encrypted at rest
	EntryKindEncrypted EntryKind = 2
)

// Store: Opaque key-value store handle target type
type Store struct {
	ptr *C.weaveffi_kv_Store
}

// Id: Internal store identifier
func (s *Store) Id() int64 {
	return int64(C.weaveffi_kv_Store_get_id(s.ptr))
}

func (s *Store) Close() {
	if s.ptr != nil {
		C.weaveffi_kv_Store_destroy(s.ptr)
		s.ptr = nil
	}
}

// Entry: A single key-value entry persisted in the store
type Entry struct {
