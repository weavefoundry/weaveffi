import "C"

import (
	"fmt"
	"sync"
	"unsafe"
)

func boolToC(b bool) C._Bool {
	return C._Bool(b)
}

func cToBool(b C._Bool) bool {
	return bool(b)
}

// WeaveFFIError reports a failure crossing the C boundary that no typed
// error domain claims: an unknown code, a marshalling failure, or a
// producer panic.
type WeaveFFIError struct {
	// Code is the numeric ABI error code.
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *WeaveFFIError) Error() string {
	return fmt.Sprintf("weaveffi: %s (code %d)", e.Message, e.Code)
}

// wvTakeError reads and clears a non-zero C error slot, returning its
// code and message.
func wvTakeError(cErr *C.weaveffi_error) (int32, string) {
	code := int32(cErr.code)
	msg := ""
	if cErr.message != nil {
		msg = C.GoString(cErr.message)
	}
	C.weaveffi_error_clear(cErr)
	return code, msg
}

func wvBrandError(code int32, message string) error {
	return &WeaveFFIError{Code: code, Message: message}
}

// wvTrap panics when the C error slot reports a failure. Non-throwing
// wrappers check their slot with it: a non-zero code there can only be
// a producer panic or a marshalling failure.
func wvTrap(cErr *C.weaveffi_error) {
	if cErr.code != 0 {
		code, msg := wvTakeError(cErr)
		panic(fmt.Sprintf("weaveffi: %s (code %d)", msg, code))
	}
}

var (
	wvCallbackMu  sync.Mutex
	wvCallbackSeq uint64
	wvCallbacks   = map[uint64]interface{}{}
	// Subscription id -> registry id, so unregister can release the Go callback.
	wvListenerCtx = map[uint64]uint64{}
)

func wvCallbackStore(v interface{}) uint64 {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	wvCallbackSeq++
	wvCallbacks[wvCallbackSeq] = v
	return wvCallbackSeq
}

func wvCallbackLoad(id uint64) interface{} {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	return wvCallbacks[id]
}

func wvCallbackTake(id uint64) interface{} {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	v := wvCallbacks[id]
	delete(wvCallbacks, id)
	return v
}

func wvCallbackDelete(id uint64) {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	delete(wvCallbacks, id)
}

// KvError is a typed error reported by the `kv` module.
type KvError struct {
	// Code is the numeric ABI error code (one of the KvError constants).
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *KvError) Error() string {
	return fmt.Sprintf("kv: %s (code %d)", e.Message, e.Code)
}

// KvError codes.
const (
	// KvErrorKeyNotFound: No entry exists for the requested key
	KvErrorKeyNotFound int32 = 1001
	// KvErrorExpired: The entry exists but its TTL has elapsed
	KvErrorExpired int32 = 1002
	// KvErrorStoreFull: The store has reached its capacity limit
	KvErrorStoreFull int32 = 1003
	// KvErrorIoError: Underlying storage reported an I/O failure
	KvErrorIoError int32 = 1004
)

// wvMapKv converts a non-zero code from the `kv` domain into a
// *KvError, falling back to the generic *WeaveFFIError for unknown codes.
func wvMapKv(code int32, message string) error {
	switch code {
	case KvErrorKeyNotFound:
		if message == "" {
			message = "key not found"
		}
		return &KvError{Code: code, Message: message}
	case KvErrorExpired:
		if message == "" {
			message = "entry expired"
		}
		return &KvError{Code: code, Message: message}
	case KvErrorStoreFull:
		if message == "" {
			message = "store has reached capacity"
		}
		return &KvError{Code: code, Message: message}
	case KvErrorIoError:
		if message == "" {
			message = "I/O failure"
		}
		return &KvError{Code: code, Message: message}
	default:
		return wvBrandError(code, message)
	}
}

// EntryKind: Persistence semantics applied to a stored entry
type EntryKind int32

const (
	// EntryKindVolatile: In-memory only; lost on close
	EntryKindVolatile EntryKind = 0
	// EntryKindPersistent: Flushed to durable storage
	EntryKindPersistent EntryKind = 1
	// EntryKindEncrypted: Persistent and encrypted at rest
	EntryKindEncrypted EntryKind = 2
)

// Entry: A single key-value entry persisted in the store
type Entry struct {
	ptr *C.weaveffi_kv_Entry
}

// Id: Stable monotonic identifier assigned on insert
func (s *Entry) Id() int64 {
	return int64(C.weaveffi_kv_Entry_get_id(s.ptr))
}

// Key: UTF-8 lookup key
func (s *Entry) Key() string {
	return C.GoString(C.weaveffi_kv_Entry_get_key(s.ptr))
}

// Value: Opaque binary payload
func (s *Entry) Value() []byte {
	var cOutLen C.size_t
	result := C.weaveffi_kv_Entry_get_value(s.ptr, &cOutLen)
	if result == nil {
		return nil
	}
	return C.GoBytes(unsafe.Pointer(result), C.int(cOutLen))
}

// CreatedAt: Unix-timestamp seconds when the entry was created
func (s *Entry) CreatedAt() int64 {
	return int64(C.weaveffi_kv_Entry_get_created_at(s.ptr))
}

// ExpiresAt: Optional unix-timestamp seconds at which the entry expires
func (s *Entry) ExpiresAt() *int64 {
	cVal := C.weaveffi_kv_Entry_get_expires_at(s.ptr)
	if cVal == nil {
		return nil
	}
	v := int64(*cVal)
	return &v
}

// Tags: Free-form labels attached to the entry
func (s *Entry) Tags() []string {
	var cOutLen C.size_t
	result := C.weaveffi_kv_Entry_get_tags(s.ptr, &cOutLen)
	count := int(cOutLen)
	goResult := make([]string, count)
	if count > 0 && result != nil {
		for i, v := range unsafe.Slice((**C.char)(unsafe.Pointer(result)), count) {
			goResult[i] = C.GoString(v)
		}
	}
	return goResult
}

// Metadata: Arbitrary string-valued metadata pairs
func (s *Entry) Metadata() map[string]string {
	var cMapKeys **C.char
	var cMapVals **C.char
	var cOutLen C.size_t
	C.weaveffi_kv_Entry_get_metadata(s.ptr, &cMapKeys, &cMapVals, &cOutLen)
	count := int(cOutLen)
	goResult := make(map[string]string, count)
	if count > 0 && cMapKeys != nil && cMapVals != nil {
		keySlice := unsafe.Slice(cMapKeys, count)
		valSlice := unsafe.Slice(cMapVals, count)
		for i := 0; i < count; i++ {
			goResult[C.GoString(keySlice[i])] = C.GoString(valSlice[i])
		}
	}
	return goResult
}

func (s *Entry) Close() {
	if s.ptr != nil {
		C.weaveffi_kv_Entry_destroy(s.ptr)
		s.ptr = nil
	}
}

// EntryBuilder: A single key-value entry persisted in the store
