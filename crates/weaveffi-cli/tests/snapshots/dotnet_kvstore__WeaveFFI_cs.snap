        }

        /// <summary>Stream every key, optionally filtered by a prefix</summary>
        public static IEnumerable<string> ListKeys(Store store, string? prefix)
        {
            var err = new WeaveffiError();
            var prefixPtr = prefix != null ? Marshal.StringToCoTaskMemUTF8(prefix) : IntPtr.Zero;
            try
            {
                var result = NativeMethods.weaveffi_kv_list_keys(store.Handle, prefixPtr, out var outLen, ref err);
                WeaveffiError.Check(err);
                if (result == IntPtr.Zero) return Array.Empty<string>();
                return Array.Empty<string>();
            }
            finally
            {
                if (prefixPtr != IntPtr.Zero) Marshal.FreeCoTaskMem(prefixPtr);
            }
        }

