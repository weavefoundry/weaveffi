    public static class Kv
    {
        private static readonly object _listenerLock = new object();
        // Live listener delegates by subscription id. Holding the delegate
        // here keeps its native thunk alive until unregistered; without this
        // the GC could collect a delegate the producer still calls.
        private static readonly Dictionary<ulong, Delegate> _listenerRefs = new Dictionary<ulong, Delegate>();

        /// <summary>Subscribe to per-key eviction notifications</summary>
        /// <returns>A subscription id for KvUnregisterEvictionListener().</returns>
        public static ulong KvRegisterEvictionListener(Action<string> callback)
        {
            NativeMethods.Cb_weaveffi_kv_OnEvict_fn trampoline = (key, context) =>
            {
                callback(Marshal.PtrToStringUTF8(key) ?? "");
            };
            ulong id;
            lock (_listenerLock)
            {
                id = NativeMethods.weaveffi_kv_register_eviction_listener(trampoline, IntPtr.Zero);
                _listenerRefs[id] = trampoline;
            }
            return id;
        }

        /// <summary>Unregisters a listener previously registered with KvRegisterEvictionListener().</summary>
        public static void KvUnregisterEvictionListener(ulong id)
        {
            NativeMethods.weaveffi_kv_unregister_eviction_listener(id);
            lock (_listenerLock)
            {
                _listenerRefs.Remove(id);
            }
        }

        /// <summary>Open (or create) a store backed by the given filesystem path</summary>
        public static Store KvOpenStore(string path)
        {
            var err = new WeaveFFIError();
            var pathPtr = Marshal.StringToCoTaskMemUTF8(path);
            try
            {
                var result = NativeMethods.weaveffi_kv_open_store(pathPtr, ref err);
                WeaveFFIError.Check(err);
                return new Store(result);
            }
            finally
            {
                Marshal.FreeCoTaskMem(pathPtr);
            }
        }

        /// <summary>Close the store and release all in-memory resources</summary>
        public static void KvCloseStore(Store store)
        {
            var err = new WeaveFFIError();
            NativeMethods.weaveffi_kv_close_store(store.Handle, ref err);
            WeaveFFIError.Check(err);
        }

        /// <summary>Insert or replace a value, returning true on success</summary>
        public static bool KvPut(Store store, string key, byte[] value, EntryKind kind, long? ttl_seconds)
        {
            var err = new WeaveFFIError();
            var keyPtr = Marshal.StringToCoTaskMemUTF8(key);
            var valuePin = GCHandle.Alloc(value, GCHandleType.Pinned);
            var ttl_secondsPtr = IntPtr.Zero;
            if (ttl_seconds.HasValue)
            {
                ttl_secondsPtr = Marshal.AllocHGlobal(sizeof(long));
                Marshal.WriteInt64(ttl_secondsPtr, ttl_seconds.Value);
            }
            try
            {
                var result = NativeMethods.weaveffi_kv_put(store.Handle, keyPtr, valuePin.AddrOfPinnedObject(), (UIntPtr)value.Length, (int)kind, ttl_secondsPtr, ref err);
                WeaveFFIError.Check(err);
                return result != 0;
            }
            finally
            {
                Marshal.FreeCoTaskMem(keyPtr);
                valuePin.Free();
                if (ttl_secondsPtr != IntPtr.Zero) Marshal.FreeHGlobal(ttl_secondsPtr);
            }
        }

        /// <summary>Look up an entry by key; returns null if missing or expired</summary>
        public static Entry? KvGet(Store store, string key)
        {
            var err = new WeaveFFIError();
            var keyPtr = Marshal.StringToCoTaskMemUTF8(key);
            try
            {
                var result = NativeMethods.weaveffi_kv_get(store.Handle, keyPtr, ref err);
                WeaveFFIError.Check(err);
                return result == IntPtr.Zero ? null : new Entry(result);
            }
            finally
