        /// <summary>Stream every key, optionally filtered by a prefix</summary>
        public static IEnumerable<string> KvListKeys(Store store, string? prefix)
        {
            var err = new WeaveFFIError();
            var prefixPtr = prefix != null ? Marshal.StringToCoTaskMemUTF8(prefix) : IntPtr.Zero;
            try
            {
                var iter = NativeMethods.weaveffi_kv_list_keys(store.Handle, prefixPtr, ref err);
                WeaveFFIError.Check(err);
                return EnumerateKvListKeys(iter);
            }
            finally
            {
                if (prefixPtr != IntPtr.Zero) Marshal.FreeCoTaskMem(prefixPtr);
            }
        }

        private static IEnumerable<string> EnumerateKvListKeys(IntPtr iter)
        {
            try
            {
                while (true)
                {
                    var iterErr = new WeaveFFIError();
                    if (NativeMethods.weaveffi_kv_ListKeysIterator_next(iter, out var out_item, ref iterErr) == 0)
                    {
                        WeaveFFIError.Check(iterErr);
                        yield break;
                    }
                    WeaveFFIError.Check(iterErr);
                    var item = Marshal.PtrToStringUTF8(out_item) ?? "";
                    NativeMethods.weaveffi_free_string(out_item);
                    yield return item;
                }
            }
            finally
            {
                NativeMethods.weaveffi_kv_ListKeysIterator_destroy(iter);
            }
        }

