        /// <summary>Reclaim space asynchronously; returns the number of bytes reclaimed</summary>
        public static async Task<long> CompactAsync(Store store)
        {
            var tcs = new TaskCompletionSource<long>(TaskCreationOptions.RunContinuationsAsynchronously);
            NativeMethods.AsyncCb_weaveffi_kv_compact_async callback = (context, err, result) =>
            {
                if (err != IntPtr.Zero)
                {
                    var wErr = Marshal.PtrToStructure<WeaveffiError>(err);
                    if (wErr.Code != 0)
                    {
                        var msg = Marshal.PtrToStringUTF8(wErr.Message) ?? "";
                        tcs.SetException(new WeaveffiException(wErr.Code, msg));
                        return;
                    }
                }
                tcs.SetResult(result);
            };
            var gcHandle = GCHandle.Alloc(callback);
            NativeMethods.weaveffi_kv_compact_async_async(store.Handle, IntPtr.Zero, callback, IntPtr.Zero);
            return await tcs.Task;
        }

        /// <summary>Legacy single-shot put kept for compatibility</summary>
        [Obsolete("use put() with explicit kind")]
        public static bool LegacyPut(Store store, string key, byte[] value)
        {
            var err = new WeaveffiError();
            var keyPtr = Marshal.StringToCoTaskMemUTF8(key);
            var valuePin = GCHandle.Alloc(value, GCHandleType.Pinned);
            try
            {
                var result = NativeMethods.weaveffi_kv_legacy_put(store.Handle, keyPtr, valuePin.AddrOfPinnedObject(), (UIntPtr)value.Length, ref err);
                WeaveffiError.Check(err);
                return result != 0;
            }
            finally
            {
                Marshal.FreeCoTaskMem(keyPtr);
                valuePin.Free();
            }
        }

