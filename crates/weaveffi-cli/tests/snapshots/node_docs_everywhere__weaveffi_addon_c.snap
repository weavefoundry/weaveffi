#include <node_api.h>
#include "weaveffi.h"
#include <stdlib.h>
#include <string.h>

typedef struct {
    napi_env env;
    napi_deferred deferred;
} weaveffi_napi_async_ctx;

static napi_value Napi_weaveffi_docs_create_document(napi_env env, napi_callback_info info) {
  size_t argc = 2;
  napi_value args[2];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  size_t title_len;
  napi_get_value_string_utf8(env, args[0], NULL, 0, &title_len);
  char* title = (char*)malloc(title_len + 1);
  napi_get_value_string_utf8(env, args[0], title, title_len + 1, &title_len);
  uint32_t tags_count;
  napi_get_array_length(env, args[1], &tags_count);
  const char** tags_arr = (const char**)malloc(sizeof(const char*) * (tags_count + 1));
  for (uint32_t tags_i = 0; tags_i < tags_count; tags_i++) {
    napi_value tags_el;
    napi_get_element(env, args[1], tags_i, &tags_el);
    size_t tags_sl;
    napi_get_value_string_utf8(env, tags_el, NULL, 0, &tags_sl);
    char* tags_s = (char*)malloc(tags_sl + 1);
    napi_get_value_string_utf8(env, tags_el, tags_s, tags_sl + 1, &tags_sl);
    tags_arr[tags_i] = tags_s;
  }
  weaveffi_error err = {0};
  weaveffi_docs_Document* result = weaveffi_docs_create_document(title, tags_arr, (size_t)tags_count, &err);
  free(title);
  for (uint32_t tags_j = 0; tags_j < tags_count; tags_j++) free((void*)tags_arr[tags_j]);
  free(tags_arr);
  if (err.code != 0) {
    napi_throw_error(env, NULL, err.message);
    weaveffi_error_clear(&err);
    return NULL;
  }
  napi_value ret;
  napi_create_int64(env, (int64_t)(intptr_t)result, &ret);
  return ret;
}

static napi_value Napi_weaveffi_docs_get_document(napi_env env, napi_callback_info info) {
  size_t argc = 1;
  napi_value args[1];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  int64_t id;
  napi_get_value_int64(env, args[0], &id);
  weaveffi_error err = {0};
  weaveffi_docs_Document* result = weaveffi_docs_get_document(id, &err);
  if (err.code != 0) {
    napi_throw_error(env, NULL, err.message);
    weaveffi_error_clear(&err);
    return NULL;
  }
  napi_value ret;
  if (result == NULL) {
    napi_get_null(env, &ret);
  } else {
    napi_create_int64(env, (int64_t)(intptr_t)result, &ret);
  }
  return ret;
}

static void weaveffi_docs_publish_async_napi_cb(void* context, weaveffi_error* err, bool result) {
    weaveffi_napi_async_ctx* ctx = (weaveffi_napi_async_ctx*)context;
    if (err != NULL && err->code != 0) {
        napi_value err_msg;
        napi_create_string_utf8(ctx->env, err->message, NAPI_AUTO_LENGTH, &err_msg);
        napi_reject_deferred(ctx->env, ctx->deferred, err_msg);
    } else {
        napi_value val;
        napi_get_boolean(ctx->env, result, &val);
        napi_resolve_deferred(ctx->env, ctx->deferred, val);
    }
    free(ctx);
}

static napi_value Napi_weaveffi_docs_publish_async(napi_env env, napi_callback_info info) {
  size_t argc = 1;
  napi_value args[1];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  int64_t id;
  napi_get_value_int64(env, args[0], &id);
  weaveffi_napi_async_ctx* ctx = (weaveffi_napi_async_ctx*)malloc(sizeof(weaveffi_napi_async_ctx));
  ctx->env = env;
  napi_value promise;
  napi_create_promise(env, &ctx->deferred, &promise);
  weaveffi_docs_publish_async_async(id, weaveffi_docs_publish_async_napi_cb, ctx);
  return promise;
}

static napi_value Init(napi_env env, napi_value exports) {
  napi_property_descriptor props[] = {
    { "create_document", NULL, Napi_weaveffi_docs_create_document, NULL, NULL, NULL, napi_default, NULL },
    { "get_document", NULL, Napi_weaveffi_docs_get_document, NULL, NULL, NULL, napi_default, NULL },
    { "publish_async", NULL, Napi_weaveffi_docs_publish_async, NULL, NULL, NULL, napi_default, NULL },
  };
  napi_define_properties(env, exports, 3, props);
  return exports;
}

NAPI_MODULE(NODE_GYP_MODULE_NAME, Init)
