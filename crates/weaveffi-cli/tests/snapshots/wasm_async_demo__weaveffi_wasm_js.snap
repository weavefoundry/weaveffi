// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

// WeaveFFI WASM bindings (auto-generated)
//
// Boundary conventions for a wasm32-unknown-unknown build:
//
//   Handles   -> i32 pointer into linear memory (0 = null/absent)
//   Enums     -> i32 discriminant value
//   i64/u64   -> JavaScript BigInt
//   Strings   -> NUL-terminated UTF-8 (const char*); a single i32 pointer
//   Bytes     -> i32 data pointer + i32 length (out_len for returns)
//   Optionals -> null handle / null pointer (0); scalars boxed by pointer

const _enc = new TextEncoder();
const _dec = new TextDecoder();

// Stage a JS string as a NUL-terminated C string in linear memory.
// Returns [ptr, size] (size includes the NUL); release with _free.
function _cstr(wasm, str) {
  const bytes = _enc.encode(str);
  const size = bytes.length + 1;
  const ptr = wasm.weaveffi_alloc(size);
  const mem = new Uint8Array(wasm.memory.buffer, ptr, size);
  mem.set(bytes);
  mem[bytes.length] = 0;
  return [ptr, size];
}

// Read a NUL-terminated C string (0 => null). Does not free.
function _readCStr(wasm, ptr) {
  if (ptr === 0) return null;
  const mem = new Uint8Array(wasm.memory.buffer);
  let end = ptr;
  while (mem[end] !== 0) end++;
  return _dec.decode(mem.subarray(ptr, end));
}

// Read then free a producer-owned C string.
function _takeCStr(wasm, ptr) {
  const s = _readCStr(wasm, ptr);
  if (ptr !== 0) wasm.weaveffi_free_string(ptr);
  return s;
}

// Decode a producer-owned array of `len` C strings at `base` (each
// freed); the array container itself is owned by the producer.
function _takeStrArray(wasm, base, len) {
  const out = [];
  if (base === 0) return out;
  const dv = new DataView(wasm.memory.buffer);
  const ptrs = [];
  for (let i = 0; i < len; i++) ptrs.push(dv.getUint32(base + i * 4, true));
  for (const p of ptrs) out.push(_takeCStr(wasm, p));
  return out;
}

// Allocate a zeroed {i32 code, i32 message} error slot.
function _allocErr(wasm) {
  const ptr = wasm.weaveffi_alloc(8);
  new Uint8Array(wasm.memory.buffer, ptr, 8).fill(0);
  return ptr;
}

// Throw (and free the slot) if the error slot carries a non-zero code.
function _checkErr(wasm, errPtr) {
  const dv = new DataView(wasm.memory.buffer);
  const code = dv.getInt32(errPtr, true);
  if (code !== 0) {
    const msgPtr = dv.getUint32(errPtr + 4, true);
    const msg = _readCStr(wasm, msgPtr) || '';
    wasm.weaveffi_error_clear(errPtr);
    wasm.weaveffi_dealloc(errPtr, 8);
    throw new Error(`WeaveFFI error ${code}: ${msg}`);
  }
}

// Release an error slot on the success path.
function _freeErr(wasm, errPtr) {
  wasm.weaveffi_dealloc(errPtr, 8);
}

// Throw if a borrowed (producer-owned) error carries a non-zero
// code. Used by async callbacks: the producer owns and frees the
// error struct, so the slot is read but never deallocated here.
function _checkErrRef(wasm, errPtr) {
  const dv = new DataView(wasm.memory.buffer);
  const code = dv.getInt32(errPtr, true);
  if (code === 0) return;
  const msgPtr = dv.getUint32(errPtr + 4, true);
  const msg = _readCStr(wasm, msgPtr) || '';
  throw new Error(`WeaveFFI error ${code}: ${msg}`);
}

function _registerTrampoline(table, paramTypes, handler) {
  const idx = table.grow(1);
  table.set(idx, new WebAssembly.Function(
    { parameters: paramTypes, results: [] },
    handler
  ));
  return idx;
}

class TaskResult {
  constructor(wasm, handle) {
    this._wasm = wasm;
    this._handle = handle;
  }
  get id() {
    const wasm = this._wasm;
    const _r = wasm.weaveffi_tasks_TaskResult_get_id(this._handle);
    return _r;
  }
  get value() {
    const wasm = this._wasm;
    const _r = wasm.weaveffi_tasks_TaskResult_get_value(this._handle);
    return _takeCStr(wasm, _r);
  }
  get success() {
    const wasm = this._wasm;
    const _r = wasm.weaveffi_tasks_TaskResult_get_success(this._handle);
    return _r !== 0;
  }
  static create(wasm, id, value, success) {
    const [a1_p, a1_s] = _cstr(wasm, value);
    const _err = _allocErr(wasm);
    const _r = wasm.weaveffi_tasks_TaskResult_create(BigInt(id), a1_p, success ? 1 : 0, _err);
    wasm.weaveffi_dealloc(a1_p, a1_s);
    _checkErr(wasm, _err);
    _freeErr(wasm, _err);
    return new TaskResult(wasm, _r);
  }
}

/**
 * Load a WeaveFFI WASM module from the given URL.
 *
 * @param {string} url - URL to the `.wasm` file.
 * @returns {Promise<Object>} The API bindings.
 *
 * Exported functions follow the C ABI naming convention:
 *   weaveffi_{module}_{function}(params...) -> result
 *
 * @example
 * const api = await loadWeaveffiWasm('lib.wasm');
 *
 * // Primitive: plain numbers in, number out.
 * const sum = api.math.add(1, 2);
 *
 * // Struct: returns a wrapper instance exposing field getters.
 * const person = api.contacts.create();
 * console.log(person.name);
 *
 * // Enum: pass the integer discriminant.
 * api.ui.set_color(0); // 0 = first variant
 *
 * // Optional: pass null to omit, a value to provide.
 * api.config.set_timeout(5000); // present
 * api.config.set_timeout(null); // absent
 *
 * // List/Map: pass arrays/objects; receive arrays/objects.
 * const names = api.data.all_names();
 */
export async function loadWeaveffiWasm(url) {
  const response = await fetch(url);
  const bytes = await response.arrayBuffer();
  const { instance } = await WebAssembly.instantiate(bytes, {});
  const wasm = instance.exports;

  let _nextCtxId = 1;
  const _asyncContexts = new Map();
  const _table = wasm.__indirect_function_table;

  function _asyncHandler(ctxId, errPtr, ...results) {
    const ctx = _asyncContexts.get(ctxId);
    if (!ctx) return;
    _asyncContexts.delete(ctxId);
    try {
      if (errPtr !== 0) _checkErrRef(wasm, errPtr);
      ctx.resolve(ctx.unwrap ? ctx.unwrap(wasm, ...results) : results[0]);
    } catch (e) {
      ctx.reject(e);
    }
  }

  const _cbPtr_i32_i32_i32 = _registerTrampoline(_table, ['i32', 'i32', 'i32'], _asyncHandler);
  const _cbPtr_i32_i32_i32_i32 = _registerTrampoline(_table, ['i32', 'i32', 'i32', 'i32'], _asyncHandler);

  return {
    _raw: wasm,
    tasks: {
      run_task(name) {
        return new Promise((resolve, reject) => {
          const ctxId = _nextCtxId++;
          _asyncContexts.set(ctxId, { resolve, reject, unwrap: (w, h) => new TaskResult(w, h) });
          const [a0_p, a0_s] = _cstr(wasm, name);
          wasm.weaveffi_tasks_run_task_async(a0_p, _cbPtr_i32_i32_i32, ctxId);
          wasm.weaveffi_dealloc(a0_p, a0_s);
        });
      },
      run_batch(names) {
        return new Promise((resolve, reject) => {
          const ctxId = _nextCtxId++;
          _asyncContexts.set(ctxId, { resolve, reject, unwrap: (w, base, len) => {
            const wasm = w;
            const _out = [];
            {
              const dv = new DataView(wasm.memory.buffer);
              for (let i = 0; i < len; i++) _out.push(new TaskResult(wasm, dv.getInt32(base + i * 4, true)));
            }
            return _out;
          } });
          const a0_arr = names || [];
          const a0_n = a0_arr.length;
          const a0_base = wasm.weaveffi_alloc(a0_n ? a0_n * 4 : 1);
          const a0_ep = [];
          for (let i = 0; i < a0_n; i++) a0_ep.push(_cstr(wasm, a0_arr[i]));
          {
            const dv = new DataView(wasm.memory.buffer);
            for (let i = 0; i < a0_n; i++) dv.setUint32(a0_base + i * 4, a0_ep[i][0], true);
          }
          wasm.weaveffi_tasks_run_batch_async(a0_base, a0_n, _cbPtr_i32_i32_i32_i32, ctxId);
          for (const [ep, es] of a0_ep) wasm.weaveffi_dealloc(ep, es);
          wasm.weaveffi_dealloc(a0_base, a0_n ? a0_n * 4 : 1);
        });
      },
      cancel_task(id) {
        const _err = _allocErr(wasm);
        const _r = wasm.weaveffi_tasks_cancel_task(BigInt(id), _err);
        _checkErr(wasm, _err);
        _freeErr(wasm, _err);
        return _r !== 0;
      },
      run_n_tasks(n) {
        return new Promise((resolve, reject) => {
          const ctxId = _nextCtxId++;
          _asyncContexts.set(ctxId, { resolve, reject });
          wasm.weaveffi_tasks_run_n_tasks_async(n, _cbPtr_i32_i32_i32, ctxId);
        });
      },
      active_callbacks() {
        const _err = _allocErr(wasm);
        const _r = wasm.weaveffi_tasks_active_callbacks(_err);
        _checkErr(wasm, _err);
        _freeErr(wasm, _err);
        return _r;
      },
      TaskResult: {
        create: (...args) => TaskResult.create(wasm, ...args),
      },
    },
  };
}

