// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

package weaveffi

/*
#cgo LDFLAGS: -lweaveffi
#include "weaveffi.h"
#include <stdlib.h>
*/
import "C"

import (
	"fmt"
)

// WeaveFFIError reports a failure crossing the C boundary that no typed
// error domain claims: an unknown code, a marshalling failure, or a
// producer panic.
type WeaveFFIError struct {
	// Code is the numeric ABI error code.
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *WeaveFFIError) Error() string {
	return fmt.Sprintf("weaveffi: %s (code %d)", e.Message, e.Code)
}

// wvTakeError reads and clears a non-zero C error slot, returning its
// code and message.
func wvTakeError(cErr *C.weaveffi_error) (int32, string) {
	code := int32(cErr.code)
	msg := ""
	if cErr.message != nil {
		msg = C.GoString(cErr.message)
	}
	C.weaveffi_error_clear(cErr)
	return code, msg
}

func wvBrandError(code int32, message string) error {
	return &WeaveFFIError{Code: code, Message: message}
}

// wvTrap panics when the C error slot reports a failure. Non-throwing
// wrappers check their slot with it: a non-zero code there can only be
// a producer panic or a marshalling failure.
func wvTrap(cErr *C.weaveffi_error) {
	if cErr.code != 0 {
		code, msg := wvTakeError(cErr)
		panic(fmt.Sprintf("weaveffi: %s (code %d)", msg, code))
	}
}

// GraphicsError is a typed error reported by the `graphics` module.
type GraphicsError struct {
	// Code is the numeric ABI error code (one of the GraphicsError constants).
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *GraphicsError) Error() string {
	return fmt.Sprintf("graphics: %s (code %d)", e.Message, e.Code)
}

// GraphicsError codes.
const (
	// GraphicsErrorOutOfBounds coordinate out of bounds
	GraphicsErrorOutOfBounds int32 = 1
)

// wvMapGraphics converts a non-zero code from the `graphics` domain into a
// *GraphicsError, falling back to the generic *WeaveFFIError for unknown codes.
func wvMapGraphics(code int32, message string) error {
	switch code {
	case GraphicsErrorOutOfBounds:
		if message == "" {
			message = "coordinate out of bounds"
		}
		return &GraphicsError{Code: code, Message: message}
	default:
		return wvBrandError(code, message)
	}
}

// Unit: A measurement unit shared with nested submodules.
type Unit int32

const (
	UnitPixels Unit = 0
	UnitPoints Unit = 1
)

// Canvas: Top-level struct that references a struct defined one level deeper.
type Canvas struct {
	ptr *C.weaveffi_graphics_Canvas
}

func (s *Canvas) Width() int32 {
	return int32(C.weaveffi_graphics_Canvas_get_width(s.ptr))
}

// Root: Reference down into a nested module
func (s *Canvas) Root() *Shape {
	return &Shape{ptr: C.weaveffi_graphics_Canvas_get_root(s.ptr)}
}

func (s *Canvas) Close() {
	if s.ptr != nil {
		C.weaveffi_graphics_Canvas_destroy(s.ptr)
		s.ptr = nil
	}
}

// NewCanvas: Construct a Canvas.
func NewCanvas(width int32) *Canvas {
	var cErr C.weaveffi_error
	result := C.weaveffi_graphics_new_canvas(C.int32_t(width), &cErr)
	wvTrap(&cErr)
	return &Canvas{ptr: result}
}

// Shape: A struct one level deep that references both an ancestor enum and a deeper struct.
type Shape struct {
	ptr *C.weaveffi_graphics_shapes_Shape
}

func (s *Shape) Sides() int32 {
	return int32(C.weaveffi_graphics_shapes_Shape_get_sides(s.ptr))
}

// Unit: Reference up to the parent module's enum
func (s *Shape) Unit() Unit {
	return Unit(C.weaveffi_graphics_shapes_Shape_get_unit(s.ptr))
}

// Detail: Reference down into a deeper module
func (s *Shape) Detail() *Detail {
	return &Detail{ptr: C.weaveffi_graphics_shapes_Shape_get_detail(s.ptr)}
}

func (s *Shape) Close() {
	if s.ptr != nil {
		C.weaveffi_graphics_shapes_Shape_destroy(s.ptr)
		s.ptr = nil
	}
}

// MakeShape: Construct a Shape.
func MakeShape(sides int32) *Shape {
	var cErr C.weaveffi_error
	result := C.weaveffi_graphics_shapes_make_shape(C.int32_t(sides), &cErr)
	wvTrap(&cErr)
	return &Shape{ptr: result}
}

// Describe: Nested function returning a struct owned by an ancestor module.
func Describe() *Canvas {
	var cErr C.weaveffi_error
	result := C.weaveffi_graphics_shapes_describe(&cErr)
	wvTrap(&cErr)
	return &Canvas{ptr: result}
}

// Detail: A struct two levels deep.
type Detail struct {
	ptr *C.weaveffi_graphics_shapes_geometry_Detail
}

func (s *Detail) Area() float64 {
	return float64(C.weaveffi_graphics_shapes_geometry_Detail_get_area(s.ptr))
}

func (s *Detail) Close() {
	if s.ptr != nil {
		C.weaveffi_graphics_shapes_geometry_Detail_destroy(s.ptr)
		s.ptr = nil
	}
}

// Compute: Deeper function taking an ancestor-module struct. Throws through the root module's inherited GraphicsError domain.
func Compute(shape *Shape) (*Detail, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_graphics_shapes_geometry_compute(shape.ptr, &cErr)
	if cErr.code != 0 {
		return nil, wvMapGraphics(wvTakeError(&cErr))
	}
	return &Detail{ptr: result}, nil
}


