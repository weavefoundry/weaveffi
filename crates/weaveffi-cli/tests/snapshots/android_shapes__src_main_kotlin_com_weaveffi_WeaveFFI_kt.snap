// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

package com.weaveffi

class WeaveFFI {
    companion object {
        init { System.loadLibrary("weaveffi") }

        /**
         * Render a shape to a string
         */
        @JvmStatic private external fun describeJni(shape: Long): String
        @JvmStatic fun describe(shape: Shape): String = describeJni(shape.handle)
        /**
         * Scale a shape by a factor, returning a new shape
         */
        @JvmStatic private external fun scaleJni(shape: Long, factor: Double): Long
        @JvmStatic fun scale(shape: Shape, factor: Double): Shape = Shape(scaleJni(shape.handle, factor))
        /**
         * Sum a list of bytes into a wide integer (numerics smoke)
         */
        @JvmStatic external fun sumBytes(values: ByteArray): Long
        /**
         * Build a Numerics struct from every numeric primitive
         */
        @JvmStatic private external fun makeNumericsJni(a: Byte, b: Short, c: Int, d: Long, e: Byte, f: Short, g: Long, h: Long, i: Float, j: Double): Long
        @JvmStatic fun makeNumerics(a: Byte, b: Short, c: Int, d: Long, e: Byte, f: Short, g: Long, h: Long, i: Float, j: Double): Numerics = Numerics(makeNumericsJni(a, b, c, d, e, f, g, h, i, j))
    }
}

/** An algebraic shape (sum type with associated data) */
class Shape internal constructor(internal var handle: Long) : java.io.Closeable {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic external fun nativeTag(handle: Long): Int
        @JvmStatic external fun nativeDestroy(handle: Long)
        @JvmStatic external fun nativeNewEmpty(): Long
        @JvmStatic external fun nativeNewCircle(radius: Double): Long
        @JvmStatic external fun nativeNewRectangle(width: Float, height: Float): Long
        @JvmStatic external fun nativeNewBounded(min: Short, max: Short, weight: Long): Long
        @JvmStatic external fun nativeNewLabeled(label: String, count: Byte): Long
        @JvmStatic external fun nativeGetCircleRadius(handle: Long): Double
        @JvmStatic external fun nativeGetRectangleWidth(handle: Long): Float
        @JvmStatic external fun nativeGetRectangleHeight(handle: Long): Float
        @JvmStatic external fun nativeGetBoundedMin(handle: Long): Short
        @JvmStatic external fun nativeGetBoundedMax(handle: Long): Short
        @JvmStatic external fun nativeGetBoundedWeight(handle: Long): Long
        @JvmStatic external fun nativeGetLabeledLabel(handle: Long): String
        @JvmStatic external fun nativeGetLabeledCount(handle: Long): Byte

        /** The empty shape (a unit variant) */
        fun empty(): Shape = Shape(nativeNewEmpty())
        /** A circle with a radius */
        fun circle(radius: Double): Shape = Shape(nativeNewCircle(radius))
        /** An axis-aligned rectangle */
        fun rectangle(width: Float, height: Float): Shape = Shape(nativeNewRectangle(width, height))
        /** An integer-bounded shape (exercises narrow + wide ints) */
        fun bounded(min: Short, max: Short, weight: Long): Shape = Shape(nativeNewBounded(min, max, weight))
        /** A labeled shape with a small count */
        fun labeled(label: String, count: Byte): Shape = Shape(nativeNewLabeled(label, count))
    }

    enum class Tag(val value: Int) {
        /** The empty shape (a unit variant) */
        Empty(0),
        /** A circle with a radius */
        Circle(1),
        /** An axis-aligned rectangle */
        Rectangle(2),
        /** An integer-bounded shape (exercises narrow + wide ints) */
        Bounded(3),
        /** A labeled shape with a small count */
        Labeled(4);

        companion object {
            fun fromValue(value: Int): Tag = entries.first { it.value == value }
        }
    }

    val tag: Tag get() = Tag.fromValue(nativeTag(handle))

    /** Radius in points */
    val circleRadius: Double get() = nativeGetCircleRadius(handle)
    val rectangleWidth: Float get() = nativeGetRectangleWidth(handle)
    val rectangleHeight: Float get() = nativeGetRectangleHeight(handle)
    val boundedMin: Short get() = nativeGetBoundedMin(handle)
    val boundedMax: Short get() = nativeGetBoundedMax(handle)
    val boundedWeight: Long get() = nativeGetBoundedWeight(handle)
    val labeledLabel: String get() = nativeGetLabeledLabel(handle)
    val labeledCount: Byte get() = nativeGetLabeledCount(handle)

    override fun close() {
        if (handle != 0L) {
            nativeDestroy(handle)
            handle = 0L
        }
    }

    protected fun finalize() {
        close()
    }
}

/** A plain C-style enum (no payloads) */
enum class Channel(val value: Int) {
    Red(0),
    Green(1),
    Blue(2);

    companion object {
        fun fromValue(value: Int): Channel = entries.first { it.value == value }
    }
}

/** One field per supported numeric primitive */
class Numerics internal constructor(internal var handle: Long) : java.io.Closeable {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic external fun nativeCreate(a: Byte, b: Short, c: Int, d: Long, e: Byte, f: Short, g: Long, h: Long, i: Float, j: Double): Long
        @JvmStatic external fun nativeDestroy(handle: Long)
        @JvmStatic external fun nativeGetA(handle: Long): Byte
        @JvmStatic external fun nativeGetB(handle: Long): Short
        @JvmStatic external fun nativeGetC(handle: Long): Int
        @JvmStatic external fun nativeGetD(handle: Long): Long
        @JvmStatic external fun nativeGetE(handle: Long): Byte
        @JvmStatic external fun nativeGetF(handle: Long): Short
        @JvmStatic external fun nativeGetG(handle: Long): Long
        @JvmStatic external fun nativeGetH(handle: Long): Long
        @JvmStatic external fun nativeGetI(handle: Long): Float
        @JvmStatic external fun nativeGetJ(handle: Long): Double

        fun create(a: Byte, b: Short, c: Int, d: Long, e: Byte, f: Short, g: Long, h: Long, i: Float, j: Double): Numerics = Numerics(nativeCreate(a, b, c, d, e, f, g, h, i, j))
    }

    val a: Byte get() = nativeGetA(handle)
    val b: Short get() = nativeGetB(handle)
    val c: Int get() = nativeGetC(handle)
    val d: Long get() = nativeGetD(handle)
    val e: Byte get() = nativeGetE(handle)
    val f: Short get() = nativeGetF(handle)
    val g: Long get() = nativeGetG(handle)
    val h: Long get() = nativeGetH(handle)
    val i: Float get() = nativeGetI(handle)
    val j: Double get() = nativeGetJ(handle)

    override fun close() {
        if (handle != 0L) {
            nativeDestroy(handle)
            handle = 0L
        }
    }

    protected fun finalize() {
        close()
    }
}

/** Generic WeaveFFI failure: panics, marshalling errors, and unknown codes. */
open class WeaveFFIException(val code: Int, message: String) : Exception(message)

// END WeaveFFI.kt
