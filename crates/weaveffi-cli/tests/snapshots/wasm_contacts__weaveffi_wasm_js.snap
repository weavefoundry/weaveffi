// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

// WeaveFFI Wasm bindings (auto-generated)
//
// Boundary conventions for a wasm32-unknown-unknown build:
//
//   Handles   -> i32 pointer into linear memory (0 = null/absent)
//   Enums     -> i32 discriminant value
//   i64/u64   -> JavaScript BigInt
//   Strings   -> NUL-terminated UTF-8 (const char*); a single i32 pointer
//   Bytes     -> i32 data pointer + i32 length (out_len for returns)
//   Optionals -> null handle / null pointer (0); scalars boxed by pointer

const _enc = new TextEncoder();
const _dec = new TextDecoder();

// Stage a JS string as a NUL-terminated C string in linear memory.
// Returns [ptr, size] (size includes the NUL); release with _free.
function _cstr(wasm, str) {
  const bytes = _enc.encode(str);
  const size = bytes.length + 1;
  const ptr = wasm.weaveffi_alloc(size);
  const mem = new Uint8Array(wasm.memory.buffer, ptr, size);
  mem.set(bytes);
  mem[bytes.length] = 0;
  return [ptr, size];
}

// Read a NUL-terminated C string (0 => null). Does not free.
function _readCStr(wasm, ptr) {
  if (ptr === 0) return null;
  const mem = new Uint8Array(wasm.memory.buffer);
  let end = ptr;
  while (mem[end] !== 0) end++;
  return _dec.decode(mem.subarray(ptr, end));
}

// Read then free a producer-owned C string.
function _takeCStr(wasm, ptr) {
  const s = _readCStr(wasm, ptr);
  if (ptr !== 0) wasm.weaveffi_free_string(ptr);
  return s;
}

// Allocate a zeroed {i32 code, i32 message} error slot.
function _allocErr(wasm) {
  const ptr = wasm.weaveffi_alloc(8);
  new Uint8Array(wasm.memory.buffer, ptr, 8).fill(0);
  return ptr;
}

// Throw (and free the slot) if the error slot carries a non-zero code.
function _checkErr(wasm, errPtr) {
  const dv = new DataView(wasm.memory.buffer);
  const code = dv.getInt32(errPtr, true);
  if (code !== 0) {
    const msgPtr = dv.getUint32(errPtr + 4, true);
    const msg = _readCStr(wasm, msgPtr) || '';
    wasm.weaveffi_error_clear(errPtr);
    wasm.weaveffi_dealloc(errPtr, 8);
    throw new Error(`WeaveFFI error ${code}: ${msg}`);
  }
}

// Release an error slot on the success path.
function _freeErr(wasm, errPtr) {
  wasm.weaveffi_dealloc(errPtr, 8);
}

export const ContactType = Object.freeze({
  Personal: 0,
  Work: 1,
  Other: 2,
});

class Contact {
  constructor(wasm, handle) {
    this._wasm = wasm;
    this._handle = handle;
  }
  get id() {
    const wasm = this._wasm;
    const _r = wasm.weaveffi_contacts_Contact_get_id(this._handle);
    return _r;
  }
  get first_name() {
    const wasm = this._wasm;
    const _r = wasm.weaveffi_contacts_Contact_get_first_name(this._handle);
    return _takeCStr(wasm, _r);
  }
  get last_name() {
    const wasm = this._wasm;
    const _r = wasm.weaveffi_contacts_Contact_get_last_name(this._handle);
    return _takeCStr(wasm, _r);
  }
  get email() {
    const wasm = this._wasm;
    const _r = wasm.weaveffi_contacts_Contact_get_email(this._handle);
    return _takeCStr(wasm, _r);
  }
  get contact_type() {
    const wasm = this._wasm;
    const _r = wasm.weaveffi_contacts_Contact_get_contact_type(this._handle);
    return _r;
  }
  static create(wasm, id, first_name, last_name, email, contact_type) {
    const [a1_p, a1_s] = _cstr(wasm, first_name);
    const [a2_p, a2_s] = _cstr(wasm, last_name);
    let a3_p = 0, a3_s = 0;
    if (email !== null && email !== undefined) { [a3_p, a3_s] = _cstr(wasm, email); }
    const _err = _allocErr(wasm);
    const _r = wasm.weaveffi_contacts_Contact_create(BigInt(id), a1_p, a2_p, a3_p, contact_type, _err);
    wasm.weaveffi_dealloc(a1_p, a1_s);
    wasm.weaveffi_dealloc(a2_p, a2_s);
    if (a3_p !== 0) wasm.weaveffi_dealloc(a3_p, a3_s);
    _checkErr(wasm, _err);
    _freeErr(wasm, _err);
    return new Contact(wasm, _r);
  }
}

/**
 * Load a WeaveFFI Wasm module from the given URL.
 *
 * @param {string} url - URL to the `.wasm` file.
 * @returns {Promise<Object>} The API bindings.
 *
 * Exported functions follow the C ABI naming convention:
 *   weaveffi_{module}_{function}(params...) -> result
 *
 * @example
 * const api = await loadWeaveffiWasm('lib.wasm');
 *
 * // Primitive: plain numbers in, number out.
 * const sum = api.math.add(1, 2);
 *
 * // Struct: returns a wrapper instance exposing field getters.
 * const person = api.contacts.create();
 * console.log(person.name);
 *
 * // Enum: pass the integer discriminant.
 * api.ui.set_color(0); // 0 = first variant
 *
 * // Optional: pass null to omit, a value to provide.
 * api.config.set_timeout(5000); // present
 * api.config.set_timeout(null); // absent
 *
 * // List/Map: pass arrays/objects; receive arrays/objects.
 * const names = api.data.all_names();
 */
export async function loadWeaveffiWasm(url) {
  const response = await fetch(url);
  const bytes = await response.arrayBuffer();
  const { instance } = await WebAssembly.instantiate(bytes, {});
  const wasm = instance.exports;

  return {
    _raw: wasm,
    contacts: {
      create_contact(first_name, last_name, email, contact_type) {
        const [a0_p, a0_s] = _cstr(wasm, first_name);
        const [a1_p, a1_s] = _cstr(wasm, last_name);
        let a2_p = 0, a2_s = 0;
        if (email !== null && email !== undefined) { [a2_p, a2_s] = _cstr(wasm, email); }
        const _err = _allocErr(wasm);
        const _r = wasm.weaveffi_contacts_create_contact(a0_p, a1_p, a2_p, contact_type, _err);
        wasm.weaveffi_dealloc(a0_p, a0_s);
        wasm.weaveffi_dealloc(a1_p, a1_s);
        if (a2_p !== 0) wasm.weaveffi_dealloc(a2_p, a2_s);
        _checkErr(wasm, _err);
        _freeErr(wasm, _err);
        return _r;
      },
      get_contact(id) {
        const _err = _allocErr(wasm);
        const _r = wasm.weaveffi_contacts_get_contact(BigInt(id), _err);
        _checkErr(wasm, _err);
        _freeErr(wasm, _err);
        return new Contact(wasm, _r);
      },
      list_contacts() {
        const _lp = wasm.weaveffi_alloc(4);
        const _err = _allocErr(wasm);
        const _r = wasm.weaveffi_contacts_list_contacts(_lp, _err);
        _checkErr(wasm, _err);
        _freeErr(wasm, _err);
        const _dv = new DataView(wasm.memory.buffer);
        const _len = _dv.getUint32(_lp, true);
        wasm.weaveffi_dealloc(_lp, 4);
        const _out = [];
        {
          const dv = new DataView(wasm.memory.buffer);
          for (let i = 0; i < _len; i++) _out.push(new Contact(wasm, dv.getInt32(_r + i * 4, true)));
        }
        return _out;
      },
      delete_contact(id) {
        const _err = _allocErr(wasm);
        const _r = wasm.weaveffi_contacts_delete_contact(BigInt(id), _err);
        _checkErr(wasm, _err);
        _freeErr(wasm, _err);
        return _r !== 0;
      },
      count_contacts() {
        const _err = _allocErr(wasm);
        const _r = wasm.weaveffi_contacts_count_contacts(_err);
        _checkErr(wasm, _err);
        _freeErr(wasm, _err);
        return _r;
      },
      Contact: {
        create: (...args) => Contact.create(wasm, ...args),
      },
    },
  };
}

