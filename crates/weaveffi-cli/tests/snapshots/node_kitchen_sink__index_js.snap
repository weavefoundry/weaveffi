// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

// The WEAVEFFI_ADDON environment variable overrides the addon location
// (an absolute path to the built .node file); otherwise prefer the
// default node-gyp output path and fall back to a prebuilt index.node
// placed next to this file.
let addon;
if (process.env.WEAVEFFI_ADDON) {
  addon = require(process.env.WEAVEFFI_ADDON);
} else {
  try {
    addon = require('./build/Release/weaveffi.node');
  } catch (e) {
    addon = require('./index.node');
  }
}

// Re-export every native binding, then layer the idiomatic wrappers
// (error classes, interface and rich-enum classes, function wrappers)
// on top.
const wv = {};
for (const _name of Object.getOwnPropertyNames(addon)) {
  wv[_name] = addon[_name];
}

class WeaveFFIError extends Error {
  constructor(code, message) {
    super('(' + code + ') ' + (message || ''));
    this.name = 'WeaveFFIError';
    this.code = code;
    this.errorMessage = message || '';
  }
}
wv.WeaveFFIError = WeaveFFIError;
function __generic(code, message) {
  return new WeaveFFIError(code, message);
}
function __rebrand(e, map) {
  return e && typeof e.code === 'number' ? map(e.code, e.message) : e;
}
function __invoke(fn, args, map) {
  try {
    return fn.apply(null, args);
  } catch (e) {
    throw __rebrand(e, map);
  }
}
function __invokeAsync(fn, args, map) {
  return fn.apply(null, args).catch((e) => {
    throw __rebrand(e, map);
  });
}

class KitchenErrorsError extends WeaveFFIError {
  constructor(code, message) {
    super(code, message);
    this.name = 'KitchenErrorsError';
  }
}
wv.KitchenErrorsError = KitchenErrorsError;
class NotFoundError extends KitchenErrorsError {
  constructor(message) {
    super(1, message || 'Item not found');
    this.name = 'NotFoundError';
  }
}
NotFoundError.CODE = 1;
wv.NotFoundError = NotFoundError;
class InvalidInputError extends KitchenErrorsError {
  constructor(message) {
    super(2, message || 'Invalid input');
    this.name = 'InvalidInputError';
  }
}
InvalidInputError.CODE = 2;
wv.InvalidInputError = InvalidInputError;
const __kitchenErrorCodes = Object.freeze({ 1: NotFoundError, 2: InvalidInputError });
function __kitchenErrorFrom(code, message) {
  const _cls = __kitchenErrorCodes[code];
  return _cls === undefined ? new WeaveFFIError(code, message) : new _cls(message);
}

class Gadget {
  constructor(id) {
    this._handle = __invoke(addon.Gadget_new, [id], __generic);
    Gadget._cleanup.register(this, this._handle, this);
  }
  describe() {
    return __invoke(addon.Gadget_describe, [this._handle], __generic);
  }
  poke(times) {
    return __invoke(addon.Gadget_poke, [this._handle, times], __kitchenErrorFrom);
  }
  static version() {
    return __invoke(addon.Gadget_version, [], __generic);
  }
  destroy() {
    if (this._handle) {
      Gadget._cleanup.unregister(this);
      addon.Gadget_destroy(this._handle);
      this._handle = 0;
    }
  }
}
Gadget._fromHandle = function (handle) {
  const _o = Object.create(Gadget.prototype);
  _o._handle = handle;
  Gadget._cleanup.register(_o, handle, _o);
  return _o;
};
Gadget._cleanup = new FinalizationRegistry((handle) => {
  if (handle) { addon.Gadget_destroy(handle); }
});
wv.Gadget = Gadget;

wv.ping = function () {
  return __invoke(addon.ping, [], __generic);
};
