namespace weaveffi {

class WeaveFFIError : public std::runtime_error {
    int32_t code_;

public:
    WeaveFFIError(int32_t code, const std::string& msg) : std::runtime_error(msg), code_(code) {}
    int32_t code() const { return code_; }
};

/** Add two integers */
inline int32_t calculator_add(int32_t a, int32_t b) {
    weaveffi_error err{};
    auto result = weaveffi_calculator_add(a, b, &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        throw WeaveFFIError(code, msg);
    }
    return result;
}

/** Multiply two integers */
inline int32_t calculator_mul(int32_t a, int32_t b) {
    weaveffi_error err{};
    auto result = weaveffi_calculator_mul(a, b, &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        throw WeaveFFIError(code, msg);
    }
    return result;
}

/** Divide two integers */
inline int32_t calculator_div(int32_t a, int32_t b) {
    weaveffi_error err{};
    auto result = weaveffi_calculator_div(a, b, &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        throw WeaveFFIError(code, msg);
    }
    return result;
}

/** Echo a string back */
inline std::string calculator_echo(const std::string& s) {
    weaveffi_error err{};
    auto result = weaveffi_calculator_echo(s.c_str(), &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        throw WeaveFFIError(code, msg);
    }
    std::string ret(result);
    weaveffi_free_string(result);
    return ret;
}

} // namespace weaveffi

