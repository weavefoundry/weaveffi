namespace weaveffi {

/** Base exception for every error reported through the C ABI. */
class WeaveFFIError : public std::runtime_error {
    int32_t code_;

public:
    WeaveFFIError(int32_t code, const std::string& msg) : std::runtime_error(msg), code_(code) {}
    int32_t code() const { return code_; }
};

namespace detail {

/** Throw the generic WeaveFFIError if `err` carries a nonzero code. */
inline void check(weaveffi_error& err) {
    if (err.code == 0) return;
    std::string msg(err.message ? err.message : "unknown error");
    int32_t code = err.code;
    weaveffi_error_clear(&err);
    throw WeaveFFIError(code, msg);
}

/** Wrap an async-callback error as the generic WeaveFFIError. */
inline std::exception_ptr make_error(int32_t code, const std::string& msg) {
    return std::make_exception_ptr(WeaveFFIError(code, msg));
}

} // namespace detail

/** Typed errors reported by the `calculator` module's throwing functions. */
class CalcError : public WeaveFFIError {
public:
    CalcError(int32_t code, const std::string& msg) : WeaveFFIError(code, msg) {}
};

/** division by zero */
class DivisionByZeroError : public CalcError {
public:
    DivisionByZeroError(const std::string& msg) : CalcError(1, msg) {}
};

namespace detail {

/** Map a `calculator` error code to its typed exception (CalcError for unknown codes). */
inline std::exception_ptr make_calculator_error(int32_t code, const std::string& msg) {
    switch (code) {
    case 1: return std::make_exception_ptr(DivisionByZeroError(msg));
    default: return std::make_exception_ptr(CalcError(code, msg));
    }
}

/** Throw the typed `calculator` exception if `err` carries a nonzero code. */
inline void check_calculator(weaveffi_error& err) {
    if (err.code == 0) return;
    std::string msg(err.message ? err.message : "unknown error");
    int32_t code = err.code;
    weaveffi_error_clear(&err);
    std::rethrow_exception(make_calculator_error(code, msg));
}

} // namespace detail

namespace calculator {

/** Add two integers */
inline int32_t add(int32_t a, int32_t b) {
    weaveffi_error err{};
    auto result = weaveffi_calculator_add(a, b, &err);
    detail::check(err);
    return result;
}

/** Multiply two integers */
inline int32_t mul(int32_t a, int32_t b) {
    weaveffi_error err{};
    auto result = weaveffi_calculator_mul(a, b, &err);
    detail::check(err);
    return result;
}

/** Divide two integers, failing on a zero divisor */
inline int32_t div(int32_t a, int32_t b) {
    weaveffi_error err{};
    auto result = weaveffi_calculator_div(a, b, &err);
    detail::check_calculator(err);
    return result;
}

/** Echo a string back */
inline std::string echo(const std::string& s) {
    weaveffi_error err{};
    auto result = weaveffi_calculator_echo(s.c_str(), &err);
    detail::check(err);
    std::string ret(result);
    weaveffi_free_string(result);
    return ret;
}

