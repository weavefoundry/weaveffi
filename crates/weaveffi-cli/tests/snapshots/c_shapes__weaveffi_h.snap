/*
 * Map convention: Maps are passed as parallel arrays of keys and values.
 * A map parameter {K:V} named "m" expands to:
 *   const K* m_keys, const V* m_values, size_t m_len
 * A map return value expands to out-parameters that receive callee-
 * allocated arrays; the caller passes the address of its own pointers:
 *   K** out_keys, V** out_values, size_t* out_len
 */

/** An algebraic shape (sum type with associated data) */
typedef enum {
    /** The empty shape (a unit variant) */
    weaveffi_shapes_Shape_Empty = 0,
    /** A circle with a radius */
    weaveffi_shapes_Shape_Circle = 1,
    /** An axis-aligned rectangle */
    weaveffi_shapes_Shape_Rectangle = 2,
    /** An integer-bounded shape (exercises narrow + wide ints) */
    weaveffi_shapes_Shape_Bounded = 3,
    /** A labeled shape with a small count */
    weaveffi_shapes_Shape_Labeled = 4
} weaveffi_shapes_Shape_Tag;
