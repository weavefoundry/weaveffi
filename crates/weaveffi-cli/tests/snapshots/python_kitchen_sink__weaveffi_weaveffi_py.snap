class _StreamItemsIterator:
    def __init__(self, ptr):
        self._ptr = ptr
        self._done = False

    def __iter__(self):
        return self

    def __next__(self):
        if self._done:
            raise StopIteration
        _next_fn = _lib.weaveffi_kitchen_StreamItemsIterator_next
        _next_fn.argtypes = [ctypes.c_void_p, ctypes.POINTER(ctypes.c_void_p), ctypes.POINTER(_WeaveFFIErrorStruct)]
        _next_fn.restype = ctypes.c_int32
        _out_item = ctypes.c_void_p()
        _err = _WeaveFFIErrorStruct()
        _has = _next_fn(self._ptr, ctypes.byref(_out_item), ctypes.byref(_err))
        _check_error(_err)
        if not _has:
            self._done = True
            self._destroy()
            raise StopIteration
        return Item(_out_item.value)

    def _destroy(self):
        if self._ptr is not None:
            _destroy_fn = _lib.weaveffi_kitchen_StreamItemsIterator_destroy
            _destroy_fn.argtypes = [ctypes.c_void_p]
            _destroy_fn.restype = None
            _destroy_fn(self._ptr)
            self._ptr = None

    def __del__(self):
        self._destroy()


