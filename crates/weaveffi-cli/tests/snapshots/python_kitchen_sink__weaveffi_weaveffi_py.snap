def _do_async_sync(input: str) -> str:
    """Async operation
    """
    _fn = _lib.weaveffi_kitchen_do_async_async
    _ev = threading.Event()
    _state = {"err": None, "val": None}
    def _cb_impl(context, err, result):
        try:
            if err and err.contents.code != 0:
                _code = err.contents.code
                _msg = err.contents.message.decode("utf-8") if err.contents.message else ""
                _lib.weaveffi_error_clear(ctypes.byref(err.contents))
                _state["err"] = WeaveFFIError(_code, _msg)
            else:
                _s = _bytes_to_string(result) or "" if result else ""
                if result:
                    _lib.weaveffi_free_string(result)
                _state["val"] = _s
        finally:
            _ev.set()
    _cb_type = ctypes.CFUNCTYPE(None, ctypes.c_void_p, ctypes.POINTER(_WeaveFFIErrorStruct), ctypes.c_char_p)
    _cb = _cb_type(_cb_impl)
    _fn.argtypes = [ctypes.c_char_p, _cb_type, ctypes.c_void_p]
    _fn.restype = None
    _fn(_string_to_bytes(input), _cb, None)
    _ev.wait()
    if _state["err"] is not None:
        raise _state["err"]
    return _state["val"]


async def do_async(input: str) -> str:
    """Async operation
    """
    _loop = asyncio.get_event_loop()
    return await _loop.run_in_executor(None, _do_async_sync, input)


def _do_cancellable_sync(input: str) -> str:
    """Cancellable async operation
    """
    _fn = _lib.weaveffi_kitchen_do_cancellable_async
    _ev = threading.Event()
    _state = {"err": None, "val": None}
    def _cb_impl(context, err, result):
        try:
            if err and err.contents.code != 0:
                _code = err.contents.code
                _msg = err.contents.message.decode("utf-8") if err.contents.message else ""
                _lib.weaveffi_error_clear(ctypes.byref(err.contents))
                _state["err"] = WeaveFFIError(_code, _msg)
            else:
                _s = _bytes_to_string(result) or "" if result else ""
                if result:
                    _lib.weaveffi_free_string(result)
                _state["val"] = _s
        finally:
            _ev.set()
    _cb_type = ctypes.CFUNCTYPE(None, ctypes.c_void_p, ctypes.POINTER(_WeaveFFIErrorStruct), ctypes.c_char_p)
    _cb = _cb_type(_cb_impl)
    _fn.argtypes = [ctypes.c_char_p, ctypes.c_void_p, _cb_type, ctypes.c_void_p]
    _fn.restype = None
    _fn(_string_to_bytes(input), None, _cb, None)
    _ev.wait()
    if _state["err"] is not None:
        raise _state["err"]
    return _state["val"]


async def do_cancellable(input: str) -> str:
    """Cancellable async operation
    """
    _loop = asyncio.get_event_loop()
    return await _loop.run_in_executor(None, _do_cancellable_sync, input)


