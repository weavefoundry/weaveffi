// Generated by WeaveFFI 0.3.0 from weaveffi.yml
// DO NOT EDIT — your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

// WeaveFFI WASM bindings (auto-generated)
//
// Complex type conventions at the WASM boundary:
//
//   Structs   -> i64 opaque handle (pointer into linear memory)
//   Enums     -> i32 discriminant value
//   Optionals -> 0/null for absent; for numerics a separate _is_present i32 flag
//   Lists     -> (i32 pointer, i32 length) pair into linear memory

const _encoder = new TextEncoder();
const _decoder = new TextDecoder();

function _encodeString(wasm, str) {
  const bytes = _encoder.encode(str);
  const ptr = wasm.weaveffi_alloc(bytes.length);
  new Uint8Array(wasm.memory.buffer, ptr, bytes.length).set(bytes);
  return [ptr, bytes.length];
}

function _decodeString(wasm, ptr, len) {
  return _decoder.decode(new Uint8Array(wasm.memory.buffer, ptr, len));
}

function _allocError(wasm) {
  return wasm.weaveffi_alloc(8);
}

function _checkError(wasm, errPtr) {
  const buffer = wasm.memory.buffer;
  const code = new Int32Array(buffer, errPtr, 1)[0];
  if (code !== 0) {
    const msgPtr = new Uint32Array(buffer, errPtr + 4, 1)[0];
    const bytes = new Uint8Array(buffer, msgPtr);
    let end = 0;
    while (bytes[end] !== 0) end++;
    const msg = new TextDecoder().decode(new Uint8Array(buffer, msgPtr, end));
    wasm.weaveffi_error_clear(errPtr);
    throw new Error(`WeaveFFI error ${code}: ${msg}`);
  }
}

export const Category = Object.freeze({
  Electronics: 0,
  Clothing: 1,
  Food: 2,
  Books: 3,
});

class Product {
  constructor(wasm, handle) {
    this._wasm = wasm;
    this._handle = handle;
  }
  get id() {
    return this._wasm.weaveffi_products_Product_get_id(this._handle);
  }
  get name() {
    const retptr = this._wasm.weaveffi_alloc(8);
    this._wasm.weaveffi_products_Product_get_name(retptr, this._handle);
    const view = new DataView(this._wasm.memory.buffer);
    return _decodeString(this._wasm, view.getInt32(retptr, true), view.getInt32(retptr + 4, true));
  }
  get description() {
    return this._wasm.weaveffi_products_Product_get_description(this._handle);
  }
  get price() {
    return this._wasm.weaveffi_products_Product_get_price(this._handle);
  }
  get category() {
    return this._wasm.weaveffi_products_Product_get_category(this._handle);
  }
  get tags() {
    return this._wasm.weaveffi_products_Product_get_tags(this._handle);
  }
}

class OrderItem {
  constructor(wasm, handle) {
    this._wasm = wasm;
    this._handle = handle;
  }
  get product_id() {
    return this._wasm.weaveffi_orders_OrderItem_get_product_id(this._handle);
  }
  get quantity() {
    return this._wasm.weaveffi_orders_OrderItem_get_quantity(this._handle);
  }
  get unit_price() {
    return this._wasm.weaveffi_orders_OrderItem_get_unit_price(this._handle);
  }
}

class Order {
  constructor(wasm, handle) {
    this._wasm = wasm;
    this._handle = handle;
  }
  get id() {
    return this._wasm.weaveffi_orders_Order_get_id(this._handle);
  }
  get items() {
    return this._wasm.weaveffi_orders_Order_get_items(this._handle);
  }
  get total() {
    return this._wasm.weaveffi_orders_Order_get_total(this._handle);
  }
  get status() {
    const retptr = this._wasm.weaveffi_alloc(8);
    this._wasm.weaveffi_orders_Order_get_status(retptr, this._handle);
    const view = new DataView(this._wasm.memory.buffer);
    return _decodeString(this._wasm, view.getInt32(retptr, true), view.getInt32(retptr + 4, true));
  }
}

/**
 * Load a WeaveFFI WASM module from the given URL.
 *
 * @param {string} url - URL to the `.wasm` file.
 * @returns {Promise<Object>} The API bindings.
 *
 * Exported functions follow the C ABI naming convention:
 *   weaveffi_{module}_{function}(params...) -> result
 *
 * @example
 * const api = await loadWeaveffiWasm('lib.wasm');
 *
 * // Primitive: (i32, i32) -> i32
 * const sum = api.math.add(1, 2);
 *
 * // Struct handle: () -> i64 (opaque pointer)
 * const handle = api.contacts.create();
 *
 * // Enum: (i32 discriminant) -> void
 * api.ui.set_color(0); // 0 = first variant
 *
 * // Optional: (i32 is_present, i32 value) -> void
 * api.config.set_timeout(1, 5000); // present
 * api.config.set_timeout(0, 0);    // absent
 *
 * // List: (i32 pointer, i32 length) -> void
 * api.data.process(ptr, len);
 */
export async function loadWeaveffiWasm(url) {
  const response = await fetch(url);
  const bytes = await response.arrayBuffer();
  const { instance } = await WebAssembly.instantiate(bytes, {});
  const wasm = instance.exports;

  return {
    _raw: wasm,
    products: {
      create_product(name, price, category) {
        const _err = _allocError(wasm);
        const [name_ptr, name_len] = _encodeString(wasm, name);
        const _result = wasm.weaveffi_products_create_product(name_ptr, name_len, price, category, _err);
        _checkError(wasm, _err);
        return _result;
      },
      get_product(id) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_products_get_product(id, _err);
        _checkError(wasm, _err);
        return new Product(wasm, _result);
      },
      search_products(category) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_products_search_products(category, _err);
        _checkError(wasm, _err);
        return _result;
      },
      update_price(id, price) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_products_update_price(id, price, _err);
        _checkError(wasm, _err);
        return _result !== 0;
      },
      delete_product(id) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_products_delete_product(id, _err);
        _checkError(wasm, _err);
        return _result !== 0;
      },
    },
    orders: {
      create_order(items) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_orders_create_order(items, _err);
        _checkError(wasm, _err);
        return _result;
      },
      get_order(id) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_orders_get_order(id, _err);
        _checkError(wasm, _err);
        return new Order(wasm, _result);
      },
      cancel_order(id) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_orders_cancel_order(id, _err);
        _checkError(wasm, _err);
        return _result !== 0;
      },
      add_product_to_order(order_id, product) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_orders_add_product_to_order(order_id, product._handle, _err);
        _checkError(wasm, _err);
        return _result !== 0;
      },
    },
  };
}

