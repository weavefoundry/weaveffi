#pragma once

#include <cstdint>
#include <string>
#include <vector>
#include <optional>
#include <unordered_map>
#include <memory>
#include <stdexcept>
#include <future>

extern "C" {

typedef uint64_t weaveffi_handle_t;

typedef struct weaveffi_error {
    int32_t code;
    const char* message;
} weaveffi_error;

void weaveffi_error_clear(weaveffi_error* err);
void weaveffi_free_string(const char* ptr);
void weaveffi_free_bytes(uint8_t* ptr, size_t len);

typedef struct weaveffi_cancel_token weaveffi_cancel_token;
weaveffi_cancel_token* weaveffi_cancel_token_create(void);
void weaveffi_cancel_token_cancel(weaveffi_cancel_token* token);
bool weaveffi_cancel_token_is_cancelled(const weaveffi_cancel_token* token);
void weaveffi_cancel_token_destroy(weaveffi_cancel_token* token);

/**
 * Lifecycle status of a document.
 *
 * Used to drive UI badges and filters.
 */
typedef enum {
    /** Document is being edited */
    weaveffi_docs_Status_Draft = 0,
    /** Document is publicly visible */
    weaveffi_docs_Status_Published = 1,
    /** Document is hidden from listings */
    weaveffi_docs_Status_Archived = 2
} weaveffi_docs_Status;
/**
 * Represents a single document tracked by the system.
 *
 * Documents are persisted to disk and exposed via the public API.
 */
typedef struct weaveffi_docs_Document weaveffi_docs_Document;
weaveffi_docs_Document* weaveffi_docs_Document_create(int64_t id, const char* title, weaveffi_docs_Status status, const char* const* tags, size_t tags_len, weaveffi_error* out_err);
void weaveffi_docs_Document_destroy(weaveffi_docs_Document* ptr);
/** Stable opaque identifier */
int64_t weaveffi_docs_Document_get_id(const weaveffi_docs_Document* ptr);
/** Human-readable title shown in lists */
const char* weaveffi_docs_Document_get_title(const weaveffi_docs_Document* ptr);
/** Current lifecycle status */
weaveffi_docs_Status weaveffi_docs_Document_get_status(const weaveffi_docs_Document* ptr);
/** Free-form tags for grouping */
const char** weaveffi_docs_Document_get_tags(const weaveffi_docs_Document* ptr, size_t* out_len);
typedef struct weaveffi_docs_DocumentBuilder weaveffi_docs_DocumentBuilder;
weaveffi_docs_DocumentBuilder* weaveffi_docs_Document_Builder_new(void);
/** Stable opaque identifier */
void weaveffi_docs_Document_Builder_set_id(weaveffi_docs_DocumentBuilder* builder, int64_t value);
/** Human-readable title shown in lists */
void weaveffi_docs_Document_Builder_set_title(weaveffi_docs_DocumentBuilder* builder, const char* value);
/** Current lifecycle status */
void weaveffi_docs_Document_Builder_set_status(weaveffi_docs_DocumentBuilder* builder, weaveffi_docs_Status value);
/** Free-form tags for grouping */
void weaveffi_docs_Document_Builder_set_tags(weaveffi_docs_DocumentBuilder* builder, const char* const* value, size_t value_len);
weaveffi_docs_Document* weaveffi_docs_Document_Builder_build(weaveffi_docs_DocumentBuilder* builder, weaveffi_error* out_err);
void weaveffi_docs_Document_Builder_destroy(weaveffi_docs_DocumentBuilder* builder);
/**
 * Create a brand new document.
 *
 * The document starts in `Draft` status; callers must publish
 * it explicitly to make it visible.
 */
weaveffi_docs_Document* weaveffi_docs_create_document(const char* title, const char* const* tags, size_t tags_len, weaveffi_error* out_err);
/** Look up a document by identifier */
weaveffi_docs_Document* weaveffi_docs_get_document(int64_t id, weaveffi_error* out_err);
/** Publish a document in the background */
typedef void (*weaveffi_docs_publish_async_callback)(void* context, weaveffi_error* err, bool result);
void weaveffi_docs_publish_async_async(int64_t id, weaveffi_docs_publish_async_callback callback, void* context);

} // extern "C"

namespace weaveffi {

class WeaveFFIError : public std::runtime_error {
    int32_t code_;

public:
    WeaveFFIError(int32_t code, const std::string& msg) : std::runtime_error(msg), code_(code) {}
    int32_t code() const { return code_; }
};

/** Returned when no document matches the requested id */
class not_foundError : public WeaveFFIError {
public:
    not_foundError(const std::string& msg) : WeaveFFIError(1, msg) {}
};

/** Raised when attempting to move into a forbidden state */
class invalid_statusError : public WeaveFFIError {
public:
    invalid_statusError(const std::string& msg) : WeaveFFIError(2, msg) {}
};

/**
 * Lifecycle status of a document.
 *
 * Used to drive UI badges and filters.
 */
enum class Status : int32_t {
    /** Document is being edited */
    Draft = 0,
    /** Document is publicly visible */
    Published = 1,
    /** Document is hidden from listings */
    Archived = 2
};

/**
 * Represents a single document tracked by the system.
 *
 * Documents are persisted to disk and exposed via the public API.
 */
class Document {
    void* handle_;

public:
    explicit Document(void* h) : handle_(h) {}

    ~Document() {
        if (handle_) weaveffi_docs_Document_destroy(static_cast<weaveffi_docs_Document*>(handle_));
    }

    Document(const Document&) = delete;
    Document& operator=(const Document&) = delete;

    Document(Document&& other) noexcept : handle_(other.handle_) {
        other.handle_ = nullptr;
    }

    Document& operator=(Document&& other) noexcept {
        if (this != &other) {
            if (handle_) weaveffi_docs_Document_destroy(static_cast<weaveffi_docs_Document*>(handle_));
            handle_ = other.handle_;
            other.handle_ = nullptr;
        }
        return *this;
    }

    void* handle() const { return handle_; }

    /** Stable opaque identifier */
    int64_t id() const {
        return weaveffi_docs_Document_get_id(static_cast<const weaveffi_docs_Document*>(handle_));
    }

    /** Human-readable title shown in lists */
    std::string title() const {
        const char* raw = weaveffi_docs_Document_get_title(static_cast<const weaveffi_docs_Document*>(handle_));
        std::string ret(raw);
        weaveffi_free_string(raw);
        return ret;
    }

    /** Current lifecycle status */
    Status status() const {
        return static_cast<Status>(weaveffi_docs_Document_get_status(static_cast<const weaveffi_docs_Document*>(handle_)));
    }

    /** Free-form tags for grouping */
    std::vector<std::string> tags() const {
        size_t len = 0;
        auto* raw = weaveffi_docs_Document_get_tags(static_cast<const weaveffi_docs_Document*>(handle_), &len);
        std::vector<std::string> ret;
        ret.reserve(len);
        for (size_t i = 0; i < len; ++i) ret.emplace_back(raw[i]);
        return ret;
    }

};

/**
 * Represents a single document tracked by the system.
 *
 * Documents are persisted to disk and exposed via the public API.
 */
class DocumentBuilder {
    void* handle_;

public:
    DocumentBuilder() : handle_(reinterpret_cast<void*>(weaveffi_docs_Document_Builder_new())) {}

    ~DocumentBuilder() {
        if (handle_) weaveffi_docs_Document_Builder_destroy(static_cast<weaveffi_docs_DocumentBuilder*>(handle_));
    }

    DocumentBuilder(const DocumentBuilder&) = delete;
    DocumentBuilder& operator=(const DocumentBuilder&) = delete;

    DocumentBuilder(DocumentBuilder&& other) noexcept : handle_(other.handle_) {
        other.handle_ = nullptr;
    }

    DocumentBuilder& operator=(DocumentBuilder&& other) noexcept {
        if (this != &other) {
            if (handle_) weaveffi_docs_Document_Builder_destroy(static_cast<weaveffi_docs_DocumentBuilder*>(handle_));
            handle_ = other.handle_;
            other.handle_ = nullptr;
        }
        return *this;
    }

    /** Stable opaque identifier */
    DocumentBuilder& withId(int64_t value) {
        weaveffi_docs_Document_Builder_set_id(static_cast<weaveffi_docs_DocumentBuilder*>(handle_), value);
        return *this;
    }

    /** Human-readable title shown in lists */
    DocumentBuilder& withTitle(const std::string& value) {
        weaveffi_docs_Document_Builder_set_title(static_cast<weaveffi_docs_DocumentBuilder*>(handle_), value.c_str());
        return *this;
    }

    /** Current lifecycle status */
    DocumentBuilder& withStatus(Status value) {
        weaveffi_docs_Document_Builder_set_status(static_cast<weaveffi_docs_DocumentBuilder*>(handle_), static_cast<weaveffi_docs_Status>(static_cast<int32_t>(value)));
        return *this;
    }

    /** Free-form tags for grouping */
    DocumentBuilder& withTags(const std::vector<std::string>& value) {
        std::vector<const char*> value_cstrs;
        value_cstrs.reserve(value.size());
        for (const auto& s : value) value_cstrs.push_back(s.c_str());
        weaveffi_docs_Document_Builder_set_tags(static_cast<weaveffi_docs_DocumentBuilder*>(handle_), value_cstrs.data(), value_cstrs.size());
        return *this;
    }

    Document build() {
        weaveffi_error err{};
        auto* ptr = weaveffi_docs_Document_Builder_build(static_cast<weaveffi_docs_DocumentBuilder*>(handle_), &err);
        if (err.code != 0) throw std::runtime_error(err.message ? err.message : "build failed");
        return Document(ptr);
    }
};

/**
 * Create a brand new document.
 *
 * The document starts in `Draft` status; callers must publish
 * it explicitly to make it visible.
 */
inline Document docs_create_document(const std::string& title, const std::vector<std::string>& tags) {
    std::vector<const char*> tags_cstrs;
    tags_cstrs.reserve(tags.size());
    for (const auto& s : tags) tags_cstrs.push_back(s.c_str());
    weaveffi_error err{};
    auto result = weaveffi_docs_create_document(title.c_str(), tags_cstrs.data(), tags_cstrs.size(), &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        switch (code) {
        case 1: throw not_foundError(msg);
        case 2: throw invalid_statusError(msg);
        default: throw WeaveFFIError(code, msg);
        }
    }
    return Document(result);
}

/** Look up a document by identifier */
inline std::optional<Document> docs_get_document(int64_t id) {
    weaveffi_error err{};
    auto result = weaveffi_docs_get_document(id, &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        switch (code) {
        case 1: throw not_foundError(msg);
        case 2: throw invalid_statusError(msg);
        default: throw WeaveFFIError(code, msg);
        }
    }
    if (!result) return std::nullopt;
    return Document(result);
}

/** Publish a document in the background */
inline std::future<bool> docs_publish_async(int64_t id) {
    auto* promise_ptr = new std::promise<bool>();
    auto future = promise_ptr->get_future();
    weaveffi_docs_publish_async_async(id, [](void* context, weaveffi_error* err, bool result) {
        auto* p = static_cast<std::promise<bool>*>(context);
        if (err && err->code != 0) {
            std::string msg(err->message ? err->message : "unknown error");
            p->set_exception(std::make_exception_ptr(WeaveFFIError(err->code, msg)));
        } else {
            p->set_value(result);
        }
        delete p;
    }, static_cast<void*>(promise_ptr));
    return future;
}

} // namespace weaveffi
