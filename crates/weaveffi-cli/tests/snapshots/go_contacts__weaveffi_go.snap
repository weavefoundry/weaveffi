// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

package weaveffi

/*
#cgo LDFLAGS: -lweaveffi
#include "weaveffi.h"
#include <stdlib.h>
*/
import "C"

import (
	"fmt"
	"unsafe"
)

func boolToC(b bool) C._Bool {
	return C._Bool(b)
}

func cToBool(b C._Bool) bool {
	return bool(b)
}

// WeaveFFIError reports a failure crossing the C boundary that no typed
// error domain claims: an unknown code, a marshalling failure, or a
// producer panic.
type WeaveFFIError struct {
	// Code is the numeric ABI error code.
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *WeaveFFIError) Error() string {
	return fmt.Sprintf("weaveffi: %s (code %d)", e.Message, e.Code)
}

// wvTakeError reads and clears a non-zero C error slot, returning its
// code and message.
func wvTakeError(cErr *C.weaveffi_error) (int32, string) {
	code := int32(cErr.code)
	msg := ""
	if cErr.message != nil {
		msg = C.GoString(cErr.message)
	}
	C.weaveffi_error_clear(cErr)
	return code, msg
}

func wvBrandError(code int32, message string) error {
	return &WeaveFFIError{Code: code, Message: message}
}

// wvTrap panics when the C error slot reports a failure. Non-throwing
// wrappers check their slot with it: a non-zero code there can only be
// a producer panic or a marshalling failure.
func wvTrap(cErr *C.weaveffi_error) {
	if cErr.code != 0 {
		code, msg := wvTakeError(cErr)
		panic(fmt.Sprintf("weaveffi: %s (code %d)", msg, code))
	}
}

// ContactsError is a typed error reported by the `contacts` module.
type ContactsError struct {
	// Code is the numeric ABI error code (one of the ContactsError constants).
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *ContactsError) Error() string {
	return fmt.Sprintf("contacts: %s (code %d)", e.Message, e.Code)
}

// ContactsError codes.
const (
	// ContactsErrorInvalidName name must not be empty
	ContactsErrorInvalidName int32 = 1
	// ContactsErrorNotFound contact not found
	ContactsErrorNotFound int32 = 2
)

// wvMapContacts converts a non-zero code from the `contacts` domain into a
// *ContactsError, falling back to the generic *WeaveFFIError for unknown codes.
func wvMapContacts(code int32, message string) error {
	switch code {
	case ContactsErrorInvalidName:
		if message == "" {
			message = "name must not be empty"
		}
		return &ContactsError{Code: code, Message: message}
	case ContactsErrorNotFound:
		if message == "" {
			message = "contact not found"
		}
		return &ContactsError{Code: code, Message: message}
	default:
		return wvBrandError(code, message)
	}
}

type ContactType int32

const (
	ContactTypePersonal ContactType = 0
	ContactTypeWork ContactType = 1
	ContactTypeOther ContactType = 2
)

type Contact struct {
	ptr *C.weaveffi_contacts_Contact
}

func (s *Contact) Id() int64 {
	return int64(C.weaveffi_contacts_Contact_get_id(s.ptr))
}

func (s *Contact) FirstName() string {
	return C.GoString(C.weaveffi_contacts_Contact_get_first_name(s.ptr))
}

func (s *Contact) LastName() string {
	return C.GoString(C.weaveffi_contacts_Contact_get_last_name(s.ptr))
}

func (s *Contact) Email() *string {
	cStr := C.weaveffi_contacts_Contact_get_email(s.ptr)
	if cStr == nil {
		return nil
	}
	v := C.GoString(cStr)
	return &v
}

func (s *Contact) ContactType() ContactType {
	return ContactType(C.weaveffi_contacts_Contact_get_contact_type(s.ptr))
}

func (s *Contact) Close() {
	if s.ptr != nil {
		C.weaveffi_contacts_Contact_destroy(s.ptr)
		s.ptr = nil
	}
}

// ContactBook: An in-memory address book owning its contacts
type ContactBook struct {
	ptr *C.weaveffi_contacts_ContactBook
}

func NewContactBook() *ContactBook {
	var cErr C.weaveffi_error
	result := C.weaveffi_contacts_ContactBook_new(&cErr)
	wvTrap(&cErr)
	return &ContactBook{ptr: result}
}

func (s *ContactBook) Add(firstName string, lastName string, email *string, contactType ContactType) (*Contact, error) {
	cFirstName := C.CString(firstName)
	defer C.free(unsafe.Pointer(cFirstName))
	cLastName := C.CString(lastName)
	defer C.free(unsafe.Pointer(cLastName))
	var cEmail *C.char
	if email != nil {
		cEmail = C.CString(*email)
		defer C.free(unsafe.Pointer(cEmail))
	}
	var cErr C.weaveffi_error
	result := C.weaveffi_contacts_ContactBook_add(s.ptr, cFirstName, cLastName, cEmail, C.weaveffi_contacts_ContactType(contactType), &cErr)
	if cErr.code != 0 {
		return nil, wvMapContacts(wvTakeError(&cErr))
	}
	return &Contact{ptr: result}, nil
}

func (s *ContactBook) Get(id int64) (*Contact, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_contacts_ContactBook_get(s.ptr, C.int64_t(id), &cErr)
	if cErr.code != 0 {
		return nil, wvMapContacts(wvTakeError(&cErr))
	}
	return &Contact{ptr: result}, nil
}

func (s *ContactBook) List() []*Contact {
	var cOutLen C.size_t
	var cErr C.weaveffi_error
	result := C.weaveffi_contacts_ContactBook_list(s.ptr, &cOutLen, &cErr)
	wvTrap(&cErr)
	count := int(cOutLen)
	goResult := make([]*Contact, count)
	if count > 0 && result != nil {
		for i, v := range unsafe.Slice((**C.weaveffi_contacts_Contact)(unsafe.Pointer(result)), count) {
			goResult[i] = &Contact{ptr: v}
		}
	}
	return goResult
}

func (s *ContactBook) Remove(id int64) bool {
	var cErr C.weaveffi_error
	result := C.weaveffi_contacts_ContactBook_remove(s.ptr, C.int64_t(id), &cErr)
	wvTrap(&cErr)
	return cToBool(result)
}

func (s *ContactBook) Count() int32 {
	var cErr C.weaveffi_error
	result := C.weaveffi_contacts_ContactBook_count(s.ptr, &cErr)
	wvTrap(&cErr)
	return int32(result)
}

func (s *ContactBook) Close() {
	if s.ptr != nil {
		C.weaveffi_contacts_ContactBook_destroy(s.ptr)
		s.ptr = nil
	}
}


