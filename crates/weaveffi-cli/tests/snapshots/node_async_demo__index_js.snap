// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

// The WEAVEFFI_ADDON environment variable overrides the addon location
// (an absolute path to the built .node file); otherwise prefer the
// default node-gyp output path and fall back to a prebuilt index.node
// placed next to this file.
let addon;
if (process.env.WEAVEFFI_ADDON) {
  addon = require(process.env.WEAVEFFI_ADDON);
} else {
  try {
    addon = require('./build/Release/weaveffi.node');
  } catch (e) {
    addon = require('./index.node');
  }
}

// Re-export every native binding, then layer the idiomatic wrappers
// (error classes, interface and rich-enum classes, function wrappers)
// on top.
const wv = {};
for (const _name of Object.getOwnPropertyNames(addon)) {
  wv[_name] = addon[_name];
}

class WeaveFFIError extends Error {
  constructor(code, message) {
    super('(' + code + ') ' + (message || ''));
    this.name = 'WeaveFFIError';
    this.code = code;
    this.errorMessage = message || '';
  }
}
wv.WeaveFFIError = WeaveFFIError;
function __generic(code, message) {
  return new WeaveFFIError(code, message);
}
function __rebrand(e, map) {
  return e && typeof e.code === 'number' ? map(e.code, e.message) : e;
}
function __invoke(fn, args, map) {
  try {
    return fn.apply(null, args);
  } catch (e) {
    throw __rebrand(e, map);
  }
}
function __invokeAsync(fn, args, map) {
  return fn.apply(null, args).catch((e) => {
    throw __rebrand(e, map);
  });
}

class TaskError extends WeaveFFIError {
  constructor(code, message) {
    super(code, message);
    this.name = 'TaskError';
  }
}
wv.TaskError = TaskError;
class InvalidNameError extends TaskError {
  constructor(message) {
    super(1, message || 'task name must not be empty');
    this.name = 'InvalidNameError';
  }
}
InvalidNameError.CODE = 1;
wv.InvalidNameError = InvalidNameError;
const __tasksErrorCodes = Object.freeze({ 1: InvalidNameError });
function __tasksErrorFrom(code, message) {
  const _cls = __tasksErrorCodes[code];
  return _cls === undefined ? new WeaveFFIError(code, message) : new _cls(message);
}

wv.runTask = function (name) {
  return __invokeAsync(addon.runTask, [name], __tasksErrorFrom);
};
wv.runBatch = function (names) {
  return __invokeAsync(addon.runBatch, [names], __generic);
};
wv.cancelTask = function (id) {
  return __invoke(addon.cancelTask, [id], __generic);
};
wv.runNTasks = function (n) {
  return __invokeAsync(addon.runNTasks, [n], __generic);
};
wv.activeCallbacks = function () {
  return __invoke(addon.activeCallbacks, [], __generic);
};

module.exports = wv;

// END index.js
