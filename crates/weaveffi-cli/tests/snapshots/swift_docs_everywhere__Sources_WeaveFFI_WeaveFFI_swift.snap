public enum Docs {
    /// Create a brand new document.
    ///
    /// The document starts in `Draft` status; callers must publish
    /// it explicitly to make it visible.
    /// - Parameter title: Human-readable title for the new document
    /// - Parameter tags: Initial set of tags (may be empty)
    public static func create_document(_ title: String, _ tags: [String]) throws -> Document {
        var err = weaveffi_error(code: 0, message: nil)
        let title_bytes = Array(title.utf8)
        let result: OpaquePointer? = title_bytes.withUnsafeBufferPointer { title_buf in
            let title_ptr = title_buf.baseAddress!
            let title_len = title_buf.count
            tags.withUnsafeBufferPointer { tags_buf in
                let tags_ptr = tags_buf.baseAddress
                let tags_len = tags_buf.count
                    return weaveffi_docs_create_document(title_ptr, title_len, tags_ptr, tags_len, &err)
            }
        }
        try check(&err)
        guard let result = result else { throw WeaveFFIError.error(code: -1, message: "null pointer") }
        return Document(ptr: result)
    }
    /// Look up a document by identifier
    /// - Parameter id: Identifier returned from create_document
