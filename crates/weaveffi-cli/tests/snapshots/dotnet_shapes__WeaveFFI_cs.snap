    public static class Shapes
    {
        /// <summary>Render a shape to a string</summary>
        public static string ShapesDescribe(Shape shape)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_shapes_describe(shape.Handle, ref err);
            WeaveFFIError.Check(err);
            var str = Marshal.PtrToStringUTF8(result);
            NativeMethods.weaveffi_free_string(result);
            return str;
        }

        /// <summary>Scale a shape by a factor, returning a new shape</summary>
        public static Shape ShapesScale(Shape shape, double factor)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_shapes_scale(shape.Handle, factor, ref err);
            WeaveFFIError.Check(err);
            return new Shape(result);
        }

        /// <summary>Sum a list of bytes into a wide integer (numerics smoke)</summary>
        public static ulong ShapesSumBytes(byte[] values)
        {
            var err = new WeaveFFIError();
            var valuesArr = new byte[values.Length];
            for (var valuesIt = 0; valuesIt < values.Length; valuesIt++) valuesArr[valuesIt] = values[valuesIt];
            var valuesPin = GCHandle.Alloc(valuesArr, GCHandleType.Pinned);
            try
            {
                var result = NativeMethods.weaveffi_shapes_sum_bytes(values.Length == 0 ? IntPtr.Zero : valuesPin.AddrOfPinnedObject(), (UIntPtr)values.Length, ref err);
                WeaveFFIError.Check(err);
                return result;
            }
            finally
            {
                valuesPin.Free();
            }
        }

        /// <summary>Build a Numerics struct from every numeric primitive</summary>
        public static Numerics ShapesMakeNumerics(sbyte a, short b, int c, long d, byte e, ushort f, uint g, ulong h, float i, double j)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_shapes_make_numerics(a, b, c, d, e, f, g, h, i, j, ref err);
            WeaveFFIError.Check(err);
            return new Numerics(result);
        }

    }

