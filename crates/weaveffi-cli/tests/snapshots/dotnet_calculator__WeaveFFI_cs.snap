// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

#nullable enable

using System;
using System.Collections.Generic;
using System.Runtime.InteropServices;

namespace WeaveFFI
{
    public class WeaveFFIException : Exception
    {
        public int Code { get; }

        public WeaveFFIException(int code, string message) : base(message)
        {
            Code = code;
        }
    }

    /// <summary>Typed exception for the CalcError error domain (module calculator).</summary>
    public class CalcException : WeaveFFIException
    {
        /// <summary>division by zero</summary>
        public const int DivisionByZero = 1;

        public CalcException(int code, string message) : base(code, message)
        {
        }

        /// <summary>Wraps a raw error slot in the typed exception, falling
        /// back to <see cref="WeaveFFIException"/> for unknown codes.</summary>
        internal static WeaveFFIException FromCode(int code, string message)
        {
            switch (code)
            {
                case DivisionByZero:
                    return new CalcException(code, string.IsNullOrEmpty(message) ? "division by zero" : message);
                default:
                    return new WeaveFFIException(code, message);
            }
        }
    }

    [StructLayout(LayoutKind.Sequential)]
    internal struct WeaveFFIError
    {
        public int Code;
        public IntPtr Message;

        internal static void Check(WeaveFFIError err)
        {
            if (err.Code != 0)
            {
                var msg = Marshal.PtrToStringUTF8(err.Message) ?? "";
                throw new WeaveFFIException(err.Code, msg);
            }
        }

        internal static void CheckCalc(WeaveFFIError err)
        {
            if (err.Code != 0)
            {
                var msg = Marshal.PtrToStringUTF8(err.Message) ?? "";
                throw CalcException.FromCode(err.Code, msg);
            }
        }
    }

    internal static class WeaveFFIHelpers
    {
        internal static IntPtr StringToPtr(string? s)
        {
            return s == null ? IntPtr.Zero : Marshal.StringToCoTaskMemUTF8(s);
        }

        internal static string? PtrToString(IntPtr ptr)
        {
            return ptr == IntPtr.Zero ? null : Marshal.PtrToStringUTF8(ptr);
        }

        internal static void FreePtr(IntPtr ptr)
        {
            Marshal.FreeCoTaskMem(ptr);
        }
    }

    internal static class NativeMethods
    {
        private const string LibName = "weaveffi";

        [DllImport(LibName, CallingConvention = CallingConvention.Cdecl)]
        internal static extern void weaveffi_free_string(IntPtr ptr);

        [DllImport(LibName, CallingConvention = CallingConvention.Cdecl)]
        internal static extern void weaveffi_free_bytes(IntPtr ptr, UIntPtr len);

        [DllImport(LibName, EntryPoint = "weaveffi_calculator_add", CallingConvention = CallingConvention.Cdecl)]
        internal static extern int weaveffi_calculator_add(int a, int b, ref WeaveFFIError err);

        [DllImport(LibName, EntryPoint = "weaveffi_calculator_mul", CallingConvention = CallingConvention.Cdecl)]
        internal static extern int weaveffi_calculator_mul(int a, int b, ref WeaveFFIError err);

        [DllImport(LibName, EntryPoint = "weaveffi_calculator_div", CallingConvention = CallingConvention.Cdecl)]
        internal static extern int weaveffi_calculator_div(int a, int b, ref WeaveFFIError err);

        [DllImport(LibName, EntryPoint = "weaveffi_calculator_echo", CallingConvention = CallingConvention.Cdecl)]
        internal static extern IntPtr weaveffi_calculator_echo(IntPtr s, ref WeaveFFIError err);

    }

    public static class Calculator
    {
        /// <summary>Add two integers</summary>
        public static int Add(int a, int b)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_calculator_add(a, b, ref err);
            WeaveFFIError.Check(err);
            return result;
        }

        /// <summary>Multiply two integers</summary>
        public static int Mul(int a, int b)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_calculator_mul(a, b, ref err);
            WeaveFFIError.Check(err);
            return result;
        }

        /// <summary>Divide two integers, failing on a zero divisor</summary>
        /// <exception cref="CalcException">Thrown when the call reports a CalcError code.</exception>
        public static int Div(int a, int b)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_calculator_div(a, b, ref err);
            WeaveFFIError.CheckCalc(err);
            return result;
        }

        /// <summary>Echo a string back</summary>
        public static string Echo(string s)
        {
            var err = new WeaveFFIError();
            var sPtr = Marshal.StringToCoTaskMemUTF8(s);
            try
            {
                var result = NativeMethods.weaveffi_calculator_echo(sPtr, ref err);
                WeaveFFIError.Check(err);
                var str = Marshal.PtrToStringUTF8(result);
                NativeMethods.weaveffi_free_string(result);
                return str;
            }
            finally
            {
                Marshal.FreeCoTaskMem(sPtr);
            }
        }

    }

}

// END WeaveFFI.cs
