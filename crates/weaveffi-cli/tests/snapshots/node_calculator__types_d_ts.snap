// Generated types for WeaveFFI functions
// module calculator
/**
 * Add two integers
 * Maps to C function: weaveffi_calculator_add
 */
export function add(a: number, b: number): number
/**
 * Multiply two integers
 * Maps to C function: weaveffi_calculator_mul
 */
export function mul(a: number, b: number): number
/**
 * Divide two integers
 * Maps to C function: weaveffi_calculator_div
 */
export function div(a: number, b: number): number
/**
 * Echo a string back
 * Maps to C function: weaveffi_calculator_echo
 */
export function echo(s: string): string
