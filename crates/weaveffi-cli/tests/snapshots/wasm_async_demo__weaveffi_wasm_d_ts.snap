// Generated TypeScript declarations for WeaveFFI WASM bindings

export interface TaskResult {
  readonly id: number;
  readonly value: string;
  readonly success: boolean;
}

export interface WeaveffiWasmModule {
  _raw: WebAssembly.Exports;
  tasks: {
    /**
     * @throws {Error} if the native call fails
     */
    run_task(name: string): Promise<TaskResult>;
    /**
     * @throws {Error} if the native call fails
     */
    run_batch(names: string[]): Promise<TaskResult[]>;
    /**
     * @throws {Error} if the native call fails
     */
    cancel_task(id: number): boolean;
  };
}

export function loadWeaveffiWasm(url: string): Promise<WeaveffiWasmModule>;
