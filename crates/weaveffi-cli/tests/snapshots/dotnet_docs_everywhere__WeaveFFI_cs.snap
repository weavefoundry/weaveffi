        /// back to <see cref="WeaveFFIException"/> for unknown codes.</summary>
        internal static WeaveFFIException FromCode(int code, string message)
        {
            switch (code)
            {
                case NotFound:
                    return new DocsErrorsException(code, string.IsNullOrEmpty(message) ? "Document not found" : message);
                case InvalidStatus:
                    return new DocsErrorsException(code, string.IsNullOrEmpty(message) ? "Invalid status transition" : message);
                default:
