final _weaveffiFreeBytes = _lib.lookupFunction<
    _NativeWeaveffiFreeBytes, _DartWeaveffiFreeBytes>('weaveffi_free_bytes');

/// Generic WeaveFFI failure: panics, marshalling errors, and unknown codes.
class WeaveFFIException implements Exception {
  final int code;
  final String message;
  WeaveFFIException(this.code, this.message);
  @override
  String toString() => '$runtimeType($code): $message';
}

void _checkError(Pointer<_WeaveFFIError> err) {
  if (err.ref.code != 0) {
    final code = err.ref.code;
    final msg = err.ref.message.toDartString();
    _weaveffiErrorClear(err);
    throw WeaveFFIException(code, msg);
  }
}

// Live listener trampolines by subscription id. Holding the
// NativeCallable here keeps its native thunk alive until unregistered.
final Map<int, NativeCallable> _listenerCallables = {};

// Anchors one live native iteration for its GC-finalizer backstop.
// A suspended `sync*` frame keeps the anchor reachable; abandoning the
// iteration drops the frame, and the finalizer destroys the native
// iterator handle. Exhausted iterations detach before destroying
// eagerly, so the handle is destroyed exactly once either way.
final class _IteratorLifetime implements Finalizable {}

typedef _NativeCb_weaveffi_events_OnMessage_fn = Void Function(Pointer<Utf8>, Pointer<Void>);

typedef _NativeWeaveffiEventsRegisterMessageListener = Uint64 Function(Pointer<NativeFunction<_NativeCb_weaveffi_events_OnMessage_fn>>, Pointer<Void>);
typedef _DartWeaveffiEventsRegisterMessageListener = int Function(Pointer<NativeFunction<_NativeCb_weaveffi_events_OnMessage_fn>>, Pointer<Void>);
final _weaveffiEventsRegisterMessageListener = _lib.lookupFunction<
    _NativeWeaveffiEventsRegisterMessageListener, _DartWeaveffiEventsRegisterMessageListener>('weaveffi_events_register_message_listener');

typedef _NativeWeaveffiEventsUnregisterMessageListener = Void Function(Uint64);
typedef _DartWeaveffiEventsUnregisterMessageListener = void Function(int);
final _weaveffiEventsUnregisterMessageListener = _lib.lookupFunction<
    _NativeWeaveffiEventsUnregisterMessageListener, _DartWeaveffiEventsUnregisterMessageListener>('weaveffi_events_unregister_message_listener');

/// Registers a OnMessage listener. Returns a subscription id for unregisterMessageListener().
int registerMessageListener(void Function(String message) callback) {
  final callable = NativeCallable<_NativeCb_weaveffi_events_OnMessage_fn>.isolateLocal((Pointer<Utf8> message, Pointer<Void> context) {
    callback(message == nullptr ? '' : message.toDartString());
  });
  final id = _weaveffiEventsRegisterMessageListener(callable.nativeFunction, nullptr);
  _listenerCallables[id] = callable;
  return id;
}

/// Unregisters a listener previously registered with registerMessageListener().
void unregisterMessageListener(int id) {
  _weaveffiEventsUnregisterMessageListener(id);
  _listenerCallables.remove(id)?.close();
}

typedef _NativeWeaveffiEventsSendMessage = Void Function(Pointer<Utf8>, Pointer<_WeaveFFIError>);
typedef _DartWeaveffiEventsSendMessage = void Function(Pointer<Utf8>, Pointer<_WeaveFFIError>);
final _weaveffiEventsSendMessage = _lib.lookupFunction<
    _NativeWeaveffiEventsSendMessage, _DartWeaveffiEventsSendMessage>('weaveffi_events_send_message');

/// Send a message, triggering the OnMessage callback
void sendMessage(String text) {
  final textPtr = text.toNativeUtf8();
  final err = calloc<_WeaveFFIError>();
  try {
    _weaveffiEventsSendMessage(textPtr, err);
    _checkError(err);
  } finally {
    calloc.free(textPtr);
    calloc.free(err);
  }
}

typedef _NativeWeaveffiEventsGetMessages = Pointer<Void> Function(Pointer<_WeaveFFIError>);
typedef _DartWeaveffiEventsGetMessages = Pointer<Void> Function(Pointer<_WeaveFFIError>);
final _weaveffiEventsGetMessages = _lib.lookupFunction<
    _NativeWeaveffiEventsGetMessages, _DartWeaveffiEventsGetMessages>('weaveffi_events_get_messages');

typedef _NativeWeaveffiEventsGetMessagesIteratorNext = Int32 Function(Pointer<Void>, Pointer<Pointer<Utf8>>, Pointer<_WeaveFFIError>);
typedef _DartWeaveffiEventsGetMessagesIteratorNext = int Function(Pointer<Void>, Pointer<Pointer<Utf8>>, Pointer<_WeaveFFIError>);
final _weaveffiEventsGetMessagesIteratorNext = _lib.lookupFunction<
    _NativeWeaveffiEventsGetMessagesIteratorNext, _DartWeaveffiEventsGetMessagesIteratorNext>('weaveffi_events_GetMessagesIterator_next');

typedef _NativeWeaveffiEventsGetMessagesIteratorDestroy = Void Function(Pointer<Void>);
typedef _DartWeaveffiEventsGetMessagesIteratorDestroy = void Function(Pointer<Void>);
final _weaveffiEventsGetMessagesIteratorDestroy = _lib.lookupFunction<
    _NativeWeaveffiEventsGetMessagesIteratorDestroy, _DartWeaveffiEventsGetMessagesIteratorDestroy>('weaveffi_events_GetMessagesIterator_destroy');
final _weaveffiEventsGetMessagesIteratorDestroyFinalizer = NativeFinalizer(
    _lib.lookup<NativeFunction<Void Function(Pointer<Void>)>>('weaveffi_events_GetMessagesIterator_destroy'));

/// Return an iterator over all sent messages
///
/// Returns a lazy [Iterable]: elements are pulled from the native
/// iterator one at a time (one native `next` call per element), and
/// iterating the result again launches a fresh native iterator.
///
/// The native iterator handle is destroyed exactly once: eagerly when
/// the iteration completes or fails, or by a GC finalizer if the
/// iteration is abandoned before it is exhausted.
Iterable<String> getMessages() sync* {
  final err = calloc<_WeaveFFIError>();
  final outItem = calloc<Pointer<Utf8>>();
  Pointer<Void> iter = nullptr;
  final anchor = _IteratorLifetime();
  try {
    iter = _weaveffiEventsGetMessages(err);
    _checkError(err);
    _weaveffiEventsGetMessagesIteratorDestroyFinalizer.attach(anchor, iter, detach: anchor);
    while (_weaveffiEventsGetMessagesIteratorNext(iter, outItem, err) != 0) {
      _checkError(err);
      final itemPtr = outItem.value;
      final item = itemPtr.toDartString();
      _weaveffiFreeString(itemPtr);
      yield item;
    }
    _checkError(err);
  } finally {
    if (iter != nullptr) {
      _weaveffiEventsGetMessagesIteratorDestroyFinalizer.detach(anchor);
      _weaveffiEventsGetMessagesIteratorDestroy(iter);
      iter = nullptr;
    }
    calloc.free(outItem);
    calloc.free(err);
  }
}

