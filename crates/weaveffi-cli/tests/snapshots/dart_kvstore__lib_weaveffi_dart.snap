    try {
      final result = _weaveffiKvEntryCreate(id, keyPtr, valuePtr, value.length, createdAt, expiresAtPtr, tagsPtr, tags.length, metadataKeys, metadataVals, metadata.length, err);
      _checkError(err);
      return Entry._(result);
    } finally {
      calloc.free(keyPtr);
      if (valuePtr != nullptr) calloc.free(valuePtr);
      if (expiresAtPtr != nullptr) calloc.free(expiresAtPtr);
      if (tagsPtr != nullptr) { for (var i = 0; i < tags.length; i++) { calloc.free(tagsPtr[i]); } calloc.free(tagsPtr); }
      if (metadataKeys != nullptr) { for (var i = 0; i < metadata.length; i++) { calloc.free(metadataKeys[i]); } calloc.free(metadataKeys); }
