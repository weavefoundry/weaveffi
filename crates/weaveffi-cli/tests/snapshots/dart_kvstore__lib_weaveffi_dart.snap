  Map<String, String> get metadata {
    final outKeys = calloc<Pointer<Pointer<Utf8>>>();
    final outValues = calloc<Pointer<Pointer<Utf8>>>();
    final outLen = calloc<Size>();
    try {
      _weaveffiKvEntryGetMetadata(_handle, outKeys, outValues, outLen);
      final n = outLen.value;
      final m = <String, String>{};
      final keys = outKeys.value;
      final vals = outValues.value;
      for (var i = 0; i < n; i++) {
        m[keys[i].toDartString()] = vals[i].toDartString();
