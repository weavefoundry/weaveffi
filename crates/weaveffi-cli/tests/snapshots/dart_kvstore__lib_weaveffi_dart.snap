    });
    try {
      _weaveffiKvStoreCompactAsync(_handle, nullptr, callable.nativeFunction, nullptr);
    } catch (e) {
      callable.close();
      rethrow;
    }
    return completer.future;
  }

  /// Legacy single-shot put kept for compatibility
  ///
  /// Throws [KvException] on domain errors.
  @Deprecated('use put() with explicit kind')
  bool legacyPut(String key, List<int> value) {
    final keyPtr = key.toNativeUtf8();
    final valuePtr = value.isEmpty ? nullptr : calloc<Uint8>(value.length);
    for (var i = 0; i < value.length; i++) { valuePtr[i] = value[i]; }
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiKvStoreLegacyPut(_handle, keyPtr, valuePtr, value.length, err);
      _checkKvException(err);
      return result != 0;
    } finally {
      calloc.free(keyPtr);
      if (valuePtr != nullptr) calloc.free(valuePtr);
      calloc.free(err);
    }
  }

  /// The largest number of live entries one store will hold
  static int defaultCapacity() {
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiKvStoreDefaultCapacity(err);
      _checkError(err);
      return result;
    } finally {
      calloc.free(err);
    }
  }
}

typedef _NativeCb_weaveffi_kv_OnEvict_fn = Void Function(Pointer<Utf8>, Pointer<Void>);

typedef _NativeWeaveffiKvRegisterEvictionListener = Uint64 Function(Pointer<NativeFunction<_NativeCb_weaveffi_kv_OnEvict_fn>>, Pointer<Void>);
typedef _DartWeaveffiKvRegisterEvictionListener = int Function(Pointer<NativeFunction<_NativeCb_weaveffi_kv_OnEvict_fn>>, Pointer<Void>);
final _weaveffiKvRegisterEvictionListener = _lib.lookupFunction<
    _NativeWeaveffiKvRegisterEvictionListener, _DartWeaveffiKvRegisterEvictionListener>('weaveffi_kv_register_eviction_listener');

typedef _NativeWeaveffiKvUnregisterEvictionListener = Void Function(Uint64);
typedef _DartWeaveffiKvUnregisterEvictionListener = void Function(int);
final _weaveffiKvUnregisterEvictionListener = _lib.lookupFunction<
    _NativeWeaveffiKvUnregisterEvictionListener, _DartWeaveffiKvUnregisterEvictionListener>('weaveffi_kv_unregister_eviction_listener');

/// Subscribe to per-key eviction notifications
/// Registers a OnEvict listener. Returns a subscription id for unregisterEvictionListener().
int registerEvictionListener(void Function(String key) callback) {
  final callable = NativeCallable<_NativeCb_weaveffi_kv_OnEvict_fn>.isolateLocal((Pointer<Utf8> key, Pointer<Void> context) {
    callback(key == nullptr ? '' : key.toDartString());
  });
  final id = _weaveffiKvRegisterEvictionListener(callable.nativeFunction, nullptr);
  _listenerCallables[id] = callable;
  return id;
}

/// Unregisters a listener previously registered with registerEvictionListener().
void unregisterEvictionListener(int id) {
  _weaveffiKvUnregisterEvictionListener(id);
  _listenerCallables.remove(id)?.close();
}

typedef _NativeWeaveffiKvStatsStatsDestroy = Void Function(Pointer<Void>);
typedef _DartWeaveffiKvStatsStatsDestroy = void Function(Pointer<Void>);
final _weaveffiKvStatsStatsDestroy = _lib.lookupFunction<
    _NativeWeaveffiKvStatsStatsDestroy, _DartWeaveffiKvStatsStatsDestroy>('weaveffi_kv_stats_Stats_destroy');

typedef _NativeWeaveffiKvStatsStatsGetTotalEntries = Int64 Function(Pointer<Void>);
typedef _DartWeaveffiKvStatsStatsGetTotalEntries = int Function(Pointer<Void>);
final _weaveffiKvStatsStatsGetTotalEntries = _lib.lookupFunction<
    _NativeWeaveffiKvStatsStatsGetTotalEntries, _DartWeaveffiKvStatsStatsGetTotalEntries>('weaveffi_kv_stats_Stats_get_total_entries');

typedef _NativeWeaveffiKvStatsStatsGetTotalBytes = Int64 Function(Pointer<Void>);
typedef _DartWeaveffiKvStatsStatsGetTotalBytes = int Function(Pointer<Void>);
final _weaveffiKvStatsStatsGetTotalBytes = _lib.lookupFunction<
    _NativeWeaveffiKvStatsStatsGetTotalBytes, _DartWeaveffiKvStatsStatsGetTotalBytes>('weaveffi_kv_stats_Stats_get_total_bytes');

typedef _NativeWeaveffiKvStatsStatsGetExpiredEntries = Int64 Function(Pointer<Void>);
typedef _DartWeaveffiKvStatsStatsGetExpiredEntries = int Function(Pointer<Void>);
final _weaveffiKvStatsStatsGetExpiredEntries = _lib.lookupFunction<
    _NativeWeaveffiKvStatsStatsGetExpiredEntries, _DartWeaveffiKvStatsStatsGetExpiredEntries>('weaveffi_kv_stats_Stats_get_expired_entries');

/// Aggregate store statistics
class Stats {
  final Pointer<Void> _handle;
  Stats._(this._handle);

  void dispose() {
    _weaveffiKvStatsStatsDestroy(_handle);
  }

  /// Number of live entries
  int get totalEntries {
    final result = _weaveffiKvStatsStatsGetTotalEntries(_handle);
    return result;
  }

  /// Sum of all value byte lengths
  int get totalBytes {
    final result = _weaveffiKvStatsStatsGetTotalBytes(_handle);
    return result;
  }

  /// Number of entries past their TTL but not yet evicted
  int get expiredEntries {
    final result = _weaveffiKvStatsStatsGetExpiredEntries(_handle);
    return result;
  }
}

typedef _NativeWeaveffiKvStatsGetStats = Pointer<Void> Function(Pointer<Void>, Pointer<_WeaveFFIError>);
typedef _DartWeaveffiKvStatsGetStats = Pointer<Void> Function(Pointer<Void>, Pointer<_WeaveFFIError>);
final _weaveffiKvStatsGetStats = _lib.lookupFunction<
    _NativeWeaveffiKvStatsGetStats, _DartWeaveffiKvStatsGetStats>('weaveffi_kv_stats_get_stats');

/// Snapshot the current store statistics
///
/// Throws [KvException] on domain errors.
Stats getStats(Store store) {
  final err = calloc<_WeaveFFIError>();
  try {
    final result = _weaveffiKvStatsGetStats(store._handle, err);
    _checkKvException(err);
    return Stats._(result);
  } finally {
    calloc.free(err);
  }
}

