    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiKvStoreOpen(pathPtr, err);
      _checkKvException(err);
      return Store._(result);
    } finally {
      calloc.free(pathPtr);
      calloc.free(err);
    }
  }

  /// Insert or replace a value, returning true on success
  ///
  /// Throws [KvException] on domain errors.
  bool put(String key, List<int> value, EntryKind kind, int? ttlSeconds) {
    final keyPtr = key.toNativeUtf8();
    final valuePtr = value.isEmpty ? nullptr : calloc<Uint8>(value.length);
    for (var i = 0; i < value.length; i++) { valuePtr[i] = value[i]; }
    Pointer<Int64> ttlSecondsPtr = nullptr;
    if (ttlSeconds != null) {
      ttlSecondsPtr = calloc<Int64>();
      ttlSecondsPtr.value = ttlSeconds;
    }
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiKvStorePut(_handle, keyPtr, valuePtr, value.length, kind.value, ttlSecondsPtr, err);
      _checkKvException(err);
      return result != 0;
    } finally {
      calloc.free(keyPtr);
      if (valuePtr != nullptr) calloc.free(valuePtr);
      if (ttlSecondsPtr != nullptr) calloc.free(ttlSecondsPtr);
      calloc.free(err);
    }
  }

  /// Look up an entry by key; returns null if missing or expired
  ///
  /// Throws [KvException] on domain errors.
  Entry? get(String key) {
    final keyPtr = key.toNativeUtf8();
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiKvStoreGet(_handle, keyPtr, err);
      _checkKvException(err);
      if (result == nullptr) return null;
      return Entry._(result);
    } finally {
      calloc.free(keyPtr);
      calloc.free(err);
    }
  }

  /// Remove the entry for the given key, returning true if it existed
  ///
  /// Throws [KvException] on domain errors.
  bool delete(String key) {
