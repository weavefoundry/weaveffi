/// Typed error domain `KvError` declared by module `kv`.
class KvException extends WeaveFFIException {
  KvException(super.code, super.message);
}

/// No entry exists for the requested key
class KeyNotFoundException extends KvException {
  KeyNotFoundException([String message = 'key not found']) : super(1001, message);
}

/// The entry exists but its TTL has elapsed
class ExpiredException extends KvException {
  ExpiredException([String message = 'entry expired']) : super(1002, message);
}

/// The store has reached its capacity limit
class StoreFullException extends KvException {
  StoreFullException([String message = 'store has reached capacity']) : super(1003, message);
}

/// Underlying storage reported an I/O failure
class IoException extends KvException {
  IoException([String message = 'I/O failure']) : super(1004, message);
}

WeaveFFIException _mapKvException(int code, String message) {
  switch (code) {
    case 1001:
      return KeyNotFoundException(message);
    case 1002:
      return ExpiredException(message);
    case 1003:
      return StoreFullException(message);
    case 1004:
      return IoException(message);
    default:
      return WeaveFFIException(code, message);
  }
}

void _checkKvException(Pointer<_WeaveFFIError> err) {
  if (err.ref.code != 0) {
    final code = err.ref.code;
    final msg = err.ref.message.toDartString();
    _weaveffiErrorClear(err);
    throw _mapKvException(code, msg);
  }
}

/// Persistence semantics applied to a stored entry
enum EntryKind {
  /// In-memory only; lost on close
  volatile(0),
  /// Flushed to durable storage
  persistent(1),
  /// Persistent and encrypted at rest
  encrypted(2),
  ;
  const EntryKind(this.value);
  final int value;

  static EntryKind fromValue(int value) =>
      EntryKind.values.firstWhere((e) => e.value == value);
}

