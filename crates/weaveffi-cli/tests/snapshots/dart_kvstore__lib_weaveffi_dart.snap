    final id = _id!;
    final key = _key!;
    final value = _value!;
    final createdAt = _createdAt!;
    final expiresAt = _expiresAt;
    final tags = _tags!;
    final metadata = _metadata!;
  final keyPtr = key.toNativeUtf8();
  final valuePtr = value.isEmpty ? nullptr : calloc<Uint8>(value.length);
