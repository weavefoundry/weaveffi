  int get createdAt {
    final result = _weaveffiKvEntryGetCreatedAt(_handle);
    return result;
  }

  /// Optional unix-timestamp seconds at which the entry expires
  int? get expiresAt {
    final result = _weaveffiKvEntryGetExpiresAt(_handle);
    if (result == nullptr) return null;
    return result.value;
