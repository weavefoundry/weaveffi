  final metadataVals = metadata.isEmpty ? nullptr : calloc<Pointer<Utf8>>(metadata.length);
  for (var i = 0; i < metadataEntries.length; i++) {
    metadataKeys[i] = metadataEntries[i].key.toNativeUtf8();
    metadataVals[i] = metadataEntries[i].value.toNativeUtf8();
  }
