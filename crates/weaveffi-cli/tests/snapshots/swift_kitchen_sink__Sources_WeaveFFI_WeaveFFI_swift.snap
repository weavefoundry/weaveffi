    public func describe() -> String {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_Gadget_describe(ptr, &err)
        trap(&err)
        guard let rv = rv else { fatalError("-1: null string") }
        defer { weaveffi_free_string(rv) }
        return String(cString: rv)
    }
    /// Poke the gadget a number of times, failing on a negative count
    public func poke(times: Int32) throws -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_Gadget_poke(ptr, times, &err)
        try checkKitchen(&err)
        return rv
    }
    /// The gadget subsystem version string
    public static func version() -> String {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_Gadget_version(&err)
        trap(&err)
        guard let rv = rv else { fatalError("-1: null string") }
        defer { weaveffi_free_string(rv) }
        return String(cString: rv)
    }
}

/// A lazy sequence over the `Item` elements streamed by `weaveffi_kitchen_stream_items`.
///
/// Each `next()` call pulls exactly one element from the producer. The
/// underlying C iterator is destroyed eagerly on exhaustion and from
/// `deinit` when iteration is abandoned early.
public final class KitchenStreamItemsIterator: Sequence, IteratorProtocol {
    private var handle: OpaquePointer?

    init(handle: OpaquePointer) {
        self.handle = handle
    }

    deinit {
        destroyHandle()
    }

    private func destroyHandle() {
        guard let handle = handle else { return }
        weaveffi_kitchen_StreamItemsIterator_destroy(handle)
        self.handle = nil
    }

    /// Pulls the next element from the producer, or returns `nil` once the
    /// stream is exhausted (destroying the underlying iterator).
    public func next() -> Item? {
        guard let handle = handle else { return nil }
        var item: OpaquePointer? = nil
        var err = weaveffi_error(code: 0, message: nil)
        if weaveffi_kitchen_StreamItemsIterator_next(handle, &item, &err) == 0 {
            if err.code != 0 {
                let code = err.code
                let message = err.message.flatMap { String(cString: $0) } ?? ""
                weaveffi_error_clear(&err)
                fatalError("\(code): \(message)")
            }
            destroyHandle()
            return nil
        }
        let element = Item(ptr: item!)
        return element
    }
}

public enum Kitchen {
    /// Subscribe to OnReady events
    /// - Returns: A subscription id for ``unregisterReadyListener(_:)``.
    public static func registerReadyListener(_ callback: @escaping (Int32, String) -> Void) -> UInt64 {
        let box = WvCallbackBox(callback)
        let ctx = Unmanaged.passRetained(box).toOpaque()
        let id = weaveffi_kitchen_register_ready_listener({ code, msg, context in
            let cb = Unmanaged<WvCallbackBox<(Int32, String) -> Void>>.fromOpaque(context!).takeUnretainedValue().value
            cb(code, String(cString: msg!))
        }, ctx)
        wvListenerLock.lock()
        wvListenerContexts[id] = ctx
        wvListenerLock.unlock()
        return id
    }
    /// Unregisters a listener previously registered with ``registerReadyListener(_:)``.
    public static func unregisterReadyListener(_ id: UInt64) {
        weaveffi_kitchen_unregister_ready_listener(id)
        wvListenerLock.lock()
        let ctx = wvListenerContexts.removeValue(forKey: id)
        wvListenerLock.unlock()
        if let ctx = ctx {
            Unmanaged<WvCallbackBox<(Int32, String) -> Void>>.fromOpaque(ctx).release()
        }
    }
    /// Identity for bool
    public static func boolId(x: Bool) -> Bool {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_bool_id(x, &err)
        trap(&err)
        return rv
    }
