    }
    public static func i64Id(x: Int64) -> Int64 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_i64_id(x, &err)
        trap(&err)
        return rv
    }
    public static func f64Id(x: Double) -> Double {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_f64_id(x, &err)
        trap(&err)
        return rv
    }
    public static func echoString(s: String) -> String {
        var err = weaveffi_error(code: 0, message: nil)
        let result: String = s.withCString { s_ptr in
                let rv = weaveffi_kitchen_echo_string(s_ptr, &err)
                trap(&err)
                guard let rv = rv else { fatalError("-1: null string") }
                defer { weaveffi_free_string(rv) }
                return String(cString: rv)
        }
        return result
    }
    public static func echoBytes(b: Data) -> Data {
        var err = weaveffi_error(code: 0, message: nil)
        let b_bytes = Array(b)
        let result: Data = b_bytes.withUnsafeBufferPointer { b_buf in
            let b_ptr = b_buf.baseAddress!
            let b_len = b_buf.count
                return weaveffi_kitchen_echo_bytes(b_ptr, b_len, &err)
        }
        trap(&err)
        return result
    }
    /// Borrowed string parameter
    public static func echoBorrowedStr(s: String) -> String {
        var err = weaveffi_error(code: 0, message: nil)
        let result: String = s.withCString { s_ptr in
                let rv = weaveffi_kitchen_echo_borrowed_str(s_ptr, &err)
                trap(&err)
                guard let rv = rv else { fatalError("-1: null string") }
                defer { weaveffi_free_string(rv) }
                return String(cString: rv)
        }
        return result
    }
    /// Borrowed bytes parameter
    public static func echoBorrowedBytes(b: Data) -> Data {
        var err = weaveffi_error(code: 0, message: nil)
        let b_bytes = Array(b)
        let result: Data = b_bytes.withUnsafeBufferPointer { b_buf in
            let b_ptr = b_buf.baseAddress!
            let b_len = b_buf.count
                return weaveffi_kitchen_echo_borrowed_bytes(b_ptr, b_len, &err)
        }
        trap(&err)
        return result
    }
    /// Returns an opaque handle
    public static func openHandle() -> UInt64 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_open_handle(&err)
        trap(&err)
        return rv
    }
    /// Returns a typed handle
    public static func openTypedHandle() -> Token {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_open_typed_handle(&err)
        trap(&err)
        guard let rv = rv else { fatalError("-1: null pointer") }
        return Token(ptr: rv)
    }
    /// Optional struct return
    public static func maybeItem(id: Int64) throws -> Item? {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_maybe_item(id, &err)
        try checkKitchen(&err)
        return rv.map { Item(ptr: $0) }
    }
    /// List of structs
    public static func listItems() -> [Item] {
        var err = weaveffi_error(code: 0, message: nil)
        var outLen: Int = 0
        let rv = weaveffi_kitchen_list_items(&outLen, &err)
        trap(&err)
        guard let rv = rv else { return [] }
        defer { wvFreeArray(rv, outLen) }
        return (0..<outLen).map { Item(ptr: rv[$0]!) }
    }
    /// Map return type
    public static func getAttrs() -> [String: Int32] {
        var err = weaveffi_error(code: 0, message: nil)
        var outKeysPtr: UnsafeMutablePointer<UnsafePointer<CChar>?>? = nil
        var outValuesPtr: UnsafeMutablePointer<Int32>? = nil
        var outLen: Int = 0
        weaveffi_kitchen_get_attrs(&outKeysPtr, &outValuesPtr, &outLen, &err)
        trap(&err)
        guard let outKeys = outKeysPtr, let outValues = outValuesPtr else { return [:] }
        defer { wvFreeArray(outKeys, outLen); wvFreeArray(outValues, outLen) }
        var result: [String: Int32] = [:]
        for i in 0..<outLen {
            result[String(cString: outKeys[i]!)] = outValues[i]
            weaveffi_free_string(outKeys[i])
        }
        return result
    }
    /// Iterator return type
    /// - Returns: A lazy sequence that pulls one element per step from the
    ///   producer; the underlying iterator is destroyed when the sequence is
    ///   exhausted or deinitialized.
    public static func streamItems() -> KitchenStreamItemsIterator {
        var err = weaveffi_error(code: 0, message: nil)
        let iter = weaveffi_kitchen_stream_items(&err)
        trap(&err)
        guard let iter = iter else { fatalError("-1: null iterator") }
        return KitchenStreamItemsIterator(handle: iter)
    }
    /// Returns the shared Token type from another module
    public static func crossModuleToken() -> Token {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_cross_module_token(&err)
        trap(&err)
        guard let rv = rv else { fatalError("-1: null pointer") }
        return Token(ptr: rv)
    }
    /// Async operation
    public static func doAsync(input: String) async -> String {
        await withCheckedContinuation { (continuation: CheckedContinuation<String, Never>) in
            let ctx = Unmanaged.passRetained(ContinuationRef(continuation)).toOpaque()
            input.withCString { input_ptr in
                weaveffi_kitchen_do_async_async(input_ptr, { context, err, result in
                    let contRef = Unmanaged<ContinuationRef<String, Never>>.fromOpaque(context!).takeRetainedValue()
                    if let err = err, err.pointee.code != 0 {
                        let code = err.pointee.code
                        let msg = err.pointee.message.flatMap { String(cString: $0) } ?? ""
                        fatalError("\(code): \(msg)")
                    } else {
                        guard let result = result else {
                            fatalError("-1: null string")
                        }
                        contRef.value.resume(returning: String(cString: result))
                    }
                }, ctx)
            }
        }
    }
    /// Cancellable async operation
    public static func doCancellable(input: String) async -> String {
        await withCheckedContinuation { (continuation: CheckedContinuation<String, Never>) in
            let ctx = Unmanaged.passRetained(ContinuationRef(continuation)).toOpaque()
            input.withCString { input_ptr in
                weaveffi_kitchen_do_cancellable_async(input_ptr, nil, { context, err, result in
                    let contRef = Unmanaged<ContinuationRef<String, Never>>.fromOpaque(context!).takeRetainedValue()
                    if let err = err, err.pointee.code != 0 {
                        let code = err.pointee.code
                        let msg = err.pointee.message.flatMap { String(cString: $0) } ?? ""
                        fatalError("\(code): \(msg)")
                    } else {
                        guard let result = result else {
                            fatalError("-1: null string")
                        }
                        contRef.value.resume(returning: String(cString: result))
                    }
                }, ctx)
            }
        }
    }
    /// Legacy operation kept for compatibility
    @available(*, deprecated, message: "Use new_op instead")
    public static func legacyOp() -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_legacy_op(&err)
        trap(&err)
        return rv
    }
    /// Replacement for legacy_op
    public static func newOp() -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_new_op(&err)
        trap(&err)
        return rv
    }
    public enum Nested {
        /// Trivial nested-module function
        public static func hello() -> String {
            var err = weaveffi_error(code: 0, message: nil)
            let rv = weaveffi_kitchen_nested_hello(&err)
            trap(&err)
            guard let rv = rv else { fatalError("-1: null string") }
            defer { weaveffi_free_string(rv) }
            return String(cString: rv)
        }
    }
}

// END WeaveFFI.swift
