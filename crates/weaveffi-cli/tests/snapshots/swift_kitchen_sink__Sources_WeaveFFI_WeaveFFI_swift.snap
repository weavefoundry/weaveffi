import CWeaveFFI
import Foundation

public enum WeaveFFIError: Error, LocalizedError {
    case error(code: Int32, message: String)
    case notFound
    case invalidInput
    public var errorDescription: String? {
        switch self {
        case let .error(_, message): return message
        case .notFound: return "Item not found"
        case .invalidInput: return "Invalid input"
        }
    }
    public var errorCode: Int32 {
        switch self {
        case let .error(code, _): return code
        case .notFound: return 1
        case .invalidInput: return 2
        }
    }
}

@inline(__always)
func check(_ err: inout weaveffi_error) throws {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        switch code {
        case 1: throw WeaveFFIError.notFound
        case 2: throw WeaveFFIError.invalidInput
        default: throw WeaveFFIError.error(code: code, message: message)
        }
    }
}

@inline(__always)
func withOptionalPointer<T, R>(to value: T?, _ body: (UnsafePointer<T>?) throws -> R) rethrows -> R {
    guard let value = value else { return try body(nil) }
    return try withUnsafePointer(to: value) { try body($0) }
}

private final class ContinuationRef<T> {
    let value: CheckedContinuation<T, Error>
    init(_ value: CheckedContinuation<T, Error>) { self.value = value }
}

/// A reusable token referenced across modules
public class Token {
    let ptr: OpaquePointer

    init(ptr: OpaquePointer) {
        self.ptr = ptr
    }

    deinit {
        weaveffi_shared_Token_destroy(ptr)
    }

    public var id: Int64 {
        return weaveffi_shared_Token_get_id(ptr)
    }

    public var label: String {
        let raw = weaveffi_shared_Token_get_label(ptr)
        guard let raw = raw else { return "" }
        defer { weaveffi_free_string(raw) }
        return String(cString: raw)
    }
}

public enum Shared {
    /// Trivial cross-module helper
    public static func ping() throws -> String {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_shared_ping(&err)
        try check(&err)
        guard let rv = rv else { throw WeaveFFIError.error(code: -1, message: "null string") }
        defer { weaveffi_free_string(rv) }
        return String(cString: rv)
    }
}

/// Task priority levels
public enum Priority: Int32 {
    /// Low priority
    case low = 0
    /// Normal priority
    case normal = 1
    /// High priority
    case high = 2
}

/// Kitchen sink struct exercising every field feature
public class Item {
    let ptr: OpaquePointer

    init(ptr: OpaquePointer) {
        self.ptr = ptr
    }

    deinit {
        weaveffi_kitchen_Item_destroy(ptr)
    }

    /// Stable identifier
    public var id: Int64 {
        return weaveffi_kitchen_Item_get_id(ptr)
    }

    /// Display name
    public var name: String {
        let raw = weaveffi_kitchen_Item_get_name(ptr)
        guard let raw = raw else { return "" }
        defer { weaveffi_free_string(raw) }
        return String(cString: raw)
    }

    /// Initial count
    public var count: Int32 {
        return weaveffi_kitchen_Item_get_count(ptr)
    }

    /// Whether the item is enabled
    public var enabled: Bool {
        return weaveffi_kitchen_Item_get_enabled(ptr)
    }

    /// Scaling ratio
    public var ratio: Double {
        return weaveffi_kitchen_Item_get_ratio(ptr)
    }

    public var nick: UInt32 {
        return weaveffi_kitchen_Item_get_nick(ptr)
    }

    public var payload: Data {
        var outLen: Int = 0
        let raw = weaveffi_kitchen_Item_get_payload(ptr, &outLen)
        guard let raw = raw else { return Data() }
        defer { weaveffi_free_bytes(UnsafeMutablePointer(mutating: raw), outLen) }
        return Data(bytes: raw, count: outLen)
    }

    public var tags: [String] {
        var outLen: Int = 0
        let rv = weaveffi_kitchen_Item_get_tags(ptr, &outLen)
        guard let rv = rv else { return [] }
        return Array(UnsafeBufferPointer(start: rv, count: outLen))
    }

    public var attrs: [String: String] {
        return weaveffi_kitchen_Item_get_attrs(ptr)
    }

    public var parent: Int64? {
        let p = weaveffi_kitchen_Item_get_parent(ptr)
        return p?.pointee
    }

    /// Cross-module struct reference
    public var token: Token {
        return Token(ptr: weaveffi_kitchen_Item_get_token(ptr)!)
    }

    public var priority: Priority {
        return weaveffi_kitchen_Item_get_priority(ptr)
    }
}

/// Kitchen sink struct exercising every field feature
public class ItemBuilder {
    private var _id: Int64?
    private var _name: String?
    private var _count: Int32?
    private var _enabled: Bool?
    private var _ratio: Double?
    private var _nick: UInt32?
    private var _payload: Data?
    private var _tags: [String]?
    private var _attrs: [String: String]?
    private var _parent: Int64??
    private var _token: Token?
    private var _priority: Priority?

    public init() {}

    /// Stable identifier
    @discardableResult
    public func withId(_ value: Int64) -> Self {
        self._id = value
        return self
    }

    /// Display name
    @discardableResult
    public func withName(_ value: String) -> Self {
        self._name = value
        return self
    }

    /// Initial count
    @discardableResult
    public func withCount(_ value: Int32) -> Self {
        self._count = value
        return self
    }

    /// Whether the item is enabled
    @discardableResult
    public func withEnabled(_ value: Bool) -> Self {
        self._enabled = value
        return self
    }

    /// Scaling ratio
    @discardableResult
    public func withRatio(_ value: Double) -> Self {
        self._ratio = value
        return self
    }

    @discardableResult
    public func withNick(_ value: UInt32) -> Self {
        self._nick = value
        return self
    }

    @discardableResult
    public func withPayload(_ value: Data) -> Self {
        self._payload = value
        return self
    }

    @discardableResult
    public func withTags(_ value: [String]) -> Self {
        self._tags = value
        return self
    }

    @discardableResult
    public func withAttrs(_ value: [String: String]) -> Self {
        self._attrs = value
        return self
    }

    @discardableResult
    public func withParent(_ value: Int64?) -> Self {
        self._parent = value
        return self
    }

    /// Cross-module struct reference
    @discardableResult
    public func withToken(_ value: Token) -> Self {
        self._token = value
        return self
    }

    @discardableResult
    public func withPriority(_ value: Priority) -> Self {
        self._priority = value
        return self
    }

    public func build() throws -> Item {
        guard let id = _id else { fatalError("missing field: id") }
        guard let name = _name else { fatalError("missing field: name") }
        guard let count = _count else { fatalError("missing field: count") }
        guard let enabled = _enabled else { fatalError("missing field: enabled") }
        guard let ratio = _ratio else { fatalError("missing field: ratio") }
        guard let nick = _nick else { fatalError("missing field: nick") }
        guard let payload = _payload else { fatalError("missing field: payload") }
        guard let tags = _tags else { fatalError("missing field: tags") }
        guard let attrs = _attrs else { fatalError("missing field: attrs") }
        guard let parent = _parent else { fatalError("missing field: parent") }
        guard let token = _token else { fatalError("missing field: token") }
        guard let priority = _priority else { fatalError("missing field: priority") }
        var err = weaveffi_error(code: 0, message: nil)
        let name_bytes = Array(name.utf8)
        let payload_bytes = Array(payload)
        let attrs_keys = Array(attrs.keys)
        let attrs_values = attrs_keys.map { attrs[$0]! }
        let result: OpaquePointer? = name_bytes.withUnsafeBufferPointer { name_buf in
            let name_ptr = name_buf.baseAddress!
            let name_len = name_buf.count
            payload_bytes.withUnsafeBufferPointer { payload_buf in
                let payload_ptr = payload_buf.baseAddress!
                let payload_len = payload_buf.count
                tags.withUnsafeBufferPointer { tags_buf in
                    let tags_ptr = tags_buf.baseAddress
                    let tags_len = tags_buf.count
                    attrs_keys.withUnsafeBufferPointer { attrs_keys_buf in
                        let attrs_keys_ptr = attrs_keys_buf.baseAddress
                        attrs_values.withUnsafeBufferPointer { attrs_values_buf in
                            let attrs_values_ptr = attrs_values_buf.baseAddress
                            let attrs_len = attrs_values_buf.count
                            withOptionalPointer(to: parent) { parent_ptr in
                                    return weaveffi_kitchen_Item_create(id, name_ptr, name_len, count, enabled, ratio, nick, payload_ptr, payload_len, tags_ptr, tags_len, attrs_keys_ptr, attrs_values_ptr, attrs_len, parent_ptr, token.ptr, weaveffi_kitchen_Priority(priority.rawValue), &err)
                            }
                        }
                    }
                }
            }
        }
        try check(&err)
        guard let result = result else { throw WeaveFFIError.error(code: -1, message: "null pointer") }
        return Item(ptr: result)
    }
}

public enum Kitchen {
    /// Identity for bool
    public static func bool_id(_ x: Bool) throws -> Bool {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_bool_id(x, &err)
        try check(&err)
        return rv
    }
    public static func i32_id(_ x: Int32) throws -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_i32_id(x, &err)
        try check(&err)
        return rv
    }
    public static func u32_id(_ x: UInt32) throws -> UInt32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_u32_id(x, &err)
        try check(&err)
        return rv
    }
    public static func i64_id(_ x: Int64) throws -> Int64 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_i64_id(x, &err)
        try check(&err)
        return rv
    }
    public static func f64_id(_ x: Double) throws -> Double {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_f64_id(x, &err)
        try check(&err)
        return rv
    }
    public static func echo_string(_ s: String) throws -> String {
        var err = weaveffi_error(code: 0, message: nil)
        let s_bytes = Array(s.utf8)
        let result: String = s_bytes.withUnsafeBufferPointer { s_buf in
            let s_ptr = s_buf.baseAddress!
            let s_len = s_buf.count
                let rv = weaveffi_kitchen_echo_string(s_ptr, s_len, &err)
                try check(&err)
                guard let rv = rv else { throw WeaveFFIError.error(code: -1, message: "null string") }
                defer { weaveffi_free_string(rv) }
                return String(cString: rv)
        }
        return result
    }
    public static func echo_bytes(_ b: Data) throws -> Data {
        var err = weaveffi_error(code: 0, message: nil)
        let b_bytes = Array(b)
        let result: Data = b_bytes.withUnsafeBufferPointer { b_buf in
            let b_ptr = b_buf.baseAddress!
            let b_len = b_buf.count
                return weaveffi_kitchen_echo_bytes(b_ptr, b_len, &err)
        }
        try check(&err)
        return result
    }
    /// Borrowed string parameter
    public static func echo_borrowed_str(_ s: String) throws -> String {
        var err = weaveffi_error(code: 0, message: nil)
        let s_bytes = Array(s.utf8)
        let result: String = s_bytes.withUnsafeBufferPointer { s_buf in
            let s_ptr = s_buf.baseAddress!
            let s_len = s_buf.count
                let rv = weaveffi_kitchen_echo_borrowed_str(s_ptr, s_len, &err)
                try check(&err)
                guard let rv = rv else { throw WeaveFFIError.error(code: -1, message: "null string") }
                defer { weaveffi_free_string(rv) }
                return String(cString: rv)
        }
        return result
    }
    /// Borrowed bytes parameter
    public static func echo_borrowed_bytes(_ b: Data) throws -> Data {
        var err = weaveffi_error(code: 0, message: nil)
        let b_bytes = Array(b)
        let result: Data = b_bytes.withUnsafeBufferPointer { b_buf in
            let b_ptr = b_buf.baseAddress!
            let b_len = b_buf.count
                return weaveffi_kitchen_echo_borrowed_bytes(b_ptr, b_len, &err)
        }
        try check(&err)
        return result
    }
    /// Returns an opaque handle
    public static func open_handle() throws -> UInt64 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_open_handle(&err)
        try check(&err)
        return rv
    }
    /// Returns a typed handle
    public static func open_typed_handle() throws -> Token {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_open_typed_handle(&err)
        try check(&err)
        guard let rv = rv else { throw WeaveFFIError.error(code: -1, message: "null pointer") }
        return Token(ptr: rv)
    }
    /// Optional struct return
    public static func maybe_item(_ id: Int64) throws -> Item? {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_maybe_item(id, &err)
        try check(&err)
        return rv.map { Item(ptr: $0) }
    }
    /// List of structs
    public static func list_items() throws -> [Item] {
        var err = weaveffi_error(code: 0, message: nil)
        var outLen: Int = 0
        let rv = weaveffi_kitchen_list_items(&outLen, &err)
        try check(&err)
        guard let rv = rv else { return [] }
        return (0..<outLen).map { Item(ptr: rv[$0]!) }
    }
    /// Map return type
    public static func get_attrs() throws -> [String: Int32] {
        var err = weaveffi_error(code: 0, message: nil)
        var outKeysPtr: UnsafeMutablePointer<UnsafePointer<CChar>?>? = nil
        var outValuesPtr: UnsafeMutablePointer<Int32>? = nil
        var outLen: Int = 0
        weaveffi_kitchen_get_attrs(&outKeysPtr, &outValuesPtr, &outLen, &err)
        try check(&err)
        guard let outKeys = outKeysPtr, let outValues = outValuesPtr else { return [:] }
        var result: [String: Int32] = [:]
        for i in 0..<outLen {
            result[String(cString: outKeys[i]!)] = outValues[i]
        }
        return result
    }
    /// Iterator return type
    public static func stream_items() throws -> [Item] {
        var err = weaveffi_error(code: 0, message: nil)
        let iter = weaveffi_kitchen_stream_items(&err)
        try check(&err)
        guard let iter = iter else { return [] }
        var items: [Item] = []
        while let ptr = weaveffi_kitchen_StreamItemsIterator_next(iter) {
            items.append(Item(ptr: ptr))
        }
        weaveffi_kitchen_StreamItemsIterator_destroy(iter)
        return items
    }
    /// Returns the shared Token type from another module
    public static func cross_module_token() throws -> Token {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_cross_module_token(&err)
        try check(&err)
        guard let rv = rv else { throw WeaveFFIError.error(code: -1, message: "null pointer") }
        return Token(ptr: rv)
    }
    /// Async operation
    public static func do_async(_ input: String) async throws -> String {
        try await withCheckedThrowingContinuation { (continuation: CheckedContinuation<String, Error>) in
            let ctx = Unmanaged.passRetained(ContinuationRef(continuation)).toOpaque()
            let input_bytes = Array(input.utf8)
            input_bytes.withUnsafeBufferPointer { input_buf in
                let input_ptr = input_buf.baseAddress!
                let input_len = input_buf.count
                weaveffi_kitchen_do_async_async(input_ptr, input_len, { context, err, result in
                    let contRef = Unmanaged<ContinuationRef<String>>.fromOpaque(context!).takeRetainedValue()
                    if let err = err, err.pointee.code != 0 {
                        let code = err.pointee.code
                        let msg = err.pointee.message.flatMap { String(cString: $0) } ?? ""
                        contRef.value.resume(throwing: WeaveFFIError.error(code: code, message: msg))
                    } else {
                        guard let result = result else {
                            contRef.value.resume(throwing: WeaveFFIError.error(code: -1, message: "null string"))
                            return
                        }
                        let str = String(cString: result)
                        weaveffi_free_string(UnsafeMutablePointer(mutating: result))
                        contRef.value.resume(returning: str)
                    }
                }, ctx)
            }
        }
    }
    /// Cancellable async operation
    public static func do_cancellable(_ input: String) async throws -> String {
        try await withCheckedThrowingContinuation { (continuation: CheckedContinuation<String, Error>) in
            let ctx = Unmanaged.passRetained(ContinuationRef(continuation)).toOpaque()
            let input_bytes = Array(input.utf8)
            input_bytes.withUnsafeBufferPointer { input_buf in
                let input_ptr = input_buf.baseAddress!
                let input_len = input_buf.count
                weaveffi_kitchen_do_cancellable_async(input_ptr, input_len, nil, { context, err, result in
                    let contRef = Unmanaged<ContinuationRef<String>>.fromOpaque(context!).takeRetainedValue()
                    if let err = err, err.pointee.code != 0 {
                        let code = err.pointee.code
                        let msg = err.pointee.message.flatMap { String(cString: $0) } ?? ""
                        contRef.value.resume(throwing: WeaveFFIError.error(code: code, message: msg))
                    } else {
                        guard let result = result else {
                            contRef.value.resume(throwing: WeaveFFIError.error(code: -1, message: "null string"))
                            return
                        }
                        let str = String(cString: result)
                        weaveffi_free_string(UnsafeMutablePointer(mutating: result))
                        contRef.value.resume(returning: str)
                    }
                }, ctx)
            }
        }
    }
    /// Legacy operation kept for compatibility
    @available(*, deprecated, message: "Use new_op instead")
    public static func legacy_op() throws -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_legacy_op(&err)
        try check(&err)
        return rv
    }
    /// Replacement for legacy_op
    public static func new_op() throws -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_kitchen_new_op(&err)
        try check(&err)
        return rv
    }
    public enum Nested {
        /// Trivial nested-module function
        public static func hello() throws -> String {
            var err = weaveffi_error(code: 0, message: nil)
            let rv = weaveffi_kitchen_nested_hello(&err)
            try check(&err)
            guard let rv = rv else { throw WeaveFFIError.error(code: -1, message: "null string") }
            defer { weaveffi_free_string(rv) }
            return String(cString: rv)
        }
    }
}
