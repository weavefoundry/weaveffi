    public func withRatio(_ value: Double) -> Self {
        self._ratio = value
        return self
    }

    @discardableResult
    public func withNick(_ value: UInt32) -> Self {
        self._nick = value
        return self
    }

    @discardableResult
    public func withPayload(_ value: Data) -> Self {
        self._payload = value
        return self
    }

    @discardableResult
    public func withTags(_ value: [String]) -> Self {
        self._tags = value
        return self
    }

    @discardableResult
    public func withAttrs(_ value: [String: String]) -> Self {
        self._attrs = value
        return self
    }

    @discardableResult
    public func withParent(_ value: Int64?) -> Self {
        self._parent = value
        return self
    }

    /// Cross-module struct reference
    @discardableResult
    public func withToken(_ value: Token) -> Self {
        self._token = value
        return self
    }

    @discardableResult
    public func withPriority(_ value: Priority) -> Self {
        self._priority = value
        return self
    }

    public func build() throws -> Item {
        guard let id = _id else { throw WeaveFFIError.error(code: -1, message: "missing field: id") }
        guard let name = _name else { throw WeaveFFIError.error(code: -1, message: "missing field: name") }
        guard let count = _count else { throw WeaveFFIError.error(code: -1, message: "missing field: count") }
        guard let enabled = _enabled else { throw WeaveFFIError.error(code: -1, message: "missing field: enabled") }
        guard let ratio = _ratio else { throw WeaveFFIError.error(code: -1, message: "missing field: ratio") }
        guard let nick = _nick else { throw WeaveFFIError.error(code: -1, message: "missing field: nick") }
        guard let payload = _payload else { throw WeaveFFIError.error(code: -1, message: "missing field: payload") }
        guard let tags = _tags else { throw WeaveFFIError.error(code: -1, message: "missing field: tags") }
        guard let attrs = _attrs else { throw WeaveFFIError.error(code: -1, message: "missing field: attrs") }
        guard let parent = _parent else { throw WeaveFFIError.error(code: -1, message: "missing field: parent") }
        guard let token = _token else { throw WeaveFFIError.error(code: -1, message: "missing field: token") }
        guard let priority = _priority else { throw WeaveFFIError.error(code: -1, message: "missing field: priority") }
        var err = weaveffi_error(code: 0, message: nil)
        let payload_bytes = Array(payload)
        let tags_cstrs: [UnsafePointer<CChar>?] = tags.map { UnsafePointer(strdup($0)) }
        defer { tags_cstrs.forEach { if let s = $0 { free(UnsafeMutablePointer(mutating: s)) } } }
        let attrs_keys = Array(attrs.keys)
        let attrs_values = attrs_keys.map { attrs[$0]! }
        let attrs_keysCstrs: [UnsafePointer<CChar>?] = attrs_keys.map { UnsafePointer(strdup($0)) }
        defer { attrs_keysCstrs.forEach { if let s = $0 { free(UnsafeMutablePointer(mutating: s)) } } }
        let attrs_valuesCstrs: [UnsafePointer<CChar>?] = attrs_values.map { UnsafePointer(strdup($0)) }
        defer { attrs_valuesCstrs.forEach { if let s = $0 { free(UnsafeMutablePointer(mutating: s)) } } }
        let result: OpaquePointer? = name.withCString { name_ptr in
            return payload_bytes.withUnsafeBufferPointer { payload_buf in
                let payload_ptr = payload_buf.baseAddress!
                let payload_len = payload_buf.count
                return tags_cstrs.withUnsafeBufferPointer { tags_buf in
                    let tags_ptr = tags_buf.baseAddress
                    let tags_len = tags_buf.count
                    return attrs_keysCstrs.withUnsafeBufferPointer { attrs_keys_buf in
                        let attrs_keys_ptr = attrs_keys_buf.baseAddress
                        return attrs_valuesCstrs.withUnsafeBufferPointer { attrs_values_buf in
                            let attrs_values_ptr = attrs_values_buf.baseAddress
                            let attrs_len = attrs_values_buf.count
                            return withOptionalPointer(to: parent) { parent_ptr in
                                    return weaveffi_kitchen_Item_create(id, name_ptr, count, enabled, ratio, nick, payload_ptr, payload_len, tags_ptr, tags_len, attrs_keys_ptr, attrs_values_ptr, attrs_len, parent_ptr, token.ptr, weaveffi_kitchen_Priority(priority.rawValue), &err)
                            }
                        }
                    }
                }
            }
        }
        try check(&err)
        guard let result = result else { throw WeaveFFIError.error(code: -1, message: "null pointer") }
        return Item(ptr: result)
    }
}

/// A pocket-sized interface exercising the object surface
public final class Gadget {
    let ptr: OpaquePointer

    init(ptr: OpaquePointer) {
