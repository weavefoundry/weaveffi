// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

import CWeaveFFI
import Foundation

public enum WeaveFFIError: Error, LocalizedError {
    case error(code: Int32, message: String)
    public var errorDescription: String? {
        switch self {
        case let .error(_, message): return message
        }
    }
    public var errorCode: Int32 {
        switch self {
        case let .error(code, _): return code
        }
    }
}

@inline(__always)
func check(_ err: inout weaveffi_error) throws {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        throw WeaveFFIError.error(code: code, message: message)
    }
}

@inline(__always)
func trap(_ err: inout weaveffi_error) {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        fatalError("\(code): \(message)")
    }
}

@inline(__always)
func withOptionalPointer<T, R>(to value: T?, _ body: (UnsafePointer<T>?) throws -> R) rethrows -> R {
    guard let value = value else { return try body(nil) }
    return try withUnsafePointer(to: value) { try body($0) }
}

@inline(__always)
func withOptionalCString<R>(_ value: String?, _ body: (UnsafePointer<CChar>?) throws -> R) rethrows -> R {
    guard let value = value else { return try body(nil) }
    return try value.withCString { try body($0) }
}

@inline(__always)
func wvFreeArray<T>(_ ptr: UnsafeMutablePointer<T>, _ count: Int) {
    weaveffi_free_bytes(UnsafeMutableRawPointer(ptr).assumingMemoryBound(to: UInt8.self), count * MemoryLayout<T>.stride)
}

@inline(__always)
func wvFreeBox<T>(_ ptr: UnsafeMutablePointer<T>) {
    weaveffi_free_bytes(UnsafeMutableRawPointer(ptr).assumingMemoryBound(to: UInt8.self), MemoryLayout<T>.size)
}

private final class ContinuationRef<T, E: Error> {
    let value: CheckedContinuation<T, E>
    init(_ value: CheckedContinuation<T, E>) { self.value = value }
}

final class WvCallbackBox<T> {
    let value: T
    init(_ value: T) { self.value = value }
}

var wvListenerContexts: [UInt64: UnsafeMutableRawPointer] = [:]
let wvListenerLock = NSLock()

/// A reusable token referenced across modules
public class Token {
    let ptr: OpaquePointer

    init(ptr: OpaquePointer) {
        self.ptr = ptr
    }

    deinit {
        weaveffi_shared_Token_destroy(ptr)
    }

    public var id: Int64 {
        return weaveffi_shared_Token_get_id(ptr)
    }

    public var label: String {
        let raw = weaveffi_shared_Token_get_label(ptr)
        guard let raw = raw else { return "" }
        defer { weaveffi_free_string(raw) }
        return String(cString: raw)
    }
}

public enum Shared {
    /// Trivial cross-module helper
    public static func ping() -> String {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_shared_ping(&err)
        trap(&err)
        guard let rv = rv else { fatalError("-1: null string") }
        defer { weaveffi_free_string(rv) }
        return String(cString: rv)
    }
}

/// Typed errors reported by the `kitchen` module.
public enum KitchenErrorsError: Error, LocalizedError {
    case notFound(message: String)
    case invalidInput(message: String)
    public var errorDescription: String? {
        switch self {
        case let .notFound(message): return message
        case let .invalidInput(message): return message
        }
    }
    /// The numeric ABI code carried by this error.
    public var errorCode: Int32 {
        switch self {
        case .notFound: return 1
        case .invalidInput: return 2
        }
    }
}

@inline(__always)
func mapKitchen(code: Int32, message: String) -> Error {
    switch code {
    case 1: return KitchenErrorsError.notFound(message: message.isEmpty ? "Item not found" : message)
    case 2: return KitchenErrorsError.invalidInput(message: message.isEmpty ? "Invalid input" : message)
    default: return WeaveFFIError.error(code: code, message: message)
    }
}

@inline(__always)
func checkKitchen(_ err: inout weaveffi_error) throws {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        throw mapKitchen(code: code, message: message)
    }
}

/// Task priority levels
public enum Priority: UInt32 {
    /// Low priority
    case low = 0
    /// Normal priority
    case normal = 1
    /// High priority
    case high = 2
}

/// Kitchen sink struct exercising every field feature
public class Item {
    let ptr: OpaquePointer

    init(ptr: OpaquePointer) {
        self.ptr = ptr
    }

    deinit {
        weaveffi_kitchen_Item_destroy(ptr)
    }

    /// Stable identifier
    public var id: Int64 {
        return weaveffi_kitchen_Item_get_id(ptr)
    }

    /// Display name
    public var name: String {
        let raw = weaveffi_kitchen_Item_get_name(ptr)
        guard let raw = raw else { return "" }
        defer { weaveffi_free_string(raw) }
        return String(cString: raw)
    }

    /// Initial count
    public var count: Int32 {
        return weaveffi_kitchen_Item_get_count(ptr)
    }

    /// Whether the item is enabled
    public var enabled: Bool {
        return weaveffi_kitchen_Item_get_enabled(ptr)
    }

    /// Scaling ratio
    public var ratio: Double {
        return weaveffi_kitchen_Item_get_ratio(ptr)
    }

    public var nick: UInt32 {
        return weaveffi_kitchen_Item_get_nick(ptr)
    }

    public var payload: Data {
        var outLen: Int = 0
        let raw = weaveffi_kitchen_Item_get_payload(ptr, &outLen)
        guard let raw = raw else { return Data() }
        defer { weaveffi_free_bytes(UnsafeMutablePointer(mutating: raw), outLen) }
        return Data(bytes: raw, count: outLen)
    }

    public var tags: [String] {
        var outLen: Int = 0
        let rv = weaveffi_kitchen_Item_get_tags(ptr, &outLen)
        guard let rv = rv else { return [] }
        defer { wvFreeArray(rv, outLen) }
        var items: [String] = []
        items.reserveCapacity(outLen)
        for i in 0..<outLen {
            items.append(String(cString: rv[i]!))
            weaveffi_free_string(rv[i])
        }
        return items
    }

    public var attrs: [String: String] {
        var outKeysPtr: UnsafeMutablePointer<UnsafePointer<CChar>?>? = nil
        var outValuesPtr: UnsafeMutablePointer<UnsafePointer<CChar>?>? = nil
        var outLen: Int = 0
        weaveffi_kitchen_Item_get_attrs(ptr, &outKeysPtr, &outValuesPtr, &outLen)
        guard let outKeys = outKeysPtr, let outValues = outValuesPtr else { return [:] }
        defer { wvFreeArray(outKeys, outLen); wvFreeArray(outValues, outLen) }
        var result: [String: String] = [:]
        for i in 0..<outLen {
            result[String(cString: outKeys[i]!)] = String(cString: outValues[i]!)
            weaveffi_free_string(outKeys[i])
            weaveffi_free_string(outValues[i])
        }
        return result
    }

    public var parent: Int64? {
        let p = weaveffi_kitchen_Item_get_parent(ptr)
        guard let p = p else { return nil }
        defer { wvFreeBox(p) }
        return p.pointee
    }

    /// Cross-module struct reference
    public var token: Token {
        return Token(ptr: weaveffi_kitchen_Item_get_token(ptr)!)
    }

    public var priority: Priority {
        return Priority(rawValue: weaveffi_kitchen_Item_get_priority(ptr).rawValue)!
    }
}

/// Kitchen sink struct exercising every field feature
public class ItemBuilder {
    private var _id: Int64?
    private var _name: String?
    private var _count: Int32?
    private var _enabled: Bool?
    private var _ratio: Double?
    private var _nick: UInt32?
    private var _payload: Data?
    private var _tags: [String]?
    private var _attrs: [String: String]?
    private var _parent: Int64??
    private var _token: Token?
    private var _priority: Priority?

    public init() {}

    /// Stable identifier
    @discardableResult
    public func withId(_ value: Int64) -> Self {
        self._id = value
        return self
    }

    /// Display name
    @discardableResult
