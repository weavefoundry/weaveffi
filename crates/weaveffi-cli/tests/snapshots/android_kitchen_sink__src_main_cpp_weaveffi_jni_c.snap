JNIEXPORT jbyteArray JNICALL Java_com_weaveffi_Item_nativeGetPayload(JNIEnv* env, jclass clazz, jlong handle) {
    size_t out_len = 0;
    const uint8_t* rv = weaveffi_kitchen_Item_get_payload((const weaveffi_kitchen_Item*)(intptr_t)handle, &out_len);
    jbyteArray jout = (*env)->NewByteArray(env, (jsize)out_len);
    if (jout && rv) { (*env)->SetByteArrayRegion(env, jout, 0, (jsize)out_len, (const jbyte*)rv); }
    weaveffi_free_bytes((uint8_t*)rv, (size_t)out_len);
    return jout;
}

