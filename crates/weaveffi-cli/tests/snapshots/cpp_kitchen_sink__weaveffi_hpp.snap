/** Optional struct return */
inline std::optional<Item> maybe_item(int64_t id) {
    weaveffi_error err{};
    auto result = weaveffi_kitchen_maybe_item(id, &err);
    detail::check_kitchen(err);
    if (!result) return std::nullopt;
    return Item(result);
}

/** List of structs */
inline std::vector<Item> list_items() {
    size_t out_len = 0;
    weaveffi_error err{};
    auto result = weaveffi_kitchen_list_items(&out_len, &err);
    detail::check(err);
    std::vector<Item> ret;
    ret.reserve(out_len);
    for (size_t i = 0; i < out_len; ++i) ret.emplace_back(Item(result[i]));
    weaveffi_free_bytes(reinterpret_cast<uint8_t*>(result), out_len * sizeof(*result));
    return ret;
}

/** Map return type */
inline std::unordered_map<std::string, int32_t> get_attrs() {
    const char** out_keys = nullptr;
    int32_t* out_values = nullptr;
    size_t out_len = 0;
    weaveffi_error err{};
    weaveffi_kitchen_get_attrs(&out_keys, &out_values, &out_len, &err);
    detail::check(err);
    std::unordered_map<std::string, int32_t> ret;
    for (size_t i = 0; i < out_len; ++i) {
        ret[std::string(out_keys[i])] = out_values[i];
        weaveffi_free_string(out_keys[i]);
    }
    weaveffi_free_bytes(reinterpret_cast<uint8_t*>(out_keys), out_len * sizeof(*out_keys));
    weaveffi_free_bytes(reinterpret_cast<uint8_t*>(out_values), out_len * sizeof(*out_values));
    return ret;
}

/**
 * A lazy, move-only range over the `Item` elements produced by `stream_items()`.
 *
 * Each iteration step pulls exactly one element from the producer, so results stream in constant memory. The range owns the producer-side iterator and releases it exactly once: eagerly when the range is exhausted, or from the destructor when iteration is abandoned early.
 */
class StreamItemsIterator {
    weaveffi_kitchen_StreamItemsIterator* handle_;

public:
    /** Adopts ownership of the raw producer iterator handle. */
    explicit StreamItemsIterator(weaveffi_kitchen_StreamItemsIterator* h) : handle_(h) {}

    ~StreamItemsIterator() {
        if (handle_) weaveffi_kitchen_StreamItemsIterator_destroy(handle_);
    }

    StreamItemsIterator(const StreamItemsIterator&) = delete;
    StreamItemsIterator& operator=(const StreamItemsIterator&) = delete;

    StreamItemsIterator(StreamItemsIterator&& other) noexcept : handle_(other.handle_) {
        other.handle_ = nullptr;
    }

    StreamItemsIterator& operator=(StreamItemsIterator&& other) noexcept {
        if (this != &other) {
            if (handle_) weaveffi_kitchen_StreamItemsIterator_destroy(handle_);
            handle_ = other.handle_;
            other.handle_ = nullptr;
        }
        return *this;
    }

    /** Pulls the next element from the producer, or `std::nullopt` once exhausted (which releases the producer iterator eagerly). A producer error throws the generic WeaveFFIError after releasing the iterator. */
    std::optional<Item> next() {
        if (!handle_) return std::nullopt;
        weaveffi_error err{};
        weaveffi_kitchen_Item* item{};
        int32_t has_item = weaveffi_kitchen_StreamItemsIterator_next(handle_, &item, &err);
        if (err.code != 0) {
            weaveffi_kitchen_StreamItemsIterator_destroy(handle_);
            handle_ = nullptr;
            detail::check(err);
        }
        if (has_item == 0) {
            weaveffi_kitchen_StreamItemsIterator_destroy(handle_);
            handle_ = nullptr;
            return std::nullopt;
        }
        return Item(item);
    }

    /** Sentinel type marking the end of the range. */
    struct sentinel {};

    /** Single-pass input iterator; each increment pulls one element from the producer. */
    class iterator {
        StreamItemsIterator* range_;
        std::optional<Item> current_;

    public:
        using iterator_category = std::input_iterator_tag;
        using value_type = Item;
        using difference_type = std::ptrdiff_t;
        using pointer = Item*;
        using reference = Item&;

        /** Binds to `range` and pulls the first element. */
        explicit iterator(StreamItemsIterator* range) : range_(range), current_(range->next()) {}
        reference operator*() { return *current_; }
        pointer operator->() { return &*current_; }
        iterator& operator++() { current_ = range_->next(); return *this; }
        void operator++(int) { current_ = range_->next(); }
        bool operator==(sentinel) const { return !current_.has_value(); }
        bool operator!=(sentinel) const { return current_.has_value(); }
    };

    /** Begins iteration by pulling the first element. */
    iterator begin() { return iterator(this); }

    /** The past-the-end sentinel. */
    sentinel end() const { return sentinel{}; }
};

/**
 * Iterator return type
 *
 * @return A lazy `StreamItemsIterator` range that streams one element per iteration step and releases the producer iterator when exhausted or destroyed.
 */
inline StreamItemsIterator stream_items() {
    weaveffi_error err{};
    weaveffi_kitchen_StreamItemsIterator* iter = weaveffi_kitchen_stream_items(&err);
    detail::check(err);
    return StreamItemsIterator(iter);
}

/** Returns the shared Token type from another module */
inline Token cross_module_token() {
    weaveffi_error err{};
    auto result = weaveffi_kitchen_cross_module_token(&err);
    detail::check(err);
    return Token(result);
}

/** Async operation */
inline std::future<std::string> do_async(const std::string& input) {
    auto* promise_ptr = new std::promise<std::string>();
    auto future = promise_ptr->get_future();
    weaveffi_kitchen_do_async_async(input.c_str(), [](void* context, weaveffi_error* err, const char* result) {
        auto* p = static_cast<std::promise<std::string>*>(context);
        if (err && err->code != 0) {
            std::string msg(err->message ? err->message : "unknown error");
            p->set_exception(detail::make_error(err->code, msg));
        } else {
            p->set_value(std::string(result));
        }
        delete p;
    }, static_cast<void*>(promise_ptr));
    return future;
}

/** Cancellable async operation */
inline std::future<std::string> do_cancellable(const std::string& input, weaveffi_cancel_token* cancel_token = nullptr) {
    auto* promise_ptr = new std::promise<std::string>();
    auto future = promise_ptr->get_future();
    weaveffi_kitchen_do_cancellable_async(input.c_str(), cancel_token, [](void* context, weaveffi_error* err, const char* result) {
        auto* p = static_cast<std::promise<std::string>*>(context);
        if (err && err->code != 0) {
            std::string msg(err->message ? err->message : "unknown error");
            p->set_exception(detail::make_error(err->code, msg));
        } else {
            p->set_value(std::string(result));
        }
        delete p;
    }, static_cast<void*>(promise_ptr));
    return future;
}

