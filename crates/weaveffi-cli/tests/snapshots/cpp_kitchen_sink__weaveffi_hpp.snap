/** Subscribe to OnReady events */
/** @return A subscription id for unregister_ready_listener(). */
inline uint64_t register_ready_listener(std::function<void(int32_t, std::string)> callback) {
    auto fn = std::make_shared<std::function<void(int32_t, std::string)>>(std::move(callback));
    uint64_t id = weaveffi_kitchen_register_ready_listener(
        [](int32_t code, const char* msg, void* context) {
            auto& cb = *static_cast<std::function<void(int32_t, std::string)>*>(context);
            cb(code, std::string(msg ? msg : ""));
        },
        fn.get());
    std::lock_guard<std::mutex> lock(detail::wv_listener_mutex());
    detail::wv_listener_registry()[id] = fn;
    return id;
}

/** Unregisters a listener previously registered with register_ready_listener(). */
inline void unregister_ready_listener(uint64_t id) {
    weaveffi_kitchen_unregister_ready_listener(id);
    std::lock_guard<std::mutex> lock(detail::wv_listener_mutex());
    detail::wv_listener_registry().erase(id);
}

