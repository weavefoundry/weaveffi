inline void* kitchen_open_handle() {
    weaveffi_error err{};
    auto result = weaveffi_kitchen_open_handle(&err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        switch (code) {
        case 1: throw not_foundError(msg);
        case 2: throw invalid_inputError(msg);
        default: throw WeaveFFIError(code, msg);
        }
    }
    return reinterpret_cast<void*>(static_cast<uintptr_t>(result));
}

inline Token kitchen_open_typed_handle() {
    weaveffi_error err{};
    auto result = weaveffi_kitchen_open_typed_handle(&err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        switch (code) {
        case 1: throw not_foundError(msg);
        case 2: throw invalid_inputError(msg);
        default: throw WeaveFFIError(code, msg);
        }
    }
    return Token(result);
}

inline std::optional<Item> kitchen_maybe_item(int64_t id) {
    weaveffi_error err{};
    auto result = weaveffi_kitchen_maybe_item(id, &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        switch (code) {
        case 1: throw not_foundError(msg);
        case 2: throw invalid_inputError(msg);
        default: throw WeaveFFIError(code, msg);
        }
    }
    if (!result) return std::nullopt;
    return Item(result);
}

inline std::vector<Item> kitchen_list_items() {
    size_t out_len = 0;
    weaveffi_error err{};
    auto result = weaveffi_kitchen_list_items(&out_len, &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        switch (code) {
        case 1: throw not_foundError(msg);
        case 2: throw invalid_inputError(msg);
        default: throw WeaveFFIError(code, msg);
        }
    }
    std::vector<Item> ret;
    ret.reserve(out_len);
    for (size_t i = 0; i < out_len; ++i) ret.emplace_back(Item(result[i]));
    return ret;
}

inline std::unordered_map<std::string, int32_t> kitchen_get_attrs() {
    const char** out_keys = nullptr;
    int32_t* out_values = nullptr;
    size_t out_len = 0;
    weaveffi_error err{};
    weaveffi_kitchen_get_attrs(out_keys, out_values, &out_len, &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        switch (code) {
        case 1: throw not_foundError(msg);
        case 2: throw invalid_inputError(msg);
        default: throw WeaveFFIError(code, msg);
        }
    }
    std::unordered_map<std::string, int32_t> ret;
    for (size_t i = 0; i < out_len; ++i) {
        ret[std::string(out_keys[i])] = out_values[i];
    }
    return ret;
}

