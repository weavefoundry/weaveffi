weaveffi_shared_Token* weaveffi_kitchen_cross_module_token(weaveffi_error* out_err);
typedef void (*weaveffi_kitchen_do_async_callback)(void* context, weaveffi_error* err, const char* result);
void weaveffi_kitchen_do_async_async(const char* input, weaveffi_kitchen_do_async_callback callback, void* context);
typedef void (*weaveffi_kitchen_do_cancellable_callback)(void* context, weaveffi_error* err, const char* result);
void weaveffi_kitchen_do_cancellable_async(const char* input, weaveffi_cancel_token* cancel_token, weaveffi_kitchen_do_cancellable_callback callback, void* context);
int32_t weaveffi_kitchen_legacy_op(weaveffi_error* out_err);
int32_t weaveffi_kitchen_new_op(weaveffi_error* out_err);

const char* weaveffi_kitchen_nested_hello(weaveffi_error* out_err);

} // extern "C"

namespace weaveffi {

class WeaveFFIError : public std::runtime_error {
    int32_t code_;

public:
    WeaveFFIError(int32_t code, const std::string& msg) : std::runtime_error(msg), code_(code) {}
    int32_t code() const { return code_; }
};

class not_foundError : public WeaveFFIError {
public:
    not_foundError(const std::string& msg) : WeaveFFIError(1, msg) {}
};

class invalid_inputError : public WeaveFFIError {
public:
    invalid_inputError(const std::string& msg) : WeaveFFIError(2, msg) {}
};

class Token {
    void* handle_;

public:
    explicit Token(void* h) : handle_(h) {}

    ~Token() {
        if (handle_) weaveffi_shared_Token_destroy(static_cast<weaveffi_shared_Token*>(handle_));
    }

    Token(const Token&) = delete;
    Token& operator=(const Token&) = delete;

    Token(Token&& other) noexcept : handle_(other.handle_) {
        other.handle_ = nullptr;
    }

    Token& operator=(Token&& other) noexcept {
        if (this != &other) {
            if (handle_) weaveffi_shared_Token_destroy(static_cast<weaveffi_shared_Token*>(handle_));
            handle_ = other.handle_;
            other.handle_ = nullptr;
        }
        return *this;
    }

    void* handle() const { return handle_; }

    int64_t id() const {
        return weaveffi_shared_Token_get_id(static_cast<const weaveffi_shared_Token*>(handle_));
    }

    std::string label() const {
        const char* raw = weaveffi_shared_Token_get_label(static_cast<const weaveffi_shared_Token*>(handle_));
        std::string ret(raw);
        weaveffi_free_string(raw);
        return ret;
    }

};

inline std::string shared_ping() {
    weaveffi_error err{};
    auto result = weaveffi_shared_ping(&err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        switch (code) {
        case 1: throw not_foundError(msg);
        case 2: throw invalid_inputError(msg);
        default: throw WeaveFFIError(code, msg);
        }
    }
    std::string ret(result);
    weaveffi_free_string(result);
    return ret;
}

enum class Priority : int32_t {
    Low = 0,
    Normal = 1,
    High = 2
};

class Item {
    void* handle_;

public:
    explicit Item(void* h) : handle_(h) {}

    ~Item() {
        if (handle_) weaveffi_kitchen_Item_destroy(static_cast<weaveffi_kitchen_Item*>(handle_));
    }

    Item(const Item&) = delete;
    Item& operator=(const Item&) = delete;

    Item(Item&& other) noexcept : handle_(other.handle_) {
        other.handle_ = nullptr;
    }

    Item& operator=(Item&& other) noexcept {
        if (this != &other) {
            if (handle_) weaveffi_kitchen_Item_destroy(static_cast<weaveffi_kitchen_Item*>(handle_));
            handle_ = other.handle_;
            other.handle_ = nullptr;
        }
        return *this;
    }

    void* handle() const { return handle_; }

    int64_t id() const {
        return weaveffi_kitchen_Item_get_id(static_cast<const weaveffi_kitchen_Item*>(handle_));
    }

    std::string name() const {
        const char* raw = weaveffi_kitchen_Item_get_name(static_cast<const weaveffi_kitchen_Item*>(handle_));
        std::string ret(raw);
        weaveffi_free_string(raw);
        return ret;
    }

    int32_t count() const {
        return weaveffi_kitchen_Item_get_count(static_cast<const weaveffi_kitchen_Item*>(handle_));
    }

    bool enabled() const {
        return weaveffi_kitchen_Item_get_enabled(static_cast<const weaveffi_kitchen_Item*>(handle_));
    }

    double ratio() const {
        return weaveffi_kitchen_Item_get_ratio(static_cast<const weaveffi_kitchen_Item*>(handle_));
    }

    uint32_t nick() const {
        return weaveffi_kitchen_Item_get_nick(static_cast<const weaveffi_kitchen_Item*>(handle_));
    }

    std::vector<uint8_t> payload() const {
        size_t len = 0;
        auto* raw = weaveffi_kitchen_Item_get_payload(static_cast<const weaveffi_kitchen_Item*>(handle_), &len);
        return std::vector<uint8_t>(raw, raw + len);
    }

    std::vector<std::string> tags() const {
        size_t len = 0;
        auto* raw = weaveffi_kitchen_Item_get_tags(static_cast<const weaveffi_kitchen_Item*>(handle_), &len);
        std::vector<std::string> ret;
        ret.reserve(len);
        for (size_t i = 0; i < len; ++i) ret.emplace_back(raw[i]);
        return ret;
    }

    std::unordered_map<std::string, std::string> attrs() const {
        const char** out_keys = nullptr;
        const char** out_values = nullptr;
        size_t len = 0;
        weaveffi_kitchen_Item_get_attrs(static_cast<const weaveffi_kitchen_Item*>(handle_), out_keys, out_values, &len);
        std::unordered_map<std::string, std::string> ret;
        for (size_t i = 0; i < len; ++i) {
            ret[std::string(out_keys[i])] = std::string(out_values[i]);
        }
        return ret;
    }

    std::optional<int64_t> parent() const {
        auto* raw = weaveffi_kitchen_Item_get_parent(static_cast<const weaveffi_kitchen_Item*>(handle_));
        if (!raw) return std::nullopt;
        return *raw;
    }

    Token token() const {
        return Token(weaveffi_kitchen_Item_get_token(static_cast<const weaveffi_kitchen_Item*>(handle_)));
    }

    Priority priority() const {
        return static_cast<Priority>(weaveffi_kitchen_Item_get_priority(static_cast<const weaveffi_kitchen_Item*>(handle_)));
    }

};

class ItemBuilder {
    void* handle_;

public:
    ItemBuilder() : handle_(reinterpret_cast<void*>(weaveffi_kitchen_Item_Builder_new())) {}

    ~ItemBuilder() {
        if (handle_) weaveffi_kitchen_Item_Builder_destroy(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_));
    }

    ItemBuilder(const ItemBuilder&) = delete;
    ItemBuilder& operator=(const ItemBuilder&) = delete;

    ItemBuilder(ItemBuilder&& other) noexcept : handle_(other.handle_) {
        other.handle_ = nullptr;
    }

    ItemBuilder& operator=(ItemBuilder&& other) noexcept {
        if (this != &other) {
            if (handle_) weaveffi_kitchen_Item_Builder_destroy(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_));
            handle_ = other.handle_;
            other.handle_ = nullptr;
        }
        return *this;
    }

    ItemBuilder& withId(int64_t value) {
        weaveffi_kitchen_Item_Builder_set_id(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), value);
        return *this;
    }

    ItemBuilder& withName(const std::string& value) {
        weaveffi_kitchen_Item_Builder_set_name(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), value.c_str());
        return *this;
    }

    ItemBuilder& withCount(int32_t value) {
        weaveffi_kitchen_Item_Builder_set_count(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), value);
        return *this;
    }

    ItemBuilder& withEnabled(bool value) {
        weaveffi_kitchen_Item_Builder_set_enabled(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), value);
        return *this;
    }

    ItemBuilder& withRatio(double value) {
        weaveffi_kitchen_Item_Builder_set_ratio(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), value);
        return *this;
    }

    ItemBuilder& withNick(uint32_t value) {
        weaveffi_kitchen_Item_Builder_set_nick(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), value);
        return *this;
    }

    ItemBuilder& withPayload(const std::vector<uint8_t>& value) {
        weaveffi_kitchen_Item_Builder_set_payload(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), value.data(), value.size());
        return *this;
    }

    ItemBuilder& withTags(const std::vector<std::string>& value) {
        std::vector<const char*> value_cstrs;
        value_cstrs.reserve(value.size());
        for (const auto& s : value) value_cstrs.push_back(s.c_str());
        weaveffi_kitchen_Item_Builder_set_tags(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), value_cstrs.data(), value_cstrs.size());
        return *this;
    }

    ItemBuilder& withAttrs(const std::unordered_map<std::string, std::string>& value) {
        std::vector<const char*> value_keys_v;
        std::vector<const char*> value_vals_v;
        for (const auto& kv : value) { value_keys_v.push_back(kv.first.c_str()); value_vals_v.push_back(kv.second.c_str()); }
        weaveffi_kitchen_Item_Builder_set_attrs(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), value_keys_v.data(), value_vals_v.data(), value_keys_v.size());
        return *this;
    }

    ItemBuilder& withParent(const std::optional<int64_t>& value) {
        const int64_t* value_ptr = nullptr;
        int64_t value_tmp{};
        if (value.has_value()) { value_tmp = *value; value_ptr = &value_tmp; }
        weaveffi_kitchen_Item_Builder_set_parent(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), value_ptr);
        return *this;
    }

    ItemBuilder& withToken(const Token& value) {
        weaveffi_kitchen_Item_Builder_set_token(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), static_cast<const weaveffi_shared_Token*>(value.handle()));
        return *this;
    }

    ItemBuilder& withPriority(Priority value) {
        weaveffi_kitchen_Item_Builder_set_priority(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), static_cast<weaveffi_kitchen_Priority>(static_cast<int32_t>(value)));
        return *this;
    }

    Item build() {
        weaveffi_error err{};
        auto* ptr = weaveffi_kitchen_Item_Builder_build(static_cast<weaveffi_kitchen_ItemBuilder*>(handle_), &err);
        if (err.code != 0) throw std::runtime_error(err.message ? err.message : "build failed");
        return Item(ptr);
    }
};

inline bool kitchen_bool_id(bool x) {
    weaveffi_error err{};
    auto result = weaveffi_kitchen_bool_id(x, &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        switch (code) {
        case 1: throw not_foundError(msg);
        case 2: throw invalid_inputError(msg);
        default: throw WeaveFFIError(code, msg);
        }
    }
    return result;
}

