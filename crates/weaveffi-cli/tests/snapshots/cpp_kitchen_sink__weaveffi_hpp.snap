    }
    return Token(result);
}

inline std::future<std::string> kitchen_do_async(const std::string& input) {
    auto* promise_ptr = new std::promise<std::string>();
    auto future = promise_ptr->get_future();
    weaveffi_kitchen_do_async_async(input.c_str(), [](void* context, weaveffi_error* err, const char* result) {
        auto* p = static_cast<std::promise<std::string>*>(context);
        if (err && err->code != 0) {
            std::string msg(err->message ? err->message : "unknown error");
            p->set_exception(std::make_exception_ptr(WeaveFFIError(err->code, msg)));
        } else {
            std::string ret(result);
            weaveffi_free_string(result);
            p->set_value(std::move(ret));
        }
        delete p;
    }, static_cast<void*>(promise_ptr));
    return future;
}

inline std::future<std::string> kitchen_do_cancellable(const std::string& input, weaveffi_cancel_token* cancel_token = nullptr) {
    auto* promise_ptr = new std::promise<std::string>();
    auto future = promise_ptr->get_future();
    weaveffi_kitchen_do_cancellable_async(input.c_str(), cancel_token, [](void* context, weaveffi_error* err, const char* result) {
        auto* p = static_cast<std::promise<std::string>*>(context);
        if (err && err->code != 0) {
            std::string msg(err->message ? err->message : "unknown error");
            p->set_exception(std::make_exception_ptr(WeaveFFIError(err->code, msg)));
        } else {
            std::string ret(result);
            weaveffi_free_string(result);
            p->set_value(std::move(ret));
        }
        delete p;
    }, static_cast<void*>(promise_ptr));
    return future;
}

