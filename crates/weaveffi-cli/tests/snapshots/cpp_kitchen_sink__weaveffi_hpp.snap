namespace weaveffi {

/** Base exception for every error reported through the C ABI. */
class WeaveFFIError : public std::runtime_error {
    int32_t code_;

public:
    WeaveFFIError(int32_t code, const std::string& msg) : std::runtime_error(msg), code_(code) {}
    int32_t code() const { return code_; }
};

namespace detail {

/** Throw the generic WeaveFFIError if `err` carries a nonzero code. */
inline void check(weaveffi_error& err) {
    if (err.code == 0) return;
    std::string msg(err.message ? err.message : "unknown error");
    int32_t code = err.code;
    weaveffi_error_clear(&err);
    throw WeaveFFIError(code, msg);
}

/** Wrap an async-callback error as the generic WeaveFFIError. */
inline std::exception_ptr make_error(int32_t code, const std::string& msg) {
    return std::make_exception_ptr(WeaveFFIError(code, msg));
}

} // namespace detail

/** Typed errors reported by the `kitchen` module's throwing functions. */
class KitchenErrorsError : public WeaveFFIError {
public:
    KitchenErrorsError(int32_t code, const std::string& msg) : WeaveFFIError(code, msg) {}
};

/** Item not found */
class NotFoundError : public KitchenErrorsError {
public:
    NotFoundError(const std::string& msg) : KitchenErrorsError(1, msg) {}
};

/** Invalid input */
class InvalidInputError : public KitchenErrorsError {
public:
    InvalidInputError(const std::string& msg) : KitchenErrorsError(2, msg) {}
};

namespace detail {

/** Map a `kitchen` error code to its typed exception (KitchenErrorsError for unknown codes). */
inline std::exception_ptr make_kitchen_error(int32_t code, const std::string& msg) {
    switch (code) {
    case 1: return std::make_exception_ptr(NotFoundError(msg));
    case 2: return std::make_exception_ptr(InvalidInputError(msg));
    default: return std::make_exception_ptr(KitchenErrorsError(code, msg));
    }
}

/** Throw the typed `kitchen` exception if `err` carries a nonzero code. */
inline void check_kitchen(weaveffi_error& err) {
    if (err.code == 0) return;
    std::string msg(err.message ? err.message : "unknown error");
    int32_t code = err.code;
    weaveffi_error_clear(&err);
    std::rethrow_exception(make_kitchen_error(code, msg));
}

} // namespace detail

namespace detail {

inline std::mutex& wv_listener_mutex() {
    static std::mutex m;
    return m;
}

inline std::unordered_map<uint64_t, std::shared_ptr<void>>& wv_listener_registry() {
    static std::unordered_map<uint64_t, std::shared_ptr<void>> registry;
    return registry;
}

} // namespace detail

/** Task priority levels */
enum class Priority : int32_t {
    /** Low priority */
    Low = 0,
    /** Normal priority */
    Normal = 1,
    /** High priority */
    High = 2
};

/** A reusable token referenced across modules */
class Token {
    void* handle_;

public:
    explicit Token(void* h) : handle_(h) {}

    ~Token() {
        if (handle_) weaveffi_shared_Token_destroy(static_cast<weaveffi_shared_Token*>(handle_));
    }

    Token(const Token&) = delete;
    Token& operator=(const Token&) = delete;

    Token(Token&& other) noexcept : handle_(other.handle_) {
        other.handle_ = nullptr;
    }

    Token& operator=(Token&& other) noexcept {
        if (this != &other) {
            if (handle_) weaveffi_shared_Token_destroy(static_cast<weaveffi_shared_Token*>(handle_));
            handle_ = other.handle_;
            other.handle_ = nullptr;
        }
        return *this;
    }

    void* handle() const { return handle_; }

    int64_t id() const {
        return weaveffi_shared_Token_get_id(static_cast<const weaveffi_shared_Token*>(handle_));
    }

    std::string label() const {
        const char* raw = weaveffi_shared_Token_get_label(static_cast<const weaveffi_shared_Token*>(handle_));
        std::string ret(raw);
        weaveffi_free_string(raw);
        return ret;
    }

};

/** Kitchen sink struct exercising every field feature */
class Item {
    void* handle_;

public:
    explicit Item(void* h) : handle_(h) {}

    ~Item() {
        if (handle_) weaveffi_kitchen_Item_destroy(static_cast<weaveffi_kitchen_Item*>(handle_));
    }

    Item(const Item&) = delete;
    Item& operator=(const Item&) = delete;

    Item(Item&& other) noexcept : handle_(other.handle_) {
        other.handle_ = nullptr;
    }

    Item& operator=(Item&& other) noexcept {
        if (this != &other) {
            if (handle_) weaveffi_kitchen_Item_destroy(static_cast<weaveffi_kitchen_Item*>(handle_));
            handle_ = other.handle_;
            other.handle_ = nullptr;
        }
        return *this;
    }

    void* handle() const { return handle_; }

    /** Stable identifier */
    int64_t id() const {
        return weaveffi_kitchen_Item_get_id(static_cast<const weaveffi_kitchen_Item*>(handle_));
    }

    /** Display name */
    std::string name() const {
        const char* raw = weaveffi_kitchen_Item_get_name(static_cast<const weaveffi_kitchen_Item*>(handle_));
        std::string ret(raw);
        weaveffi_free_string(raw);
        return ret;
    }

    /** Initial count */
    int32_t count() const {
        return weaveffi_kitchen_Item_get_count(static_cast<const weaveffi_kitchen_Item*>(handle_));
    }

    /** Whether the item is enabled */
    bool enabled() const {
        return weaveffi_kitchen_Item_get_enabled(static_cast<const weaveffi_kitchen_Item*>(handle_));
    }

    /** Scaling ratio */
    double ratio() const {
        return weaveffi_kitchen_Item_get_ratio(static_cast<const weaveffi_kitchen_Item*>(handle_));
    }

    uint32_t nick() const {
        return weaveffi_kitchen_Item_get_nick(static_cast<const weaveffi_kitchen_Item*>(handle_));
    }

    std::vector<uint8_t> payload() const {
        size_t len = 0;
        auto* raw = weaveffi_kitchen_Item_get_payload(static_cast<const weaveffi_kitchen_Item*>(handle_), &len);
        std::vector<uint8_t> ret(raw, raw + len);
        weaveffi_free_bytes(const_cast<uint8_t*>(raw), len);
        return ret;
    }

    std::vector<std::string> tags() const {
        size_t len = 0;
        auto* raw = weaveffi_kitchen_Item_get_tags(static_cast<const weaveffi_kitchen_Item*>(handle_), &len);
        std::vector<std::string> ret;
        ret.reserve(len);
        for (size_t i = 0; i < len; ++i) {
            ret.emplace_back(raw[i]);
            weaveffi_free_string(raw[i]);
        }
        weaveffi_free_bytes(reinterpret_cast<uint8_t*>(raw), len * sizeof(*raw));
        return ret;
    }

    std::unordered_map<std::string, std::string> attrs() const {
        const char** out_keys = nullptr;
        const char** out_values = nullptr;
        size_t len = 0;
        weaveffi_kitchen_Item_get_attrs(static_cast<const weaveffi_kitchen_Item*>(handle_), &out_keys, &out_values, &len);
        std::unordered_map<std::string, std::string> ret;
        for (size_t i = 0; i < len; ++i) {
            ret[std::string(out_keys[i])] = std::string(out_values[i]);
            weaveffi_free_string(out_keys[i]);
            weaveffi_free_string(out_values[i]);
        }
        weaveffi_free_bytes(reinterpret_cast<uint8_t*>(out_keys), len * sizeof(*out_keys));
        weaveffi_free_bytes(reinterpret_cast<uint8_t*>(out_values), len * sizeof(*out_values));
        return ret;
    }

    std::optional<int64_t> parent() const {
        auto* raw = weaveffi_kitchen_Item_get_parent(static_cast<const weaveffi_kitchen_Item*>(handle_));
        if (!raw) return std::nullopt;
        auto ret = *raw;
        weaveffi_free_bytes(reinterpret_cast<uint8_t*>(raw), sizeof(*raw));
        return ret;
    }

    /** Cross-module struct reference */
    Token token() const {
        return Token(weaveffi_kitchen_Item_get_token(static_cast<const weaveffi_kitchen_Item*>(handle_)));
    }

    Priority priority() const {
        return static_cast<Priority>(weaveffi_kitchen_Item_get_priority(static_cast<const weaveffi_kitchen_Item*>(handle_)));
    }

};

