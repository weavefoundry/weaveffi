inline std::string kitchen_echo_string(const std::string& s) {
    weaveffi_error err{};
    auto result = weaveffi_kitchen_echo_string(s.c_str(), &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        switch (code) {
        case 1: throw not_foundError(msg);
        case 2: throw invalid_inputError(msg);
        default: throw WeaveFFIError(code, msg);
        }
    }
    std::string ret(result);
    weaveffi_free_string(result);
    return ret;
}

inline std::vector<uint8_t> kitchen_echo_bytes(const std::vector<uint8_t>& b) {
    size_t out_len = 0;
    weaveffi_error err{};
    auto result = weaveffi_kitchen_echo_bytes(b.data(), b.size(), &out_len, &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        switch (code) {
        case 1: throw not_foundError(msg);
        case 2: throw invalid_inputError(msg);
        default: throw WeaveFFIError(code, msg);
        }
    }
    std::vector<uint8_t> ret(result, result + out_len);
    weaveffi_free_bytes(const_cast<uint8_t*>(result), out_len);
    return ret;
}

