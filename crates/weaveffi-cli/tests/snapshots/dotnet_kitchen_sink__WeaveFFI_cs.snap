    public class WeaveFFIException : Exception
    {
        public int Code { get; }

        public WeaveFFIException(int code, string message) : base(message)
        {
            Code = code;
        }
    }

    /// <summary>Typed exception for the KitchenErrorsError error domain (module kitchen).</summary>
    public class KitchenErrorsException : WeaveFFIException
    {
        /// <summary>Item not found</summary>
        public const int NotFound = 1;
        /// <summary>Invalid input</summary>
        public const int InvalidInput = 2;

        public KitchenErrorsException(int code, string message) : base(code, message)
        {
        }

        /// <summary>Wraps a raw error slot in the typed exception, falling
        /// back to <see cref="WeaveFFIException"/> for unknown codes.</summary>
        internal static WeaveFFIException FromCode(int code, string message)
        {
            switch (code)
            {
                case NotFound:
                    return new KitchenErrorsException(code, string.IsNullOrEmpty(message) ? "Item not found" : message);
                case InvalidInput:
                    return new KitchenErrorsException(code, string.IsNullOrEmpty(message) ? "Invalid input" : message);
                default:
                    return new WeaveFFIException(code, message);
            }
        }
    }

    [StructLayout(LayoutKind.Sequential)]
    internal struct WeaveFFIError
    {
        public int Code;
        public IntPtr Message;

        internal static void Check(WeaveFFIError err)
        {
            if (err.Code != 0)
            {
                var msg = Marshal.PtrToStringUTF8(err.Message) ?? "";
                throw new WeaveFFIException(err.Code, msg);
            }
        }

        internal static void CheckKitchenErrors(WeaveFFIError err)
        {
            if (err.Code != 0)
            {
                var msg = Marshal.PtrToStringUTF8(err.Message) ?? "";
                throw KitchenErrorsException.FromCode(err.Code, msg);
            }
        }
    }

