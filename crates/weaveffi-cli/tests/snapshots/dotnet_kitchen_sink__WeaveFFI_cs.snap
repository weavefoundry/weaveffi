        public static string Version()
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_Gadget_version(ref err);
            WeaveFFIError.Check(err);
            var str = Marshal.PtrToStringUTF8(result);
            NativeMethods.weaveffi_free_string(result);
            return str;
        }

        public void Dispose()
        {
            if (!_disposed)
            {
                NativeMethods.weaveffi_kitchen_Gadget_destroy(_handle);
                _disposed = true;
            }
            GC.SuppressFinalize(this);
        }

        ~Gadget()
        {
            Dispose();
        }
    }

