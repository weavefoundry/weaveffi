        public string Describe()
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_Gadget_describe(_handle, ref err);
            WeaveFFIError.Check(err);
            var str = Marshal.PtrToStringUTF8(result);
            NativeMethods.weaveffi_free_string(result);
            return str;
        }

        /// <summary>Poke the gadget a number of times, failing on a negative count</summary>
        /// <exception cref="KitchenErrorsException">Thrown when the call reports a KitchenErrorsError code.</exception>
        public int Poke(int times)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_Gadget_poke(_handle, times, ref err);
            WeaveFFIError.CheckKitchenErrors(err);
            return result;
