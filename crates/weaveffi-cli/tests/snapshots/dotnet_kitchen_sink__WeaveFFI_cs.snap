    public static class Kitchen
    {
        private static readonly object _listenerLock = new object();
        // Live listener delegates by subscription id. Holding the delegate
        // here keeps its native thunk alive until unregistered; without this
        // the GC could collect a delegate the producer still calls.
        private static readonly Dictionary<ulong, Delegate> _listenerRefs = new Dictionary<ulong, Delegate>();

        /// <summary>Subscribe to OnReady events</summary>
        /// <returns>A subscription id for UnregisterReadyListener().</returns>
        public static ulong RegisterReadyListener(Action<int, string> callback)
        {
            NativeMethods.Cb_weaveffi_kitchen_OnReady_fn trampoline = (code, msg, context) =>
            {
                callback(code, Marshal.PtrToStringUTF8(msg) ?? "");
            };
            ulong id;
            lock (_listenerLock)
            {
                id = NativeMethods.weaveffi_kitchen_register_ready_listener(trampoline, IntPtr.Zero);
                _listenerRefs[id] = trampoline;
            }
            return id;
        }

        /// <summary>Unregisters a listener previously registered with RegisterReadyListener().</summary>
        public static void UnregisterReadyListener(ulong id)
        {
            NativeMethods.weaveffi_kitchen_unregister_ready_listener(id);
            lock (_listenerLock)
            {
                _listenerRefs.Remove(id);
            }
        }

        /// <summary>Identity for bool</summary>
        public static bool BoolId(bool x)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_bool_id((byte)(x ? 1 : 0), ref err);
            WeaveFFIError.Check(err);
            return result != 0;
        }

        public static int I32Id(int x)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_i32_id(x, ref err);
            WeaveFFIError.Check(err);
            return result;
        }

        public static uint U32Id(uint x)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_u32_id(x, ref err);
            WeaveFFIError.Check(err);
            return result;
        }

        public static long I64Id(long x)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_i64_id(x, ref err);
            WeaveFFIError.Check(err);
            return result;
        }

        public static double F64Id(double x)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_f64_id(x, ref err);
            WeaveFFIError.Check(err);
            return result;
        }

        public static string EchoString(string s)
        {
            var err = new WeaveFFIError();
            var sPtr = Marshal.StringToCoTaskMemUTF8(s);
            try
            {
                var result = NativeMethods.weaveffi_kitchen_echo_string(sPtr, ref err);
                WeaveFFIError.Check(err);
                var str = Marshal.PtrToStringUTF8(result);
                NativeMethods.weaveffi_free_string(result);
                return str;
            }
            finally
            {
                Marshal.FreeCoTaskMem(sPtr);
            }
        }

        public static byte[] EchoBytes(byte[] b)
        {
            var err = new WeaveFFIError();
            var bPin = GCHandle.Alloc(b, GCHandleType.Pinned);
            try
            {
                var result = NativeMethods.weaveffi_kitchen_echo_bytes(bPin.AddrOfPinnedObject(), (UIntPtr)b.Length, out var outLen, ref err);
                WeaveFFIError.Check(err);
                if (result == IntPtr.Zero) return Array.Empty<byte>();
                var arr = new byte[(int)outLen];
                Marshal.Copy(result, arr, 0, (int)outLen);
                NativeMethods.weaveffi_free_bytes(result, outLen);
                return arr;
            }
            finally
            {
                bPin.Free();
            }
        }

        /// <summary>Borrowed string parameter</summary>
        public static string EchoBorrowedStr(string s)
        {
            var err = new WeaveFFIError();
            var sPtr = Marshal.StringToCoTaskMemUTF8(s);
            try
            {
                var result = NativeMethods.weaveffi_kitchen_echo_borrowed_str(sPtr, ref err);
                WeaveFFIError.Check(err);
                var str = Marshal.PtrToStringUTF8(result);
                NativeMethods.weaveffi_free_string(result);
                return str;
            }
            finally
            {
                Marshal.FreeCoTaskMem(sPtr);
            }
        }

        /// <summary>Borrowed bytes parameter</summary>
        public static byte[] EchoBorrowedBytes(byte[] b)
        {
            var err = new WeaveFFIError();
            var bPin = GCHandle.Alloc(b, GCHandleType.Pinned);
            try
            {
                var result = NativeMethods.weaveffi_kitchen_echo_borrowed_bytes(bPin.AddrOfPinnedObject(), (UIntPtr)b.Length, out var outLen, ref err);
                WeaveFFIError.Check(err);
                if (result == IntPtr.Zero) return Array.Empty<byte>();
                var arr = new byte[(int)outLen];
                Marshal.Copy(result, arr, 0, (int)outLen);
                NativeMethods.weaveffi_free_bytes(result, outLen);
                return arr;
            }
            finally
            {
                bPin.Free();
            }
        }

        /// <summary>Returns an opaque handle</summary>
        public static ulong OpenHandle()
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_open_handle(ref err);
            WeaveFFIError.Check(err);
            return result;
        }

        /// <summary>Returns a typed handle</summary>
        public static Token OpenTypedHandle()
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_open_typed_handle(ref err);
            WeaveFFIError.Check(err);
            return new Token(result);
        }

        /// <summary>Optional struct return</summary>
        /// <exception cref="KitchenErrorsException">Thrown when the call reports a KitchenErrorsError code.</exception>
        public static Item? MaybeItem(long id)
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_maybe_item(id, ref err);
            WeaveFFIError.CheckKitchenErrors(err);
            return result == IntPtr.Zero ? null : new Item(result);
        }

        /// <summary>List of structs</summary>
        public static Item[] ListItems()
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_list_items(out var outLen, ref err);
            WeaveFFIError.Check(err);
            if (result == IntPtr.Zero) return Array.Empty<Item>();
            var arr = new Item[(int)outLen];
            for (int i = 0; i < (int)outLen; i++)
            {
                var item = new Item(Marshal.ReadIntPtr(result, i * IntPtr.Size));
                arr[i] = item;
            }
            NativeMethods.weaveffi_free_bytes(result, (UIntPtr)((int)outLen * IntPtr.Size));
            return arr;
        }

        /// <summary>Map return type</summary>
        public static Dictionary<string, int> GetAttrs()
        {
            var err = new WeaveFFIError();
            NativeMethods.weaveffi_kitchen_get_attrs(out var outKeys, out var outValues, out var outLen, ref err);
            WeaveFFIError.Check(err);
            var dict = new Dictionary<string, int>();
            if (outKeys != IntPtr.Zero && outValues != IntPtr.Zero)
            {
                for (int i = 0; i < (int)outLen; i++)
                {
                    var keyPtr = Marshal.ReadIntPtr(outKeys, i * IntPtr.Size);
                    var key = Marshal.PtrToStringUTF8(keyPtr) ?? "";
                    NativeMethods.weaveffi_free_string(keyPtr);
                    var value = Marshal.ReadInt32(outValues + i * sizeof(int));
                    dict[key] = value;
                }
                NativeMethods.weaveffi_free_bytes(outKeys, (UIntPtr)((int)outLen * IntPtr.Size));
                NativeMethods.weaveffi_free_bytes(outValues, (UIntPtr)((int)outLen * 4));
            }
            return dict;
        }

        /// <summary>Iterator return type</summary>
        /// <remarks>Streams lazily: each element is pulled from the native
        /// iterator on demand, and the iterator is destroyed when enumeration
        /// completes or the enumerator is disposed (a <c>foreach</c> disposes it
        /// automatically, including on early exit). The returned sequence can be
        /// enumerated only once.</remarks>
        public static IEnumerable<Item> StreamItems()
        {
            var err = new WeaveFFIError();
            var iter = NativeMethods.weaveffi_kitchen_stream_items(ref err);
            WeaveFFIError.Check(err);
            return new WeaveFFIOnceEnumerable<Item>(EnumerateStreamItems(iter));
        }

        private static IEnumerator<Item> EnumerateStreamItems(IntPtr iter)
        {
            try
            {
                while (true)
                {
                    var iterErr = new WeaveFFIError();
                    if (NativeMethods.weaveffi_kitchen_StreamItemsIterator_next(iter, out var out_item, ref iterErr) == 0)
                    {
                        WeaveFFIError.Check(iterErr);
                        yield break;
                    }
                    WeaveFFIError.Check(iterErr);
                    yield return new Item(out_item);
                }
            }
            finally
            {
                NativeMethods.weaveffi_kitchen_StreamItemsIterator_destroy(iter);
            }
        }

        /// <summary>Returns the shared Token type from another module</summary>
        public static Token CrossModuleToken()
        {
            var err = new WeaveFFIError();
            var result = NativeMethods.weaveffi_kitchen_cross_module_token(ref err);
            WeaveFFIError.Check(err);
            return new Token(result);
        }

        /// <summary>Async operation</summary>
        public static async Task<string> DoAsync(string input)
        {
            var tcs = new TaskCompletionSource<string>(TaskCreationOptions.RunContinuationsAsynchronously);
            NativeMethods.AsyncCb_weaveffi_kitchen_do_async callback = (context, err, result) =>
            {
                try
                {
                    if (err != IntPtr.Zero)
                    {
                        var wErr = Marshal.PtrToStructure<WeaveFFIError>(err);
                        if (wErr.Code != 0)
                        {
                            var msg = Marshal.PtrToStringUTF8(wErr.Message) ?? "";
                            tcs.SetException(new WeaveFFIException(wErr.Code, msg));
                            return;
                        }
                    }
                    tcs.SetResult(Marshal.PtrToStringUTF8(result) ?? "");
                }
                finally
                {
                    if (context != IntPtr.Zero)
                    {
                        GCHandle.FromIntPtr(context).Free();
                    }
                }
            };
            var gcHandle = GCHandle.Alloc(callback, GCHandleType.Normal);
            var ctx = GCHandle.ToIntPtr(gcHandle);
            var inputPtr = Marshal.StringToCoTaskMemUTF8(input);
            try
            {
                try
                {
                    NativeMethods.weaveffi_kitchen_do_async_async(inputPtr, callback, ctx);
                }
                catch
                {
                    if (gcHandle.IsAllocated) gcHandle.Free();
                    throw;
                }
            }
            finally
            {
                Marshal.FreeCoTaskMem(inputPtr);
            }
            return await tcs.Task;
        }

        /// <summary>Cancellable async operation</summary>
        public static async Task<string> DoCancellable(string input)
        {
            var tcs = new TaskCompletionSource<string>(TaskCreationOptions.RunContinuationsAsynchronously);
            NativeMethods.AsyncCb_weaveffi_kitchen_do_cancellable callback = (context, err, result) =>
            {
                try
                {
                    if (err != IntPtr.Zero)
                    {
                        var wErr = Marshal.PtrToStructure<WeaveFFIError>(err);
                        if (wErr.Code != 0)
                        {
                            var msg = Marshal.PtrToStringUTF8(wErr.Message) ?? "";
                            tcs.SetException(new WeaveFFIException(wErr.Code, msg));
                            return;
                        }
                    }
                    tcs.SetResult(Marshal.PtrToStringUTF8(result) ?? "");
                }
                finally
                {
                    if (context != IntPtr.Zero)
                    {
                        GCHandle.FromIntPtr(context).Free();
                    }
                }
            };
            var gcHandle = GCHandle.Alloc(callback, GCHandleType.Normal);
            var ctx = GCHandle.ToIntPtr(gcHandle);
            var inputPtr = Marshal.StringToCoTaskMemUTF8(input);
            try
            {
                try
                {
                    NativeMethods.weaveffi_kitchen_do_cancellable_async(inputPtr, IntPtr.Zero, callback, ctx);
                }
                catch
                {
                    if (gcHandle.IsAllocated) gcHandle.Free();
                    throw;
                }
            }
            finally
            {
                Marshal.FreeCoTaskMem(inputPtr);
            }
            return await tcs.Task;
        }

