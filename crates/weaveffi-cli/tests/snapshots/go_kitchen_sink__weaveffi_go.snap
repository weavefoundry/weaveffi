type wvOutcomeKitchenDoAsync struct {
	val string
	err error
}

//export goWv_weaveffi_kitchen_do_async_callback
func goWv_weaveffi_kitchen_do_async_callback(context unsafe.Pointer, err *C.weaveffi_error, result *C.char) {
	v := wvCallbackTake(uint64(uintptr(context)))
	if v == nil {
		return
	}
	ch := v.(chan wvOutcomeKitchenDoAsync)
	if err != nil && err.code != 0 {
		ch <- wvOutcomeKitchenDoAsync{err: wvMapKitchen(wvTakeError(err))}
		return
	}
	val := ""
	if result != nil {
		val = C.GoString(result)
		C.weaveffi_free_string(result)
	}
	ch <- wvOutcomeKitchenDoAsync{val: val}
}

// DoAsync: Async operation
// Blocks until the async producer completes.
func DoAsync(input string) string {
	ch := make(chan wvOutcomeKitchenDoAsync, 1)
	ctxID := wvCallbackStore(ch)
	cInput := C.CString(input)
	defer C.free(unsafe.Pointer(cInput))
	C.weaveffi_kitchen_do_async_async(cInput, C.weaveffi_kitchen_do_async_callback(unsafe.Pointer(C.goWv_weaveffi_kitchen_do_async_callback)), unsafe.Pointer(uintptr(ctxID)))
	outcome := <-ch
	if outcome.err != nil {
		panic(outcome.err)
	}
	return outcome.val
}

type wvOutcomeKitchenDoCancellable struct {
	val string
	err error
}

//export goWv_weaveffi_kitchen_do_cancellable_callback
func goWv_weaveffi_kitchen_do_cancellable_callback(context unsafe.Pointer, err *C.weaveffi_error, result *C.char) {
	v := wvCallbackTake(uint64(uintptr(context)))
	if v == nil {
		return
	}
	ch := v.(chan wvOutcomeKitchenDoCancellable)
	if err != nil && err.code != 0 {
		ch <- wvOutcomeKitchenDoCancellable{err: wvMapKitchen(wvTakeError(err))}
		return
	}
	val := ""
	if result != nil {
		val = C.GoString(result)
		C.weaveffi_free_string(result)
	}
	ch <- wvOutcomeKitchenDoCancellable{val: val}
}

// DoCancellable: Cancellable async operation
// Blocks until the async producer completes.
func DoCancellable(input string) string {
	ch := make(chan wvOutcomeKitchenDoCancellable, 1)
	ctxID := wvCallbackStore(ch)
	cInput := C.CString(input)
	defer C.free(unsafe.Pointer(cInput))
	C.weaveffi_kitchen_do_cancellable_async(cInput, nil, C.weaveffi_kitchen_do_cancellable_callback(unsafe.Pointer(C.goWv_weaveffi_kitchen_do_cancellable_callback)), unsafe.Pointer(uintptr(ctxID)))
	outcome := <-ch
	if outcome.err != nil {
		panic(outcome.err)
	}
	return outcome.val
}

// LegacyOp: Legacy operation kept for compatibility
// Deprecated: Use new_op instead
func LegacyOp() int32 {
	var cErr C.weaveffi_error
	result := C.weaveffi_kitchen_legacy_op(&cErr)
	wvTrap(&cErr)
	return int32(result)
}

// NewOp: Replacement for legacy_op
func NewOp() int32 {
	var cErr C.weaveffi_error
	result := C.weaveffi_kitchen_new_op(&cErr)
	wvTrap(&cErr)
	return int32(result)
}

// Hello: Trivial nested-module function
func Hello() string {
	var cErr C.weaveffi_error
	result := C.weaveffi_kitchen_nested_hello(&cErr)
	wvTrap(&cErr)
	goResult := C.GoString(result)
	C.weaveffi_free_string(result)
	return goResult
}


