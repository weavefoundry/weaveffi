}

func (s *Token) Id() int64 {
	return int64(C.weaveffi_shared_Token_get_id(s.ptr))
}

func (s *Token) Label() string {
	return C.GoString(C.weaveffi_shared_Token_get_label(s.ptr))
}

func (s *Token) Close() {
	if s.ptr != nil {
		C.weaveffi_shared_Token_destroy(s.ptr)
		s.ptr = nil
	}
}

// Ping: Trivial cross-module helper
func Ping() string {
	var cErr C.weaveffi_error
	result := C.weaveffi_shared_ping(&cErr)
	wvTrap(&cErr)
	goResult := C.GoString(result)
	C.weaveffi_free_string(result)
	return goResult
}

// KitchenErrorsError is a typed error reported by the `kitchen` module.
type KitchenErrorsError struct {
	// Code is the numeric ABI error code (one of the KitchenErrorsError constants).
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *KitchenErrorsError) Error() string {
	return fmt.Sprintf("kitchen: %s (code %d)", e.Message, e.Code)
}

// KitchenErrorsError codes.
const (
	// KitchenErrorsErrorNotFound: Item not found
	KitchenErrorsErrorNotFound int32 = 1
	// KitchenErrorsErrorInvalidInput: Invalid input
	KitchenErrorsErrorInvalidInput int32 = 2
)

// wvMapKitchen converts a non-zero code from the `kitchen` domain into a
// *KitchenErrorsError, falling back to the generic *WeaveFFIError for unknown codes.
func wvMapKitchen(code int32, message string) error {
	switch code {
	case KitchenErrorsErrorNotFound:
		if message == "" {
			message = "Item not found"
		}
		return &KitchenErrorsError{Code: code, Message: message}
	case KitchenErrorsErrorInvalidInput:
		if message == "" {
			message = "Invalid input"
		}
		return &KitchenErrorsError{Code: code, Message: message}
	default:
		return wvBrandError(code, message)
	}
}

// Priority: Task priority levels
type Priority int32

const (
	// PriorityLow: Low priority
	PriorityLow Priority = 0
	// PriorityNormal: Normal priority
	PriorityNormal Priority = 1
	// PriorityHigh: High priority
	PriorityHigh Priority = 2
)

