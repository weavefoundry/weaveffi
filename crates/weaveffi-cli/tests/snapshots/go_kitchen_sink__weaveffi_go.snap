package weaveffi

/*
#cgo LDFLAGS: -lweaveffi
#include "weaveffi.h"
#include <stdlib.h>
*/
import "C"

import (
	"fmt"
	"unsafe"
)

func boolToC(b bool) C._Bool {
	if b {
		return 1
	}
	return 0
}

func cToBool(b C._Bool) bool {
	return b != 0
}

type Token struct {
	ptr *C.weaveffi_shared_Token
}

func (s *Token) Id() int64 {
	return int64(C.weaveffi_shared_Token_get_id(s.ptr))
}

func (s *Token) Label() string {
	return C.GoString(C.weaveffi_shared_Token_get_label(s.ptr))
}

func (s *Token) Close() {
	if s.ptr != nil {
		C.weaveffi_shared_Token_destroy(s.ptr)
		s.ptr = nil
	}
}

func SharedPing() (string, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_shared_ping(&cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return "", goErr
	}
	goResult := C.GoString(result)
	C.weaveffi_free_string(result)
	return goResult, nil
}

type Priority int32

const (
	PriorityLow Priority = 0
	PriorityNormal Priority = 1
	PriorityHigh Priority = 2
)

type Item struct {
	ptr *C.weaveffi_kitchen_Item
}

func (s *Item) Id() int64 {
	return int64(C.weaveffi_kitchen_Item_get_id(s.ptr))
}

func (s *Item) Name() string {
	return C.GoString(C.weaveffi_kitchen_Item_get_name(s.ptr))
}

func (s *Item) Count() int32 {
	return int32(C.weaveffi_kitchen_Item_get_count(s.ptr))
}

func (s *Item) Enabled() bool {
	return cToBool(C.weaveffi_kitchen_Item_get_enabled(s.ptr))
}

func (s *Item) Ratio() float64 {
	return float64(C.weaveffi_kitchen_Item_get_ratio(s.ptr))
}

func (s *Item) Nick() uint32 {
	return uint32(C.weaveffi_kitchen_Item_get_nick(s.ptr))
}

func (s *Item) Payload() []byte {
	return []byte(C.weaveffi_kitchen_Item_get_payload(s.ptr))
}

func (s *Item) Tags() []string {
	return []string(C.weaveffi_kitchen_Item_get_tags(s.ptr))
}

func (s *Item) Attrs() map[string]string {
	return map[string]string(C.weaveffi_kitchen_Item_get_attrs(s.ptr))
}

func (s *Item) Parent() *int64 {
	cVal := C.weaveffi_kitchen_Item_get_parent(s.ptr)
	if cVal == nil {
		return nil
	}
	v := int64(*cVal)
	return &v
}

func (s *Item) Token() *Token {
	return &Token{ptr: C.weaveffi_kitchen_Item_get_token(s.ptr)}
}

func (s *Item) Priority() Priority {
	return Priority(C.weaveffi_kitchen_Item_get_priority(s.ptr))
}

func (s *Item) Close() {
	if s.ptr != nil {
		C.weaveffi_kitchen_Item_destroy(s.ptr)
		s.ptr = nil
	}
}

type ItemBuilder struct {
	fields map[string]interface{}
}

func NewItemBuilder() *ItemBuilder {
	return &ItemBuilder{fields: make(map[string]interface{})}
}

func (b *ItemBuilder) WithId(value int64) *ItemBuilder {
	b.fields["id"] = value
	return b
}

func (b *ItemBuilder) WithName(value string) *ItemBuilder {
	b.fields["name"] = value
	return b
}

func (b *ItemBuilder) WithCount(value int32) *ItemBuilder {
	b.fields["count"] = value
	return b
}

func (b *ItemBuilder) WithEnabled(value bool) *ItemBuilder {
	b.fields["enabled"] = value
	return b
}

func (b *ItemBuilder) WithRatio(value float64) *ItemBuilder {
	b.fields["ratio"] = value
	return b
}

func (b *ItemBuilder) WithNick(value uint32) *ItemBuilder {
	b.fields["nick"] = value
	return b
}

func (b *ItemBuilder) WithPayload(value []byte) *ItemBuilder {
	b.fields["payload"] = value
	return b
}

func (b *ItemBuilder) WithTags(value []string) *ItemBuilder {
	b.fields["tags"] = value
	return b
}

func (b *ItemBuilder) WithAttrs(value map[string]string) *ItemBuilder {
	b.fields["attrs"] = value
	return b
}

func (b *ItemBuilder) WithParent(value *int64) *ItemBuilder {
	b.fields["parent"] = value
	return b
}

func (b *ItemBuilder) WithToken(value *Token) *ItemBuilder {
	b.fields["token"] = value
	return b
}

func (b *ItemBuilder) WithPriority(value Priority) *ItemBuilder {
	b.fields["priority"] = value
	return b
}

func KitchenBoolId(x bool) (bool, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_kitchen_bool_id(boolToC(x), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return false, goErr
	}
	return cToBool(result), nil
}

