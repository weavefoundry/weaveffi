	cb := v.(func(code int32, msg string))
	arg0 := int32(code)
	arg1 := ""
	if msg != nil {
		arg1 = C.GoString(msg)
	}
	cb(arg0, arg1)
}

// KitchenRegisterReadyListener: Subscribe to OnReady events
// Returns a subscription id for KitchenUnregisterReadyListener.
func KitchenRegisterReadyListener(callback func(code int32, msg string)) uint64 {
	ctxID := wvCallbackStore(callback)
	id := uint64(C.weaveffi_kitchen_register_ready_listener(C.weaveffi_kitchen_OnReady_fn(unsafe.Pointer(C.goWv_weaveffi_kitchen_OnReady_fn)), unsafe.Pointer(uintptr(ctxID))))
	wvCallbackMu.Lock()
	wvListenerCtx[id] = ctxID
	wvCallbackMu.Unlock()
	return id
}

// KitchenUnregisterReadyListener unregisters a listener previously registered with KitchenRegisterReadyListener.
func KitchenUnregisterReadyListener(id uint64) {
	C.weaveffi_kitchen_unregister_ready_listener(C.uint64_t(id))
	wvCallbackMu.Lock()
	ctxID, ok := wvListenerCtx[id]
	delete(wvListenerCtx, id)
	wvCallbackMu.Unlock()
	if ok {
		wvCallbackDelete(ctxID)
	}
}

