}

var (
	wvCallbackMu  sync.Mutex
	wvCallbackSeq uint64
	wvCallbacks   = map[uint64]interface{}{}
	// Subscription id -> registry id, so unregister can release the Go callback.
	wvListenerCtx = map[uint64]uint64{}
