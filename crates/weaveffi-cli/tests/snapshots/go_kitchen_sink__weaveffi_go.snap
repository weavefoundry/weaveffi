//export goWv_weaveffi_kitchen_OnReady_fn
func goWv_weaveffi_kitchen_OnReady_fn(code C.int32_t, msg *C.char, context unsafe.Pointer) {
	v := wvCallbackLoad(uint64(uintptr(context)))
	if v == nil {
		return
