func KitchenEchoString(s string) (string, error) {
	cS := C.CString(s)
	defer C.free(unsafe.Pointer(cS))
	var cErr C.weaveffi_error
	result := C.weaveffi_kitchen_echo_string(cS, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return "", goErr
	}
	goResult := C.GoString(result)
	C.weaveffi_free_string(result)
	return goResult, nil
}

func KitchenEchoBytes(b []byte) ([]byte, error) {
	var cBPtr *C.uint8_t
	cBLen := C.size_t(len(b))
	if len(b) > 0 {
		cBPtr = (*C.uint8_t)(unsafe.Pointer(&b[0]))
	}
	var cOutLen C.size_t
	var cErr C.weaveffi_error
	result := C.weaveffi_kitchen_echo_bytes(cBPtr, cBLen, &cOutLen, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	if result == nil {
		return nil, nil
	}
	goResult := C.GoBytes(unsafe.Pointer(result), C.int(cOutLen))
	C.weaveffi_free_bytes(result, cOutLen)
	return goResult, nil
}

