// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

package weaveffi

/*
#cgo LDFLAGS: -lweaveffi
#include "weaveffi.h"
#include <stdlib.h>
extern void goWv_weaveffi_kitchen_OnReady_fn(int32_t code, char* msg, void* context);
extern void goWv_weaveffi_kitchen_do_async_callback(void* context, weaveffi_error* err, char* result);
extern void goWv_weaveffi_kitchen_do_cancellable_callback(void* context, weaveffi_error* err, char* result);
