func (b *ItemBuilder) Build() (*Item, error) {
	id := b.id
	name := b.name
	cName := C.CString(name)
	defer C.free(unsafe.Pointer(cName))
	count := b.count
	enabled := b.enabled
	ratio := b.ratio
	nick := b.nick
	payload := b.payload
	var cPayloadPtr *C.uint8_t
	cPayloadLen := C.size_t(len(payload))
