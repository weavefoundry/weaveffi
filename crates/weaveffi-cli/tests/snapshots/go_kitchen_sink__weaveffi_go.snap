		cTagsPtr = (**C.char)(unsafe.Pointer(&cTagsArr[0]))
	}
	attrs := b.attrs
	cAttrsLen := C.size_t(len(attrs))
	keysAttrs := make([]string, 0, len(attrs))
	valsAttrs := make([]string, 0, len(attrs))
	for mk, mv := range attrs {
		keysAttrs = append(keysAttrs, mk)
		valsAttrs = append(valsAttrs, mv)
	}
	cAttrsKeysPtrArr := make([]*C.char, len(keysAttrs))
	for i, s := range keysAttrs {
		cAttrsKeysPtrArr[i] = C.CString(s)
	}
	defer func() {
		for _, p := range cAttrsKeysPtrArr {
			C.free(unsafe.Pointer(p))
		}
	}()
	var cAttrsKeysPtr **C.char
	if len(cAttrsKeysPtrArr) > 0 {
		cAttrsKeysPtr = (**C.char)(unsafe.Pointer(&cAttrsKeysPtrArr[0]))
	}
	cAttrsValsPtrArr := make([]*C.char, len(valsAttrs))
	for i, s := range valsAttrs {
		cAttrsValsPtrArr[i] = C.CString(s)
	}
	defer func() {
		for _, p := range cAttrsValsPtrArr {
			C.free(unsafe.Pointer(p))
		}
	}()
	var cAttrsValsPtr **C.char
	if len(cAttrsValsPtrArr) > 0 {
		cAttrsValsPtr = (**C.char)(unsafe.Pointer(&cAttrsValsPtrArr[0]))
	}
	parent := b.parent
	var cParent *C.int64_t
	if parent != nil {
		tmp := C.int64_t(*parent)
		cParent = &tmp
	}
	token := b.token
	priority := b.priority
	var cErr C.weaveffi_error
	result := C.weaveffi_kitchen_Item_create(C.int64_t(id), cName, C.int32_t(count), boolToC(enabled), C.double(ratio), C.uint32_t(nick), cPayloadPtr, cPayloadLen, cTagsPtr, cTagsLen, cAttrsKeysPtr, cAttrsValsPtr, cAttrsLen, cParent, token.ptr, C.weaveffi_kitchen_Priority(priority), &cErr)
	if cErr.code != 0 {
		return nil, wvBrandError(wvTakeError(&cErr))
	}
	return &Item{ptr: result}, nil
}

