func KitchenMaybeItem(id int64) (*Item, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_kitchen_maybe_item(C.int64_t(id), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	if result == nil {
		return nil, nil
	}
	return &Item{ptr: result}, nil
}

func KitchenListItems() ([]*Item, error) {
	var cOutLen C.size_t
	var cErr C.weaveffi_error
	result := C.weaveffi_kitchen_list_items(&cOutLen, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	count := int(cOutLen)
	if count == 0 || result == nil {
		return nil, nil
	}
	goResult := make([]*Item, count)
	cSlice := unsafe.Slice((**C.weaveffi_kitchen_Item)(unsafe.Pointer(result)), count)
	for i, v := range cSlice {
		goResult[i] = &Item{ptr: v}
	}
	return goResult, nil
}

