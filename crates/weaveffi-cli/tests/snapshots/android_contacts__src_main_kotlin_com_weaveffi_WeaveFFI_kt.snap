/** Generic WeaveFFI failure: panics, marshalling errors, and unknown codes. */
open class WeaveFFIException(val code: Int, message: String) : Exception(message)

/** Typed error domain `ContactsError` declared by module `contacts`. */
sealed class ContactsException(code: Int, message: String) : WeaveFFIException(code, message) {
    class InvalidName(message: String = "name must not be empty") : ContactsException(1, message)
    class NotFound(message: String = "contact not found") : ContactsException(2, message)

    companion object {
        /** Map a raw `ContactsError` code to its typed exception; unknown codes yield the generic [WeaveFFIException]. */
        fun fromCode(code: Int, message: String): WeaveFFIException = when (code) {
            1 -> InvalidName(message)
            2 -> NotFound(message)
            else -> WeaveFFIException(code, message)
        }
    }
}

