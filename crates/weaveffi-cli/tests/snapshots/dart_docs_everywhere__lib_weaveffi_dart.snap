      throw StateError('missing field: title');
    }
    if (_status == null) {
      throw StateError('missing field: status');
    }
    if (_tags == null) {
      throw StateError('missing field: tags');
    }
    final id = _id!;
    final title = _title!;
    final status = _status!;
    final tags = _tags!;
  final titlePtr = title.toNativeUtf8();
  final tagsPtr = tags.isEmpty ? nullptr : calloc<Pointer<Utf8>>(tags.length);
  for (var i = 0; i < tags.length; i++) {
    tagsPtr[i] = tags[i].toNativeUtf8();
  }
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiDocsDocumentCreate(id, titlePtr, status.value, tagsPtr, tags.length, err);
      _checkError(err);
      return Document._(result);
    } finally {
      calloc.free(titlePtr);
      if (tagsPtr != nullptr) { for (var i = 0; i < tags.length; i++) { calloc.free(tagsPtr[i]); } calloc.free(tagsPtr); }
      calloc.free(err);
    }
  }
}

