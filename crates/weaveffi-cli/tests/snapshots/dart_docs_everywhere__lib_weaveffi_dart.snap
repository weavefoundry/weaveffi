/// Publish a document in the background
Future<bool> publishAsync(int id) {
  final completer = Completer<bool>();
  late NativeCallable<_NativeAsyncCb_weaveffi_docs_publish_async> callable;
  callable = NativeCallable<_NativeAsyncCb_weaveffi_docs_publish_async>.listener((Pointer<Void> context, Pointer<_WeaveFFIError> err, bool result) {
    try {
      if (err.address != 0 && err.ref.code != 0) {
        final code = err.ref.code;
        final msg = err.ref.message.toDartString();
        _weaveffiErrorClear(err);
        completer.completeError(WeaveFFIException(code, msg));
        return;
      }
      completer.complete(result);
    } catch (e) {
      completer.completeError(e);
    } finally {
      callable.close();
    }
  });
  try {
    _weaveffiDocsPublishAsyncAsync(id, callable.nativeFunction, nullptr);
  } catch (e) {
    callable.close();
    rethrow;
  }
  return completer.future;
}

