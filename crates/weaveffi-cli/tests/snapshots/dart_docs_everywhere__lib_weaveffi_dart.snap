/// An ordered collection of documents.
///
/// Notebooks own their documents and release them when destroyed.
class Notebook {
  final Pointer<Void> _handle;
  Notebook._(this._handle);

  /// Releases the native object reference.
  void dispose() {
    _weaveffiDocsNotebookDestroy(_handle);
  }

