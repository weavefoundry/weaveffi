/// Represents a single document tracked by the system.
///
/// Documents are persisted to disk and exposed via the public API.
class Document {
  final Pointer<Void> _handle;
  Document._(this._handle);

  void dispose() {
    _weaveffiDocsDocumentDestroy(_handle);
  }

  /// Stable opaque identifier
  int get id {
    final result = _weaveffiDocsDocumentGetId(_handle);
    return result;
  }

  /// Human-readable title shown in lists
  String get title {
    final result = _weaveffiDocsDocumentGetTitle(_handle);
    final value = result.toDartString();
    _weaveffiFreeString(result);
    return value;
  }

  /// Current lifecycle status
  Status get status {
    final result = _weaveffiDocsDocumentGetStatus(_handle);
    return Status.fromValue(result);
  }

  /// Free-form tags for grouping
  List<String> get tags {
    final outLen = calloc<Size>();
    try {
      final result = _weaveffiDocsDocumentGetTags(_handle, outLen);
      final n = outLen.value;
      if (result == nullptr) return <String>[];
      final arr = result.cast<Pointer<Utf8>>();
      final items = List<String>.generate(n, (i) => arr[i].toDartString());
      for (var i = 0; i < n; i++) {
        _weaveffiFreeString(arr[i]);
      }
      _weaveffiFreeBytes(result.cast(), n * sizeOf<Pointer<Utf8>>());
      return items;
    } finally {
      calloc.free(outLen);
    }
  }
}

