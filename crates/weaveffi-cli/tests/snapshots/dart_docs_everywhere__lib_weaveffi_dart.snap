/// Typed error domain `DocsErrors` declared by module `docs`.
class DocsErrorsException extends WeaveFFIException {
  DocsErrorsException(super.code, super.message);
}

/// Returned when no document matches the requested id
class NotFoundException extends DocsErrorsException {
  NotFoundException([String message = 'Document not found']) : super(1, message);
}

/// Raised when attempting to move into a forbidden state
class InvalidStatusException extends DocsErrorsException {
  InvalidStatusException([String message = 'Invalid status transition']) : super(2, message);
}

WeaveFFIException _mapDocsErrorsException(int code, String message) {
  switch (code) {
    case 1:
      return NotFoundException(message);
    case 2:
      return InvalidStatusException(message);
    default:
      return WeaveFFIException(code, message);
  }
}

void _checkDocsErrorsException(Pointer<_WeaveFFIError> err) {
  if (err.ref.code != 0) {
    final code = err.ref.code;
    final msg = err.ref.message.toDartString();
    _weaveffiErrorClear(err);
    throw _mapDocsErrorsException(code, msg);
  }
}

/// Lifecycle status of a document.
///
/// Used to drive UI badges and filters.
enum Status {
  /// Document is being edited
  draft(0),
  /// Document is publicly visible
  published(1),
  /// Document is hidden from listings
  archived(2),
  ;
  const Status(this.value);
  final int value;

  static Status fromValue(int value) =>
      Status.values.firstWhere((e) => e.value == value);
}

