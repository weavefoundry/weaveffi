    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiDocsNotebookNew(err);
      _checkError(err);
      return Notebook._(result);
    } finally {
      calloc.free(err);
    }
  }

  /// Add a document, returning its position in the notebook
  int insert(Document document) {
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiDocsNotebookInsert(_handle, document._handle, err);
      _checkError(err);
      return result;
    } finally {
      calloc.free(err);
    }
  }

  /// Look up a document by identifier, failing when none matches
  ///
  /// Throws [DocsErrorsException] on domain errors.
  Document find(int id) {
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiDocsNotebookFind(_handle, id, err);
      _checkDocsErrorsException(err);
      return Document._(result);
    } finally {
      calloc.free(err);
    }
  }

  /// The number of documents currently held
  int size() {
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiDocsNotebookSize(_handle, err);
      _checkError(err);
      return result;
    } finally {
      calloc.free(err);
    }
  }

  /// The largest number of documents one notebook will hold
  static int maxDocuments() {
    final err = calloc<_WeaveFFIError>();
    try {
      final result = _weaveffiDocsNotebookMaxDocuments(err);
      _checkError(err);
      return result;
    } finally {
      calloc.free(err);
    }
  }
}

