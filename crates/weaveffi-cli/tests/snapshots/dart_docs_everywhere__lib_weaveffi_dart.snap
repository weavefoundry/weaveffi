/// Subscribe to document-saved notifications
/// Registers a OnSaved listener. Returns a subscription id for unregisterSavedListener().
int registerSavedListener(void Function(int docId, int revision) callback) {
  final callable = NativeCallable<_NativeCb_weaveffi_docs_OnSaved_fn>.isolateLocal((int docId, int revision, Pointer<Void> context) {
    callback(docId, revision);
  });
  final id = _weaveffiDocsRegisterSavedListener(callable.nativeFunction, nullptr);
  _listenerCallables[id] = callable;
  return id;
}

/// Unregisters a listener previously registered with registerSavedListener().
void unregisterSavedListener(int id) {
  _weaveffiDocsUnregisterSavedListener(id);
  _listenerCallables.remove(id)?.close();
}

