/// Create a brand new document.
///
/// The document starts in `Draft` status; callers must publish
/// it explicitly to make it visible.
Document createDocument(String title, List<String> tags) {
  final titlePtr = title.toNativeUtf8();
  final tagsPtr = tags.isEmpty ? nullptr : calloc<Pointer<Utf8>>(tags.length);
  for (var i = 0; i < tags.length; i++) {
    tagsPtr[i] = tags[i].toNativeUtf8();
  }
  final err = calloc<_WeaveFFIError>();
  try {
    final result = _weaveffiDocsCreateDocument(titlePtr, tagsPtr, tags.length, err);
    _checkError(err);
    return Document._(result);
  } finally {
    calloc.free(titlePtr);
    if (tagsPtr != nullptr) { for (var i = 0; i < tags.length; i++) { calloc.free(tagsPtr[i]); } calloc.free(tagsPtr); }
    calloc.free(err);
  }
}

