from enum import IntEnum
from typing import Dict, Iterator, List, Optional

class Category(IntEnum):
    Electronics: int
    Clothing: int
    Food: int
    Books: int

class Product:
    @property
    def id(self) -> int: ...
    @property
    def name(self) -> str: ...
    @property
    def description(self) -> Optional[str]: ...
    @property
    def price(self) -> float: ...
    @property
    def category(self) -> "Category": ...
    @property
    def tags(self) -> List[str]: ...

def create_product(name: str, price: float, category: "Category") -> int: ...

def get_product(id: int) -> "Product": ...

def search_products(category: "Category") -> List["Product"]: ...

def update_price(id: int, price: float) -> bool: ...

def delete_product(id: int) -> bool: ...

class OrderItem:
    @property
    def product_id(self) -> int: ...
    @property
    def quantity(self) -> int: ...
    @property
    def unit_price(self) -> float: ...

class Order:
    @property
    def id(self) -> int: ...
    @property
    def items(self) -> List["OrderItem"]: ...
    @property
    def total(self) -> float: ...
    @property
    def status(self) -> str: ...

def create_order(items: List["OrderItem"]) -> int: ...

def get_order(id: int) -> "Order": ...

def cancel_order(id: int) -> bool: ...

def add_product_to_order(order_id: int, product: "Product") -> bool: ...
