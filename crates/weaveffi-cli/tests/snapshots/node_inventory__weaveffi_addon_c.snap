static napi_value Napi_weaveffi_orders_add_product_to_order(napi_env env, napi_callback_info info) {
  size_t argc = 2;
  napi_value args[2];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  int64_t order_id_raw;
  napi_get_value_int64(env, args[0], &order_id_raw);
  int64_t product_raw;
  napi_get_value_int64(env, args[1], &product_raw);
  weaveffi_error err = {0};
  bool result = weaveffi_orders_add_product_to_order((weaveffi_handle_t)order_id_raw, (const weaveffi_products_Product*)(intptr_t)product_raw, &err);
  if (err.code != 0) {
    napi_throw_error(env, NULL, err.message);
    weaveffi_error_clear(&err);
    return NULL;
  }
  napi_value ret;
  napi_get_boolean(env, result, &ret);
  return ret;
}

static napi_value Init(napi_env env, napi_value exports) {
  napi_property_descriptor props[] = {
    { "create_product", NULL, Napi_weaveffi_products_create_product, NULL, NULL, NULL, napi_default, NULL },
    { "get_product", NULL, Napi_weaveffi_products_get_product, NULL, NULL, NULL, napi_default, NULL },
    { "search_products", NULL, Napi_weaveffi_products_search_products, NULL, NULL, NULL, napi_default, NULL },
    { "update_price", NULL, Napi_weaveffi_products_update_price, NULL, NULL, NULL, napi_default, NULL },
    { "delete_product", NULL, Napi_weaveffi_products_delete_product, NULL, NULL, NULL, napi_default, NULL },
    { "create_order", NULL, Napi_weaveffi_orders_create_order, NULL, NULL, NULL, napi_default, NULL },
    { "get_order", NULL, Napi_weaveffi_orders_get_order, NULL, NULL, NULL, napi_default, NULL },
    { "cancel_order", NULL, Napi_weaveffi_orders_cancel_order, NULL, NULL, NULL, napi_default, NULL },
    { "add_product_to_order", NULL, Napi_weaveffi_orders_add_product_to_order, NULL, NULL, NULL, napi_default, NULL },
  };
  napi_define_properties(env, exports, 9, props);
  return exports;
}

NAPI_MODULE(NODE_GYP_MODULE_NAME, Init)
