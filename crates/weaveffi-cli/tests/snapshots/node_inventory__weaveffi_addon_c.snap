#include <node_api.h>
#include "weaveffi.h"
#include <stdlib.h>
#include <string.h>

static napi_value Napi_weaveffi_products_create_product(napi_env env, napi_callback_info info) {
  size_t argc = 3;
  napi_value args[3];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  size_t name_len;
  napi_get_value_string_utf8(env, args[0], NULL, 0, &name_len);
  char* name = (char*)malloc(name_len + 1);
  napi_get_value_string_utf8(env, args[0], name, name_len + 1, &name_len);
  double price;
  napi_get_value_double(env, args[1], &price);
  int32_t category;
  napi_get_value_int32(env, args[2], &category);
  weaveffi_error err = {0};
  weaveffi_handle_t result = weaveffi_products_create_product(name, price, (weaveffi_products_Category)category, &err);
  free(name);
  if (err.code != 0) {
    napi_throw_error(env, NULL, err.message);
    weaveffi_error_clear(&err);
    return NULL;
  }
  napi_value ret;
  napi_create_int64(env, (int64_t)result, &ret);
  return ret;
}

static napi_value Napi_weaveffi_products_get_product(napi_env env, napi_callback_info info) {
  size_t argc = 1;
  napi_value args[1];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  int64_t id_raw;
  napi_get_value_int64(env, args[0], &id_raw);
  weaveffi_error err = {0};
  weaveffi_products_Product* result = weaveffi_products_get_product((weaveffi_handle_t)id_raw, &err);
  if (err.code != 0) {
    napi_throw_error(env, NULL, err.message);
    weaveffi_error_clear(&err);
    return NULL;
  }
  napi_value ret;
  napi_create_int64(env, (int64_t)(intptr_t)result, &ret);
  return ret;
}

static napi_value Napi_weaveffi_products_search_products(napi_env env, napi_callback_info info) {
  size_t argc = 1;
  napi_value args[1];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  int32_t category;
  napi_get_value_int32(env, args[0], &category);
  weaveffi_error err = {0};
  size_t out_len;
  weaveffi_products_Product** result = weaveffi_products_search_products((weaveffi_products_Category)category, &out_len, &err);
  if (err.code != 0) {
    napi_throw_error(env, NULL, err.message);
    weaveffi_error_clear(&err);
    return NULL;
  }
  napi_value ret;
  napi_create_array_with_length(env, out_len, &ret);
  for (size_t ret_i = 0; ret_i < out_len; ret_i++) {
    napi_value elem;
    napi_create_int64(env, (int64_t)(intptr_t)result[ret_i], &elem);
    napi_set_element(env, ret, (uint32_t)ret_i, elem);
  }
  free(result);
  return ret;
}

static napi_value Napi_weaveffi_products_update_price(napi_env env, napi_callback_info info) {
  size_t argc = 2;
  napi_value args[2];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  int64_t id_raw;
  napi_get_value_int64(env, args[0], &id_raw);
  double price;
  napi_get_value_double(env, args[1], &price);
  weaveffi_error err = {0};
  bool result = weaveffi_products_update_price((weaveffi_handle_t)id_raw, price, &err);
  if (err.code != 0) {
    napi_throw_error(env, NULL, err.message);
    weaveffi_error_clear(&err);
    return NULL;
  }
  napi_value ret;
  napi_get_boolean(env, result, &ret);
  return ret;
}

