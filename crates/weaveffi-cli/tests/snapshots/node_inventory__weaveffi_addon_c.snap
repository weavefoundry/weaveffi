static napi_value Napi_weaveffi_orders_create_order(napi_env env, napi_callback_info info) {
  size_t argc = 1;
  napi_value args[1];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  uint32_t items_count;
  napi_get_array_length(env, args[0], &items_count);
  weaveffi_orders_OrderItem** items_arr = (weaveffi_orders_OrderItem**)malloc(sizeof(weaveffi_orders_OrderItem*) * (items_count + 1));
  for (uint32_t items_i = 0; items_i < items_count; items_i++) {
    napi_value items_el;
    napi_get_element(env, args[0], items_i, &items_el);
    int64_t items_sp;
    napi_get_value_int64(env, items_el, &items_sp);
    items_arr[items_i] = (weaveffi_orders_OrderItem*)(intptr_t)items_sp;
  }
  weaveffi_error err = {0};
  weaveffi_handle_t result = weaveffi_orders_create_order(items_arr, (size_t)items_count, &err);
  free(items_arr);
  if (err.code != 0) {
    napi_throw_error(env, NULL, err.message);
    weaveffi_error_clear(&err);
    return NULL;
  }
  napi_value ret;
  napi_create_int64(env, (int64_t)result, &ret);
  return ret;
}

