// ShapesDescribe: Render a shape to a string
func ShapesDescribe(shape *Shape) (string, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_describe(shape.ptr, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return "", goErr
	}
	goResult := C.GoString(result)
	C.weaveffi_free_string(result)
	return goResult, nil
}

