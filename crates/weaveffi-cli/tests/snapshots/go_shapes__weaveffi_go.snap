// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

package weaveffi

/*
#cgo LDFLAGS: -lweaveffi
#include "weaveffi.h"
#include <stdlib.h>
*/
import "C"

import (
	"fmt"
	"unsafe"
)

// WeaveFFIError reports a failure crossing the C boundary that no typed
// error domain claims: an unknown code, a marshalling failure, or a
// producer panic.
type WeaveFFIError struct {
	// Code is the numeric ABI error code.
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *WeaveFFIError) Error() string {
	return fmt.Sprintf("weaveffi: %s (code %d)", e.Message, e.Code)
}

// wvTakeError reads and clears a non-zero C error slot, returning its
// code and message.
func wvTakeError(cErr *C.weaveffi_error) (int32, string) {
	code := int32(cErr.code)
	msg := ""
	if cErr.message != nil {
		msg = C.GoString(cErr.message)
	}
	C.weaveffi_error_clear(cErr)
	return code, msg
}

func wvBrandError(code int32, message string) error {
	return &WeaveFFIError{Code: code, Message: message}
}

// wvTrap panics when the C error slot reports a failure. Non-throwing
// wrappers check their slot with it: a non-zero code there can only be
// a producer panic or a marshalling failure.
func wvTrap(cErr *C.weaveffi_error) {
	if cErr.code != 0 {
		code, msg := wvTakeError(cErr)
		panic(fmt.Sprintf("weaveffi: %s (code %d)", msg, code))
	}
}

// Shape: An algebraic shape (sum type with associated data)
type Shape struct {
	ptr *C.weaveffi_shapes_Shape
}

const (
	// ShapeEmpty: The empty shape (a unit variant)
	ShapeEmpty int32 = 0
	// ShapeCircle: A circle with a radius
	ShapeCircle int32 = 1
	// ShapeRectangle: An axis-aligned rectangle
	ShapeRectangle int32 = 2
	// ShapeBounded: An integer-bounded shape (exercises narrow + wide ints)
	ShapeBounded int32 = 3
	// ShapeLabeled: A labeled shape with a small count
	ShapeLabeled int32 = 4
)

func (s *Shape) Tag() int32 {
	return int32(C.weaveffi_shapes_Shape_tag(s.ptr))
}

// NewShapeEmpty: The empty shape (a unit variant)
func NewShapeEmpty() (*Shape, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_Shape_Empty_new(&cErr)
	if cErr.code != 0 {
		return nil, wvBrandError(wvTakeError(&cErr))
	}
	return &Shape{ptr: result}, nil
}

// NewShapeCircle: A circle with a radius
func NewShapeCircle(radius float64) (*Shape, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_Shape_Circle_new(C.double(radius), &cErr)
	if cErr.code != 0 {
		return nil, wvBrandError(wvTakeError(&cErr))
	}
	return &Shape{ptr: result}, nil
}

// NewShapeRectangle: An axis-aligned rectangle
func NewShapeRectangle(width float32, height float32) (*Shape, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_Shape_Rectangle_new(C.float(width), C.float(height), &cErr)
	if cErr.code != 0 {
		return nil, wvBrandError(wvTakeError(&cErr))
	}
	return &Shape{ptr: result}, nil
}

// NewShapeBounded: An integer-bounded shape (exercises narrow + wide ints)
func NewShapeBounded(min int16, max int16, weight uint64) (*Shape, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_Shape_Bounded_new(C.int16_t(min), C.int16_t(max), C.uint64_t(weight), &cErr)
	if cErr.code != 0 {
		return nil, wvBrandError(wvTakeError(&cErr))
	}
	return &Shape{ptr: result}, nil
}

// NewShapeLabeled: A labeled shape with a small count
func NewShapeLabeled(label string, count uint8) (*Shape, error) {
	cLabel := C.CString(label)
	defer C.free(unsafe.Pointer(cLabel))
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_Shape_Labeled_new(cLabel, C.uint8_t(count), &cErr)
	if cErr.code != 0 {
		return nil, wvBrandError(wvTakeError(&cErr))
	}
	return &Shape{ptr: result}, nil
}

// CircleRadius: Radius in points
func (s *Shape) CircleRadius() float64 {
	return float64(C.weaveffi_shapes_Shape_Circle_get_radius(s.ptr))
}

func (s *Shape) RectangleWidth() float32 {
	return float32(C.weaveffi_shapes_Shape_Rectangle_get_width(s.ptr))
}

func (s *Shape) RectangleHeight() float32 {
	return float32(C.weaveffi_shapes_Shape_Rectangle_get_height(s.ptr))
}

func (s *Shape) BoundedMin() int16 {
	return int16(C.weaveffi_shapes_Shape_Bounded_get_min(s.ptr))
}

func (s *Shape) BoundedMax() int16 {
	return int16(C.weaveffi_shapes_Shape_Bounded_get_max(s.ptr))
}

func (s *Shape) BoundedWeight() uint64 {
	return uint64(C.weaveffi_shapes_Shape_Bounded_get_weight(s.ptr))
}

func (s *Shape) LabeledLabel() string {
	cStr := C.weaveffi_shapes_Shape_Labeled_get_label(s.ptr)
	goResult := C.GoString(cStr)
	C.weaveffi_free_string(cStr)
	return goResult
}

func (s *Shape) LabeledCount() uint8 {
	return uint8(C.weaveffi_shapes_Shape_Labeled_get_count(s.ptr))
}

func (s *Shape) Close() {
	if s.ptr != nil {
		C.weaveffi_shapes_Shape_destroy(s.ptr)
		s.ptr = nil
	}
}

// Channel: A plain C-style enum (no payloads)
type Channel int32

const (
	ChannelRed Channel = 0
	ChannelGreen Channel = 1
	ChannelBlue Channel = 2
)

// Numerics: One field per supported numeric primitive
type Numerics struct {
	ptr *C.weaveffi_shapes_Numerics
}

func (s *Numerics) A() int8 {
	return int8(C.weaveffi_shapes_Numerics_get_a(s.ptr))
}

