func (s *Numerics) J() float64 {
	return float64(C.weaveffi_shapes_Numerics_get_j(s.ptr))
}

func (s *Numerics) Close() {
	if s.ptr != nil {
		C.weaveffi_shapes_Numerics_destroy(s.ptr)
		s.ptr = nil
	}
}

// Describe: Render a shape to a string
func Describe(shape *Shape) string {
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_describe(shape.ptr, &cErr)
	wvTrap(&cErr)
	goResult := C.GoString(result)
	C.weaveffi_free_string(result)
	return goResult
}

// Scale: Scale a shape by a factor, returning a new shape
func Scale(shape *Shape, factor float64) *Shape {
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_scale(shape.ptr, C.double(factor), &cErr)
	wvTrap(&cErr)
	return &Shape{ptr: result}
}

// SumBytes: Sum a list of bytes into a wide integer (numerics smoke)
func SumBytes(values []uint8) uint64 {
	cValuesLen := C.size_t(len(values))
	var cValuesPtr *C.uint8_t
	if len(values) > 0 {
		cValuesPtr = (*C.uint8_t)(unsafe.Pointer(&values[0]))
	}
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_sum_bytes(cValuesPtr, cValuesLen, &cErr)
	wvTrap(&cErr)
	return uint64(result)
}

// MakeNumerics: Build a Numerics struct from every numeric primitive
func MakeNumerics(a int8, b int16, c int32, d int64, e uint8, f uint16, g uint32, h uint64, i float32, j float64) *Numerics {
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_make_numerics(C.int8_t(a), C.int16_t(b), C.int32_t(c), C.int64_t(d), C.uint8_t(e), C.uint16_t(f), C.uint32_t(g), C.uint64_t(h), C.float(i), C.double(j), &cErr)
	wvTrap(&cErr)
	return &Numerics{ptr: result}
}


