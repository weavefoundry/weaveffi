		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	return &Shape{ptr: result}, nil
}

// ShapesSumBytes: Sum a list of bytes into a wide integer (numerics smoke)
func ShapesSumBytes(values []uint8) (uint64, error) {
	cValuesLen := C.size_t(len(values))
	var cValuesPtr *C.uint8_t
	if len(values) > 0 {
		cValuesPtr = (*C.uint8_t)(unsafe.Pointer(&values[0]))
	}
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_sum_bytes(cValuesPtr, cValuesLen, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return 0, goErr
	}
	return uint64(result), nil
}

// ShapesMakeNumerics: Build a Numerics struct from every numeric primitive
func ShapesMakeNumerics(a int8, b int16, c int32, d int64, e uint8, f uint16, g uint32, h uint64, i float32, j float64) (*Numerics, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_shapes_make_numerics(C.int8_t(a), C.int16_t(b), C.int32_t(c), C.int64_t(d), C.uint8_t(e), C.uint16_t(f), C.uint32_t(g), C.uint64_t(h), C.float(i), C.double(j), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	return &Numerics{ptr: result}, nil
}


