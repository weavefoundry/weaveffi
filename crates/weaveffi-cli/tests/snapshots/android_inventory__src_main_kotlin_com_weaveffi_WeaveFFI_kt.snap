/** Generic WeaveFFI failure: panics, marshalling errors, and unknown codes. */
open class WeaveFFIException(val code: Int, message: String) : Exception(message)

/** Typed error domain `ProductsError` declared by module `products`. */
sealed class ProductsException(code: Int, message: String) : WeaveFFIException(code, message) {
    class InvalidPrice(message: String = "price must be positive") : ProductsException(1, message)
    class ProductNotFound(message: String = "product not found") : ProductsException(2, message)

    companion object {
        /** Map a raw `ProductsError` code to its typed exception; unknown codes yield the generic [WeaveFFIException]. */
        fun fromCode(code: Int, message: String): WeaveFFIException = when (code) {
            1 -> InvalidPrice(message)
            2 -> ProductNotFound(message)
            else -> WeaveFFIException(code, message)
        }
    }
}

/** Typed error domain `OrdersError` declared by module `orders`. */
sealed class OrdersException(code: Int, message: String) : WeaveFFIException(code, message) {
    class OrderNotFound(message: String = "order not found") : OrdersException(1, message)
    class EmptyOrder(message: String = "order must contain at least one item") : OrdersException(2, message)

    companion object {
        /** Map a raw `OrdersError` code to its typed exception; unknown codes yield the generic [WeaveFFIException]. */
        fun fromCode(code: Int, message: String): WeaveFFIException = when (code) {
            1 -> OrderNotFound(message)
            2 -> EmptyOrder(message)
            else -> WeaveFFIException(code, message)
        }
    }
}

