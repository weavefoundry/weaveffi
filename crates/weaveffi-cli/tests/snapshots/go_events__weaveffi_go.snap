import "C"

import (
	"fmt"
	"sync"
	"unsafe"
)

var (
	wvCallbackMu  sync.Mutex
	wvCallbackSeq uint64
	wvCallbacks   = map[uint64]interface{}{}
	// Subscription id -> registry id, so unregister can release the Go callback.
	wvListenerCtx = map[uint64]uint64{}
)

func wvCallbackStore(v interface{}) uint64 {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	wvCallbackSeq++
	wvCallbacks[wvCallbackSeq] = v
	return wvCallbackSeq
}

func wvCallbackLoad(id uint64) interface{} {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	return wvCallbacks[id]
}

func wvCallbackTake(id uint64) interface{} {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	v := wvCallbacks[id]
	delete(wvCallbacks, id)
	return v
}

func wvCallbackDelete(id uint64) {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	delete(wvCallbacks, id)
}

//export goWv_weaveffi_events_OnMessage_fn
func goWv_weaveffi_events_OnMessage_fn(message *C.char, context unsafe.Pointer) {
	v := wvCallbackLoad(uint64(uintptr(context)))
	if v == nil {
		return
	}
	cb := v.(func(message string))
	arg0 := ""
	if message != nil {
		arg0 = C.GoString(message)
	}
	cb(arg0)
}

// Returns a subscription id for EventsUnregisterMessageListener.
func EventsRegisterMessageListener(callback func(message string)) uint64 {
	ctxID := wvCallbackStore(callback)
	id := uint64(C.weaveffi_events_register_message_listener(C.weaveffi_events_OnMessage_fn(unsafe.Pointer(C.goWv_weaveffi_events_OnMessage_fn)), unsafe.Pointer(uintptr(ctxID))))
	wvCallbackMu.Lock()
	wvListenerCtx[id] = ctxID
	wvCallbackMu.Unlock()
	return id
}

// EventsUnregisterMessageListener unregisters a listener previously registered with EventsRegisterMessageListener.
func EventsUnregisterMessageListener(id uint64) {
	C.weaveffi_events_unregister_message_listener(C.uint64_t(id))
	wvCallbackMu.Lock()
	ctxID, ok := wvListenerCtx[id]
	delete(wvListenerCtx, id)
	wvCallbackMu.Unlock()
	if ok {
		wvCallbackDelete(ctxID)
	}
}

// EventsSendMessage: Send a message, triggering the OnMessage callback
func EventsSendMessage(text string) error {
	cText := C.CString(text)
	defer C.free(unsafe.Pointer(cText))
	var cErr C.weaveffi_error
	C.weaveffi_events_send_message(cText, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return goErr
	}
	return nil
}

// EventsGetMessages: Return an iterator over all sent messages
func EventsGetMessages() ([]string, error) {
	var cErr C.weaveffi_error
	it := C.weaveffi_events_get_messages(&cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	defer C.weaveffi_events_GetMessagesIterator_destroy(it)
	goResult := []string{}
	for {
		var outItem *C.char
		var iterErr C.weaveffi_error
		if C.weaveffi_events_GetMessagesIterator_next(it, &outItem, &iterErr) == 0 {
			break
		}
		if iterErr.code != 0 {
			goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(iterErr.message), int(iterErr.code))
			C.weaveffi_error_clear(&iterErr)
			return nil, goErr
		}
		goResult = append(goResult, C.GoString(outItem))
		C.weaveffi_free_string(outItem)
	}
	return goResult, nil
