static napi_value Napi_weaveffi_calculator_echo(napi_env env, napi_callback_info info) {
  size_t argc = 1;
  napi_value args[1];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  size_t s_len;
  napi_get_value_string_utf8(env, args[0], NULL, 0, &s_len);
  char* s = (char*)malloc(s_len + 1);
  napi_get_value_string_utf8(env, args[0], s, s_len + 1, &s_len);
  weaveffi_error err = {0};
  const char* result = weaveffi_calculator_echo(s, &err);
  free(s);
  if (err.code != 0) {
    napi_throw_error(env, NULL, err.message);
    weaveffi_error_clear(&err);
    return NULL;
  }
  napi_value ret;
  napi_create_string_utf8(env, result, NAPI_AUTO_LENGTH, &ret);
  weaveffi_free_string(result);
  return ret;
}

static napi_value Init(napi_env env, napi_value exports) {
  napi_property_descriptor props[] = {
    { "add", NULL, Napi_weaveffi_calculator_add, NULL, NULL, NULL, napi_default, NULL },
    { "mul", NULL, Napi_weaveffi_calculator_mul, NULL, NULL, NULL, napi_default, NULL },
    { "div", NULL, Napi_weaveffi_calculator_div, NULL, NULL, NULL, napi_default, NULL },
    { "echo", NULL, Napi_weaveffi_calculator_echo, NULL, NULL, NULL, napi_default, NULL },
  };
  napi_define_properties(env, exports, 4, props);
  return exports;
}

NAPI_MODULE(NODE_GYP_MODULE_NAME, Init)
