#include <node_api.h>
#include "weaveffi.h"
#include <stdlib.h>
#include <string.h>

static napi_value Napi_weaveffi_calculator_add(napi_env env, napi_callback_info info) {
  size_t argc = 2;
  napi_value args[2];
  napi_get_cb_info(env, info, &argc, args, NULL, NULL);
  int32_t a;
  napi_get_value_int32(env, args[0], &a);
  int32_t b;
  napi_get_value_int32(env, args[1], &b);
  weaveffi_error err = {0};
  int32_t result = weaveffi_calculator_add(a, b, &err);
  if (err.code != 0) {
    napi_throw_error(env, NULL, err.message);
    weaveffi_error_clear(&err);
    return NULL;
  }
  napi_value ret;
  napi_create_int32(env, result, &ret);
  return ret;
}

