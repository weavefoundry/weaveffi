/** Render a shape to a string */
inline std::string shapes_describe(const Shape& shape) {
    weaveffi_error err{};
    auto result = weaveffi_shapes_describe(static_cast<const weaveffi_shapes_Shape*>(shape.handle()), &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        throw WeaveFFIError(code, msg);
    }
    std::string ret(result);
    weaveffi_free_string(result);
    return ret;
}

/** Scale a shape by a factor, returning a new shape */
inline Shape shapes_scale(const Shape& shape, double factor) {
    weaveffi_error err{};
    auto result = weaveffi_shapes_scale(static_cast<const weaveffi_shapes_Shape*>(shape.handle()), factor, &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        throw WeaveFFIError(code, msg);
    }
    return Shape(result);
}

/** Sum a list of bytes into a wide integer (numerics smoke) */
inline uint64_t shapes_sum_bytes(const std::vector<uint8_t>& values) {
    weaveffi_error err{};
    auto result = weaveffi_shapes_sum_bytes(values.data(), values.size(), &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        throw WeaveFFIError(code, msg);
    }
    return result;
}

/** Build a Numerics struct from every numeric primitive */
inline Numerics shapes_make_numerics(int8_t a, int16_t b, int32_t c, int64_t d, uint8_t e, uint16_t f, uint32_t g, uint64_t h, float i, double j) {
    weaveffi_error err{};
    auto result = weaveffi_shapes_make_numerics(a, b, c, d, e, f, g, h, i, j, &err);
    if (err.code != 0) {
        std::string msg(err.message ? err.message : "unknown error");
        int32_t code = err.code;
        weaveffi_error_clear(&err);
        throw WeaveFFIError(code, msg);
    }
    return Numerics(result);
}

