// Generated types for WeaveFFI functions
export interface Token {
  id: number;
  label: string;
}
// module shared
/** Maps to C function: weaveffi_shared_ping */
export function ping(): string
export interface Item {
  id: number;
  name: string;
  count: number;
  enabled: boolean;
  ratio: number;
  nick: number;
  payload: Buffer;
  tags: string[];
  attrs: Record<string, string>;
  parent: number | null;
  token: Token;
  priority: Priority;
}
export interface ItemBuilder {
  withId(value: number): ItemBuilder;
  withName(value: string): ItemBuilder;
  withCount(value: number): ItemBuilder;
  withEnabled(value: boolean): ItemBuilder;
  withRatio(value: number): ItemBuilder;
  withNick(value: number): ItemBuilder;
  withPayload(value: Buffer): ItemBuilder;
  withTags(value: string[]): ItemBuilder;
  withAttrs(value: Record<string, string>): ItemBuilder;
  withParent(value: number | null): ItemBuilder;
  withToken(value: Token): ItemBuilder;
  withPriority(value: Priority): ItemBuilder;
  build(): Item;
}
export enum Priority {
  Low = 0,
  Normal = 1,
  High = 2,
}
