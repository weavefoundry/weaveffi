public enum WeaveFFIError: Error, LocalizedError {
    case error(code: Int32, message: String)
    public var errorDescription: String? {
        switch self {
        case let .error(_, message): return message
        }
    }
    public var errorCode: Int32 {
        switch self {
        case let .error(code, _): return code
        }
    }
}

@inline(__always)
func check(_ err: inout weaveffi_error) throws {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        throw WeaveFFIError.error(code: code, message: message)
    }
}

@inline(__always)
func trap(_ err: inout weaveffi_error) {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        fatalError("\(code): \(message)")
    }
}

@inline(__always)
func withOptionalPointer<T, R>(to value: T?, _ body: (UnsafePointer<T>?) throws -> R) rethrows -> R {
    guard let value = value else { return try body(nil) }
    return try withUnsafePointer(to: value) { try body($0) }
}

@inline(__always)
func withOptionalCString<R>(_ value: String?, _ body: (UnsafePointer<CChar>?) throws -> R) rethrows -> R {
    guard let value = value else { return try body(nil) }
    return try value.withCString { try body($0) }
}

@inline(__always)
func wvFreeArray<T>(_ ptr: UnsafeMutablePointer<T>, _ count: Int) {
    weaveffi_free_bytes(UnsafeMutableRawPointer(ptr).assumingMemoryBound(to: UInt8.self), count * MemoryLayout<T>.stride)
}

@inline(__always)
func wvFreeBox<T>(_ ptr: UnsafeMutablePointer<T>) {
    weaveffi_free_bytes(UnsafeMutableRawPointer(ptr).assumingMemoryBound(to: UInt8.self), MemoryLayout<T>.size)
}

/// Typed errors reported by the `calculator` module.
public enum CalcError: Error, LocalizedError {
    case divisionByZero(message: String)
    public var errorDescription: String? {
        switch self {
        case let .divisionByZero(message): return message
        }
    }
    /// The numeric ABI code carried by this error.
    public var errorCode: Int32 {
        switch self {
        case .divisionByZero: return 1
        }
    }
}

@inline(__always)
func mapCalculator(code: Int32, message: String) -> Error {
    switch code {
    case 1: return CalcError.divisionByZero(message: message.isEmpty ? "division by zero" : message)
    default: return WeaveFFIError.error(code: code, message: message)
    }
}

@inline(__always)
func checkCalculator(_ err: inout weaveffi_error) throws {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        throw mapCalculator(code: code, message: message)
    }
}

public enum Calculator {
    /// Add two integers
    public static func add(a: Int32, b: Int32) -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_calculator_add(a, b, &err)
        trap(&err)
        return rv
    }
    /// Multiply two integers
    public static func mul(a: Int32, b: Int32) -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_calculator_mul(a, b, &err)
        trap(&err)
        return rv
    }
    /// Divide two integers, failing on a zero divisor
    public static func div(a: Int32, b: Int32) throws -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_calculator_div(a, b, &err)
        try checkCalculator(&err)
        return rv
    }
    /// Echo a string back
    public static func echo(s: String) -> String {
        var err = weaveffi_error(code: 0, message: nil)
        let result: String = s.withCString { s_ptr in
                let rv = weaveffi_calculator_echo(s_ptr, &err)
                trap(&err)
                guard let rv = rv else { fatalError("-1: null string") }
                defer { weaveffi_free_string(rv) }
                return String(cString: rv)
        }
        return result
    }
}

