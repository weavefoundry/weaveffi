// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT — your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

import CWeaveFFI
import Foundation

public enum WeaveFFIError: Error, LocalizedError {
    case error(code: Int32, message: String)
    public var errorDescription: String? {
        switch self {
        case let .error(_, message): return message
        }
    }
    public var errorCode: Int32 {
        switch self {
        case let .error(code, _): return code
        }
    }
}

@inline(__always)
func check(_ err: inout weaveffi_error) throws {
    if err.code != 0 {
        let code = err.code
        let message = err.message.flatMap { String(cString: $0) } ?? ""
        weaveffi_error_clear(&err)
        throw WeaveFFIError.error(code: code, message: message)
    }
}

@inline(__always)
func withOptionalPointer<T, R>(to value: T?, _ body: (UnsafePointer<T>?) throws -> R) rethrows -> R {
    guard let value = value else { return try body(nil) }
    return try withUnsafePointer(to: value) { try body($0) }
}

@inline(__always)
func withOptionalCString<R>(_ value: String?, _ body: (UnsafePointer<CChar>?) throws -> R) rethrows -> R {
    guard let value = value else { return try body(nil) }
    return try value.withCString { try body($0) }
}

public enum Calculator {
    /// Add two integers
    public static func calculator_add(_ a: Int32, _ b: Int32) throws -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_calculator_add(a, b, &err)
        try check(&err)
        return rv
    }
    /// Multiply two integers
    public static func calculator_mul(_ a: Int32, _ b: Int32) throws -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_calculator_mul(a, b, &err)
        try check(&err)
        return rv
    }
    /// Divide two integers
    public static func calculator_div(_ a: Int32, _ b: Int32) throws -> Int32 {
        var err = weaveffi_error(code: 0, message: nil)
        let rv = weaveffi_calculator_div(a, b, &err)
        try check(&err)
        return rv
    }
    /// Echo a string back
    public static func calculator_echo(_ s: String) throws -> String {
        var err = weaveffi_error(code: 0, message: nil)
        let result: String = try s.withCString { s_ptr in
                let rv = weaveffi_calculator_echo(s_ptr, &err)
                try check(&err)
                guard let rv = rv else { throw WeaveFFIError.error(code: -1, message: "null string") }
                defer { weaveffi_free_string(rv) }
                return String(cString: rv)
        }
        return result
    }
}

