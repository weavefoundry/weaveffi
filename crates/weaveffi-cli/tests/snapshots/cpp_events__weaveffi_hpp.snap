namespace weaveffi {

/** Base exception for every error reported through the C ABI. */
class WeaveFFIError : public std::runtime_error {
    int32_t code_;

public:
    WeaveFFIError(int32_t code, const std::string& msg) : std::runtime_error(msg), code_(code) {}
    int32_t code() const { return code_; }
};

namespace detail {

/** Throw the generic WeaveFFIError if `err` carries a nonzero code. */
inline void check(weaveffi_error& err) {
    if (err.code == 0) return;
    std::string msg(err.message ? err.message : "unknown error");
    int32_t code = err.code;
    weaveffi_error_clear(&err);
    throw WeaveFFIError(code, msg);
}

/** Wrap an async-callback error as the generic WeaveFFIError. */
inline std::exception_ptr make_error(int32_t code, const std::string& msg) {
    return std::make_exception_ptr(WeaveFFIError(code, msg));
}

} // namespace detail

namespace detail {

inline std::mutex& wv_listener_mutex() {
    static std::mutex m;
    return m;
}

inline std::unordered_map<uint64_t, std::shared_ptr<void>>& wv_listener_registry() {
    static std::unordered_map<uint64_t, std::shared_ptr<void>> registry;
    return registry;
}

} // namespace detail

namespace events {

/** @return A subscription id for unregister_message_listener(). */
inline uint64_t register_message_listener(std::function<void(std::string)> callback) {
    auto fn = std::make_shared<std::function<void(std::string)>>(std::move(callback));
    uint64_t id = weaveffi_events_register_message_listener(
        [](const char* message, void* context) {
            auto& cb = *static_cast<std::function<void(std::string)>*>(context);
            cb(std::string(message ? message : ""));
        },
        fn.get());
    std::lock_guard<std::mutex> lock(detail::wv_listener_mutex());
    detail::wv_listener_registry()[id] = fn;
    return id;
}

/** Unregisters a listener previously registered with register_message_listener(). */
inline void unregister_message_listener(uint64_t id) {
    weaveffi_events_unregister_message_listener(id);
    std::lock_guard<std::mutex> lock(detail::wv_listener_mutex());
    detail::wv_listener_registry().erase(id);
}

/** Send a message, triggering the OnMessage callback */
inline void send_message(const std::string& text) {
    weaveffi_error err{};
    weaveffi_events_send_message(text.c_str(), &err);
    detail::check(err);
}

/**
 * A lazy, move-only range over the `std::string` elements produced by `get_messages()`.
 *
 * Each iteration step pulls exactly one element from the producer, so results stream in constant memory. The range owns the producer-side iterator and releases it exactly once: eagerly when the range is exhausted, or from the destructor when iteration is abandoned early.
 */
class GetMessagesIterator {
    weaveffi_events_GetMessagesIterator* handle_;

public:
    /** Adopts ownership of the raw producer iterator handle. */
    explicit GetMessagesIterator(weaveffi_events_GetMessagesIterator* h) : handle_(h) {}

    ~GetMessagesIterator() {
        if (handle_) weaveffi_events_GetMessagesIterator_destroy(handle_);
    }

    GetMessagesIterator(const GetMessagesIterator&) = delete;
    GetMessagesIterator& operator=(const GetMessagesIterator&) = delete;

    GetMessagesIterator(GetMessagesIterator&& other) noexcept : handle_(other.handle_) {
        other.handle_ = nullptr;
    }

    GetMessagesIterator& operator=(GetMessagesIterator&& other) noexcept {
        if (this != &other) {
            if (handle_) weaveffi_events_GetMessagesIterator_destroy(handle_);
            handle_ = other.handle_;
            other.handle_ = nullptr;
        }
        return *this;
    }

    /** Pulls the next element from the producer, or `std::nullopt` once exhausted (which releases the producer iterator eagerly). A producer error throws the generic WeaveFFIError after releasing the iterator. */
    std::optional<std::string> next() {
        if (!handle_) return std::nullopt;
        weaveffi_error err{};
        const char* item{};
        int32_t has_item = weaveffi_events_GetMessagesIterator_next(handle_, &item, &err);
        if (err.code != 0) {
            weaveffi_events_GetMessagesIterator_destroy(handle_);
            handle_ = nullptr;
            detail::check(err);
        }
        if (has_item == 0) {
            weaveffi_events_GetMessagesIterator_destroy(handle_);
            handle_ = nullptr;
            return std::nullopt;
        }
        std::string value(item);
        weaveffi_free_string(item);
        return value;
    }

    /** Sentinel type marking the end of the range. */
    struct sentinel {};

    /** Single-pass input iterator; each increment pulls one element from the producer. */
    class iterator {
        GetMessagesIterator* range_;
        std::optional<std::string> current_;

    public:
        using iterator_category = std::input_iterator_tag;
        using value_type = std::string;
        using difference_type = std::ptrdiff_t;
        using pointer = std::string*;
        using reference = std::string&;

        /** Binds to `range` and pulls the first element. */
        explicit iterator(GetMessagesIterator* range) : range_(range), current_(range->next()) {}
        reference operator*() { return *current_; }
        pointer operator->() { return &*current_; }
        iterator& operator++() { current_ = range_->next(); return *this; }
        void operator++(int) { current_ = range_->next(); }
        bool operator==(sentinel) const { return !current_.has_value(); }
        bool operator!=(sentinel) const { return current_.has_value(); }
    };

    /** Begins iteration by pulling the first element. */
    iterator begin() { return iterator(this); }

    /** The past-the-end sentinel. */
    sentinel end() const { return sentinel{}; }
};

/**
 * Return an iterator over all sent messages
 *
 * @return A lazy `GetMessagesIterator` range that streams one element per iteration step and releases the producer iterator when exhausted or destroyed.
 */
inline GetMessagesIterator get_messages() {
    weaveffi_error err{};
    weaveffi_events_GetMessagesIterator* iter = weaveffi_events_get_messages(&err);
    detail::check(err);
    return GetMessagesIterator(iter);
}

