// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

package weaveffi

/*
#cgo LDFLAGS: -lweaveffi
#include "weaveffi.h"
#include <stdlib.h>
*/
import "C"

import (
	"fmt"
	"unsafe"
)

// WeaveFFIError reports a failure crossing the C boundary that no typed
// error domain claims: an unknown code, a marshalling failure, or a
// producer panic.
type WeaveFFIError struct {
	// Code is the numeric ABI error code.
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *WeaveFFIError) Error() string {
	return fmt.Sprintf("weaveffi: %s (code %d)", e.Message, e.Code)
}

// wvTakeError reads and clears a non-zero C error slot, returning its
// code and message.
func wvTakeError(cErr *C.weaveffi_error) (int32, string) {
	code := int32(cErr.code)
	msg := ""
	if cErr.message != nil {
		msg = C.GoString(cErr.message)
	}
	C.weaveffi_error_clear(cErr)
	return code, msg
}

func wvBrandError(code int32, message string) error {
	return &WeaveFFIError{Code: code, Message: message}
}

// wvTrap panics when the C error slot reports a failure. Non-throwing
// wrappers check their slot with it: a non-zero code there can only be
// a producer panic or a marshalling failure.
func wvTrap(cErr *C.weaveffi_error) {
	if cErr.code != 0 {
		code, msg := wvTakeError(cErr)
		panic(fmt.Sprintf("weaveffi: %s (code %d)", msg, code))
	}
}

// CalcError is a typed error reported by the `calculator` module.
type CalcError struct {
	// Code is the numeric ABI error code (one of the CalcError constants).
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *CalcError) Error() string {
	return fmt.Sprintf("calculator: %s (code %d)", e.Message, e.Code)
}

// CalcError codes.
const (
	// CalcErrorDivisionByZero division by zero
	CalcErrorDivisionByZero int32 = 1
)

// wvMapCalculator converts a non-zero code from the `calculator` domain into a
// *CalcError, falling back to the generic *WeaveFFIError for unknown codes.
func wvMapCalculator(code int32, message string) error {
	switch code {
	case CalcErrorDivisionByZero:
		if message == "" {
			message = "division by zero"
		}
		return &CalcError{Code: code, Message: message}
	default:
		return wvBrandError(code, message)
	}
}

// Add: Add two integers
func Add(a int32, b int32) int32 {
	var cErr C.weaveffi_error
	result := C.weaveffi_calculator_add(C.int32_t(a), C.int32_t(b), &cErr)
	wvTrap(&cErr)
	return int32(result)
}

// Mul: Multiply two integers
func Mul(a int32, b int32) int32 {
	var cErr C.weaveffi_error
	result := C.weaveffi_calculator_mul(C.int32_t(a), C.int32_t(b), &cErr)
	wvTrap(&cErr)
	return int32(result)
}

// Div: Divide two integers, failing on a zero divisor
func Div(a int32, b int32) (int32, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_calculator_div(C.int32_t(a), C.int32_t(b), &cErr)
	if cErr.code != 0 {
		return 0, wvMapCalculator(wvTakeError(&cErr))
	}
	return int32(result), nil
}

// Echo: Echo a string back
func Echo(s string) string {
	cS := C.CString(s)
	defer C.free(unsafe.Pointer(cS))
	var cErr C.weaveffi_error
	result := C.weaveffi_calculator_echo(cS, &cErr)
	wvTrap(&cErr)
	goResult := C.GoString(result)
	C.weaveffi_free_string(result)
	return goResult
}


// END weaveffi.go
