package weaveffi

/*
#cgo LDFLAGS: -lweaveffi
#include "weaveffi.h"
#include <stdlib.h>
*/
import "C"

import (
	"fmt"
	"unsafe"
)

// CalculatorAdd: Add two integers
func CalculatorAdd(a int32, b int32) (int32, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_calculator_add(C.int32_t(a), C.int32_t(b), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return 0, goErr
	}
	return int32(result), nil
}

// CalculatorMul: Multiply two integers
func CalculatorMul(a int32, b int32) (int32, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_calculator_mul(C.int32_t(a), C.int32_t(b), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return 0, goErr
	}
	return int32(result), nil
}

// CalculatorDiv: Divide two integers
func CalculatorDiv(a int32, b int32) (int32, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_calculator_div(C.int32_t(a), C.int32_t(b), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return 0, goErr
	}
	return int32(result), nil
}

// CalculatorEcho: Echo a string back
func CalculatorEcho(s string) (string, error) {
	cS := C.CString(s)
	defer C.free(unsafe.Pointer(cS))
	var cErr C.weaveffi_error
	result := C.weaveffi_calculator_echo(cS, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return "", goErr
	}
	goResult := C.GoString(result)
	C.weaveffi_free_string(result)
	return goResult, nil
}
