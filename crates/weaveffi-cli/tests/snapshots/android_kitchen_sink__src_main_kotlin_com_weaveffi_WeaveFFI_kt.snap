class WeaveFFI {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @Volatile private var callbackExceptionHandler: ((Throwable) -> Unit)? = null

        /**
         * Installs a handler for exceptions thrown by listener callbacks and
         * async continuations on native producer threads. These exceptions have
         * no Kotlin caller to propagate to; when no handler is installed, they
         * are logged with their stack trace and dropped. Pass `null` to
         * restore the default logging behavior.
         */
        @JvmStatic fun setCallbackExceptionHandler(handler: ((Throwable) -> Unit)?) {
            callbackExceptionHandler = handler
        }

        // Invoked from the JNI glue; rethrowing signals "no handler" so the
        // glue falls back to ExceptionDescribe.
        @JvmStatic private fun dispatchCallbackException(t: Throwable) {
            callbackExceptionHandler?.invoke(t) ?: throw t
        }

        /**
         * Trivial cross-module helper
         */
        @JvmStatic external fun ping(): String
        /**
         * Subscribe to OnReady events
         *
         * Exceptions thrown by the callback cannot propagate to a caller (events fire on a producer thread); they are delivered to the handler installed via [setCallbackExceptionHandler], or logged with their stack trace and dropped when no handler is set.
         */
        @JvmStatic external fun registerReadyListener(callback: (Int, String) -> Unit): Long
        @JvmStatic external fun unregisterReadyListener(id: Long)
        /**
         * Identity for bool
         */
        @JvmStatic external fun boolId(x: Boolean): Boolean
        @JvmStatic external fun i32Id(x: Int): Int
        @JvmStatic external fun u32Id(x: Long): Long
        @JvmStatic external fun i64Id(x: Long): Long
        @JvmStatic external fun f64Id(x: Double): Double
        @JvmStatic external fun echoString(s: String): String
        @JvmStatic external fun echoBytes(b: ByteArray): ByteArray
        /**
         * Borrowed string parameter
         */
        @JvmStatic external fun echoBorrowedStr(s: String): String
        /**
         * Borrowed bytes parameter
         */
        @JvmStatic external fun echoBorrowedBytes(b: ByteArray): ByteArray
        /**
         * Returns an opaque handle
         */
        @JvmStatic external fun openHandle(): Long
        /**
         * Returns a typed handle
         */
        @JvmStatic private external fun openTypedHandleJni(): Long
        @JvmStatic fun openTypedHandle(): Token = Token(openTypedHandleJni())
        /**
         * Optional struct return
         */
        @JvmStatic private external fun maybeItemJni(id: Long): Long?
        @JvmStatic fun maybeItem(id: Long): Item? = maybeItemJni(id)?.let { Item(it) }
        /**
         * List of structs
         */
        @JvmStatic external fun listItems(): LongArray
        /**
         * Map return type
         */
        @JvmStatic external fun getAttrs(): Map<String, Int>
        /**
         * Iterator return type
         */
        @JvmStatic private external fun streamItemsJni(): Long
        @JvmStatic fun streamItems(): Iterator<Item> = KitchenStreamItemsIterator(streamItemsJni())
        /**
         * Returns the shared Token type from another module
         */
        @JvmStatic private external fun crossModuleTokenJni(): Long
        @JvmStatic fun crossModuleToken(): Token = Token(crossModuleTokenJni())
        /**
         * Async operation
         */
        @JvmStatic private external fun doAsyncAsync(input: String, callback: Any)
        @JvmStatic suspend fun doAsync(input: String): String = suspendCancellableCoroutine { cont ->
            doAsyncAsync(input, WeaveContinuation(cont) { code, message -> WeaveFFIException(code, message) })
        }
        /**
         * Cancellable async operation
         */
        @JvmStatic private external fun doCancellableAsync(input: String, cancelToken: Long, callback: Any)
        @JvmStatic suspend fun doCancellable(input: String): String = suspendCancellableCoroutine { cont ->
            doCancellableAsync(input, 0L, WeaveContinuation(cont) { code, message -> WeaveFFIException(code, message) })
        }
        /**
         * Legacy operation kept for compatibility
         */
        @Deprecated("Use new_op instead")
        @JvmStatic external fun legacyOp(): Int
        /**
         * Replacement for legacy_op
         */
        @JvmStatic external fun newOp(): Int
        /**
         * Trivial nested-module function
         */
        @JvmStatic external fun hello(): String
    }
}

/** A reusable token referenced across modules */
class Token internal constructor(internal var handle: Long) : java.io.Closeable {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic external fun nativeCreate(id: Long, label: String): Long
        @JvmStatic external fun nativeDestroy(handle: Long)
        @JvmStatic external fun nativeGetId(handle: Long): Long
        @JvmStatic external fun nativeGetLabel(handle: Long): String

        fun create(id: Long, label: String): Token = Token(nativeCreate(id, label))
    }

    val id: Long get() = nativeGetId(handle)
    val label: String get() = nativeGetLabel(handle)

    override fun close() {
        if (handle != 0L) {
            nativeDestroy(handle)
            handle = 0L
        }
    }

    protected fun finalize() {
        close()
    }
}

/** Task priority levels */
enum class Priority(val value: Int) {
    /** Low priority */
    Low(0),
    /** Normal priority */
    Normal(1),
    /** High priority */
    High(2);

    companion object {
        fun fromValue(value: Int): Priority = entries.first { it.value == value }
    }
}

