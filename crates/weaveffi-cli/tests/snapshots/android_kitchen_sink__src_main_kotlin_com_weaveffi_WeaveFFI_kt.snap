/** A pocket-sized interface exercising the object surface */
class Gadget internal constructor(internal var handle: Long) : java.io.Closeable {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic private external fun nativeNew(id: Long): Long
        @JvmStatic private external fun nativeVersion(): String
        @JvmStatic private external fun nativeDescribe(selfHandle: Long): String
        @JvmStatic private external fun nativePoke(selfHandle: Long, times: Int): Int
        @JvmStatic private external fun nativeDestroy(handle: Long)

        /**
         * Create a gadget with the given id
         */
        operator fun invoke(id: Long): Gadget = Gadget(nativeNew(id))

        /**
         * The gadget subsystem version string
         */
        fun version(): String = nativeVersion()
    }

    /**
     * Render the gadget as a human-readable string
     */
    fun describe(): String = nativeDescribe(handle)

    /**
     * Poke the gadget a number of times, failing on a negative count
     */
    fun poke(times: Int): Int = nativePoke(handle, times)

    override fun close() {
        if (handle != 0L) {
            nativeDestroy(handle)
            handle = 0L
        }
    }

    protected fun finalize() {
        close()
    }
}

/**
 * A lazy iterator over the `Item` elements streamed by [streamItems]. Each step pulls
 * exactly one element from the native producer. The native handle is
 * released when the producer is exhausted, when [close] is called, or by
 * the finalizer if the iterator is abandoned, whichever comes first.
 */
class KitchenStreamItemsIterator internal constructor(private var handle: Long) : Iterator<Item>, java.io.Closeable {
    private var nextSlot: Array<Any?>? = null

    override fun hasNext(): Boolean {
        if (nextSlot != null) return true
        if (handle == 0L) return false
        val slot = nativeNext(handle)
        if (slot == null) {
            close()
            return false
        }
        nextSlot = slot
        return true
    }

    override fun next(): Item {
        if (!hasNext()) throw NoSuchElementException()
        val raw = nextSlot!![0]
        nextSlot = null
        return Item(raw as Long)
    }

    override fun close() {
        if (handle != 0L) {
            nativeDestroy(handle)
            handle = 0L
        }
    }

    protected fun finalize() {
        close()
    }

    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic private external fun nativeNext(handle: Long): Array<Any?>?
        @JvmStatic private external fun nativeDestroy(handle: Long)
    }
}

/** Generic WeaveFFI failure: panics, marshalling errors, and unknown codes. */
open class WeaveFFIException(val code: Int, message: String) : Exception(message)

/** Typed error domain `KitchenErrors` declared by module `kitchen`. */
sealed class KitchenErrorsException(code: Int, message: String) : WeaveFFIException(code, message) {
    class NotFound(message: String = "Item not found") : KitchenErrorsException(1, message)
    class InvalidInput(message: String = "Invalid input") : KitchenErrorsException(2, message)

    companion object {
        /** Map a raw `KitchenErrors` code to its typed exception; unknown codes yield the generic [WeaveFFIException]. */
        fun fromCode(code: Int, message: String): WeaveFFIException = when (code) {
            1 -> NotFound(message)
            2 -> InvalidInput(message)
            else -> WeaveFFIException(code, message)
        }
    }
}

internal class WeaveContinuation<T>(
    private val cont: kotlinx.coroutines.CancellableContinuation<T>,
    private val mapError: (Int, String) -> Throwable
) {
    @Suppress("UNCHECKED_CAST")
    fun onSuccess(result: Any?) { cont.resume(result as T) }
    fun onError(code: Int, message: String) { cont.resumeWithException(mapError(code, message)) }
}

