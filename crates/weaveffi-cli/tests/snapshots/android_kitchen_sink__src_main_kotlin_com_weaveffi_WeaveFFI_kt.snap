package com.weaveffi

import kotlinx.coroutines.suspendCancellableCoroutine
import kotlin.coroutines.resume
import kotlin.coroutines.resumeWithException

class WeaveFFI {
    companion object {
        init { System.loadLibrary("weaveffi") }

        /**
         * Trivial cross-module helper
         */
        @JvmStatic external fun ping(): String
        /**
         * Identity for bool
         */
        @JvmStatic external fun bool_id(x: Boolean): Boolean
        @JvmStatic external fun i32_id(x: Int): Int
        @JvmStatic external fun u32_id(x: Long): Long
        @JvmStatic external fun i64_id(x: Long): Long
        @JvmStatic external fun f64_id(x: Double): Double
        @JvmStatic external fun echo_string(s: String): String
        @JvmStatic external fun echo_bytes(b: ByteArray): ByteArray
        /**
         * Borrowed string parameter
         */
        @JvmStatic external fun echo_borrowed_str(s: String): String
        /**
         * Borrowed bytes parameter
         */
        @JvmStatic external fun echo_borrowed_bytes(b: ByteArray): ByteArray
        /**
         * Returns an opaque handle
         */
        @JvmStatic external fun open_handle(): Long
        /**
         * Returns a typed handle
         */
        @JvmStatic external fun open_typed_handle(): Token
        /**
         * Optional struct return
         */
        @JvmStatic external fun maybe_item(id: Long): Long?
        /**
         * List of structs
         */
        @JvmStatic external fun list_items(): LongArray
        /**
         * Map return type
         */
        @JvmStatic external fun get_attrs(): Map<String, Int>
        /**
         * Iterator return type
         */
        @JvmStatic external fun stream_items(): Iterator<Long>
        /**
         * Returns the shared Token type from another module
         */
        @JvmStatic external fun cross_module_token(): Long
        /**
         * Async operation
         */
        @JvmStatic private external fun do_asyncAsync(input: String, callback: Any)
        @JvmStatic suspend fun do_async(input: String): String = suspendCancellableCoroutine { cont ->
            do_asyncAsync(input, WeaveContinuation(cont))
        }
        /**
         * Cancellable async operation
         */
        @JvmStatic private external fun do_cancellableAsync(input: String, cancelToken: Long, callback: Any)
        @JvmStatic suspend fun do_cancellable(input: String): String = suspendCancellableCoroutine { cont ->
            do_cancellableAsync(input, 0L, WeaveContinuation(cont))
        }
        /**
         * Legacy operation kept for compatibility
         */
        @Deprecated("Use new_op instead")
        @JvmStatic external fun legacy_op(): Int
        /**
         * Replacement for legacy_op
         */
        @JvmStatic external fun new_op(): Int
        /**
         * Trivial nested-module function
         */
        @JvmStatic external fun hello(): String
    }
}

/** A reusable token referenced across modules */
class Token internal constructor(private var handle: Long) : java.io.Closeable {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic external fun nativeCreate(id: Long, label: String): Long
        @JvmStatic external fun nativeDestroy(handle: Long)
        @JvmStatic external fun nativeGetId(handle: Long): Long
        @JvmStatic external fun nativeGetLabel(handle: Long): String

        fun create(id: Long, label: String): Token = Token(nativeCreate(id, label))
    }

    val id: Long get() = nativeGetId(handle)
    val label: String get() = nativeGetLabel(handle)

    override fun close() {
        if (handle != 0L) {
            nativeDestroy(handle)
            handle = 0L
        }
    }

    protected fun finalize() {
        close()
    }
}

/** Task priority levels */
enum class Priority(val value: Int) {
    /** Low priority */
    Low(0),
    /** Normal priority */
    Normal(1),
    /** High priority */
    High(2);

    companion object {
        fun fromValue(value: Int): Priority = entries.first { it.value == value }
    }
}

/** Kitchen sink struct exercising every field feature */
class Item internal constructor(private var handle: Long) : java.io.Closeable {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic external fun nativeCreate(id: Long, name: String, count: Int, enabled: Boolean, ratio: Double, nick: Long, payload: ByteArray, tags: Array<String>, attrs: Map<String, String>, parent: Long?, token: Long, priority: Int): Long
        @JvmStatic external fun nativeDestroy(handle: Long)
        @JvmStatic external fun nativeGetId(handle: Long): Long
        @JvmStatic external fun nativeGetName(handle: Long): String
        @JvmStatic external fun nativeGetCount(handle: Long): Int
        @JvmStatic external fun nativeGetEnabled(handle: Long): Boolean
        @JvmStatic external fun nativeGetRatio(handle: Long): Double
        @JvmStatic external fun nativeGetNick(handle: Long): Long
        @JvmStatic external fun nativeGetPayload(handle: Long): ByteArray
        @JvmStatic external fun nativeGetTags(handle: Long): Array<String>
        @JvmStatic external fun nativeGetAttrs(handle: Long): Map<String, String>
        @JvmStatic external fun nativeGetParent(handle: Long): Long?
        @JvmStatic external fun nativeGetToken(handle: Long): Long
        @JvmStatic external fun nativeGetPriority(handle: Long): Int

        fun create(id: Long, name: String, count: Int, enabled: Boolean, ratio: Double, nick: Long, payload: ByteArray, tags: Array<String>, attrs: Map<String, String>, parent: Long?, token: Long, priority: Int): Item = Item(nativeCreate(id, name, count, enabled, ratio, nick, payload, tags, attrs, parent, token, priority))
    }

    /** Stable identifier */
    val id: Long get() = nativeGetId(handle)
    /** Display name */
    val name: String get() = nativeGetName(handle)
    /** Initial count */
    val count: Int get() = nativeGetCount(handle)
    /** Whether the item is enabled */
    val enabled: Boolean get() = nativeGetEnabled(handle)
    /** Scaling ratio */
    val ratio: Double get() = nativeGetRatio(handle)
    val nick: Long get() = nativeGetNick(handle)
    val payload: ByteArray get() = nativeGetPayload(handle)
    val tags: Array<String> get() = nativeGetTags(handle)
    val attrs: Map<String, String> get() = nativeGetAttrs(handle)
    val parent: Long? get() = nativeGetParent(handle)
    /** Cross-module struct reference */
    val token: Token get() = Token(nativeGetToken(handle))
    val priority: Priority get() = nativeGetPriority(handle)

    override fun close() {
        if (handle != 0L) {
            nativeDestroy(handle)
            handle = 0L
        }
    }

    protected fun finalize() {
        close()
    }
}

/** Kitchen sink struct exercising every field feature */
class ItemBuilder {
    private var id: Long? = null
    private var name: String? = null
    private var count: Int? = null
    private var enabled: Boolean? = null
    private var ratio: Double? = null
    private var nick: Long? = null
    private var payload: ByteArray? = null
    private var tags: Array<String>? = null
    private var attrs: Map<String, String>? = null
    private var parent: Long?? = null
    private var token: Token? = null
    private var priority: Priority? = null
    /** Stable identifier */
    fun withId(id: Long): ItemBuilder {
        this.id = id
        return this
    }
    /** Display name */
    fun withName(name: String): ItemBuilder {
        this.name = name
        return this
    }
    /** Initial count */
    fun withCount(count: Int): ItemBuilder {
        this.count = count
        return this
    }
    /** Whether the item is enabled */
    fun withEnabled(enabled: Boolean): ItemBuilder {
        this.enabled = enabled
        return this
    }
    /** Scaling ratio */
    fun withRatio(ratio: Double): ItemBuilder {
        this.ratio = ratio
        return this
    }
    fun withNick(nick: Long): ItemBuilder {
        this.nick = nick
        return this
    }
    fun withPayload(payload: ByteArray): ItemBuilder {
        this.payload = payload
        return this
    }
    fun withTags(tags: Array<String>): ItemBuilder {
        this.tags = tags
        return this
    }
    fun withAttrs(attrs: Map<String, String>): ItemBuilder {
        this.attrs = attrs
        return this
    }
    fun withParent(parent: Long?): ItemBuilder {
        this.parent = parent
        return this
    }
    /** Cross-module struct reference */
    fun withToken(token: Token): ItemBuilder {
        this.token = token
        return this
    }
    fun withPriority(priority: Priority): ItemBuilder {
        this.priority = priority
        return this
    }
    fun build(): Item {
        return Item.create(
            id ?: throw IllegalStateException("missing field: id"),
            name ?: throw IllegalStateException("missing field: name"),
            count ?: throw IllegalStateException("missing field: count"),
            enabled ?: throw IllegalStateException("missing field: enabled"),
            ratio ?: throw IllegalStateException("missing field: ratio"),
            nick ?: throw IllegalStateException("missing field: nick"),
            payload ?: throw IllegalStateException("missing field: payload"),
            tags ?: throw IllegalStateException("missing field: tags"),
            attrs ?: throw IllegalStateException("missing field: attrs"),
            parent ?: throw IllegalStateException("missing field: parent"),
            token ?: throw IllegalStateException("missing field: token"),
            priority ?: throw IllegalStateException("missing field: priority")
        )
    }
}

sealed class WeaveFFIException(val code: Int, message: String) : Exception(message) {
    class not_found(message: String = "Item not found") : WeaveFFIException(1, message)
    class invalid_input(message: String = "Invalid input") : WeaveFFIException(2, message)
}

internal class WeaveContinuation<T>(private val cont: kotlinx.coroutines.CancellableContinuation<T>) {
    @Suppress("UNCHECKED_CAST")
    fun onSuccess(result: Any?) { cont.resume(result as T) }
    fun onError(message: String) { cont.resumeWithException(RuntimeException(message)) }
}
