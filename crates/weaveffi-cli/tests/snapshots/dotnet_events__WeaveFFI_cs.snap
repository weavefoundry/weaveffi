// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

#nullable enable

using System;
using System.Collections.Generic;
using System.Runtime.InteropServices;

namespace WeaveFFI
{
    public class WeaveFFIException : Exception
    {
        public int Code { get; }

        public WeaveFFIException(int code, string message) : base(message)
        {
            Code = code;
        }
    }

    [StructLayout(LayoutKind.Sequential)]
    internal struct WeaveFFIError
    {
        public int Code;
        public IntPtr Message;

        internal static void Check(WeaveFFIError err)
        {
            if (err.Code != 0)
            {
                var msg = Marshal.PtrToStringUTF8(err.Message) ?? "";
                throw new WeaveFFIException(err.Code, msg);
            }
        }
    }

    internal static class WeaveFFIHelpers
    {
        internal static IntPtr StringToPtr(string? s)
        {
            return s == null ? IntPtr.Zero : Marshal.StringToCoTaskMemUTF8(s);
        }

        internal static string? PtrToString(IntPtr ptr)
        {
            return ptr == IntPtr.Zero ? null : Marshal.PtrToStringUTF8(ptr);
        }

        internal static void FreePtr(IntPtr ptr)
        {
            Marshal.FreeCoTaskMem(ptr);
        }
    }

    internal static class NativeMethods
    {
        private const string LibName = "weaveffi";

        [DllImport(LibName, CallingConvention = CallingConvention.Cdecl)]
        internal static extern void weaveffi_free_string(IntPtr ptr);

        [DllImport(LibName, CallingConvention = CallingConvention.Cdecl)]
        internal static extern void weaveffi_free_bytes(IntPtr ptr, UIntPtr len);

        [UnmanagedFunctionPointer(CallingConvention.Cdecl)]
        internal delegate void Cb_weaveffi_events_OnMessage_fn(IntPtr message, IntPtr context);

        [DllImport(LibName, EntryPoint = "weaveffi_events_register_message_listener", CallingConvention = CallingConvention.Cdecl)]
        internal static extern ulong weaveffi_events_register_message_listener(Cb_weaveffi_events_OnMessage_fn callback, IntPtr context);

        [DllImport(LibName, EntryPoint = "weaveffi_events_unregister_message_listener", CallingConvention = CallingConvention.Cdecl)]
        internal static extern void weaveffi_events_unregister_message_listener(ulong id);

        [DllImport(LibName, EntryPoint = "weaveffi_events_send_message", CallingConvention = CallingConvention.Cdecl)]
        internal static extern void weaveffi_events_send_message(IntPtr text, ref WeaveFFIError err);

        [DllImport(LibName, EntryPoint = "weaveffi_events_get_messages", CallingConvention = CallingConvention.Cdecl)]
        internal static extern IntPtr weaveffi_events_get_messages(ref WeaveFFIError out_err);

        [DllImport(LibName, EntryPoint = "weaveffi_events_GetMessagesIterator_next", CallingConvention = CallingConvention.Cdecl)]
        internal static extern int weaveffi_events_GetMessagesIterator_next(IntPtr iter, out IntPtr out_item, ref WeaveFFIError out_err);

        [DllImport(LibName, EntryPoint = "weaveffi_events_GetMessagesIterator_destroy", CallingConvention = CallingConvention.Cdecl)]
        internal static extern void weaveffi_events_GetMessagesIterator_destroy(IntPtr iter);

    }

    public static class Events
    {
        private static readonly object _listenerLock = new object();
        // Live listener delegates by subscription id. Holding the delegate
        // here keeps its native thunk alive until unregistered; without this
        // the GC could collect a delegate the producer still calls.
        private static readonly Dictionary<ulong, Delegate> _listenerRefs = new Dictionary<ulong, Delegate>();

        /// <returns>A subscription id for UnregisterMessageListener().</returns>
        public static ulong RegisterMessageListener(Action<string> callback)
        {
            NativeMethods.Cb_weaveffi_events_OnMessage_fn trampoline = (message, context) =>
            {
                callback(Marshal.PtrToStringUTF8(message) ?? "");
            };
            ulong id;
            lock (_listenerLock)
            {
                id = NativeMethods.weaveffi_events_register_message_listener(trampoline, IntPtr.Zero);
                _listenerRefs[id] = trampoline;
            }
            return id;
        }

        /// <summary>Unregisters a listener previously registered with RegisterMessageListener().</summary>
        public static void UnregisterMessageListener(ulong id)
        {
            NativeMethods.weaveffi_events_unregister_message_listener(id);
            lock (_listenerLock)
            {
                _listenerRefs.Remove(id);
            }
        }

        /// <summary>Send a message, triggering the OnMessage callback</summary>
        public static void SendMessage(string text)
        {
            var err = new WeaveFFIError();
            var textPtr = Marshal.StringToCoTaskMemUTF8(text);
            try
            {
                NativeMethods.weaveffi_events_send_message(textPtr, ref err);
                WeaveFFIError.Check(err);
            }
            finally
            {
                Marshal.FreeCoTaskMem(textPtr);
            }
        }

        /// <summary>Return an iterator over all sent messages</summary>
        public static IEnumerable<string> GetMessages()
        {
            var err = new WeaveFFIError();
            var iter = NativeMethods.weaveffi_events_get_messages(ref err);
            WeaveFFIError.Check(err);
            return EnumerateGetMessages(iter);
        }

        private static IEnumerable<string> EnumerateGetMessages(IntPtr iter)
        {
            try
            {
                while (true)
                {
                    var iterErr = new WeaveFFIError();
                    if (NativeMethods.weaveffi_events_GetMessagesIterator_next(iter, out var out_item, ref iterErr) == 0)
                    {
                        WeaveFFIError.Check(iterErr);
                        yield break;
                    }
                    WeaveFFIError.Check(iterErr);
                    var item = Marshal.PtrToStringUTF8(out_item) ?? "";
                    NativeMethods.weaveffi_free_string(out_item);
                    yield return item;
                }
            }
            finally
            {
                NativeMethods.weaveffi_events_GetMessagesIterator_destroy(iter);
            }
        }

    }

}

