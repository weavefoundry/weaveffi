// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

package weaveffi

/*
#cgo LDFLAGS: -lweaveffi
#include "weaveffi.h"
#include <stdlib.h>
extern void goWv_weaveffi_tasks_run_task_callback(void* context, weaveffi_error* err, weaveffi_tasks_TaskResult* result);
extern void goWv_weaveffi_tasks_run_batch_callback(void* context, weaveffi_error* err, weaveffi_tasks_TaskResult** result, size_t result_len);
extern void goWv_weaveffi_tasks_run_n_tasks_callback(void* context, weaveffi_error* err, int32_t result);
*/
import "C"

import (
	"fmt"
	"sync"
	"unsafe"
)

func boolToC(b bool) C._Bool {
	return C._Bool(b)
}

func cToBool(b C._Bool) bool {
	return bool(b)
}

// WeaveFFIError reports a failure crossing the C boundary that no typed
// error domain claims: an unknown code, a marshalling failure, or a
// producer panic.
type WeaveFFIError struct {
	// Code is the numeric ABI error code.
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *WeaveFFIError) Error() string {
	return fmt.Sprintf("weaveffi: %s (code %d)", e.Message, e.Code)
}

// wvTakeError reads and clears a non-zero C error slot, returning its
// code and message.
func wvTakeError(cErr *C.weaveffi_error) (int32, string) {
	code := int32(cErr.code)
	msg := ""
	if cErr.message != nil {
		msg = C.GoString(cErr.message)
	}
	C.weaveffi_error_clear(cErr)
	return code, msg
}

func wvBrandError(code int32, message string) error {
	return &WeaveFFIError{Code: code, Message: message}
}

// wvTrap panics when the C error slot reports a failure. Non-throwing
// wrappers check their slot with it: a non-zero code there can only be
// a producer panic or a marshalling failure.
func wvTrap(cErr *C.weaveffi_error) {
	if cErr.code != 0 {
		code, msg := wvTakeError(cErr)
		panic(fmt.Sprintf("weaveffi: %s (code %d)", msg, code))
	}
}

var (
	wvCallbackMu  sync.Mutex
	wvCallbackSeq uint64
	wvCallbacks   = map[uint64]interface{}{}
)

func wvCallbackStore(v interface{}) uint64 {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	wvCallbackSeq++
	wvCallbacks[wvCallbackSeq] = v
	return wvCallbackSeq
}

func wvCallbackLoad(id uint64) interface{} {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	return wvCallbacks[id]
}

func wvCallbackTake(id uint64) interface{} {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	v := wvCallbacks[id]
	delete(wvCallbacks, id)
	return v
}

func wvCallbackDelete(id uint64) {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	delete(wvCallbacks, id)
}

// TaskError is a typed error reported by the `tasks` module.
type TaskError struct {
	// Code is the numeric ABI error code (one of the TaskError constants).
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *TaskError) Error() string {
	return fmt.Sprintf("tasks: %s (code %d)", e.Message, e.Code)
}

// TaskError codes.
const (
	// TaskErrorInvalidName task name must not be empty
	TaskErrorInvalidName int32 = 1
)

// wvMapTasks converts a non-zero code from the `tasks` domain into a
// *TaskError, falling back to the generic *WeaveFFIError for unknown codes.
func wvMapTasks(code int32, message string) error {
	switch code {
	case TaskErrorInvalidName:
		if message == "" {
			message = "task name must not be empty"
		}
		return &TaskError{Code: code, Message: message}
	default:
		return wvBrandError(code, message)
	}
}

type TaskResult struct {
	ptr *C.weaveffi_tasks_TaskResult
}

func (s *TaskResult) Id() int64 {
	return int64(C.weaveffi_tasks_TaskResult_get_id(s.ptr))
}

func (s *TaskResult) Value() string {
	return C.GoString(C.weaveffi_tasks_TaskResult_get_value(s.ptr))
}

func (s *TaskResult) Success() bool {
	return cToBool(C.weaveffi_tasks_TaskResult_get_success(s.ptr))
}

func (s *TaskResult) Close() {
	if s.ptr != nil {
		C.weaveffi_tasks_TaskResult_destroy(s.ptr)
		s.ptr = nil
	}
}

type wvOutcomeTasksRunTask struct {
	val *TaskResult
	err error
}

//export goWv_weaveffi_tasks_run_task_callback
func goWv_weaveffi_tasks_run_task_callback(context unsafe.Pointer, err *C.weaveffi_error, result *C.weaveffi_tasks_TaskResult) {
	v := wvCallbackTake(uint64(uintptr(context)))
	if v == nil {
		return
	}
	ch := v.(chan wvOutcomeTasksRunTask)
	if err != nil && err.code != 0 {
		ch <- wvOutcomeTasksRunTask{err: wvMapTasks(wvTakeError(err))}
		return
	}
	ch <- wvOutcomeTasksRunTask{val: &TaskResult{ptr: result}}
}

// Blocks until the async producer completes.
func RunTask(name string) (*TaskResult, error) {
	ch := make(chan wvOutcomeTasksRunTask, 1)
	ctxID := wvCallbackStore(ch)
	cName := C.CString(name)
	defer C.free(unsafe.Pointer(cName))
	C.weaveffi_tasks_run_task_async(cName, C.weaveffi_tasks_run_task_callback(unsafe.Pointer(C.goWv_weaveffi_tasks_run_task_callback)), unsafe.Pointer(uintptr(ctxID)))
	outcome := <-ch
	if outcome.err != nil {
		return nil, outcome.err
	}
	return outcome.val, nil
}

type wvOutcomeTasksRunBatch struct {
	val []*TaskResult
	err error
}

//export goWv_weaveffi_tasks_run_batch_callback
func goWv_weaveffi_tasks_run_batch_callback(context unsafe.Pointer, err *C.weaveffi_error, result **C.weaveffi_tasks_TaskResult, result_len C.size_t) {
	v := wvCallbackTake(uint64(uintptr(context)))
	if v == nil {
		return
	}
	ch := v.(chan wvOutcomeTasksRunBatch)
	if err != nil && err.code != 0 {
		ch <- wvOutcomeTasksRunBatch{err: wvMapTasks(wvTakeError(err))}
		return
	}
	count := int(result_len)
	val := make([]*TaskResult, count)
	if count > 0 && result != nil {
		for i, v := range unsafe.Slice((**C.weaveffi_tasks_TaskResult)(unsafe.Pointer(result)), count) {
			val[i] = &TaskResult{ptr: v}
		}
	}
	ch <- wvOutcomeTasksRunBatch{val: val}
}

// Blocks until the async producer completes.
func RunBatch(names []string) []*TaskResult {
	ch := make(chan wvOutcomeTasksRunBatch, 1)
	ctxID := wvCallbackStore(ch)
	cNamesLen := C.size_t(len(names))
	cNamesArr := make([]*C.char, len(names))
	for i, s := range names {
		cNamesArr[i] = C.CString(s)
	}
	defer func() {
		for _, p := range cNamesArr {
			C.free(unsafe.Pointer(p))
		}
	}()
	var cNamesPtr **C.char
	if len(cNamesArr) > 0 {
		cNamesPtr = (**C.char)(unsafe.Pointer(&cNamesArr[0]))
	}
	C.weaveffi_tasks_run_batch_async(cNamesPtr, cNamesLen, C.weaveffi_tasks_run_batch_callback(unsafe.Pointer(C.goWv_weaveffi_tasks_run_batch_callback)), unsafe.Pointer(uintptr(ctxID)))
	outcome := <-ch
	if outcome.err != nil {
		panic(outcome.err)
	}
	return outcome.val
}

func CancelTask(id int64) bool {
	var cErr C.weaveffi_error
	result := C.weaveffi_tasks_cancel_task(C.int64_t(id), &cErr)
	wvTrap(&cErr)
	return cToBool(result)
}

type wvOutcomeTasksRunNTasks struct {
	val int32
	err error
}

//export goWv_weaveffi_tasks_run_n_tasks_callback
func goWv_weaveffi_tasks_run_n_tasks_callback(context unsafe.Pointer, err *C.weaveffi_error, result C.int32_t) {
	v := wvCallbackTake(uint64(uintptr(context)))
	if v == nil {
		return
	}
	ch := v.(chan wvOutcomeTasksRunNTasks)
	if err != nil && err.code != 0 {
		ch <- wvOutcomeTasksRunNTasks{err: wvMapTasks(wvTakeError(err))}
		return
	}
	ch <- wvOutcomeTasksRunNTasks{val: int32(result)}
}

// Blocks until the async producer completes.
func RunNTasks(n int32) int32 {
	ch := make(chan wvOutcomeTasksRunNTasks, 1)
	ctxID := wvCallbackStore(ch)
	C.weaveffi_tasks_run_n_tasks_async(C.int32_t(n), C.weaveffi_tasks_run_n_tasks_callback(unsafe.Pointer(C.goWv_weaveffi_tasks_run_n_tasks_callback)), unsafe.Pointer(uintptr(ctxID)))
	outcome := <-ch
	if outcome.err != nil {
		panic(outcome.err)
	}
	return outcome.val
}

func ActiveCallbacks() int64 {
	var cErr C.weaveffi_error
	result := C.weaveffi_tasks_active_callbacks(&cErr)
	wvTrap(&cErr)
	return int64(result)
}


