namespace weaveffi {

/** Base exception for every error reported through the C ABI. */
class WeaveFFIError : public std::runtime_error {
    int32_t code_;

public:
    WeaveFFIError(int32_t code, const std::string& msg) : std::runtime_error(msg), code_(code) {}
    int32_t code() const { return code_; }
};

namespace detail {

/** Throw the generic WeaveFFIError if `err` carries a nonzero code. */
inline void check(weaveffi_error& err) {
    if (err.code == 0) return;
    std::string msg(err.message ? err.message : "unknown error");
    int32_t code = err.code;
    weaveffi_error_clear(&err);
    throw WeaveFFIError(code, msg);
}

/** Wrap an async-callback error as the generic WeaveFFIError. */
inline std::exception_ptr make_error(int32_t code, const std::string& msg) {
    return std::make_exception_ptr(WeaveFFIError(code, msg));
}

} // namespace detail

/** Typed errors reported by the `contacts` module's throwing functions. */
class ContactsError : public WeaveFFIError {
public:
    ContactsError(int32_t code, const std::string& msg) : WeaveFFIError(code, msg) {}
};

/** name must not be empty */
class InvalidNameError : public ContactsError {
public:
    InvalidNameError(const std::string& msg) : ContactsError(1, msg) {}
};

/** contact not found */
class NotFoundError : public ContactsError {
public:
    NotFoundError(const std::string& msg) : ContactsError(2, msg) {}
};

namespace detail {

/** Map a `contacts` error code to its typed exception (ContactsError for unknown codes). */
inline std::exception_ptr make_contacts_error(int32_t code, const std::string& msg) {
    switch (code) {
    case 1: return std::make_exception_ptr(InvalidNameError(msg));
    case 2: return std::make_exception_ptr(NotFoundError(msg));
    default: return std::make_exception_ptr(ContactsError(code, msg));
    }
}

/** Throw the typed `contacts` exception if `err` carries a nonzero code. */
inline void check_contacts(weaveffi_error& err) {
    if (err.code == 0) return;
    std::string msg(err.message ? err.message : "unknown error");
    int32_t code = err.code;
    weaveffi_error_clear(&err);
    std::rethrow_exception(make_contacts_error(code, msg));
}

} // namespace detail

