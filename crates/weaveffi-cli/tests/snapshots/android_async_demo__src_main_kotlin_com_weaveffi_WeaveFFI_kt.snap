// Generated by WeaveFFI [VERSION] from weaveffi.yml
// DO NOT EDIT. Your changes will be overwritten.
// To regenerate: weaveffi generate weaveffi.yml -o <out>

package com.weaveffi

import kotlinx.coroutines.suspendCancellableCoroutine
import kotlin.coroutines.resume
import kotlin.coroutines.resumeWithException

class WeaveFFI {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic private external fun runTaskAsync(name: String, callback: Any)
        @JvmStatic suspend fun runTask(name: String): TaskResult {
            val raw: Long = suspendCancellableCoroutine { cont ->
                runTaskAsync(name, WeaveContinuation(cont) { code, message -> TaskException.fromCode(code, message) })
            }
            return TaskResult(raw)
        }
        @JvmStatic private external fun runBatchAsync(names: Array<String>, callback: Any)
        @JvmStatic suspend fun runBatch(names: Array<String>): LongArray = suspendCancellableCoroutine { cont ->
            runBatchAsync(names, WeaveContinuation(cont) { code, message -> WeaveFFIException(code, message) })
        }
        @JvmStatic external fun cancelTask(id: Long): Boolean
        @JvmStatic private external fun runNTasksAsync(n: Int, callback: Any)
        @JvmStatic suspend fun runNTasks(n: Int): Int = suspendCancellableCoroutine { cont ->
            runNTasksAsync(n, WeaveContinuation(cont) { code, message -> WeaveFFIException(code, message) })
        }
        @JvmStatic external fun activeCallbacks(): Long
    }
}

class TaskResult internal constructor(internal var handle: Long) : java.io.Closeable {
    companion object {
        init { System.loadLibrary("weaveffi") }

        @JvmStatic external fun nativeCreate(id: Long, value: String, success: Boolean): Long
        @JvmStatic external fun nativeDestroy(handle: Long)
        @JvmStatic external fun nativeGetId(handle: Long): Long
        @JvmStatic external fun nativeGetValue(handle: Long): String
        @JvmStatic external fun nativeGetSuccess(handle: Long): Boolean

        fun create(id: Long, value: String, success: Boolean): TaskResult = TaskResult(nativeCreate(id, value, success))
    }

    val id: Long get() = nativeGetId(handle)
    val value: String get() = nativeGetValue(handle)
    val success: Boolean get() = nativeGetSuccess(handle)

    override fun close() {
        if (handle != 0L) {
            nativeDestroy(handle)
            handle = 0L
        }
    }

    protected fun finalize() {
        close()
    }
}

/** Generic WeaveFFI failure: panics, marshalling errors, and unknown codes. */
open class WeaveFFIException(val code: Int, message: String) : Exception(message)

/** Typed error domain `TaskError` declared by module `tasks`. */
sealed class TaskException(code: Int, message: String) : WeaveFFIException(code, message) {
    class InvalidName(message: String = "task name must not be empty") : TaskException(1, message)

    companion object {
        /** Map a raw `TaskError` code to its typed exception; unknown codes yield the generic [WeaveFFIException]. */
        fun fromCode(code: Int, message: String): WeaveFFIException = when (code) {
            1 -> InvalidName(message)
            else -> WeaveFFIException(code, message)
        }
    }
}

internal class WeaveContinuation<T>(
    private val cont: kotlinx.coroutines.CancellableContinuation<T>,
    private val mapError: (Int, String) -> Throwable
) {
    @Suppress("UNCHECKED_CAST")
    fun onSuccess(result: Any?) { cont.resume(result as T) }
    fun onError(code: Int, message: String) { cont.resumeWithException(mapError(code, message)) }
}

