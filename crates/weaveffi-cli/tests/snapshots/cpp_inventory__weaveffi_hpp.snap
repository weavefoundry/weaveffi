    }

    Product& operator=(Product&& other) noexcept {
        if (this != &other) {
            if (handle_) weaveffi_products_Product_destroy(static_cast<weaveffi_products_Product*>(handle_));
            handle_ = other.handle_;
            other.handle_ = nullptr;
        }
        return *this;
    }

    void* handle() const { return handle_; }

    int64_t id() const {
        return weaveffi_products_Product_get_id(static_cast<const weaveffi_products_Product*>(handle_));
    }

    std::string name() const {
        const char* raw = weaveffi_products_Product_get_name(static_cast<const weaveffi_products_Product*>(handle_));
        std::string ret(raw);
        weaveffi_free_string(raw);
        return ret;
    }

    std::optional<std::string> description() const {
        auto* raw = weaveffi_products_Product_get_description(static_cast<const weaveffi_products_Product*>(handle_));
        if (!raw) return std::nullopt;
        std::string ret(raw);
        weaveffi_free_string(raw);
        return ret;
    }

    double price() const {
        return weaveffi_products_Product_get_price(static_cast<const weaveffi_products_Product*>(handle_));
    }

    Category category() const {
        return static_cast<Category>(weaveffi_products_Product_get_category(static_cast<const weaveffi_products_Product*>(handle_)));
    }

    std::vector<std::string> tags() const {
        size_t len = 0;
        auto* raw = weaveffi_products_Product_get_tags(static_cast<const weaveffi_products_Product*>(handle_), &len);
        std::vector<std::string> ret;
        ret.reserve(len);
        for (size_t i = 0; i < len; ++i) {
            ret.emplace_back(raw[i]);
            weaveffi_free_string(raw[i]);
        }
        weaveffi_free_bytes(reinterpret_cast<uint8_t*>(raw), len * sizeof(*raw));
        return ret;
    }

};

/** A product catalog owning its products */
class Catalog {
    void* handle_;

public:
    explicit Catalog(void* h) : handle_(h) {}

    ~Catalog() {
        if (handle_) weaveffi_products_Catalog_destroy(static_cast<weaveffi_products_Catalog*>(handle_));
    }

    Catalog(const Catalog&) = delete;
    Catalog& operator=(const Catalog&) = delete;

    Catalog(Catalog&& other) noexcept : handle_(other.handle_) {
        other.handle_ = nullptr;
    }

    Catalog& operator=(Catalog&& other) noexcept {
        if (this != &other) {
            if (handle_) weaveffi_products_Catalog_destroy(static_cast<weaveffi_products_Catalog*>(handle_));
            handle_ = other.handle_;
            other.handle_ = nullptr;
        }
        return *this;
    }

    void* handle() const { return handle_; }

    Catalog() : handle_(nullptr) {
        weaveffi_error err{};
        auto result = weaveffi_products_Catalog_new(&err);
        detail::check(err);
        handle_ = result;
    }

    Product add_product(const std::string& name, double price, Category category) const {
        weaveffi_error err{};
        auto result = weaveffi_products_Catalog_add_product(static_cast<const weaveffi_products_Catalog*>(handle_), name.c_str(), price, static_cast<weaveffi_products_Category>(static_cast<int32_t>(category)), &err);
        detail::check_products(err);
        return Product(result);
    }

    Product get_product(int64_t id) const {
        weaveffi_error err{};
        auto result = weaveffi_products_Catalog_get_product(static_cast<const weaveffi_products_Catalog*>(handle_), id, &err);
        detail::check_products(err);
        return Product(result);
    }

    std::vector<Product> search(Category category) const {
        size_t out_len = 0;
        weaveffi_error err{};
        auto result = weaveffi_products_Catalog_search(static_cast<const weaveffi_products_Catalog*>(handle_), static_cast<weaveffi_products_Category>(static_cast<int32_t>(category)), &out_len, &err);
        detail::check(err);
        std::vector<Product> ret;
        ret.reserve(out_len);
        for (size_t i = 0; i < out_len; ++i) ret.emplace_back(Product(result[i]));
        weaveffi_free_bytes(reinterpret_cast<uint8_t*>(result), out_len * sizeof(*result));
        return ret;
    }

    bool update_price(int64_t id, double price) const {
        weaveffi_error err{};
        auto result = weaveffi_products_Catalog_update_price(static_cast<const weaveffi_products_Catalog*>(handle_), id, price, &err);
        detail::check_products(err);
        return result;
    }

    bool remove(int64_t id) const {
        weaveffi_error err{};
        auto result = weaveffi_products_Catalog_remove(static_cast<const weaveffi_products_Catalog*>(handle_), id, &err);
        detail::check(err);
        return result;
    }

};

