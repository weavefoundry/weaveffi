public:
    InvalidPriceError(const std::string& msg) : ProductsError(1, msg) {}
};

/** product not found */
class ProductNotFoundError : public ProductsError {
public:
    ProductNotFoundError(const std::string& msg) : ProductsError(2, msg) {}
};

