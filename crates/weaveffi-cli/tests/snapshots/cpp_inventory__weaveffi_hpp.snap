namespace orders {

inline int64_t create_order(const std::vector<OrderItem>& items) {
    std::vector<weaveffi_orders_OrderItem*> items_ptrs;
    items_ptrs.reserve(items.size());
    for (const auto& item : items) items_ptrs.push_back(static_cast<weaveffi_orders_OrderItem*>(item.handle()));
    weaveffi_error err{};
    auto result = weaveffi_orders_create_order(items_ptrs.data(), items_ptrs.size(), &err);
    detail::check_orders(err);
    return result;
}

inline Order get_order(int64_t id) {
    weaveffi_error err{};
    auto result = weaveffi_orders_get_order(id, &err);
    detail::check_orders(err);
    return Order(result);
}

inline bool cancel_order(int64_t id) {
    weaveffi_error err{};
    auto result = weaveffi_orders_cancel_order(id, &err);
    detail::check(err);
    return result;
}

inline bool add_product_to_order(int64_t order_id, const Product& product) {
    weaveffi_error err{};
    auto result = weaveffi_orders_add_product_to_order(order_id, static_cast<const weaveffi_products_Product*>(product.handle()), &err);
    detail::check(err);
    return result;
}

} // namespace orders

