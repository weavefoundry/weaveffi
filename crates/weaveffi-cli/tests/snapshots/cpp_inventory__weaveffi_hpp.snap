/** Map a `products` error code to its typed exception (ProductsError for unknown codes). */
inline std::exception_ptr make_products_error(int32_t code, const std::string& msg) {
    switch (code) {
    case 1: return std::make_exception_ptr(InvalidPriceError(msg));
    case 2: return std::make_exception_ptr(ProductNotFoundError(msg));
    default: return std::make_exception_ptr(ProductsError(code, msg));
    }
}

/** Throw the typed `products` exception if `err` carries a nonzero code. */
inline void check_products(weaveffi_error& err) {
    if (err.code == 0) return;
    std::string msg(err.message ? err.message : "unknown error");
    int32_t code = err.code;
    weaveffi_error_clear(&err);
    std::rethrow_exception(make_products_error(code, msg));
}

} // namespace detail

