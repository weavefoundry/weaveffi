            switch (code)
            {
                case InvalidName:
                    return new ContactsException(code, string.IsNullOrEmpty(message) ? "name must not be empty" : message);
                case NotFound:
                    return new ContactsException(code, string.IsNullOrEmpty(message) ? "contact not found" : message);
                default:
