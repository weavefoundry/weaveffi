func boolToC(b bool) C._Bool {
	return C._Bool(b)
}

func cToBool(b C._Bool) bool {
	return bool(b)
}

// WeaveFFIError reports a failure crossing the C boundary that no typed
// error domain claims: an unknown code, a marshalling failure, or a
// producer panic.
type WeaveFFIError struct {
	// Code is the numeric ABI error code.
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *WeaveFFIError) Error() string {
	return fmt.Sprintf("weaveffi: %s (code %d)", e.Message, e.Code)
}

// wvTakeError reads and clears a non-zero C error slot, returning its
// code and message.
func wvTakeError(cErr *C.weaveffi_error) (int32, string) {
	code := int32(cErr.code)
	msg := ""
	if cErr.message != nil {
		msg = C.GoString(cErr.message)
	}
	C.weaveffi_error_clear(cErr)
	return code, msg
}

func wvBrandError(code int32, message string) error {
	return &WeaveFFIError{Code: code, Message: message}
}

// wvTrap panics when the C error slot reports a failure. Non-throwing
// wrappers check their slot with it: a non-zero code there can only be
// a producer panic or a marshalling failure.
func wvTrap(cErr *C.weaveffi_error) {
	if cErr.code != 0 {
		code, msg := wvTakeError(cErr)
		panic(fmt.Sprintf("weaveffi: %s (code %d)", msg, code))
	}
}

var (
	wvCallbackMu  sync.Mutex
	wvCallbackSeq uint64
	wvCallbacks   = map[uint64]interface{}{}
	// Subscription id -> registry id, so unregister can release the Go callback.
	wvListenerCtx = map[uint64]uint64{}
)

func wvCallbackStore(v interface{}) uint64 {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	wvCallbackSeq++
	wvCallbacks[wvCallbackSeq] = v
	return wvCallbackSeq
}

func wvCallbackLoad(id uint64) interface{} {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	return wvCallbacks[id]
}

func wvCallbackTake(id uint64) interface{} {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	v := wvCallbacks[id]
	delete(wvCallbacks, id)
	return v
}

func wvCallbackDelete(id uint64) {
	wvCallbackMu.Lock()
	defer wvCallbackMu.Unlock()
	delete(wvCallbacks, id)
}

// DocsErrorsError is a typed error reported by the `docs` module.
type DocsErrorsError struct {
	// Code is the numeric ABI error code (one of the DocsErrorsError constants).
	Code int32
	// Message is the human-readable error message.
	Message string
}

func (e *DocsErrorsError) Error() string {
	return fmt.Sprintf("docs: %s (code %d)", e.Message, e.Code)
}

// DocsErrorsError codes.
const (
	// DocsErrorsErrorNotFound: Returned when no document matches the requested id
	DocsErrorsErrorNotFound int32 = 1
	// DocsErrorsErrorInvalidStatus: Raised when attempting to move into a forbidden state
	DocsErrorsErrorInvalidStatus int32 = 2
)

// wvMapDocs converts a non-zero code from the `docs` domain into a
// *DocsErrorsError, falling back to the generic *WeaveFFIError for unknown codes.
func wvMapDocs(code int32, message string) error {
	switch code {
	case DocsErrorsErrorNotFound:
		if message == "" {
			message = "Document not found"
		}
		return &DocsErrorsError{Code: code, Message: message}
	case DocsErrorsErrorInvalidStatus:
		if message == "" {
			message = "Invalid status transition"
		}
		return &DocsErrorsError{Code: code, Message: message}
	default:
		return wvBrandError(code, message)
	}
}

// Status: Lifecycle status of a document.
//
// Used to drive UI badges and filters.
type Status int32

const (
	// StatusDraft: Document is being edited
	StatusDraft Status = 0
	// StatusPublished: Document is publicly visible
	StatusPublished Status = 1
	// StatusArchived: Document is hidden from listings
	StatusArchived Status = 2
)

// Document: Represents a single document tracked by the system.
//
// Documents are persisted to disk and exposed via the public API.
