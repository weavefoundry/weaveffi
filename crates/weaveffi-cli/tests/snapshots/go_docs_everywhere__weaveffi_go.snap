package weaveffi

/*
#cgo LDFLAGS: -lweaveffi
#include "weaveffi.h"
#include <stdlib.h>
*/
import "C"

import (
	"fmt"
	"unsafe"
)

// Status: Lifecycle status of a document.
//
// Used to drive UI badges and filters.
type Status int32

const (
	// StatusDraft: Document is being edited
	StatusDraft Status = 0
	// StatusPublished: Document is publicly visible
	StatusPublished Status = 1
	// StatusArchived: Document is hidden from listings
	StatusArchived Status = 2
)

// Document: Represents a single document tracked by the system.
//
// Documents are persisted to disk and exposed via the public API.
type Document struct {
	ptr *C.weaveffi_docs_Document
}

// Id: Stable opaque identifier
func (s *Document) Id() int64 {
	return int64(C.weaveffi_docs_Document_get_id(s.ptr))
}

// Title: Human-readable title shown in lists
func (s *Document) Title() string {
	return C.GoString(C.weaveffi_docs_Document_get_title(s.ptr))
}

// Status: Current lifecycle status
func (s *Document) Status() Status {
	return Status(C.weaveffi_docs_Document_get_status(s.ptr))
}

// Tags: Free-form tags for grouping
func (s *Document) Tags() []string {
	return []string(C.weaveffi_docs_Document_get_tags(s.ptr))
}

func (s *Document) Close() {
	if s.ptr != nil {
		C.weaveffi_docs_Document_destroy(s.ptr)
		s.ptr = nil
	}
}

// DocumentBuilder: Represents a single document tracked by the system.
//
// Documents are persisted to disk and exposed via the public API.
type DocumentBuilder struct {
	fields map[string]interface{}
}

func NewDocumentBuilder() *DocumentBuilder {
	return &DocumentBuilder{fields: make(map[string]interface{})}
}

// WithId: Stable opaque identifier
func (b *DocumentBuilder) WithId(value int64) *DocumentBuilder {
	b.fields["id"] = value
	return b
}

// WithTitle: Human-readable title shown in lists
func (b *DocumentBuilder) WithTitle(value string) *DocumentBuilder {
	b.fields["title"] = value
	return b
}

// WithStatus: Current lifecycle status
func (b *DocumentBuilder) WithStatus(value Status) *DocumentBuilder {
	b.fields["status"] = value
	return b
}

// WithTags: Free-form tags for grouping
func (b *DocumentBuilder) WithTags(value []string) *DocumentBuilder {
	b.fields["tags"] = value
	return b
}

// DocsCreateDocument: Create a brand new document.
//
// The document starts in `Draft` status; callers must publish
// it explicitly to make it visible.
//
// Parameters:
//   - title: Human-readable title for the new document
//   - tags: Initial set of tags (may be empty)
func DocsCreateDocument(title string, tags []string) (*Document, error) {
	cTitle := C.CString(title)
	defer C.free(unsafe.Pointer(cTitle))
	cTagsLen := C.size_t(len(tags))
	cTagsArr := make([]*C.char, len(tags))
	for i, s := range tags {
		cTagsArr[i] = C.CString(s)
	}
	defer func() {
		for _, p := range cTagsArr {
			C.free(unsafe.Pointer(p))
		}
	}()
	var cTagsPtr **C.char
	if len(cTagsArr) > 0 {
		cTagsPtr = (**C.char)(unsafe.Pointer(&cTagsArr[0]))
	}
	var cErr C.weaveffi_error
	result := C.weaveffi_docs_create_document(cTitle, cTagsPtr, cTagsLen, &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	return &Document{ptr: result}, nil
}

// DocsGetDocument: Look up a document by identifier
//
// Parameters:
//   - id: Identifier returned from create_document
func DocsGetDocument(id int64) (*Document, error) {
	var cErr C.weaveffi_error
	result := C.weaveffi_docs_get_document(C.int64_t(id), &cErr)
	if cErr.code != 0 {
		goErr := fmt.Errorf("weaveffi: %s (code %d)", C.GoString(cErr.message), int(cErr.code))
		C.weaveffi_error_clear(&cErr)
		return nil, goErr
	}
	if result == nil {
		return nil, nil
	}
	return &Document{ptr: result}, nil
}
