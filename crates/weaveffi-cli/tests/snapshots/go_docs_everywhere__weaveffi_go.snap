}

// Status: Current lifecycle status
func (s *Document) Status() Status {
	return Status(C.weaveffi_docs_Document_get_status(s.ptr))
}

// Tags: Free-form tags for grouping
func (s *Document) Tags() []string {
	var cOutLen C.size_t
	result := C.weaveffi_docs_Document_get_tags(s.ptr, &cOutLen)
	count := int(cOutLen)
	goResult := make([]string, count)
	if count > 0 && result != nil {
		for i, v := range unsafe.Slice((**C.char)(unsafe.Pointer(result)), count) {
			goResult[i] = C.GoString(v)
		}
	}
	return goResult
}

func (s *Document) Close() {
	if s.ptr != nil {
		C.weaveffi_docs_Document_destroy(s.ptr)
		s.ptr = nil
	}
}

