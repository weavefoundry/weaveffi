type wvOutcomeDocsPublishAsync struct {
	val bool
	err error
}

//export goWv_weaveffi_docs_publish_async_callback
func goWv_weaveffi_docs_publish_async_callback(context unsafe.Pointer, err *C.weaveffi_error, result C._Bool) {
	v := wvCallbackTake(uint64(uintptr(context)))
	if v == nil {
		return
	}
	ch := v.(chan wvOutcomeDocsPublishAsync)
	if err != nil && err.code != 0 {
		ch <- wvOutcomeDocsPublishAsync{err: wvMapDocs(wvTakeError(err))}
		return
	}
	ch <- wvOutcomeDocsPublishAsync{val: cToBool(result)}
}

// PublishAsync: Publish a document in the background
//
// Parameters:
//   - id: Identifier of the document to publish
// Blocks until the async producer completes.
func PublishAsync(id int64) bool {
	ch := make(chan wvOutcomeDocsPublishAsync, 1)
	ctxID := wvCallbackStore(ch)
	C.weaveffi_docs_publish_async_async(C.int64_t(id), C.weaveffi_docs_publish_async_callback(unsafe.Pointer(C.goWv_weaveffi_docs_publish_async_callback)), unsafe.Pointer(uintptr(ctxID)))
	outcome := <-ch
	if outcome.err != nil {
		panic(outcome.err)
	}
	return outcome.val
}


