      ctx.reject(e);
    }
  }

  const _cbPtr_i32_i32_i64 = _registerTrampoline(_table, ['i32', 'i32', 'i64'], _asyncHandler);

  return {
    _raw: wasm,
    kv: {
      open_store(path) {
        const _err = _allocError(wasm);
        const [path_ptr, path_len] = _encodeString(wasm, path);
        const _result = wasm.weaveffi_kv_open_store(path_ptr, path_len, _err);
        _checkError(wasm, _err);
        return _result;
      },
      close_store(store) {
        const _err = _allocError(wasm);
        wasm.weaveffi_kv_close_store(store._handle, _err);
        _checkError(wasm, _err);
      },
      put(store, key, value, kind, ttl_seconds) {
        const _err = _allocError(wasm);
        const [key_ptr, key_len] = _encodeString(wasm, key);
        const _result = wasm.weaveffi_kv_put(store._handle, key_ptr, key_len, value, kind, ttl_seconds, _err);
        _checkError(wasm, _err);
        return _result !== 0;
      },
      get(store, key) {
        const _err = _allocError(wasm);
        const [key_ptr, key_len] = _encodeString(wasm, key);
        const result = wasm.weaveffi_kv_get(store._handle, key_ptr, key_len, _err);
        _checkError(wasm, _err);
        return result === 0n ? null : new Entry(wasm, result);
      },
      delete(store, key) {
        const _err = _allocError(wasm);
        const [key_ptr, key_len] = _encodeString(wasm, key);
        const _result = wasm.weaveffi_kv_delete(store._handle, key_ptr, key_len, _err);
        _checkError(wasm, _err);
        return _result !== 0;
      },
      list_keys(store, prefix) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kv_list_keys(store._handle, prefix, _err);
        _checkError(wasm, _err);
        return _result;
      },
      count(store) {
        const _err = _allocError(wasm);
        const _result = wasm.weaveffi_kv_count(store._handle, _err);
        _checkError(wasm, _err);
        return _result;
      },
      clear(store) {
        const _err = _allocError(wasm);
        wasm.weaveffi_kv_clear(store._handle, _err);
        _checkError(wasm, _err);
      },
      compact_async(store) {
        return new Promise((resolve, reject) => {
          const ctxId = _nextCtxId++;
          _asyncContexts.set(ctxId, { resolve, reject });
          wasm.weaveffi_kv_compact_async_async(store._handle, 0, _cbPtr_i32_i32_i64, ctxId);
        }));
      },
      /** @deprecated use put() with explicit kind */
      legacy_put(store, key, value) {
        const _err = _allocError(wasm);
        const [key_ptr, key_len] = _encodeString(wasm, key);
        const _result = wasm.weaveffi_kv_legacy_put(store._handle, key_ptr, key_len, value, _err);
        _checkError(wasm, _err);
        return _result !== 0;
      },
      stats: {
        get_stats(store) {
          const _err = _allocError(wasm);
          const _result = wasm.weaveffi_kv_stats_get_stats(store._handle, _err);
          _checkError(wasm, _err);
          return new Stats(wasm, _result);
