    const char** out_keys = NULL;
    const char** out_vals = NULL;
    size_t out_len = 0;
    weaveffi_kv_Entry_get_metadata((const weaveffi_kv_Entry*)(intptr_t)handle, &out_keys, &out_vals, &out_len);
    jclass hm_cls = (*env)->FindClass(env, "java/util/HashMap");
    jobject result = (*env)->NewObject(env, hm_cls, (*env)->GetMethodID(env, hm_cls, "<init>", "(I)V"), (jint)out_len);
    jmethodID hm_put = (*env)->GetMethodID(env, hm_cls, "put", "(Ljava/lang/Object;Ljava/lang/Object;)Ljava/lang/Object;");
    for (size_t i = 0; i < out_len; i++) {
        jstring jkey = (*env)->NewStringUTF(env, out_keys[i]);
        jstring jval = (*env)->NewStringUTF(env, out_vals[i]);
        (*env)->CallObjectMethod(env, result, hm_put, jkey, jval);
        (*env)->DeleteLocalRef(env, jkey);
        (*env)->DeleteLocalRef(env, jval);
        weaveffi_free_string(out_keys[i]);
        weaveffi_free_string(out_vals[i]);
    }
    return result;
}

JNIEXPORT jlong JNICALL Java_com_weaveffi_Stats_nativeCreate(JNIEnv* env, jclass clazz, jlong total_entries, jlong total_bytes, jlong expired_entries) {
    weaveffi_error err = {0, NULL};
    weaveffi_kv_stats_Stats* rv = weaveffi_kv_stats_Stats_create((int64_t)total_entries, (int64_t)total_bytes, (int64_t)expired_entries, &err);
    if (err.code != 0) {
        throw_weaveffi_error(env, &err);
        return 0;
    }
    return (jlong)(intptr_t)rv;
}

JNIEXPORT void JNICALL Java_com_weaveffi_Stats_nativeDestroy(JNIEnv* env, jclass clazz, jlong handle) {
    weaveffi_kv_stats_Stats_destroy((weaveffi_kv_stats_Stats*)(intptr_t)handle);
}

JNIEXPORT jlong JNICALL Java_com_weaveffi_Stats_nativeGetTotalEntries(JNIEnv* env, jclass clazz, jlong handle) {
    int64_t rv = weaveffi_kv_stats_Stats_get_total_entries((const weaveffi_kv_stats_Stats*)(intptr_t)handle);
    return (jlong)rv;
}

JNIEXPORT jlong JNICALL Java_com_weaveffi_Stats_nativeGetTotalBytes(JNIEnv* env, jclass clazz, jlong handle) {
    int64_t rv = weaveffi_kv_stats_Stats_get_total_bytes((const weaveffi_kv_stats_Stats*)(intptr_t)handle);
    return (jlong)rv;
}

JNIEXPORT jlong JNICALL Java_com_weaveffi_Stats_nativeGetExpiredEntries(JNIEnv* env, jclass clazz, jlong handle) {
    int64_t rv = weaveffi_kv_stats_Stats_get_expired_entries((const weaveffi_kv_stats_Stats*)(intptr_t)handle);
    return (jlong)rv;
}


